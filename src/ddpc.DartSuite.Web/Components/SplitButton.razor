<div class="btn-group split-button-component">
    <button type="button" class="btn @ButtonClass @SizeClass" @onclick="OnPrimaryClick" disabled="@Disabled">
        @PrimaryText
    </button>
    <button type="button" class="btn @ButtonClass @SizeClass dropdown-toggle dropdown-toggle-split"
            data-bs-toggle="dropdown" aria-expanded="false" disabled="@Disabled">
        <span class="visually-hidden">Toggle Dropdown</span>
    </button>
    <ul class="dropdown-menu">
        @if (Items is not null)
        {
            @foreach (var item in Items)
            {
                @if (item.IsDivider)
                {
                    <li><hr class="dropdown-divider" /></li>
                }
                else
                {
                    <li>
                        <button class="dropdown-item @(item.IsDanger ? "text-danger" : "") @(item.IsDisabled ? "disabled" : "")"
                                @onclick="() => item.OnClick.InvokeAsync()" disabled="@item.IsDisabled"
                                title="@item.Title">
                            @if (!string.IsNullOrEmpty(item.Icon))
                            {
                                <span class="me-1">@item.Icon</span>
                            }
                            @item.Text
                        </button>
                    </li>
                }
            }
        }
        @ChildContent
    </ul>
</div>

@code {
    [Parameter, EditorRequired] public string PrimaryText { get; set; } = "";
    [Parameter] public EventCallback OnPrimaryClick { get; set; }
    [Parameter] public string ButtonStyle { get; set; } = "primary";
    [Parameter] public string Size { get; set; } = "";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public IReadOnlyList<SplitButtonItem>? Items { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string ButtonClass => $"btn-{ButtonStyle}";
    private string SizeClass => string.IsNullOrEmpty(Size) ? "" : $"btn-{Size}";

    public class SplitButtonItem
    {
        public string Text { get; set; } = "";
        public string? Icon { get; set; }
        public string? Title { get; set; }
        public EventCallback OnClick { get; set; }
        public bool IsDivider { get; set; }
        public bool IsDanger { get; set; }
        public bool IsDisabled { get; set; }
    }
}
