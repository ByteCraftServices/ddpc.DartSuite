@using ddpc.DartSuite.Application.Contracts.Tournaments
@inject AppStateService AppState

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">DartSuite</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        @* ─── Mobile-only: Tournament selector & user info ─── *@
        <div class="nav-mobile-header d-sm-none px-3 py-2">
            <select class="form-select form-select-sm bg-dark text-light border-secondary"
                    value="@SelectedTournamentId" @onchange="OnTournamentChanged" @onclick:stopPropagation>
                <option value="">-- Turnier --</option>
                @foreach (var t in Tournaments)
                {
                    <option value="@t.Id">@t.Name</option>
                }
            </select>
            <div class="mt-2 small">
                @if (AppState.IsAutodartsConnected && AppState.AutodartsProfile is not null)
                {
                    <div class="d-flex align-items-center gap-2 text-light">
                        @if (!string.IsNullOrEmpty(AppState.AutodartsProfile.Email))
                        {
                            <img src="@GravatarUrl(AppState.AutodartsProfile.Email)" alt="Avatar"
                                 class="rounded-circle" width="24" height="24" referrerpolicy="no-referrer" />
                        }
                        <span class="text-truncate">@(AppState.AutodartsProfile.DisplayName ?? AppState.AutodartsProfile.Email)</span>
                        <span class="badge bg-success">Verbunden</span>
                    </div>
                }
                else
                {
                    <a href="login" class="btn btn-outline-light btn-sm w-100">Login</a>
                }
            </div>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tournaments">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Turniere
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="matches">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Matches
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="boards">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Boards
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="login">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Autodarts
            </NavLink>
        </div>
    </nav>
</div>

@code {
    [Parameter] public List<TournamentDto> Tournaments { get; set; } = [];
    [Parameter] public string SelectedTournamentId { get; set; } = "";
    [Parameter] public EventCallback<ChangeEventArgs> OnTournamentChanged { get; set; }

    private static string GravatarUrl(string email)
    {
        using var md5 = System.Security.Cryptography.MD5.Create();
        var hash = md5.ComputeHash(System.Text.Encoding.UTF8.GetBytes(email.Trim().ToLowerInvariant()));
        var hex = Convert.ToHexStringLower(hash);
        return $"https://www.gravatar.com/avatar/{hex}?s=64&d=identicon";
    }
}