@using ddpc.DartSuite.Application.Contracts.Boards
@using ddpc.DartSuite.Application.Contracts.Tournaments
@inject DartSuiteApiService Api
@inject AppStateService AppState
@inject BoardHubService BoardHubService
@inject IUiHelpService UiHelp
@inject NavigationManager Navigation
@implements IAsyncDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">DartSuite</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        @* ─── Mobile-only: Tournament selector & user info ─── *@
        <div class="nav-mobile-header d-sm-none px-3 py-2">
            <select class="form-select form-select-sm bg-dark text-light border-secondary"
                    value="@SelectedTournamentId" @onchange="OnTournamentChanged" @onclick:stopPropagation>
                <option value="">-- Turnier --</option>
                @foreach (var t in Tournaments)
                {
                    <option value="@t.Id">@t.Name</option>
                }
            </select>
            <div class="mt-2 small">
                @if (AppState.IsAutodartsConnected && AppState.AutodartsProfile is not null)
                {
                    <div class="d-flex align-items-center gap-2 text-light">
                        @if (!string.IsNullOrEmpty(AppState.AutodartsProfile.Email))
                        {
                            <img src="@GravatarUrl(AppState.AutodartsProfile.Email)" alt="Avatar"
                                 class="rounded-circle" width="24" height="24" referrerpolicy="no-referrer" />
                        }
                        <span class="text-truncate">@(AppState.AutodartsProfile.DisplayName ?? AppState.AutodartsProfile.Email)</span>
                        <span class="badge bg-success">Verbunden</span>
                    </div>
                }
                else
                {
                    <a href="login" class="btn btn-outline-light btn-sm w-100">Login</a>
                }
            </div>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="dashboard">
                <span class="bi bi-display-nav-menu" aria-hidden="true"></span> Infowall
            </NavLink>
        </div>

        <div class="nav-item nav-level-0 nav-group-head">
            <NavLink class="nav-link flex-grow-1" href="@TournamentOverviewHref" @onclick="OnOverviewParentClick">
                <span class="bi bi-kanban-nav-menu" aria-hidden="true"></span> Turnieruebersicht
            </NavLink>
            <button type="button" class="btn btn-link nav-expand-btn" title="Untermenue ein-/ausklappen"
                    @onclick="ToggleOverviewGroup" @onclick:stopPropagation="true">@ExpandIndicator(isOverviewExpanded)</button>
        </div>

        @if (isOverviewExpanded)
        {
            <div class="nav-item nav-level-1">
                <NavLink class="nav-link small nav-level-1-link" href="my-tournaments?filter=overview">Meine Turniere</NavLink>
            </div>
            <div class="nav-item nav-level-1">
                <NavLink class="nav-link small nav-level-1-link" href="my-tournaments?filter=running">Laufende</NavLink>
            </div>
        }

        <div class="nav-item nav-level-0 nav-group-head">
            <button type="button" class="btn btn-link nav-link flex-grow-1 text-start text-decoration-none"
                    @onclick="OnPlayerParentClick">
                <span class="bi bi-person-nav-menu" aria-hidden="true"></span> Spieler
            </button>
            <button type="button" class="btn btn-link nav-expand-btn" title="Untermenue ein-/ausklappen"
                    @onclick="TogglePlayerGroup" @onclick:stopPropagation="true">@ExpandIndicator(isPlayerExpanded)</button>
        </div>

        @if (isPlayerExpanded)
        {
            @if (IsAdminMenuVisible)
            {
                <div class="nav-item nav-level-1">
                    <NavLink class="nav-link small nav-level-1-link" href="@LandingHref" title="@UiHelp.GetTooltip("page.landing")">Landing</NavLink>
                </div>
            }

            <div class="nav-item nav-level-1">
                <NavLink class="nav-link small nav-level-1-link" href="@RegisterHref" title="@UiHelp.GetTooltip("page.register")">Registrieren</NavLink>
            </div>
            <div class="nav-item nav-level-1">
                <NavLink class="nav-link small nav-level-1-link" href="spieler" title="@UiHelp.GetTooltip("page.spieler")">Meine Übersicht</NavLink>
            </div>
        }
        <div class="nav-item nav-level-0 nav-group-head">
            <NavLink class="nav-link flex-grow-1" href="settings?tab=general" @onclick="OnSettingsParentClick">
                <span class="bi bi-gear-nav-menu" aria-hidden="true"></span> Einstellungen
            </NavLink>
            <button type="button" class="btn btn-link nav-expand-btn" title="Untermenue ein-/ausklappen"
                    @onclick="ToggleSettingsGroup" @onclick:stopPropagation="true">@ExpandIndicator(isSettingsExpanded)</button>
        </div>

        @if (isSettingsExpanded)
        {
            <div class="nav-item nav-level-1">
                <NavLink class="nav-link small nav-level-1-link" href="settings?tab=user">Benutzer</NavLink>
            </div>
            <div class="nav-item nav-level-1">
                <NavLink class="nav-link small nav-level-1-link" href="profile">Profil</NavLink>
            </div>
        }

        <hr class="nav-separator" />

        @foreach (var tournament in Tournaments.OrderBy(t => t.Name, StringComparer.OrdinalIgnoreCase))
        {
            var isSelectedTournament = IsSelectedTournament(tournament.Id);
            <div class="nav-item nav-level-0 mt-1 nav-group-head">
                <NavLink class="@($"nav-link flex-grow-1 {(isSelectedTournament ? "text-info fw-semibold" : string.Empty)}")"
                         href="@TournamentTabHref(tournament.Id, "general")"
                         @onclick="() => OnTournamentParentClick(tournament.Id)">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> @tournament.Name
                </NavLink>
                @if (!isSelectedTournament)
                {
                    <button type="button" class="btn btn-link nav-expand-btn" title="Turniermenue ein-/ausklappen"
                            @onclick="() => ToggleTournamentGroup(tournament.Id)" @onclick:stopPropagation="true">@ExpandIndicator(IsTournamentExpanded(tournament.Id))</button>
                }
            </div>

            @if (IsTournamentExpanded(tournament.Id))
            {
                <div class="nav-item nav-level-1"><NavLink class="nav-link small nav-level-1-link" href="@TournamentTabHref(tournament.Id, "general")">Allgemein</NavLink></div>
                <div class="nav-item nav-level-1"><NavLink class="nav-link small nav-level-1-link" href="@TournamentTabHref(tournament.Id, "boards-participants")">Teilnehmer & Boards</NavLink></div>
                <div class="nav-item nav-level-1"><NavLink class="nav-link small nav-level-1-link" href="@TournamentTabHref(tournament.Id, "draw")">Auslosung</NavLink></div>
                <div class="nav-item nav-level-1"><NavLink class="nav-link small nav-level-1-link" href="@TournamentTabHref(tournament.Id, "rounds")">Spielmodus</NavLink></div>
                @if (string.Equals(tournament.Mode, "GroupAndKnockout", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="nav-item nav-level-1"><NavLink class="nav-link small nav-level-1-link" href="@TournamentTabHref(tournament.Id, "groups")">Gruppenphase</NavLink></div>
                }
                <div class="nav-item nav-level-1"><NavLink class="nav-link small nav-level-1-link" href="@TournamentTabHref(tournament.Id, "knockout")">Knockout</NavLink></div>
                <div class="nav-item nav-level-1"><NavLink class="nav-link small nav-level-1-link" href="@TournamentTabHref(tournament.Id, "schedule")">Spielplan</NavLink></div>
            }
        }

        @if (IsAdminMenuVisible)
        {
            <div class="nav-item nav-level-0 nav-group-head mt-2">
                <button type="button" class="btn btn-link nav-link flex-grow-1 text-start text-decoration-none" @onclick="ToggleAdminGroup">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Admin
                </button>
                <button type="button" class="btn btn-link nav-expand-btn" title="Untermenue ein-/ausklappen"
                        @onclick="ToggleAdminGroup" @onclick:stopPropagation="true">@ExpandIndicator(isAdminExpanded)</button>
            </div>

            @if (isAdminExpanded)
            {
                <div class="nav-item nav-level-1">
                    <NavLink class="nav-link small nav-level-1-link" href="tournaments">Turniere</NavLink>
                </div>
                <div class="nav-item nav-level-1">
                    <NavLink class="nav-link small nav-level-1-link" href="matches">Matches</NavLink>
                </div>
                <div class="nav-item nav-level-1">
                    <NavLink class="nav-link small nav-level-1-link" href="infowall" title="Live Kamerastream mit Scoring-Overlay">Infowall</NavLink>
                </div>
                @if (AppState.IsAdmin)
                {
                    <div class="nav-item nav-level-1">
                        <NavLink class="nav-link small nav-level-1-link" href="admin/accounts">Accounts</NavLink>
                    </div>
                }
                <div class="nav-item nav-level-1 nav-group-head nav-subgroup-head">
                    <NavLink class="nav-link small flex-grow-1 nav-level-1-link" href="boards" @onclick="OnBoardsParentClick">Boards</NavLink>
                    @if (HasBoardSubentries)
                    {
                        <button type="button" class="btn btn-link nav-expand-btn" title="Boards ein-/ausklappen"
                                @onclick="ToggleBoardsGroup" @onclick:stopPropagation="true">@ExpandIndicator(isBoardsExpanded)</button>
                    }
                </div>

                @if (isBoardsExpanded && HasBoardSubentries)
                {
                    @foreach (var board in VisibleBoards)
                    {
                        <div class="nav-item nav-level-2">
                            <NavLink class="nav-link small board-subentry nav-level-2-link" href="@TournamentBoardHref(board.Id)">
                                <span class="status-dot @StatusDotClass(board.OverallStatus)"></span>
                                @board.Name
                            </NavLink>
                        </div>
                    }
                }
            }
        }

        <div class="nav-item px-3 mt-2">
            <NavLink class="nav-link" href="login">
                @if (AppState.IsAutodartsConnected && AppState.AutodartsProfile is not null)
                {
                    @if (!string.IsNullOrEmpty(AppState.AutodartsProfile.Email))
                    {
                        <img src="@GravatarUrl(AppState.AutodartsProfile.Email)" alt="Avatar"
                             class="rounded-circle me-2 flex-shrink-0" width="20" height="20"
                             referrerpolicy="no-referrer" />
                    }
                    else
                    {
                        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span>
                    }

                    <span class="text-truncate" title="@(AppState.AutodartsProfile.DisplayName ?? AppState.AutodartsProfile.Email ?? "Autodarts")">
                        @(AppState.AutodartsProfile.DisplayName ?? AppState.AutodartsProfile.Email ?? "Autodarts")
                    </span>
                }
                else
                {
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span>
                    <span>Autodarts - Login</span>
                }
            </NavLink>
        </div>
    </nav>
</div>

@code {
    [Parameter] public List<TournamentDto> Tournaments { get; set; } = [];
    [Parameter] public string SelectedTournamentId { get; set; } = "";
    [Parameter] public EventCallback<ChangeEventArgs> OnTournamentChanged { get; set; }

    private readonly List<BoardDto> boards = [];
    private string _loadedScopeTournamentId = string.Empty;
    private bool isOverviewExpanded;
    private bool isSettingsExpanded;
    private bool isPlayerExpanded;
    private bool isAdminExpanded;
    private bool isBoardsExpanded = true;
    private string _lastKnownSelectedTournamentId = string.Empty;
    private readonly HashSet<Guid> expandedTournamentIds = [];

    private TournamentDto? SelectedTournament => Tournaments.FirstOrDefault(t => t.Id.ToString() == SelectedTournamentId);

    private bool IsAdminMenuVisible
    {
        get
        {
            if (!AppState.IsAutodartsConnected)
                return false;

            var actor = AppState.AutodartsProfile?.DisplayName;
            if (string.IsNullOrWhiteSpace(actor))
                return false;

            // Admin role takes precedence
            if (AppState.IsAdmin)
                return true;

            return Tournaments.Any(t => string.Equals(t.OrganizerAccount, actor, StringComparison.OrdinalIgnoreCase));
        }
    }

    private string LandingHref => string.IsNullOrWhiteSpace(SelectedTournamentId)
        ? "landing"
        : $"landing?tournamentId={SelectedTournamentId}";

    private string TournamentOverviewHref => string.IsNullOrWhiteSpace(SelectedTournamentId)
        ? "tournaments?tab=general"
        : $"tournaments?tournamentId={SelectedTournamentId}&tab=general";

    private string RegisterHref => string.IsNullOrWhiteSpace(SelectedTournamentId)
        ? "register"
        : $"register?tournamentId={SelectedTournamentId}";

    private static string TournamentTabHref(Guid tournamentId, string tab)
        => $"tournaments?tournamentId={tournamentId}&tab={tab}";

    private string TournamentBoardHref(Guid boardId)
        => string.IsNullOrWhiteSpace(SelectedTournamentId)
            ? $"tournaments?boardId={boardId}"
            : $"tournaments?tournamentId={SelectedTournamentId}&boardId={boardId}";

    private IReadOnlyList<BoardDto> VisibleBoards
    {
        get
        {
            if (!Guid.TryParse(SelectedTournamentId, out var selectedId))
                return boards.Where(b => !b.TournamentId.HasValue).OrderBy(b => b.Name).ToList();

            return boards
                .Where(b => !b.TournamentId.HasValue || b.TournamentId == selectedId)
                .OrderBy(b => b.Name)
                .ToList();
        }
    }

    private bool HasBoardSubentries => VisibleBoards.Count > 0;

    protected override async Task OnParametersSetAsync()
    {
        var normalized = SelectedTournamentId ?? string.Empty;
        if (!string.Equals(_lastKnownSelectedTournamentId, normalized, StringComparison.Ordinal))
        {
            if (Guid.TryParse(_lastKnownSelectedTournamentId, out var previousSelectedId))
                expandedTournamentIds.Remove(previousSelectedId);

            _lastKnownSelectedTournamentId = normalized;

            if (Guid.TryParse(normalized, out var selectedId))
            {
                expandedTournamentIds.Add(selectedId);
                isBoardsExpanded = true;
            }
        }

        SyncExpansionWithRoute();

        if (string.Equals(_loadedScopeTournamentId, normalized, StringComparison.Ordinal))
            return;

        await LoadBoardsAsync(normalized);
    }

    protected override async Task OnInitializedAsync()
    {
        SyncExpansionWithRoute();
        await LoadBoardsAsync(SelectedTournamentId);

        try
        {
            BoardHubService.OnBoardAdded += OnBoardChanged;
            BoardHubService.OnBoardStatusChanged += OnBoardChanged;
            BoardHubService.OnBoardConnectionChanged += OnBoardChanged;
            BoardHubService.OnBoardExtensionStatusChanged += OnBoardChanged;
            BoardHubService.OnBoardCurrentMatchChanged += OnBoardChanged;
            BoardHubService.OnBoardManagedModeChanged += OnBoardChanged;
            BoardHubService.OnBoardRemoved += OnBoardRemoved;

            await BoardHubService.StartAsync();
        }
        catch
        {
            // Navigation still works without live board events.
        }
    }

    private async Task LoadBoardsAsync(string? selectedTournamentId = null)
    {
        try
        {
            _loadedScopeTournamentId = selectedTournamentId ?? string.Empty;
            boards.Clear();

            if (Guid.TryParse(selectedTournamentId, out var selectedId))
            {
                boards.AddRange((await Api.GetBoardsByTournamentAsync(selectedId)).OrderBy(b => b.Name));
            }
            else
            {
                boards.AddRange((await Api.GetBoardsAsync())
                    .Where(b => !b.TournamentId.HasValue)
                    .OrderBy(b => b.Name));
            }
        }
        catch
        {
            // Ignore transient API errors in navigation panel.
        }
    }

    private async Task OnBoardChanged(BoardDto board)
    {
        await InvokeAsync(() =>
        {
            if (!IsBoardVisibleInCurrentScope(board))
            {
                boards.RemoveAll(b => b.Id == board.Id);
                StateHasChanged();
                return;
            }

            var index = boards.FindIndex(b => b.Id == board.Id);
            if (index >= 0)
                boards[index] = board;
            else
                boards.Add(board);

            StateHasChanged();
        });
    }

    private async Task OnBoardRemoved(Guid boardId)
    {
        await InvokeAsync(() =>
        {
            boards.RemoveAll(b => b.Id == boardId);
            StateHasChanged();
        });
    }

    private static string StatusDotClass(string? overallStatus) => overallStatus switch
    {
        "Ok" => "dot-ok",
        "Warning" => "dot-warning",
        "Error" => "dot-error",
        _ => "dot-unknown"
    };

    private static string ExpandIndicator(bool expanded) => expanded ? "▾" : "▸";

    private void ToggleOverviewGroup() => isOverviewExpanded = !isOverviewExpanded;
    private void ToggleSettingsGroup() => isSettingsExpanded = !isSettingsExpanded;
    private void TogglePlayerGroup() => isPlayerExpanded = !isPlayerExpanded;
    private void ToggleAdminGroup()
    {
        isAdminExpanded = !isAdminExpanded;
        if (isAdminExpanded)
            isBoardsExpanded = true;
    }
    private void ToggleBoardsGroup() => isBoardsExpanded = !isBoardsExpanded;

    private void OnOverviewParentClick() => isOverviewExpanded = true;
    private void OnSettingsParentClick() => isSettingsExpanded = true;
    private void OnPlayerParentClick() => isPlayerExpanded = true;
    private void OnBoardsParentClick() => isBoardsExpanded = true;

    private void OnTournamentParentClick(Guid tournamentId)
    {
        expandedTournamentIds.Add(tournamentId);
    }

    private bool IsSelectedTournament(Guid tournamentId)
        => Guid.TryParse(SelectedTournamentId, out var selectedId) && selectedId == tournamentId;

    private bool IsTournamentExpanded(Guid tournamentId)
        => IsSelectedTournament(tournamentId) || expandedTournamentIds.Contains(tournamentId);

    private void ToggleTournamentGroup(Guid tournamentId)
    {
        if (IsSelectedTournament(tournamentId))
            return;

        if (!expandedTournamentIds.Add(tournamentId))
            expandedTournamentIds.Remove(tournamentId);
    }

    private static string GravatarUrl(string email)
    {
        using var md5 = System.Security.Cryptography.MD5.Create();
        var hash = md5.ComputeHash(System.Text.Encoding.UTF8.GetBytes(email.Trim().ToLowerInvariant()));
        var hex = Convert.ToHexStringLower(hash);
        return $"https://www.gravatar.com/avatar/{hex}?s=64&d=identicon";
    }

    private bool IsBoardVisibleInCurrentScope(BoardDto board)
    {
        if (!Guid.TryParse(SelectedTournamentId, out var selectedId))
            return !board.TournamentId.HasValue;

        return !board.TournamentId.HasValue || board.TournamentId == selectedId;
    }

    private void SyncExpansionWithRoute()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri).ToLowerInvariant();

        if (relative.StartsWith("tournaments") || relative.StartsWith("my-tournaments"))
            isOverviewExpanded = true;

        if (relative.StartsWith("settings") || relative.StartsWith("profile"))
            isSettingsExpanded = true;

        if (relative.StartsWith("register") || relative.StartsWith("landing") || relative.StartsWith("spieler"))
            isPlayerExpanded = true;

        if (relative.StartsWith("boards"))
        {
            isAdminExpanded = true;
            isBoardsExpanded = true;
        }
    }

    public async ValueTask DisposeAsync()
    {
        BoardHubService.OnBoardAdded -= OnBoardChanged;
        BoardHubService.OnBoardStatusChanged -= OnBoardChanged;
        BoardHubService.OnBoardConnectionChanged -= OnBoardChanged;
        BoardHubService.OnBoardExtensionStatusChanged -= OnBoardChanged;
        BoardHubService.OnBoardCurrentMatchChanged -= OnBoardChanged;
        BoardHubService.OnBoardManagedModeChanged -= OnBoardChanged;
        BoardHubService.OnBoardRemoved -= OnBoardRemoved;
        await Task.CompletedTask;
    }
}
