@inherits LayoutComponentBase
@using ddpc.DartSuite.Application.Contracts.Autodarts
@using ddpc.DartSuite.Application.Contracts.Tournaments
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using ddpc.DartSuite.Web.Services
@inject DartSuiteApiService Api
@inject AppStateService AppState
@inject ProtectedLocalStorage LocalStorage
@implements IDisposable

<ApiOfflineOverlay IsVisible="@isApiOffline"
                   RetryCount="@apiRetryCount"
                   SecondsToNextRetry="@apiSecondsToNextRetry" />

<div class="page">
    <div class="sidebar">
        <NavMenu Tournaments="tournaments" SelectedTournamentId="@selectedTournamentId"
                 OnTournamentChanged="OnTournamentChanged" />
    </div>

    <main>
        <div class="top-row px-4 d-none d-sm-flex">
            <div class="d-flex align-items-center gap-3 w-100">
                <a href="" class="fw-semibold me-auto text-decoration-none text-dark">DartSuite Tournament Control</a>

                @* ─── Tournament selector ─── *@
                <select class="form-select form-select-sm" style="width:auto;max-width:260px"
                        value="@selectedTournamentId" @onchange="OnTournamentChanged">
                    <option value="">-- Turnier --</option>
                    @foreach (var t in tournaments)
                    {
                        <option value="@t.Id">@t.Name</option>
                    }
                </select>

                @* ─── Autodarts account ─── *@
                @if (AppState.IsAutodartsConnected && AppState.AutodartsProfile is not null)
                {
                    <div class="d-flex align-items-center gap-2">
                        @if (!string.IsNullOrEmpty(AppState.AutodartsProfile.Email))
                        {
                            <img src="@GravatarUrl(AppState.AutodartsProfile.Email)" alt="Avatar"
                                 class="rounded-circle" width="32" height="32" referrerpolicy="no-referrer" />
                        }
                        <span class="small fw-semibold text-nowrap">@(AppState.AutodartsProfile.DisplayName ?? AppState.AutodartsProfile.Email)</span>
                        @if (AppState.LoginSource == AutodartsLoginSource.AutoRestore)
                        {
                            <span class="badge bg-info text-dark" title="Automatisch wiederhergestellt">Auto</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Verbunden</span>
                        }
                    </div>
                }
                else
                {
                    <a href="login" class="btn btn-outline-secondary btn-sm">Login</a>
                }
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private const string StorageKeyEmail = "autodarts.email";
    private const string StorageKeyPassword = "autodarts.password";
    private const string StorageKeyRememberLogin = "autodarts.rememberLogin";

    private List<TournamentDto> tournaments = new();
    private string selectedTournamentId = "";
    private bool initialized;

    // ─── API Health ───
    private bool isApiOffline;
    private int apiRetryCount;
    private int apiSecondsToNextRetry;
    private CancellationTokenSource? _healthCts;

    /// <summary>Retry delays for successive connection attempts (seconds).</summary>
    private static readonly int[] RetryDelays = [3, 5, 10, 15, 30];

    protected override void OnInitialized()
    {
        AppState.OnChange += OnAppStateChanged;
    }

    private void OnAppStateChanged()
    {
        // Sync header dropdown when another page sets the selected tournament
        if (AppState.SelectedTournament is not null)
            selectedTournamentId = AppState.SelectedTournament.Id.ToString();
        else
            selectedTournamentId = "";

        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || initialized) return;
        initialized = true;

        _healthCts = new CancellationTokenSource();
        await RunWithApiHealthMonitoringAsync(_healthCts.Token);
    }

    /// <summary>
    /// Runs the initial data load.  If the API is unreachable, shows the offline overlay
    /// and keeps retrying until the API responds, then completes initialization.
    /// Retry delays escalate with each attempt: 3 → 5 → 10 → 15 → 30 seconds (capped).
    /// </summary>
    private async Task RunWithApiHealthMonitoringAsync(CancellationToken cancellationToken)
    {
        // ── 1. Check if API is available before loading data ──
        var healthy = await Api.CheckHealthAsync(cancellationToken);

        if (!healthy)
        {
            isApiOffline = true;
            apiRetryCount = 0;
            apiSecondsToNextRetry = 0;
            await InvokeAsync(StateHasChanged);

            while (!healthy && !cancellationToken.IsCancellationRequested)
            {
                apiRetryCount++;
                var delaySec = RetryDelays[Math.Min(apiRetryCount - 1, RetryDelays.Length - 1)];

                // Countdown display
                for (var remaining = delaySec; remaining > 0 && !cancellationToken.IsCancellationRequested; remaining--)
                {
                    apiSecondsToNextRetry = remaining;
                    await InvokeAsync(StateHasChanged);
                    try
                    {
                        await Task.Delay(1000, cancellationToken);
                    }
                    catch (OperationCanceledException)
                    {
                        return;
                    }
                }

                if (cancellationToken.IsCancellationRequested)
                    return;

                apiSecondsToNextRetry = 0;
                await InvokeAsync(StateHasChanged);

                healthy = await Api.CheckHealthAsync(cancellationToken);
            }

            if (cancellationToken.IsCancellationRequested)
                return;

            isApiOffline = false;
            apiRetryCount = 0;
            await InvokeAsync(StateHasChanged);
        }

        // ── 2. API is reachable – load initial data ──
        try
        {
            tournaments = (await Api.GetTournamentsAsync(cancellationToken))
                .Where(t => t.Status != "Beendet" && t.Status != "Abgebrochen")
                .ToList();

            // Restore saved tournament selection
            var stored = await LocalStorage.GetAsync<string>("dartsuite.selectedTournamentId");
            if (stored.Success && !string.IsNullOrWhiteSpace(stored.Value))
            {
                var match = tournaments.FirstOrDefault(t => t.Id.ToString() == stored.Value);
                if (match is not null)
                {
                    selectedTournamentId = stored.Value;
                    // Set without firing OnChange back to us (we already set selectedTournamentId)
                    AppState.SetSelectedTournamentSilent(match);
                }
            }

            // Restore Autodarts session
            var status = await Api.GetAutodartsStatusAsync(cancellationToken);
            if (status.IsConnected && status.Profile is not null)
            {
                AppState.SetAutodartsProfileSilent(status.Profile, true, AutodartsLoginSource.AutoRestore);
            }
            else
            {
                await TryAutoReconnectAutodartsAsync(cancellationToken);
            }

            // Load admin status
            var isAdmin = await Api.CheckIsAdminAsync(cancellationToken);
            AppState.SetIsAdminSilent(isAdmin);
        }
        catch { /* Secondary initialisation calls may fail if the API goes offline again immediately after the health check; degrade gracefully. */ }

        await InvokeAsync(StateHasChanged);
    }

    private async Task TryAutoReconnectAutodartsAsync(CancellationToken cancellationToken)
    {
        try
        {
            var rememberSetting = await LocalStorage.GetAsync<bool>(StorageKeyRememberLogin);
            if (!rememberSetting.Success || !rememberSetting.Value)
                return;

            var storedEmail = await LocalStorage.GetAsync<string>(StorageKeyEmail);
            var storedPassword = await LocalStorage.GetAsync<string>(StorageKeyPassword);

            if (!storedEmail.Success || string.IsNullOrWhiteSpace(storedEmail.Value)
                || !storedPassword.Success || string.IsNullOrWhiteSpace(storedPassword.Value))
                return;

            var response = await Api.LoginAutodartsAsync(storedEmail.Value, storedPassword.Value, cancellationToken);
            var profile = response.Profile;
            if (profile is null || string.IsNullOrWhiteSpace(profile.DisplayName) || string.IsNullOrWhiteSpace(profile.Email))
                return;

            AppState.SetAutodartsProfileSilent(profile, true, AutodartsLoginSource.AutoRestore);
        }
        catch
        {
            // Best effort: keep UI usable and let user login manually if reconnect fails.
        }
    }

    private async Task OnTournamentChanged(ChangeEventArgs e)
    {
        selectedTournamentId = e.Value?.ToString() ?? "";
        var tournament = tournaments.FirstOrDefault(t => t.Id.ToString() == selectedTournamentId);
        AppState.SetSelectedTournament(tournament);

        try
        {
            if (!string.IsNullOrEmpty(selectedTournamentId))
                await LocalStorage.SetAsync("dartsuite.selectedTournamentId", selectedTournamentId);
            else
                await LocalStorage.DeleteAsync("dartsuite.selectedTournamentId");
        }
        catch { /* storage may not be available */ }
    }

    private static string GravatarUrl(string email)
    {
        using var md5 = System.Security.Cryptography.MD5.Create();
        var hash = md5.ComputeHash(System.Text.Encoding.UTF8.GetBytes(email.Trim().ToLowerInvariant()));
        var hex = Convert.ToHexStringLower(hash);
        return $"https://www.gravatar.com/avatar/{hex}?s=64&d=identicon";
    }

    public void Dispose()
    {
        AppState.OnChange -= OnAppStateChanged;
        _healthCts?.Cancel();
        _healthCts?.Dispose();
    }
}