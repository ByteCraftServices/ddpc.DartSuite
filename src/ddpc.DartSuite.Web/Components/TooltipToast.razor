@* DS-038: Toast für Disabled Button Tooltips *@

<div id="tooltipToastContainer" class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
    <div id="tooltipToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true" style="display: none;">
        <div class="toast-header bg-info text-white">
            <strong class="me-auto">💬 Hinweis</strong>
            <button type="button" class="btn-close btn-close-white" id="tooltipCloseBtn" aria-label="Close"></button>
        </div>
        <div id="tooltipBody" class="toast-body">
            <!-- Content wird von JS gesetzt -->
        </div>
    </div>
</div>

@code {
    // Diese Component rendered einfach das HTML
    // Die Logik läuft vollständig in JavaScript
}
