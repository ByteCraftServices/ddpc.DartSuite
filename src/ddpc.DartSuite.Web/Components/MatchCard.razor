    private bool HeaderShowsStartTime => ShouldShowHeaderStartTimeChip;
    private bool HeaderShowsMatchNumber => ResolvedShowHeaderMatchNumber && !string.IsNullOrWhiteSpace(Label);
    private bool HeaderShowsMatchName => ResolvedShowHeaderMatchName && !string.IsNullOrWhiteSpace(ResolvedMatchName);
    private bool HeaderShowsBoardName => ResolvedShowHeaderBoardName && !string.IsNullOrWhiteSpace(ResolvedBoardName);
    private bool HeaderShowsBoardLock => ResolvedShowHeaderBoardLock;
    private bool HeaderShowsMatchStatus => ResolvedShowHeaderMatchStatus;
    private bool HeaderShowsLiveBadge => ResolvedShowHeaderLiveBadge && IsRunning;
        private bool PreMatchInlineShowsStartTimeChip => UsePreMatchInlineHorizontalRow && (ShouldShowNotStartedStartTimeFallback || ShouldShowNotStartedStartTimeWithBoardFallback);
        private bool PreMatchInlineShowsBoardChip => UsePreMatchInlineHorizontalRow && (ShouldShowNotStartedBoardFallback || ShouldShowNotStartedStartTimeWithBoardFallback);
        private bool PrematchInlineStartTimeHasLockOverlay => PreMatchInlineShowsStartTimeChip && ResolvedShowBodyStartTimeLock;
        private bool PrematchInlineBoardHasLockOverlay => PreMatchInlineShowsBoardChip && ResolvedShowBodyBoardLock;
        private bool ShouldShowBodyStartTimeChip => ResolvedShowBodyStartTime && !HeaderShowsStartTime && !PreMatchInlineShowsStartTimeChip;
    private bool ShouldShowBodyMatchNumberChip => ResolvedShowBodyMatchNumber && !HeaderShowsMatchNumber && !string.IsNullOrWhiteSpace(Label);
    private bool ShouldShowBodyMatchNameChip => ResolvedShowBodyMatchName && !HeaderShowsMatchName && !string.IsNullOrWhiteSpace(ResolvedMatchName);
    private bool ShouldShowBodyBoardNameChip
        => !string.IsNullOrWhiteSpace(ResolvedBoardName)
           && !HeaderShowsBoardName
            && ResolvedShowBodyBoardName
            && !PreMatchInlineShowsBoardChip;
        private bool ShouldShowBodyBoardLockChip => ResolvedShowBodyBoardLock && !HeaderShowsBoardLock && !PreMatchInlineShowsBoardChip;
    private bool ShouldShowBodyMatchStatusChip => ResolvedShowBodyMatchStatus && !HeaderShowsMatchStatus;
    private bool ShouldShowBodyLiveBadgeChip => ResolvedShowBodyLiveBadge && IsRunning && !HeaderShowsLiveBadge;
    private bool ShouldShowListStartTimeChip => ShouldShowHeaderStartTimeChip || (!ResolvedShowHeaderStartTime && ResolvedShowBodyStartTime);
    private bool ShouldShowListMatchNumberChip => (ResolvedShowHeaderMatchNumber || ResolvedShowBodyMatchNumber) && !string.IsNullOrWhiteSpace(Label);
    private bool ShouldShowListLiveBadge => HeaderShowsLiveBadge || (ResolvedShowBodyLiveBadge && IsRunning);
    private bool ShouldShowListMatchStatusBadge => HeaderShowsMatchStatus || ResolvedShowBodyMatchStatus;
    private bool IsListLayout => string.Equals(EffectiveLayout, "List", StringComparison.Ordinal);
    private bool ShowListDetailChevron => IsListLayout && ShowDetailsSection;
    private bool HeaderStartTimeHasLockOverlay => ShouldShowHeaderStartTimeChip && ResolvedShowHeaderStartTimeLock;
    private bool ShowHeaderStandaloneStartTimeLock => ResolvedShowHeaderStartTimeLock && !ShouldShowHeaderStartTimeChip;
    private bool BodyStartTimeHasLockOverlay => ShouldShowBodyStartTimeChip && ResolvedShowBodyStartTimeLock;
    private bool ShowBodyStandaloneStartTimeLock => ResolvedShowBodyStartTimeLock && !ShouldShowBodyStartTimeChip && !PreMatchInlineShowsStartTimeChip;
    private bool HeaderBoardHasLockOverlay => ResolvedShowHeaderBoardName && !string.IsNullOrWhiteSpace(ResolvedBoardName) && ResolvedShowHeaderBoardLock;
    private bool ShowHeaderStandaloneBoardLock => ResolvedShowHeaderBoardLock && !(ResolvedShowHeaderBoardName && !string.IsNullOrWhiteSpace(ResolvedBoardName));
    private bool BodyBoardHasLockOverlay => ShouldShowBodyBoardNameChip && ResolvedShowBodyBoardLock;
    private bool ShowBodyStandaloneBoardLock => ShouldShowBodyBoardLockChip && !ShouldShowBodyBoardNameChip;
    private bool ShouldShowListStartTimeLockOverlay
        => (ResolvedShowHeaderStartTime && ResolvedShowHeaderStartTimeLock)
           || (!ResolvedShowHeaderStartTime && ResolvedShowBodyStartTime && ResolvedShowBodyStartTimeLock);
    private bool ShouldShowListBoardLockOverlay
        => !string.IsNullOrWhiteSpace(ResolvedBoardName)
           && ((ResolvedShowHeaderBoardName && ResolvedShowHeaderBoardLock)
               || (!ResolvedShowHeaderBoardName && ResolvedShowBodyBoardName && ResolvedShowBodyBoardLock));

    private bool ResolvedShowActionButtons => ViewSettings?.ShowActionButtons ?? ShowActionButtons;
    private bool UseActionMenu => ResolvedShowActionButtons;
    private bool ResolvedShowSyncAction => ViewSettings?.ShowSyncAction ?? ShowSyncAction;
    private bool ResolvedShowFollowAction => ViewSettings?.ShowFollowAction ?? ShowFollowAction;
    private bool ResolvedShowStartMatchAction => ViewSettings?.ShowStartMatchAction ?? ShowStartMatchAction;
