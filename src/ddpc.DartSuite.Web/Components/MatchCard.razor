@using ddpc.DartSuite.Application.Contracts.Matches
@using ddpc.DartSuite.Web.Services
@implements IAsyncDisposable
@inject TournamentHubService TournamentHubService
@inject DartSuiteApiService Api

<div class="@CardClass" style="@CardInlineStyle" @onclick="HandleClickAsync">
    @if (string.Equals(EffectiveLayout, "List", StringComparison.Ordinal))
    {
        <div class="match-card-list-row py-1 px-2 small">
            @if (ShowListDetailChevron)
            {
                <button type="button"
                        class="btn btn-outline-secondary btn-sm match-list-detail-toggle"
                        aria-expanded="@IsDetailPanelExpanded"
                        aria-label="Erweiterte Details"
                        title="Erweiterte Details"
                        @onclick="ToggleDetailsExpanded"
                        @onclick:stopPropagation="true">
                    <span class="match-list-detail-toggle-glyph" aria-hidden="true">@(IsDetailPanelExpanded ? "▾" : "▸")</span>
                </button>
            }
            @if (ShouldShowListStartTimeChip)
            {
                <span class="badge text-bg-light border flex-shrink-0 detail-chip-with-lock">
                    @HeaderStartTimeText
                    @if (ShouldShowListStartTimeLockOverlay)
                    {
                        <span class="detail-chip-lock-overlay" title="Startzeit gesperrt">@StartTimeLockGlyph</span>
                    }
                </span>
            }
            @if (ShouldShowListMatchNumberChip)
            {
                <span class="badge text-bg-secondary flex-shrink-0">@Label</span>
            }
            <PlayerName Name="@ResolvedHomeName"
                        HighlightWinner="@(Match.WinnerParticipantId == Match.HomeParticipantId)"
                        ShowAverage="@ShowPlayerAverage"
                        Average="@HomeStatistic?.Average"
                        OnClick="@ResolvedHomePlayerClick" />
            @if (IsRunning && IsHomeActivePlayer)
            {
                <span class="badge text-bg-info flex-shrink-0" style="font-size:.65em">am Zug</span>
            }
            <div class="d-flex align-items-center gap-1 flex-shrink-0 match-card-list-score">
                @if (ShouldShowSets)
                {
                    <span class="badge border @ScoreChipMainClass @ScoreStatusChipClass">S @EffectiveHomeSets</span>
                }
                @if (ShouldShowLegs)
                {
                    <span class="badge border @ScoreChipMainClass @ScoreStatusChipClass">L @EffectiveHomeLegs</span>
                }
                @if (ShouldShowLivePoints)
                {
                    <span class="badge border match-score-chip @ScoreStatusChipClass">@EffectiveHomePoints</span>
                    <span class="text-muted" style="font-size:.8em">vs</span>
                    <span class="badge border match-score-chip @ScoreStatusChipClass">@EffectiveAwayPoints</span>
                }
                else if (ShouldShowFinalResultScore)
                {
                    <span class="text-muted fw-semibold" style="font-size:.85em">@FinalResultScoreText</span>
                }
                else if (ShouldShowNotStartedStartTimeFallback)
                {
                    <span class="badge text-bg-light border">@NotStartedFallbackStartTimeText</span>
                }
                else if (ShouldShowNotStartedBoardFallback)
                {
                    <span class="badge text-bg-light border">@ResolvedBoardName</span>
                }
                else if (ShouldShowNotStartedStatusFallback)
                {
                    <span class="badge @MatchStatusBadgeClass">@Match.Status</span>
                    <span class="badge text-bg-light border">@SchedulingStatusLabel</span>
                }
                else
                {
                    <span class="text-muted" style="font-size:.8em">vs</span>
                }
                @if (ShowInlineBodyActions && UseActionMenu)
                {
                    <div class="dropdown flex-shrink-0" @onclick:stopPropagation="true">
                        <button type="button" class="btn btn-outline-secondary btn-sm match-action-menu-button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Match-Aktionen oeffnen" title="Aktionen">
                            <span class="match-action-menu-glyph" aria-hidden="true">⋮</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            @if (ShowStartMatchActionItem)
                            {
                                <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableStartMatchActionItem" title="Match starten" @onclick="HandleStartMatchAsync"><i class="bi bi-play-fill"></i><span class="match-action-label">Match starten</span></button></li>
                            }
                            @if (ShowResetActionItem)
                            {
                                <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableResetActionItem" title="Match zuruecksetzen" @onclick="HandleResetMatchAsync"><i class="bi bi-arrow-counterclockwise"></i><span class="match-action-label">Zuruecksetzen</span></button></li>
                            }
                            @if (ShowStartListenerActionItem)
                            {
                                <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableStartListenerActionItem" title="Listener starten" @onclick="HandleStartListenerAsync"><i class="bi bi-broadcast-pin"></i><span class="match-action-label">Listener starten</span></button></li>
                            }
                            @if (ShowSyncActionItem)
                            {
                                <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableSyncActionItem" title="Synchronisieren" @onclick="HandleSyncAsync"><i class="bi bi-arrow-repeat"></i><span class="match-action-label">Sync</span></button></li>
                            }
                            @if (ShowFollowActionItem)
                            {
                                <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableFollowActionItem" title="@(IsFollowing ? "Nicht mehr folgen" : "Match folgen")" @onclick="HandleFollowAsync"><i class="bi @(IsFollowing ? "bi-bell-fill" : "bi-bell")"></i><span class="match-action-label">@(IsFollowing ? "Folgen aktiv" : "Folgen")</span></button></li>
                            }
                            @if (ShowToggleStartTimeLockActionItem)
                            {
                                <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableToggleStartTimeLockActionItem" title="Startzeit sperren oder entsperren" @onclick="HandleToggleStartTimeLockAsync"><span>@StartTimeLockGlyph</span><span class="match-action-label">@(Match.IsStartTimeLocked ? "Startzeit entsperren" : "Startzeit sperren")</span></button></li>
                            }
                            @if (ShowToggleBoardLockActionItem)
                            {
                                <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableToggleBoardLockActionItem" title="Board sperren oder entsperren" @onclick="HandleToggleBoardLockAsync"><span>@BoardLockGlyph</span><span class="match-action-label">@(Match.IsBoardLocked ? "Board entsperren" : "Board sperren")</span></button></li>
                            }
                        </ul>
                    </div>
                }
                @if (ShowInlineBodyActions && !UseActionMenu)
                {
                    <div class="d-flex flex-wrap align-items-center gap-1 flex-shrink-0 match-action-inline-buttons" @onclick:stopPropagation="true">
                        @if (ShowStartMatchActionItem)
                        {
                            <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableStartMatchActionItem" title="Match starten" aria-label="Match starten" @onclick="HandleStartMatchAsync"><span aria-hidden="true">▶</span></button>
                        }
                        @if (ShowResetActionItem)
                        {
                            <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableResetActionItem" title="Match zuruecksetzen" @onclick="HandleResetMatchAsync"><i class="bi bi-arrow-counterclockwise"></i></button>
                        }
                        @if (ShowStartListenerActionItem)
                        {
                            <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableStartListenerActionItem" title="Listener starten" @onclick="HandleStartListenerAsync"><i class="bi bi-broadcast-pin"></i></button>
                        }
                        @if (ShowSyncActionItem)
                        {
                            <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableSyncActionItem" title="Synchronisieren" @onclick="HandleSyncAsync"><i class="bi bi-arrow-repeat"></i></button>
                        }
                        @if (ShowFollowActionItem)
                        {
                            <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableFollowActionItem" title="@(IsFollowing ? "Nicht mehr folgen" : "Match folgen")" @onclick="HandleFollowAsync"><i class="bi @(IsFollowing ? "bi-bell-fill" : "bi-bell")"></i></button>
                        }
                        @if (ShowToggleStartTimeLockActionItem)
                        {
                            <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableToggleStartTimeLockActionItem" title="Startzeit sperren oder entsperren" @onclick="HandleToggleStartTimeLockAsync">@StartTimeLockGlyph</button>
                        }
                        @if (ShowToggleBoardLockActionItem)
                        {
                            <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableToggleBoardLockActionItem" title="Board sperren oder entsperren" @onclick="HandleToggleBoardLockAsync">@BoardLockGlyph</button>
                        }
                    </div>
                }
                @if (ShouldShowLegs)
                {
                    <span class="badge border @ScoreChipMainClass @ScoreStatusChipClass">L @EffectiveAwayLegs</span>
                }
                @if (ShouldShowSets)
                {
                    <span class="badge border @ScoreChipMainClass @ScoreStatusChipClass">S @EffectiveAwaySets</span>
                }
            </div>
            <PlayerName Name="@ResolvedAwayName"
                        HighlightWinner="@(Match.WinnerParticipantId == Match.AwayParticipantId)"
                        ShowAverage="@ShowPlayerAverage"
                        Average="@AwayStatistic?.Average"
                        OnClick="@ResolvedAwayPlayerClick" />
            @if (IsRunning && IsAwayActivePlayer)
            {
                <span class="badge text-bg-info flex-shrink-0" style="font-size:.65em">am Zug</span>
            }
            @if (ShowAnyActionButtons && ShowListInlineActions && UseActionMenu)
            {
                <div class="dropdown flex-shrink-0" @onclick:stopPropagation="true">
                    <button type="button" class="btn btn-outline-secondary btn-sm match-action-menu-button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Match-Aktionen oeffnen" title="Aktionen">
                        <span class="match-action-menu-glyph" aria-hidden="true">⋮</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        @if (ShowStartMatchActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableStartMatchActionItem" title="Match starten" @onclick="HandleStartMatchAsync"><i class="bi bi-play-fill"></i><span class="match-action-label">Match starten</span></button></li>
                        }
                        @if (ShowResetActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableResetActionItem" title="Match zuruecksetzen" @onclick="HandleResetMatchAsync"><i class="bi bi-arrow-counterclockwise"></i><span class="match-action-label">Zuruecksetzen</span></button></li>
                        }
                        @if (ShowStartListenerActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableStartListenerActionItem" title="Listener starten" @onclick="HandleStartListenerAsync"><i class="bi bi-broadcast-pin"></i><span class="match-action-label">Listener starten</span></button></li>
                        }
                        @if (ShowSyncActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableSyncActionItem" title="Synchronisieren" @onclick="HandleSyncAsync"><i class="bi bi-arrow-repeat"></i><span class="match-action-label">Sync</span></button></li>
                        }
                        @if (ShowFollowActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableFollowActionItem" title="@(IsFollowing ? "Nicht mehr folgen" : "Match folgen")" @onclick="HandleFollowAsync"><i class="bi @(IsFollowing ? "bi-bell-fill" : "bi-bell")"></i><span class="match-action-label">@(IsFollowing ? "Folgen aktiv" : "Folgen")</span></button></li>
                        }
                        @if (ShowToggleStartTimeLockActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableToggleStartTimeLockActionItem" title="Startzeit sperren oder entsperren" @onclick="HandleToggleStartTimeLockAsync"><span>@StartTimeLockGlyph</span><span class="match-action-label">@(Match.IsStartTimeLocked ? "Startzeit entsperren" : "Startzeit sperren")</span></button></li>
                        }
                        @if (ShowToggleBoardLockActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableToggleBoardLockActionItem" title="Board sperren oder entsperren" @onclick="HandleToggleBoardLockAsync"><span>@BoardLockGlyph</span><span class="match-action-label">@(Match.IsBoardLocked ? "Board entsperren" : "Board sperren")</span></button></li>
                        }
                    </ul>
                </div>
            }
            @if (ShowAnyActionButtons && ShowListInlineActions && !UseActionMenu)
            {
                <div class="d-flex flex-wrap align-items-center gap-1 flex-shrink-0 match-action-inline-buttons" @onclick:stopPropagation="true">
                    @if (ShowStartMatchActionItem)
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableStartMatchActionItem" title="Match starten" aria-label="Match starten" @onclick="HandleStartMatchAsync"><span aria-hidden="true">▶</span></button>
                    }
                    @if (ShowResetActionItem)
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableResetActionItem" title="Match zuruecksetzen" @onclick="HandleResetMatchAsync"><i class="bi bi-arrow-counterclockwise"></i></button>
                    }
                    @if (ShowStartListenerActionItem)
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableStartListenerActionItem" title="Listener starten" @onclick="HandleStartListenerAsync"><i class="bi bi-broadcast-pin"></i></button>
                    }
                    @if (ShowSyncActionItem)
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableSyncActionItem" title="Synchronisieren" @onclick="HandleSyncAsync"><i class="bi bi-arrow-repeat"></i></button>
                    }
                    @if (ShowFollowActionItem)
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableFollowActionItem" title="@(IsFollowing ? "Nicht mehr folgen" : "Match folgen")" @onclick="HandleFollowAsync"><i class="bi @(IsFollowing ? "bi-bell-fill" : "bi-bell")"></i></button>
                    }
                    @if (ShowToggleStartTimeLockActionItem)
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableToggleStartTimeLockActionItem" title="Startzeit sperren oder entsperren" @onclick="HandleToggleStartTimeLockAsync">@StartTimeLockGlyph</button>
                    }
                    @if (ShowToggleBoardLockActionItem)
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableToggleBoardLockActionItem" title="Board sperren oder entsperren" @onclick="HandleToggleBoardLockAsync">@BoardLockGlyph</button>
                    }
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(ResolvedBoardName))
            {
                @if (ShouldShowListBoardLockOverlay)
                {
                    @if (ResolvedBoardClick.HasDelegate)
                    {
                        <button type="button"
                                class="badge border-0 text-bg-dark board-name-button detail-chip-with-lock"
                                title="Boarddetails anzeigen"
                                @onclick="HandleBoardChipClickAsync"
                                @onclick:stopPropagation="true">
                            @ResolvedBoardName
                            <span class="detail-chip-lock-overlay" title="Boardzuordnung gesperrt">@BoardLockGlyph</span>
                        </button>
                    }
                    else
                    {
                        <span class="badge text-bg-dark detail-chip-with-lock" title="Boardzuordnung gesperrt">
                            @ResolvedBoardName
                            <span class="detail-chip-lock-overlay">@BoardLockGlyph</span>
                        </span>
                    }
                }
                else
                {
                    <BoardName Name="@ResolvedBoardName"
                               Status="@MonitoringStatusText"
                               Tooltip="Boarddetails anzeigen"
                               OnClick="@ResolvedBoardClick"
                               BadgeCssClass="text-bg-dark" />
                }
            }
            @if (ShouldShowListLiveBadge)
            {
                <span class="badge text-bg-info flex-shrink-0">Live</span>
            }
            @if (ShouldShowListMatchStatusBadge)
            {
                <span class="badge @MatchStatusBadgeClass flex-shrink-0">@Match.Status</span>
            }
        </div>
        @if (ShowAnyActionButtons && !ShowListInlineActions && UseActionMenu)
        {
            <div class="match-card-list-actions" @onclick:stopPropagation="true">
                <div class="dropdown">
                    <button type="button" class="btn btn-outline-secondary btn-sm match-action-menu-button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Match-Aktionen oeffnen" title="Aktionen">
                        <span class="match-action-menu-glyph" aria-hidden="true">⋮</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        @if (ShowStartMatchActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableStartMatchActionItem" title="Match starten" @onclick="HandleStartMatchAsync"><i class="bi bi-play-fill"></i><span class="match-action-label">Match starten</span></button></li>
                        }
                        @if (ShowResetActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableResetActionItem" title="Match zur�cksetzen" @onclick="HandleResetMatchAsync"><i class="bi bi-arrow-counterclockwise"></i><span class="match-action-label">Zuruecksetzen</span></button></li>
                        }
                        @if (ShowStartListenerActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableStartListenerActionItem" title="Listener starten" @onclick="HandleStartListenerAsync"><i class="bi bi-broadcast-pin"></i><span class="match-action-label">Listener starten</span></button></li>
                        }
                        @if (ShowSyncActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableSyncActionItem" title="Synchronisieren" @onclick="HandleSyncAsync"><i class="bi bi-arrow-repeat"></i><span class="match-action-label">Sync</span></button></li>
                        }
                        @if (ShowFollowActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableFollowActionItem" title="@(IsFollowing ? "Nicht mehr folgen" : "Match folgen")" @onclick="HandleFollowAsync"><i class="bi @(IsFollowing ? "bi-bell-fill" : "bi-bell")"></i><span class="match-action-label">@(IsFollowing ? "Folgen aktiv" : "Folgen")</span></button></li>
                        }
                        @if (ShowToggleStartTimeLockActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableToggleStartTimeLockActionItem" title="Startzeit sperren oder entsperren" @onclick="HandleToggleStartTimeLockAsync"><span>@StartTimeLockGlyph</span><span class="match-action-label">@(Match.IsStartTimeLocked ? "Startzeit entsperren" : "Startzeit sperren")</span></button></li>
                        }
                        @if (ShowToggleBoardLockActionItem)
                        {
                            <li><button type="button" class="dropdown-item d-flex align-items-center gap-2 match-action-menu-item" disabled="@DisableToggleBoardLockActionItem" title="Board sperren oder entsperren" @onclick="HandleToggleBoardLockAsync"><span>@BoardLockGlyph</span><span class="match-action-label">@(Match.IsBoardLocked ? "Board entsperren" : "Board sperren")</span></button></li>
                        }
                    </ul>
                </div>
            </div>
        }
        @if (ShowAnyActionButtons && !ShowListInlineActions && !UseActionMenu)
        {
            <div class="match-card-list-actions d-flex flex-wrap align-items-center gap-1" @onclick:stopPropagation="true">
                @if (ShowStartMatchActionItem)
                {
                    <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableStartMatchActionItem" title="Match starten" aria-label="Match starten" @onclick="HandleStartMatchAsync"><span aria-hidden="true">▶</span></button>
                }
                @if (ShowResetActionItem)
                {
                    <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableResetActionItem" title="Match zuruecksetzen" @onclick="HandleResetMatchAsync"><i class="bi bi-arrow-counterclockwise"></i></button>
                }
                @if (ShowStartListenerActionItem)
                {
                    <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableStartListenerActionItem" title="Listener starten" @onclick="HandleStartListenerAsync"><i class="bi bi-broadcast-pin"></i></button>
                }
                @if (ShowSyncActionItem)
                {
                    <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableSyncActionItem" title="Synchronisieren" @onclick="HandleSyncAsync"><i class="bi bi-arrow-repeat"></i></button>
                }
                @if (ShowFollowActionItem)
                {
                    <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableFollowActionItem" title="@(IsFollowing ? "Nicht mehr folgen" : "Match folgen")" @onclick="HandleFollowAsync"><i class="bi @(IsFollowing ? "bi-bell-fill" : "bi-bell")"></i></button>
                }
                @if (ShowToggleStartTimeLockActionItem)
                {
                    <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableToggleStartTimeLockActionItem" title="Startzeit sperren oder entsperren" @onclick="HandleToggleStartTimeLockAsync">@StartTimeLockGlyph</button>
                }
                @if (ShowToggleBoardLockActionItem)
                {
                    <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@DisableToggleBoardLockActionItem" title="Board sperren oder entsperren" @onclick="HandleToggleBoardLockAsync">@BoardLockGlyph</button>
                }
            </div>
        }
    }
    else
    {
    @if (!ResolvedSuppressHeader && ShowHeaderSection)
    {
        <div class="card-header py-1 px-3 d-flex align-items-center gap-2 overflow-hidden">
            @if (ShowHeaderTitleLine)
            {
                <span class="fw-semibold small text-nowrap flex-shrink-0" style="overflow:hidden;text-overflow:ellipsis;max-width:50%">@HeaderTitleLine</span>
            }
            @if (ShowHeaderMetaLine)
            {
                <div class="d-flex align-items-center gap-1 flex-wrap overflow-hidden" style="min-width:0;">
                        @if (ResolvedShowRuntimeBadge && Match.StartedUtc is not null)
                        {
                            <span class="badge text-bg-light text-muted border" style="font-size:.7em">
                                ? @CurrentRuntimeLabel
                            </span>
                        }
                        @if (ShouldShowHeaderStartTimeChip)
                        {
                            <span class="badge text-bg-light border detail-chip-with-lock">
                                @HeaderStartTimeText
                                @if (HeaderStartTimeHasLockOverlay)
                                {
                                    <span class="detail-chip-lock-overlay" title="Startzeit gesperrt">@StartTimeLockGlyph</span>
                                }
                            </span>
                        }
                        @if (ShowHeaderStandaloneStartTimeLock)
                        {
                            <span class="badge text-bg-light border" title="Startzeit gesperrt">@StartTimeLockGlyph</span>
                        }
                        @if (ResolvedShowHeaderBoardName && !string.IsNullOrWhiteSpace(ResolvedBoardName))
                        {
                            @if (HeaderBoardHasLockOverlay)
                            {
                                @if (ResolvedBoardClick.HasDelegate)
                                {
                                    <button type="button"
                                            class="badge border-0 text-bg-dark board-name-button detail-chip-with-lock"
                                            title="Boarddetails anzeigen"
                                            @onclick="HandleBoardChipClickAsync"
                                            @onclick:stopPropagation="true">
                                        @ResolvedBoardName
                                        <span class="detail-chip-lock-overlay" title="Boardzuordnung gesperrt">@BoardLockGlyph</span>
                                    </button>
                                }
                                else
                                {
                                    <span class="badge text-bg-dark detail-chip-with-lock" title="Boardzuordnung gesperrt">
                                        @ResolvedBoardName
                                        <span class="detail-chip-lock-overlay">@BoardLockGlyph</span>
                                    </span>
                                }
                            }
                            else
                            {
                                <BoardName Name="@ResolvedBoardName"
                                           Status="@MonitoringStatusText"
                                           Tooltip="Boarddetails anzeigen"
                                           OnClick="@ResolvedBoardClick"
                                           BadgeCssClass="text-bg-dark" />
                            }
                        }
                        @if (ShowHeaderStandaloneBoardLock)
                        {
                            <span class="badge text-bg-light border" title="Boardzuordnung gesperrt">@BoardLockGlyph</span>
                        }
                        @if (ResolvedShowHeaderDelay && HasDelayInformation)
                        {
                            <span class="badge @DelayBadgeCss">@DelayBadgeText</span>
                        }
                        @if (ResolvedShowHeaderMatchStatus)
                        {
                            <span class="badge @MatchStatusBadgeClass">@Match.Status</span>
                        }
                        @if (ResolvedShowHeaderLiveBadge && IsRunning)
                        {
                            <span class="badge text-bg-info">Live</span>
                        }
                        @if (ResolvedShowMonitoringStatus && !string.IsNullOrWhiteSpace(MonitoringStatusText))
                        {
                            <span class="badge @ResolvedMonitoringStatusCss" style="font-size:.7em">@MonitoringStatusText</span>
                        }
                </div>
            }
            @if (ShowAnyActionButtons && string.Equals(EffectiveActionButtonsLocation, "Header", StringComparison.Ordinal) && UseActionMenu)
            {
                <div class="dropdown ms-auto flex-shrink-0" @onclick:stopPropagation="true">
