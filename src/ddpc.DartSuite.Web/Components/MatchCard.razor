    protected override async Task OnParametersSetAsync()
    {
        EnsureRuntimeTimer();
        await TryLoadPredictionAsync();

        if (!_detailsExpandedInitialized)
        {
            _detailsExpanded = DetailsExpandedByDefault;
            _detailsExpandedInitialized = true;
        }

        if (ForceDetailsExpanded.HasValue)
            _detailsExpanded = ForceDetailsExpanded.Value;

        if (!IsDetailTabAvailable(ActiveDetailTab))
        {
            ActiveDetailTab = HasAnyPlayerStatisticsEnabled
                ? "stats"
                : HasAnyGeneralDetailsEnabled
                    ? "details"
                    : "prediction";
        }

        if (!EnableRealtimeConsumer || Match.Id == Guid.Empty)
        {
            if (_consumerSubscribed)
            {
                TournamentHubService.OnMatchDataReceived -= OnHubMatchDataReceived;
                _consumerSubscribed = false;
            }

            return;
        }

        if (!_consumerSubscribed)
        {
            TournamentHubService.OnMatchDataReceived += OnHubMatchDataReceived;
            _consumerSubscribed = true;
        }

        try
        {
            await TournamentHubService.StartAsync();

            if (_joinedTournamentId != Match.TournamentId)
            {
                await TournamentHubService.JoinTournamentAsync(Match.TournamentId.ToString());
                _joinedTournamentId = Match.TournamentId;
            }

            if (_joinedMatchId != Match.Id)
            {
                await TournamentHubService.JoinMatchAsync(Match.Id.ToString());
                _joinedMatchId = Match.Id;
                _liveData = null;
            }
        }
        catch
        {
            // MatchCard should remain usable without live transport.
        }
    }

    private void EnsureRuntimeTimer()
    {
        var shouldRun = Match.StartedUtc is not null && Match.FinishedUtc is null;
        if (!shouldRun)
        {
            StopRuntimeTimer();
            return;
        }

        if (_runtimeTimer is not null)
            return;

        _runtimeTimer = new System.Threading.Timer(
            _ => _ = InvokeAsync(StateHasChanged),
            null,
            TimeSpan.FromSeconds(1),
            TimeSpan.FromSeconds(1));
    }

    private void StopRuntimeTimer()
    {
        _runtimeTimer?.Dispose();
        _runtimeTimer = null;
    }

    private async Task TryLoadPredictionAsync()
    {
        _predictionData = null;
        if (!ResolvedShowMatchPrediction)
            return;

        try
        {
            var elapsedSeconds = Match.StartedUtc.HasValue
                ? Math.Max(0, (int)(DateTimeOffset.UtcNow - Match.StartedUtc.Value).TotalSeconds)
                : 0;
            var targetLegs = Math.Max(1, Math.Max(EffectiveHomeLegs, EffectiveAwayLegs) + 1);
            _predictionData = await Api.GetMatchPredictionAsync(
                targetLegs,
                EffectiveHomeLegs,
                EffectiveAwayLegs,
                EffectiveHomeRemainingPoints,
                EffectiveAwayRemainingPoints,
                elapsedSeconds);
        }
        catch
        {
            // Local fallback is used when API prediction is unavailable.
        }
    }

