    private bool ResolvedShowHeaderMatchStatus => ViewSettings?.ShowHeaderMatchStatus ?? ShowHeaderMatchStatus;
    private bool ResolvedShowHeaderLiveBadge => ViewSettings?.ShowHeaderLiveBadge ?? ShowHeaderLiveBadge;
    private bool ShouldShowHeaderStartTimeChip => ResolvedShowHeaderStartTime && !ShouldShowNotStartedStartTimeFallback;

    private bool ResolvedShowBodyStartTime => ViewSettings?.ShowBodyStartTime ?? ShowBodyStartTime;
    private bool ResolvedShowBodyStartTimeLock => ViewSettings?.ShowBodyStartTimeLock ?? ShowBodyStartTimeLock;
