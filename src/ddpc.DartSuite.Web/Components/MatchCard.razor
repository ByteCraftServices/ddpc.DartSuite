                                        <div class="d-flex justify-content-between"><span class="text-muted">Matchname</span><span>@(string.IsNullOrWhiteSpace(ResolvedMatchName) ? "-" : ResolvedMatchName)</span></div>
                                    }
                                    @if (ResolvedShowDetailsMatchStatus)
                                    {
                                        <div class="d-flex justify-content-between"><span class="text-muted">Status</span><span>@Match.Status</span></div>
                                    }
                                    @if (ResolvedShowSchedulingStatus)
                                    {
                                        <div class="d-flex justify-content-between"><span class="text-muted">Scheduling</span><span>@SchedulingStatusLabel</span></div>
                                    }
                                    @if (ResolvedShowDetailsStartTime)
                                    {
                                        <div class="d-flex justify-content-between"><span class="text-muted">Startzeit</span><span>@DetailStartTimeText</span></div>
                                    }
                                    @if (ResolvedShowDetailsStartTimeLock)
                                    {
                                        <div class="d-flex justify-content-between"><span class="text-muted">Startzeit gesperrt</span><span>@(Match.IsStartTimeLocked ? "Ja" : "Nein")</span></div>
                                    }
                                    @if (ResolvedShowDetailsBoardName)
                                    {
                                        <div class="d-flex justify-content-between"><span class="text-muted">Board</span><span>@(string.IsNullOrWhiteSpace(ResolvedBoardName) ? "-" : ResolvedBoardName)</span></div>
                                    }
                                    @if (ResolvedShowDetailsBoardLock)
                                    {
                                        <div class="d-flex justify-content-between"><span class="text-muted">Board gesperrt</span><span>@(Match.IsBoardLocked ? "Ja" : "Nein")</span></div>
                                    }
                                    @if (ResolvedShowDetailsDelay)
                                    {
                                        <div class="d-flex justify-content-between"><span class="text-muted">Zeitdifferenz</span><span>@(HasDelayInformation ? DelayBadgeText : "0m")</span></div>
                                    }
                                    @if (ResolvedShowDetailsLiveBadge)
                                    {
                                        <div class="d-flex justify-content-between"><span class="text-muted">Live</span><span>@(IsRunning ? "Ja" : "Nein")</span></div>
                                    }
                                    @if (ResolvedShowDetailsRuntime)
                                    {
                                        <div class="d-flex justify-content-between"><span class="text-muted">Spielzeit</span><span>@(Match.StartedUtc is not null ? CurrentRuntimeLabel : "-" )</span></div>
                                    }
                                    @if (ResolvedShowDetailsMonitoringStatus)
                                    {
                                        <div class="d-flex justify-content-between"><span class="text-muted">Monitoring</span><span>@(string.IsNullOrWhiteSpace(MonitoringStatusText) ? "-" : MonitoringStatusText)</span></div>
                                    }
                                    @if (ResolvedShowDetailsGameplay)
                                    {
                                        <div class="d-flex justify-content-between"><span class="text-muted">Gameplay</span><span>@GameplaySummaryText</span></div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-muted">Keine allgemeinen Detailfelder aktiviert.</div>
                            }
                        }
                        else
                        {
                            @if (ResolvedShowMatchPrediction)
                            {
                                <div class="border rounded p-2">
                                    <div class="fw-semibold">Matchprediction</div>
                                    <div class="mt-1 d-flex justify-content-between"><span class="text-muted">Siegwahrscheinlichkeit</span><span class="fw-semibold">@MatchPredictionSummary</span></div>
                                    <div class="d-flex justify-content-between"><span class="text-muted">Vermutetes Endergebnis</span><span>@PredictedFinalScoreText</span></div>
                                    <div class="d-flex justify-content-between"><span class="text-muted">Erwartete Checkout-Punkte</span><span>@PredictedExpectedCheckoutPoints.ToString("0.0")</span></div>
                                    <div class="d-flex justify-content-between"><span class="text-muted">Checkout-Wahrscheinlichkeit</span><span>@(PredictedCheckoutProbability * 100d).ToString("0.0")%</span></div>
                                    <div class="d-flex justify-content-between"><span class="text-muted">Erwartete verbleibende Darts (Leg)</span><span>@PredictedExpectedRemainingDartsInLeg.ToString("0.0")</span></div>
                                    <div class="d-flex justify-content-between"><span class="text-muted">Erwartete Punkte pro Aufnahme (PPR)</span><span>@PredictedExpectedPpr.ToString("0.0")</span></div>
                                </div>
                            }
                            else
                            {
                                <div class="text-muted">Matchprediction ist in den Einstellungen deaktiviert.</div>
                            }
                        }
                    </div>
                </details>
            </div>
        }
    </div>

    } @* end else (non-List layout) *@
</div>

