    private void SetDetailTab(string tab)
    {
        var normalizedTab = (tab ?? string.Empty).Trim().ToLowerInvariant();
        ActiveDetailTab = normalizedTab switch
        {
            "stats" when HasAnyPlayerStatisticsEnabled => "stats",
            "details" when HasAnyGeneralDetailsEnabled => "details",
            "prediction" when ResolvedShowMatchPrediction => "prediction",
            _ when HasAnyPlayerStatisticsEnabled => "stats",
            _ when HasAnyGeneralDetailsEnabled => "details",
            _ => "prediction"
        };
    }

    private bool IsDetailTabAvailable(string? tab)
    {
        return (tab ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "stats" => HasAnyPlayerStatisticsEnabled,
            "details" => HasAnyGeneralDetailsEnabled,
            "prediction" => ResolvedShowMatchPrediction,
            _ => false
        };
    }

    private static string FormatInt(int? value)
        => value.HasValue ? value.Value.ToString() : "-";

    private static string FormatDouble(double? value)
        => value.HasValue ? value.Value.ToString("0.00") : "-";

    private Task OnHubMatchDataReceived(TournamentHubService.MatchDataReceivedDto payload)
    {
        if (!EnableRealtimeConsumer || payload.MatchId != Match.Id)
            return Task.CompletedTask;

        if (_liveData is not null)
        {
            if (payload.Sequence > 0 && _liveData.Sequence > 0)
            {
                if (payload.Sequence <= _liveData.Sequence)
                    return Task.CompletedTask;
            }
            else if (payload.Timestamp <= _liveData.Timestamp)
            {
                return Task.CompletedTask;
            }
        }

        _liveData = payload;
        return InvokeAsync(StateHasChanged);
    }

    public ValueTask DisposeAsync()
    {
        StopRuntimeTimer();

        if (_consumerSubscribed)
        {
            TournamentHubService.OnMatchDataReceived -= OnHubMatchDataReceived;
            _consumerSubscribed = false;
        }

        return ValueTask.CompletedTask;
    }
}

