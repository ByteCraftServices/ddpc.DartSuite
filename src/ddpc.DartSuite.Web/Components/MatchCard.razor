        ? $"{Match.SchedulingStatus} (+{Match.DelayMinutes}m)"
        : Match.SchedulingStatus;

    private string MatchPredictionSummary
    {
        get
        {
            if (_predictionData is not null)
                return $"{Math.Round(_predictionData.HomeWinProbability * 100d)}% / {Math.Round(_predictionData.AwayWinProbability * 100d)}%";

            var homeStrength = (HomeStatistic?.Average ?? 0d) + (HomeStatistic?.HighestRoundScore ?? 0) / 8d + (EffectiveHomeLegs * 2) + (EffectiveHomeSets * 3) + ((501 - EffectiveHomeRemainingPoints) / 30d);
            var awayStrength = (AwayStatistic?.Average ?? 0d) + (AwayStatistic?.HighestRoundScore ?? 0) / 8d + (EffectiveAwayLegs * 2) + (EffectiveAwaySets * 3) + ((501 - EffectiveAwayRemainingPoints) / 30d);
            var total = homeStrength + awayStrength;
            if (total <= 0)
                return "50% / 50%";

            var homePct = (int)Math.Round((homeStrength / total) * 100);
            homePct = Math.Clamp(homePct, 1, 99);
            var awayPct = 100 - homePct;
            return $"{homePct}% / {awayPct}%";
        }
    }

    private int PredictedHomeWinPercentage
    {
        get
        {
            var parts = MatchPredictionSummary.Split('/', StringSplitOptions.TrimEntries);
            if (parts.Length == 0)
                return 50;

            var token = parts[0].Replace("%", string.Empty, StringComparison.Ordinal);
            return int.TryParse(token, out var parsed) ? Math.Clamp(parsed, 1, 99) : 50;
        }
    }

    private string PredictedFinalScoreText
    {
        get
        {
            if (_predictionData is not null && !string.IsNullOrWhiteSpace(_predictionData.ExpectedFinalScore))
                return _predictionData.ExpectedFinalScore;

            var targetLegs = Math.Max(1, Math.Max(EffectiveHomeLegs, EffectiveAwayLegs) + 1);
            return PredictedHomeWinPercentage >= 50
                ? $"{targetLegs}:{Math.Max(0, targetLegs - 1)}"
                : $"{Math.Max(0, targetLegs - 1)}:{targetLegs}";
        }
    }

    private int EffectiveHomeRemainingPoints
        => int.TryParse(EffectiveHomePoints, out var parsed) ? Math.Clamp(parsed, 0, 501) : 501;

    private int EffectiveAwayRemainingPoints
        => int.TryParse(EffectiveAwayPoints, out var parsed) ? Math.Clamp(parsed, 0, 501) : 501;

    private int EffectiveLowestRemainingPoints => Math.Min(EffectiveHomeRemainingPoints, EffectiveAwayRemainingPoints);

    private double PredictedExpectedCheckoutPoints
        => _predictionData?.ExpectedCheckoutPoints
           ?? Math.Round(Math.Clamp((EffectiveLowestRemainingPoints * 0.72) + (Math.Max(EffectiveHomeRemainingPoints, EffectiveAwayRemainingPoints) * 0.08), 2d, 170d), 2);

    private double PredictedCheckoutProbability
    {
        get
        {
            if (_predictionData is not null)
                return _predictionData.CheckoutProbability;

            var baseline = EffectiveLowestRemainingPoints switch
            {
                <= 40 => 0.84,
                <= 80 => 0.68,
                <= 120 => 0.52,
                <= 170 => 0.39,
                _ => 0.22
            };

            return Math.Round(Math.Clamp(baseline + ((PredictedHomeWinPercentage - 50) / 100d * 0.15), 0.05, 0.95), 4);
        }
    }

    private double PredictedExpectedPpr
        => _predictionData?.ExpectedPpr
           ?? Math.Round(Math.Clamp(66d + (((PredictedHomeWinPercentage - (100 - PredictedHomeWinPercentage)) / 100d) * 14d), 45d, 105d), 2);

    private double PredictedExpectedRemainingDartsInLeg
        => _predictionData?.ExpectedRemainingDartsInLeg
           ?? Math.Round(Math.Clamp((Math.Max(1d, EffectiveLowestRemainingPoints) / Math.Max(35d, PredictedExpectedPpr)) * 3d, 1d, 24d), 2);

    private bool IsDelayedMatch => string.Equals(Match.SchedulingStatus, "Delayed", StringComparison.OrdinalIgnoreCase) || Match.DelayMinutes > 0;
    private bool IsAheadMatch => string.Equals(Match.SchedulingStatus, "Ahead", StringComparison.OrdinalIgnoreCase) || Match.DelayMinutes < 0;
    private bool IsNoBoardMatch => string.IsNullOrWhiteSpace(ResolvedBoardName);
    private bool IsHighlightPhase => IsRunning && (EffectiveLowestRemainingPoints <= ResolvedHighlightCheckoutThreshold || EffectiveLowestRemainingPoints <= PredictedExpectedCheckoutPoints);

    private (string border, string background) CurrentHighlightPreset
    {
        get
        {
            if (!ResolvedEnableHighlighting)
                return ("none", "none");

            var statusPreset = ResolveStatusHighlightPreset();
            var schedulingPreset = ResolveSchedulingHighlightPreset();

            // Highlight-Phase has the highest priority, but only per channel.
            // If a higher layer has "none" for border/background, fall back to lower layers.
            if (IsHighlightPhase)
            {
                return ComposeHighlightPreset(
                    (ResolvedHighlightPhaseBorderPreset, ResolvedHighlightPhaseBackgroundPreset),
                    statusPreset,
                    schedulingPreset);
            }

            // Status has priority over delay/ahead/no-board with the same per-channel fallback behavior.
            return ComposeHighlightPreset(statusPreset, schedulingPreset);
        }
    }

    private (string border, string background) ResolveSchedulingHighlightPreset()
    {
        if (IsDelayedMatch)
            return (ResolvedDelayedBorderPreset, ResolvedDelayedBackgroundPreset);
        if (IsAheadMatch)
            return (ResolvedAheadBorderPreset, ResolvedAheadBackgroundPreset);
        if (IsNoBoardMatch)
            return (ResolvedNoBoardBorderPreset, ResolvedNoBoardBackgroundPreset);

        return ("none", "none");
    }

    private static (string border, string background) ComposeHighlightPreset(params (string border, string background)[] layers)
    {
        static string Pick(Func<(string border, string background), string> selector, IReadOnlyList<(string border, string background)> source)
        {
            foreach (var layer in source)
            {
                var candidate = MatchCardViewSettings.NormalizeHighlightPreset(selector(layer));
                if (!string.Equals(candidate, "none", StringComparison.OrdinalIgnoreCase))
                    return candidate;
            }

            return "none";
        }

        var border = Pick(layer => layer.border, layers);
        var background = Pick(layer => layer.background, layers);
        return (border, background);
    }

    private (string border, string background) ResolveStatusHighlightPreset()
    {
        var normalizedStatus = (Match.Status ?? string.Empty).Trim();

        if (string.Equals(normalizedStatus, "Beendet", StringComparison.OrdinalIgnoreCase))
            return (ResolvedCompletedBorderPreset, ResolvedCompletedBackgroundPreset);
        if (string.Equals(normalizedStatus, "Aktiv", StringComparison.OrdinalIgnoreCase)
            || string.Equals(normalizedStatus, "Gestartet", StringComparison.OrdinalIgnoreCase))
            return (ResolvedActiveBorderPreset, ResolvedActiveBackgroundPreset);
        if (string.Equals(normalizedStatus, "Warten", StringComparison.OrdinalIgnoreCase))
            return (ResolvedWaitingBorderPreset, ResolvedWaitingBackgroundPreset);
        if (string.Equals(normalizedStatus, "Geplant", StringComparison.OrdinalIgnoreCase))
            return (ResolvedPlannedBorderPreset, ResolvedPlannedBackgroundPreset);
        if (string.Equals(normalizedStatus, "Erstellt", StringComparison.OrdinalIgnoreCase))
            return (ResolvedCreatedBorderPreset, ResolvedCreatedBackgroundPreset);
        if (string.Equals(normalizedStatus, "WalkOver", StringComparison.OrdinalIgnoreCase))
            return (ResolvedWalkOverBorderPreset, ResolvedWalkOverBackgroundPreset);

        return (ResolvedStatusBorderPreset, ResolvedStatusBackgroundPreset);
    }

    private string MatchStatusBadgeClass => MatchStatusToBadgeCss(Match.Status, Match.SchedulingStatus, Match.DelayMinutes);

    private string ResolveScoreStatusChipClass()
    {
        var normalizedStatus = (Match.Status ?? string.Empty).Trim();
        var isDelayed = Match.DelayMinutes > 0 || string.Equals(Match.SchedulingStatus, "Delayed", StringComparison.OrdinalIgnoreCase);

        if (string.Equals(normalizedStatus, "Aktiv", StringComparison.OrdinalIgnoreCase)
            || string.Equals(normalizedStatus, "Gestartet", StringComparison.OrdinalIgnoreCase))
        {
            return "text-bg-danger";
        }

        if (string.Equals(normalizedStatus, "Beendet", StringComparison.OrdinalIgnoreCase))
            return "text-bg-dark";

        if (string.Equals(normalizedStatus, "Warten", StringComparison.OrdinalIgnoreCase))
            return isDelayed ? "text-bg-warning text-dark" : "text-bg-success";

        return "text-bg-light";
    }

    private static string MatchStatusToBadgeCss(string? status, string? schedulingStatus, int delayMinutes)
    {
        if (string.IsNullOrWhiteSpace(status))
            return "match-status-default";

        if (string.Equals(status, "Geplant", StringComparison.OrdinalIgnoreCase)
            && (delayMinutes > 0 || string.Equals(schedulingStatus, "Delayed", StringComparison.OrdinalIgnoreCase)))
        {
            return "match-status-planned-delayed";
        }

        return status switch
        {
            "Beendet" => "match-status-completed",
            "Aktiv" => "match-status-active",
            "Gestartet" => "match-status-active",
            "Warten" => "match-status-waiting",
            "Geplant" => "match-status-planned",
            "Erstellt" => "match-status-created",
            "WalkOver" => "match-status-walkover",
            _ => "match-status-default"
        };
    }

    private string CurrentRuntimeLabel
    {
        get
        {
            if (Match.StartedUtc is null)
                return "00:00";

            var elapsed = (Match.FinishedUtc ?? DateTimeOffset.UtcNow) - Match.StartedUtc.Value;
            if (elapsed < TimeSpan.Zero)
                elapsed = TimeSpan.Zero;

            return elapsed.TotalHours >= 1
                ? elapsed.ToString(@"hh\:mm\:ss")
                : elapsed.ToString(@"mm\:ss");
        }
    }

