    private string BuildStartTimeText(string label)
    {
        var value = Match.StartedUtc ?? Match.PlannedStartUtc;
        if (value is null)
            return $"{label}: --:--";

        return $"{label}: {value.Value.LocalDateTime:HH:mm}";
