    private bool IsFinalOnlyScoreMode => string.Equals(EffectiveScoreMode, "FinalOnly", StringComparison.OrdinalIgnoreCase);
    private bool HasStartedOrFinished => Match.StartedUtc is not null || Match.FinishedUtc is not null;
    private bool RealtimeScoreEnabled => ViewSettings?.LiveScoreEnabled ?? LiveScoreEnabled;
    private bool HasAnyProgressScore => Match.HomeLegs > 0 || Match.AwayLegs > 0 || Match.HomeSets > 0 || Match.AwaySets > 0 || Match.WinnerParticipantId.HasValue;
    private bool ShouldShowLegs => !IsFinalOnlyScoreMode && (IsRunning || Match.FinishedUtc is not null);
    private bool ShouldShowSets => ShouldShowLegs && SetModeActive;
    private bool ShouldShowCurrentScoreChips => ShouldShowLegs || ShouldShowSets;
    private bool ShouldShowLivePoints => RealtimeScoreEnabled
                                         && HasStartedOrFinished
                                         && string.Equals(EffectiveScoreMode, "LiveScores", StringComparison.OrdinalIgnoreCase)
                                         && IsRunning;
    private bool ShouldShowFinalResultScore => IsFinalOnlyScoreMode && (Match.FinishedUtc is not null || Match.WinnerParticipantId.HasValue);
    private bool ShouldShowNotStartedFallback => !HasStartedOrFinished && !ShouldShowFinalResultScore;
    private bool ShouldShowNotStartedStartTimeFallback => ShouldShowNotStartedFallback && ResolvedShowBodyStartTime && !ResolvedShowHeaderStartTime;
    private bool ShouldShowNotStartedStartTimeWithBoardFallback => ShouldShowNotStartedStartTimeFallback 
                                                                    && !string.IsNullOrWhiteSpace(ResolvedBoardName) 
                                                                    && ResolvedShowBodyBoardName
                                                                    && !ResolvedShowHeaderBoardName;
    private bool ShouldShowNotStartedBoardFallback => ShouldShowNotStartedFallback
                                                      && !ShouldShowNotStartedStartTimeFallback
                                                      && !string.IsNullOrWhiteSpace(ResolvedBoardName)
                                                      && ResolvedShowBodyBoardName
                                                      && !ResolvedShowHeaderBoardName;
    private bool ShouldShowNotStartedStatusFallback => ShouldShowNotStartedFallback
                                                       && !ShouldShowNotStartedStartTimeFallback
                                                       && !ShouldShowNotStartedBoardFallback;
    private bool UsePreMatchInlineHorizontalRow => string.Equals(EffectiveLayout, "Horizontal", StringComparison.Ordinal) && ShouldShowNotStartedFallback;
    private string ScoreChipMainClass => RealtimeScoreEnabled ? "match-score-chip match-score-chip-main" : "match-score-chip match-score-chip-main match-score-chip-live-size";
