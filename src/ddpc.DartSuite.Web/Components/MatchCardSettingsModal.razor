        => Array.Find(_previewSizeOptions, x => x.Key == _previewSize)?.Width ?? "100%";

    private MatchCardViewSettings EffectivePreviewSettings
        => _useDefaults ? ResolveInherited(NormalizeKey(ScopeKey)) : _settings;

    [JSInvokable]
    public void SetSettingsPanelWidth(double pct)
    {
        _settingsPanelWidthPct = pct;
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible && !_splitterInitialized && !_isLoading)
            await InitSplitterAsync();
    }

    private async Task InitSplitterAsync()
    {
        try
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("dartSuiteSplitter.init", _splitterRef, _settingsPanelRef, _dotNetRef);
            _splitterInitialized = true;
        }
        catch
        {
            // JS interop may fail (e.g., during pre-rendering)
        }
    }

    private async Task DisposeSplitterAsync()
    {
        if (!_splitterInitialized) return;
        try
        {
            await JS.InvokeVoidAsync("dartSuiteSplitter.dispose");
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        await DisposeSplitterAsync();
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

