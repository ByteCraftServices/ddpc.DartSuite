@inject IJSRuntime JS

<details class="card mb-3 settings-panel @CssClass"
         id="@ElementId"
         open="@_isExpanded">
    <summary class="card-header d-flex justify-content-between align-items-center settings-panel-summary"
             title="@DisabledReason">
        <span>
            @if (TitleContent is not null)
            {
                @TitleContent
            }
            else
            {
                @Title
            }
        </span>
        <span class="d-flex align-items-center gap-2">
            @if (!string.IsNullOrEmpty(SummaryText))
            {
                <span class="d-none d-md-inline small text-muted settings-panel-summary-text">@SummaryText</span>
            }
            @if (SummaryActions is not null)
            {
                <span @onclick:stopPropagation>@SummaryActions</span>
            }
            <span class="settings-panel-chevron" aria-hidden="true">&#9662;</span>
        </span>
    </summary>
    <div class="card-body">
        @ChildContent
    </div>
</details>

@code {
    [Parameter] public Guid? TournamentId { get; set; }
    [Parameter] public string PanelId { get; set; } = string.Empty;
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public RenderFragment? TitleContent { get; set; }
    [Parameter] public string? SummaryText { get; set; }
    [Parameter] public RenderFragment? SummaryActions { get; set; }
    [Parameter] public bool DefaultExpanded { get; set; } = true;
    [Parameter] public string? DisabledReason { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _firstParametersSet = true;
    private Guid? _lastInitializedTournamentId;
    private bool _isExpanded;

    private string ElementId => $"settings-panel-{PanelId}";

    private string StorageKey => TournamentId.HasValue
        ? $"ds-spanel-{TournamentId.Value:N}-{PanelId}"
        : $"ds-spanel-global-{PanelId}";

    protected override void OnParametersSet()
    {
        if (_firstParametersSet || _lastInitializedTournamentId != TournamentId)
        {
            _isExpanded = DefaultExpanded;
            _firstParametersSet = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _lastInitializedTournamentId != TournamentId)
        {
            _lastInitializedTournamentId = TournamentId;
            try
            {
                await JS.InvokeVoidAsync("dartSuiteUi.initDetailsStorage", ElementId, StorageKey);
            }
            catch { /* best-effort */ }
        }
    }
}
