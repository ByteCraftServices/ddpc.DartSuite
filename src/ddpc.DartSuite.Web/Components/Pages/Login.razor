@page "/login"
@using ddpc.DartSuite.Application.Contracts.Autodarts
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject DartSuiteApiService Api
@inject ProtectedLocalStorage LocalStorage
@inject AppStateService AppState
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<h1>Autodarts Login</h1>

<div class="card mt-3 shadow-sm">
    <div class="card-body">
        @if (profile is null)
        {
            <div class="mb-3">
                <label class="form-label" for="email">E-Mail</label>
                <input class="form-control" id="email" type="email" @bind="emailInput" placeholder="user@example.com" />
            </div>
            <div class="mb-3">
                <label class="form-label" for="password">Passwort</label>
                <div class="input-group">
                    <input class="form-control" id="password" type="@(showPassword ? "text" : "password")"
                           @bind="passwordInput" @onkeydown="HandleKeyDownAsync" />
                    <button class="btn btn-outline-secondary" type="button" tabindex="-1"
                            @onclick="() => showPassword = !showPassword">@(showPassword ? "🙈" : "👁")</button>
                </div>
            </div>
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="rememberLogin" @bind="rememberLogin" />
                <label class="form-check-label" for="rememberLogin">Angemeldet bleiben</label>
            </div>
            <button class="btn btn-primary w-100" @onclick="LoginAsync" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                }
                Autodarts.io verbinden
            </button>
        }
        else
        {
            <div class="d-flex align-items-center mb-3">
                <span class="badge bg-success me-2">Verbunden</span>
                <span class="fw-semibold">@(profile.DisplayName ?? profile.Email ?? "Autodarts")</span>
                <button class="btn btn-outline-secondary btn-sm ms-auto" @onclick="LogoutAsync">Abmelden</button>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(connectionStatus))
        {
            <div class="alert @statusAlertClass mt-3 mb-0">@connectionStatus</div>
        }

        @if (profile is not null)
        {
            <div class="mt-3">
                <h6 class="text-muted">Profil</h6>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@(profile.DisplayName ?? "n/a")</dd>
                    <dt class="col-sm-4">E-Mail</dt>
                    <dd class="col-sm-8">@(profile.Email ?? "n/a")</dd>
                </dl>
            </div>
        }

        @if (boards.Count > 0)
        {
            <div class="mt-3">
                <h6 class="text-muted">Verfügbare Boards</h6>
                <ul class="list-group">
                    @foreach (var board in boards)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@board.Name</span>
                            <span class="text-muted small">@board.ExternalBoardId (@(board.Ownership ?? "unbekannt"))</span>
                        </li>
                    }
                </ul>
            </div>
        }
        else if (profile is not null)
        {
            <div class="alert alert-warning mt-3 mb-0 small">
                <strong>Boards konnten nicht geladen werden.</strong>
                Der API-Zugriff auf die Board-Verwaltung ist mit dem aktuellen Token eingeschränkt.
                Boards können manuell über die Board-Verwaltung hinzugefügt werden.
            </div>
        }
    </div>
</div>

@code {
    private string? connectionStatus;
    private string statusAlertClass = "alert-info";
    private const string StorageKeyEmail = "autodarts.email";
    private const string StorageKeyPassword = "autodarts.password";
    private const string StorageKeyRefreshToken = "autodarts.refreshToken";
    private const string StorageKeyRememberLogin = "autodarts.rememberLogin";
    private AutodartsProfileDto? profile;
    private List<AutodartsBoardInfoDto> boards = new();
    private bool rememberLogin = true;
    private bool isLoading;
    private bool sessionRestored;
    private bool showPassword;
    private string? emailInput;
    private string? passwordInput;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || sessionRestored) return;
        sessionRestored = true;

        await TryRestoreSessionAsync();
        StateHasChanged();
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoginAsync();
        }
    }

    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(emailInput) || string.IsNullOrWhiteSpace(passwordInput))
        {
            connectionStatus = "E-Mail und Passwort sind erforderlich.";
            statusAlertClass = "alert-warning";
            return;
        }

        isLoading = true;
        connectionStatus = null;
        StateHasChanged();
        var passwordToPersist = passwordInput;

        try
        {
            var response = await Api.LoginAutodartsAsync(emailInput, passwordInput);
            profile = response.Profile;
            boards = response.Boards.ToList();
            connectionStatus = "Verbindung hergestellt";
            statusAlertClass = "alert-success";
            AppState.SetAutodartsProfile(profile, true);

            if (rememberLogin)
            {
                await LocalStorage.SetAsync(StorageKeyEmail, emailInput);
                await LocalStorage.SetAsync(StorageKeyPassword, passwordToPersist);
                await LocalStorage.SetAsync(StorageKeyRememberLogin, true);
            }
            else
            {
                await LocalStorage.DeleteAsync(StorageKeyEmail);
                await LocalStorage.DeleteAsync(StorageKeyPassword);
                await LocalStorage.SetAsync(StorageKeyRememberLogin, false);
            }

            NavigateToReturnUrlIfAvailable();
        }
        catch (Exception ex)
        {
            connectionStatus = ex.Message;
            statusAlertClass = "alert-danger";
            profile = null;
            boards = new();
        }
        finally
        {
            isLoading = false;
            passwordInput = null;
        }
    }

    private async Task TryRestoreSessionAsync()
    {
        try
        {
            var rememberSetting = await LocalStorage.GetAsync<bool>(StorageKeyRememberLogin);
            if (rememberSetting.Success)
            {
                rememberLogin = rememberSetting.Value;
            }

            var status = await Api.GetAutodartsStatusAsync();
            if (status.IsConnected && status.Profile is not null)
            {
                profile = status.Profile;
                connectionStatus = "Sitzung wiederhergestellt";
                statusAlertClass = "alert-success";
                AppState.SetAutodartsProfile(profile, true);

                try { boards = (await Api.GetAutodartsBoardsAsync()).ToList(); }
                catch { /* boards optional */ }
            }

            var storedEmail = await LocalStorage.GetAsync<string>(StorageKeyEmail);
            if (storedEmail.Success && !string.IsNullOrWhiteSpace(storedEmail.Value))
            {
                emailInput = storedEmail.Value;
            }

            if (profile is null && rememberLogin && !string.IsNullOrWhiteSpace(emailInput))
            {
                var storedPassword = await LocalStorage.GetAsync<string>(StorageKeyPassword);
                if (storedPassword.Success && !string.IsNullOrWhiteSpace(storedPassword.Value))
                {
                    try
                    {
                        var response = await Api.LoginAutodartsAsync(emailInput, storedPassword.Value);
                        profile = response.Profile;
                        boards = response.Boards.ToList();
                        connectionStatus = "Sitzung automatisch wiederhergestellt";
                        statusAlertClass = "alert-success";
                        AppState.SetAutodartsProfile(profile, true);
                    }
                    catch
                    {
                        // Stored credentials might be outdated; keep login page interactive.
                    }
                }
            }
        }
        catch
        {
            // Server nicht erreichbar – kein Fehler anzeigen
        }
    }

    private void NavigateToReturnUrlIfAvailable()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
            return;

        if (Uri.TryCreate(ReturnUrl, UriKind.Absolute, out _))
            return;

        var target = ReturnUrl.StartsWith('/') ? ReturnUrl : $"/{ReturnUrl}";
        if (target.StartsWith("/login", StringComparison.OrdinalIgnoreCase))
            return;

        Navigation.NavigateTo(target, replace: true);
    }

    private async Task LogoutAsync()
    {
        await LocalStorage.DeleteAsync(StorageKeyEmail);
        await LocalStorage.DeleteAsync(StorageKeyPassword);
        await LocalStorage.SetAsync(StorageKeyRememberLogin, false);
        await LocalStorage.DeleteAsync(StorageKeyRefreshToken);
        profile = null;
        boards = new();
        connectionStatus = "Abgemeldet";
        statusAlertClass = "alert-info";
        AppState.SetAutodartsProfile(null, false);
    }
}