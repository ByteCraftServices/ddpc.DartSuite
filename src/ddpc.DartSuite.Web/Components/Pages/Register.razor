@page "/register"
@using ddpc.DartSuite.Application.Contracts.Tournaments
@inject DartSuiteApiService Api
@inject AppStateService AppState
@inject IUiHelpService UiHelp

<PageTitle>Registrieren</PageTitle>

<h1 class="mb-3">Turnier-Registrierung <UiHelpIcon HelpKey="page.register" /></h1>

@if (isLoading)
{
    <div class="text-muted">Turnier wird geladen ...</div>
}
else if (activeTournament is null)
{
    <div class="alert alert-info">Bitte waehlen Sie ein Turnier aus oder verwenden Sie einen Link mit <code>?tournamentId=...</code>.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title">@activeTournament.Name</h5>
            <p class="text-muted small mb-1">Die Selbstregistrierung wird ueber Turnierstatus und Registrierungsphase gesteuert.</p>
            <p class="small text-muted mb-3">Status: <span class="badge bg-secondary">@activeTournament.Status</span></p>

            @if (!CanSelfRegister)
            {
                <div class="alert alert-warning py-2">
                    Registrierung ist derzeit geschlossen. Austragen ist nur vor Turnierstart moeglich.
                </div>
            }

            <div class="row g-2">
                <div class="col-md-6">
                    <label class="form-label">Anzeigename</label>
                          <input class="form-control" @bind="displayName" placeholder="Name"
                              title="@UiHelp.GetTooltip("register.display-name")" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Accountname (optional bei lokalem Spieler)</label>
                          <input class="form-control" @bind="accountName" placeholder="Autodarts Account" disabled="@(!isAutodartsAccount)"
                              title="@UiHelp.GetTooltip("register.account-name")" />
                </div>
            </div>

            <div class="form-check mt-3">
                  <input id="isAutodarts" class="form-check-input" type="checkbox" @bind="isAutodartsAccount"
                      title="@UiHelp.GetTooltip("register.is-autodarts")" />
                <label class="form-check-label" for="isAutodarts">Autodarts-Account verwenden</label>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-primary" @onclick="RegisterAsync" disabled="@(isWorking || !CanSelfRegister)"
                    title="@UiHelp.GetTooltip("register.submit")">Registrieren</button>
                <button class="btn btn-outline-danger" @onclick="UnregisterAsync" disabled="@(isWorking || !CanSelfUnregister)"
                    title="@UiHelp.GetTooltip("register.unregister")">Austragen</button>
                <a class="btn btn-outline-secondary" href="/login">Login</a>
                <a class="btn btn-outline-secondary" href="/profile">Profil</a>
            </div>

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <div class="alert @(isError ? "alert-danger" : "alert-success") py-2 mt-3">@message</div>
            }
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "tournamentId")]
    public string? QueryTournamentId { get; set; }

    private TournamentDto? activeTournament;
    private string displayName = string.Empty;
    private string accountName = string.Empty;
    private bool isAutodartsAccount = true;
    private string? message;
    private bool isError;
    private bool isWorking;
    private bool isLoading;

    private bool CanSelfRegister
        => activeTournament is not null
            && activeTournament.IsRegistrationOpen
            && !string.Equals(activeTournament.Status, "Gestartet", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(activeTournament.Status, "Beendet", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(activeTournament.Status, "Abgebrochen", StringComparison.OrdinalIgnoreCase);

    private bool CanSelfUnregister
        => activeTournament is not null
            && !string.Equals(activeTournament.Status, "Gestartet", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(activeTournament.Status, "Beendet", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(activeTournament.Status, "Abgebrochen", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await LoadActiveTournamentAsync();
    }

    private async Task LoadActiveTournamentAsync()
    {
        isLoading = true;
        message = null;
        isError = false;

        try
        {
            if (!string.IsNullOrWhiteSpace(QueryTournamentId) && Guid.TryParse(QueryTournamentId, out var queryTournamentId))
            {
                activeTournament = await Api.GetTournamentAsync(queryTournamentId);
                if (activeTournament is not null)
                    AppState.SetSelectedTournament(activeTournament);
            }
            else
            {
                activeTournament = AppState.SelectedTournament;
            }
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RegisterAsync()
    {
        if (activeTournament is null)
            return;

        if (!CanSelfRegister)
        {
            isError = true;
            message = "Registrierung ist aktuell nicht moeglich.";
            return;
        }

        if (string.IsNullOrWhiteSpace(displayName))
        {
            isError = true;
            message = "Bitte einen Anzeigenamen eintragen.";
            return;
        }

        var effectiveAccountName = isAutodartsAccount
            ? accountName.Trim()
            : BuildLocalAccountName(displayName);

        if (string.IsNullOrWhiteSpace(effectiveAccountName))
        {
            isError = true;
            message = "Bitte einen gueltigen Accountnamen eintragen.";
            return;
        }

        try
        {
            isWorking = true;
            isError = false;

            var participants = await Api.GetParticipantsAsync(activeTournament.Id);
            var nextSeed = participants.Count + 1;

            await Api.AddParticipantAsync(new AddParticipantRequest(
                activeTournament.Id,
                displayName.Trim(),
                effectiveAccountName,
                isAutodartsAccount,
                false,
                nextSeed));

            message = "Registrierung gespeichert.";
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            isWorking = false;
        }
    }

    private async Task UnregisterAsync()
    {
        if (activeTournament is null)
            return;

        if (!CanSelfUnregister)
        {
            isError = true;
            message = "Austragen ist in diesem Turnierstatus nicht mehr erlaubt.";
            return;
        }

        var effectiveAccountName = isAutodartsAccount
            ? accountName.Trim()
            : BuildLocalAccountName(displayName);

        if (string.IsNullOrWhiteSpace(effectiveAccountName) && string.IsNullOrWhiteSpace(displayName))
        {
            isError = true;
            message = "Bitte Accountname oder Anzeigename eintragen.";
            return;
        }

        try
        {
            isWorking = true;
            isError = false;

            var participants = await Api.GetParticipantsAsync(activeTournament.Id);
            var own = participants.FirstOrDefault(p =>
                (!string.IsNullOrWhiteSpace(effectiveAccountName)
                 && string.Equals(p.AccountName, effectiveAccountName, StringComparison.OrdinalIgnoreCase))
                || string.Equals(p.DisplayName, displayName.Trim(), StringComparison.OrdinalIgnoreCase));

            if (own is null)
            {
                isError = true;
                message = "Kein passender Teilnehmer gefunden.";
                return;
            }

            await Api.RemoveParticipantAsync(activeTournament.Id, own.Id);
            message = "Austragung erfolgreich.";
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            isWorking = false;
        }
    }

    private static string BuildLocalAccountName(string value)
    {
        var normalized = new string(value
            .Trim()
            .ToLowerInvariant()
            .Where(c => char.IsLetterOrDigit(c) || c == '-' || c == '_')
            .ToArray());

        return string.IsNullOrWhiteSpace(normalized) ? string.Empty : $"local:{normalized}";
    }
}
