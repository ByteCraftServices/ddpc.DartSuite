@using System.Globalization
@using System.Linq
@using ddpc.DartSuite.Application.Contracts.Boards
@using ddpc.DartSuite.Application.Contracts.Tournaments

<div class="d-flex justify-content-between align-items-center mb-2">
    <h6 class="fw-semibold mb-0">Spielmodus je Runde</h6>
    <button class="btn btn-sm @(EditAreGameModesLocked ? "btn-outline-success" : "btn-outline-warning")"
            @onclick="OnToggleGameModesLock"
            disabled="@(IsWorking || SelectedTournamentIsLocked)">
        @(EditAreGameModesLocked ? "🔓 Spielmodi entsperren" : "🔒 Spielmodi sperren")
    </button>
</div>

@if (EditAreGameModesLocked)
{
    <div class="alert alert-info py-2 small">🔒 Spielmodi sind gesperrt. Entsperren Sie die Spielmodi, um Änderungen vorzunehmen.</div>
}
@if (HasMissingRoundConfig)
{
    <div class="alert alert-danger py-2 small">⚠ <strong>@MissingRoundConfigCount</strong> Runde(n) ohne Spielmodus-Konfiguration. Bitte legen Sie für jede Runde den Spielmodus fest.</div>
}

<p class="text-muted small mb-3">Klicken Sie auf eine Runde, um die Einstellungen zu bearbeiten.</p>
<div class="form-check mb-3">
    <input class="form-check-input" type="checkbox" id="showCompletedRounds" checked="@ShowCompletedRounds" @onchange="HandleShowCompletedRoundsChanged" />
    <label class="form-check-label small" for="showCompletedRounds">Abgeschlossene Runden anzeigen</label>
</div>

@{
    var visibleRoundGroups = VisibleRoundGroups;
}

@if (visibleRoundGroups.Any())
{
    @foreach (var grp in visibleRoundGroups)
    {
        var started = grp.Rounds.Any(IsRoundStarted);
        var completed = grp.Rounds.All(IsRoundCompleted);
        <div class="card mb-2 @(completed ? "border-success" : started ? "border-warning" : "")" style="cursor:pointer" @onclick="() => OnOpenRoundGroupDetail.InvokeAsync(grp.Rounds)">
            <div class="card-body py-2">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span>
                        <strong class="small">@BuildGroupLabel(grp.Rounds)</strong>
                        @if (grp.Rounds.Count > 1)
                        {
                            <span class="badge text-bg-secondary ms-1">@grp.Rounds.Count Runden</span>
                        }
                        @if (completed)
                        {
                            <span class="badge text-bg-success ms-1">✓ Abgeschlossen</span>
                        }
                        else if (started)
                        {
                            <span class="badge text-bg-warning ms-1">▶ Gestartet</span>
                        }
                    </span>
                    <span class="badge text-bg-light">First to @grp.Representative.Legs Legs | @grp.Representative.BaseScore @grp.Representative.OutMode</span>
                </div>
                <div class="small text-muted">
                    Spielzeit/Leg: @grp.Representative.LegDurationSeconds s | Pause: @grp.Representative.PauseBetweenMatchesMinutes min | Spielerpause: @grp.Representative.MinPlayerPauseMinutes min | Board: @grp.Representative.BoardAssignment
                </div>
                @if (grp.Rounds.Count > 1)
                {
                    <div class="small text-muted mt-1">
                        Enthaltene Runden: @string.Join(" · ", grp.Rounds.Select(RoundDisplayLabel))
                    </div>
                }
            </div>
        </div>
    }
}

@if (!SelectedTournamentIsLocked && !EditAreGameModesLocked && CanEditTournamentStructure)
{
    <div class="card border-primary mt-3">
        <div class="card-header bg-primary text-white py-2"><strong class="small">Runde hinzufügen / bearbeiten</strong></div>
        <div class="card-body">
            <div class="row g-2 mb-2">
                <div class="col-md-3">
                    <div class="form-floating">
                        <select class="form-select form-select-sm" value="@NewRoundPhase" @onchange="HandleNewRoundPhaseChanged">
                            <option value="Knockout">Knockout</option>
                            <option value="Group">Gruppe</option>
                        </select>
                        <label>Phase</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-floating">
                        <input type="number" class="form-control form-control-sm" value="@NewRoundNumber" @onchange="HandleNewRoundNumberChanged" min="1" placeholder=" " />
                        <label>Rundennr.</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-floating">
                        <select class="form-select form-select-sm" value="@NewRoundBaseScore" @onchange="HandleNewRoundBaseScoreChanged">
                            <option value="121">121</option>
                            <option value="170">170</option>
                            <option value="301">301</option>
                            <option value="501">501</option>
                            <option value="701">701</option>
                            <option value="901">901</option>
                        </select>
                        <label>Base Score</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-floating">
                        <select class="form-select form-select-sm" value="@NewRoundGameMode" @onchange="HandleNewRoundGameModeChanged">
                            <option value="Legs">Legs</option>
                            <option value="Sets">Sets</option>
                        </select>
                        <label>Spielmodus</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-floating">
                        @if (NewRoundGameMode == "Sets")
                        {
                            <select class="form-select form-select-sm" value="@NewRoundLegs" @onchange="HandleNewRoundLegsChanged">
                                <option value="2">2</option>
                                <option value="3">3</option>
                            </select>
                        }
                        else
                        {
                            <input type="number" class="form-control form-control-sm" value="@NewRoundLegs" @onchange="HandleNewRoundLegsChanged" min="1" max="11" placeholder=" " />
                        }
                        <label>Legs (First to)</label>
                    </div>
                </div>
                @if (NewRoundGameMode == "Sets")
                {
                    <div class="col-md-2">
                        <div class="form-floating">
                            <input type="number" class="form-control form-control-sm" value="@NewRoundSets" @onchange="HandleNewRoundSetsChanged" min="2" max="7" placeholder=" " />
                            <label>Sets (First to)</label>
                        </div>
                    </div>
                }
                <div class="col-md-2">
                    <div class="form-floating">
                        <select class="form-select form-select-sm" value="@NewRoundInMode" @onchange="HandleNewRoundInModeChanged">
                            <option value="Straight">Straight In (SI)</option>
                            <option value="Double">Double In (DI)</option>
                            <option value="Master">Master In (MI)</option>
                        </select>
                        <label>In-Modus</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-floating">
                        <select class="form-select form-select-sm" value="@NewRoundOutMode" @onchange="HandleNewRoundOutModeChanged">
                            <option value="Straight">Straight Out (SO)</option>
                            <option value="Double">Double Out (DO)</option>
                            <option value="Master">Master Out (MO)</option>
                        </select>
                        <label>Out-Modus</label>
                    </div>
                </div>
            </div>
            <div class="row g-2 mb-2">
                <div class="col-md-2">
                    <div class="form-floating">
                        <select class="form-select form-select-sm" value="@NewRoundMaxRounds" @onchange="HandleNewRoundMaxRoundsChanged">
                            <option value="15">15</option>
                            <option value="20">20</option>
                            <option value="50">50</option>
                            <option value="80">80</option>
                        </select>
                        <label>Max Runden</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-floating">
                        <select class="form-select form-select-sm" value="@NewRoundBullMode" @onchange="HandleNewRoundBullModeChanged">
                            <option value="25/50">25/50</option>
                            <option value="50/50">50/50</option>
                        </select>
                        <label>Bull Mode</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-floating">
                        <select class="form-select form-select-sm" value="@NewRoundBullOffMode" @onchange="HandleNewRoundBullOffModeChanged">
                            <option value="Off">Off</option>
                            <option value="Normal">Normal</option>
                            <option value="Official">Official</option>
                        </select>
                        <label>Bull-off</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-floating">
                        <input type="number" class="form-control form-control-sm" value="@NewRoundDuration" @onchange="HandleNewRoundDurationChanged" min="0" placeholder=" " />
                        <label>Spielzeit pro Leg (s)</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-floating">
                        <input type="number" class="form-control form-control-sm" value="@NewRoundPause" @onchange="HandleNewRoundPauseChanged" min="0" placeholder=" " />
                        <label>Pause (min)</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-floating">
                        <input type="number" class="form-control form-control-sm" value="@NewRoundPlayerPause" @onchange="HandleNewRoundPlayerPauseChanged" min="0" placeholder=" " />
                        <label>Min. Spielerpause (min)</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-floating">
                        <select class="form-select form-select-sm" value="@NewRoundBoardAssignment" @onchange="HandleNewRoundBoardAssignmentChanged">
                            <option value="Dynamic">Dynamisch</option>
                            @foreach (var b in Boards)
                            {
                                <option value="Fixed:@b.Id">@b.Name (fix)</option>
                            }
                        </select>
                        <label>Boardauswahl</label>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-primary btn-sm" @onclick="OnSaveRound" disabled="@(IsWorking || !CanEditTournamentStructure)">Runde speichern</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="OnApplyRoundToAll" disabled="@(IsWorking || !CanEditTournamentStructure)">Für alle Runden festlegen</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="OnApplyRoundToSubsequent" disabled="@(IsWorking || !CanEditTournamentStructure)">Für alle nachfolgenden Runden festlegen</button>
            </div>
            @if (RoundError is not null)
            {
                <div class="alert alert-danger py-1 mt-2 small">@RoundError</div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool SelectedTournamentIsLocked { get; set; }
    [Parameter] public bool EditAreGameModesLocked { get; set; }
    [Parameter] public bool HasMissingRoundConfig { get; set; }
    [Parameter] public int MissingRoundConfigCount { get; set; }
    [Parameter] public bool ShowCompletedRounds { get; set; }
    [Parameter] public EventCallback<bool> ShowCompletedRoundsChanged { get; set; }
    [Parameter] public IReadOnlyList<TournamentRoundDto> RoundSettings { get; set; } = [];
    [Parameter] public Func<TournamentRoundDto, bool> IsRoundStarted { get; set; } = _ => false;
    [Parameter] public Func<TournamentRoundDto, bool> IsRoundCompleted { get; set; } = _ => false;
    [Parameter] public Func<TournamentRoundDto, string> RoundDisplayLabel { get; set; } = _ => string.Empty;
    [Parameter] public EventCallback<IReadOnlyList<TournamentRoundDto>> OnOpenRoundGroupDetail { get; set; }

    [Parameter] public bool CanEditTournamentStructure { get; set; }
    [Parameter] public bool IsWorking { get; set; }
    [Parameter] public EventCallback OnToggleGameModesLock { get; set; }
    [Parameter] public EventCallback OnSaveRound { get; set; }
    [Parameter] public EventCallback OnApplyRoundToAll { get; set; }
    [Parameter] public EventCallback OnApplyRoundToSubsequent { get; set; }

    [Parameter] public string NewRoundPhase { get; set; } = "Knockout";
    [Parameter] public EventCallback<string> NewRoundPhaseChanged { get; set; }
    [Parameter] public int NewRoundNumber { get; set; }
    [Parameter] public EventCallback<int> NewRoundNumberChanged { get; set; }
    [Parameter] public int NewRoundBaseScore { get; set; }
    [Parameter] public EventCallback<int> NewRoundBaseScoreChanged { get; set; }
    [Parameter] public string NewRoundGameMode { get; set; } = "Legs";
    [Parameter] public EventCallback<string> NewRoundGameModeChanged { get; set; }
    [Parameter] public int NewRoundLegs { get; set; }
    [Parameter] public EventCallback<int> NewRoundLegsChanged { get; set; }
    [Parameter] public int? NewRoundSets { get; set; }
    [Parameter] public EventCallback<int?> NewRoundSetsChanged { get; set; }
    [Parameter] public string NewRoundInMode { get; set; } = "Straight";
    [Parameter] public EventCallback<string> NewRoundInModeChanged { get; set; }
    [Parameter] public string NewRoundOutMode { get; set; } = "Double";
    [Parameter] public EventCallback<string> NewRoundOutModeChanged { get; set; }
    [Parameter] public int NewRoundMaxRounds { get; set; }
    [Parameter] public EventCallback<int> NewRoundMaxRoundsChanged { get; set; }
    [Parameter] public string NewRoundBullMode { get; set; } = "25/50";
    [Parameter] public EventCallback<string> NewRoundBullModeChanged { get; set; }
    [Parameter] public string NewRoundBullOffMode { get; set; } = "Normal";
    [Parameter] public EventCallback<string> NewRoundBullOffModeChanged { get; set; }
    [Parameter] public int NewRoundDuration { get; set; }
    [Parameter] public EventCallback<int> NewRoundDurationChanged { get; set; }
    [Parameter] public int NewRoundPause { get; set; }
    [Parameter] public EventCallback<int> NewRoundPauseChanged { get; set; }
    [Parameter] public int NewRoundPlayerPause { get; set; }
    [Parameter] public EventCallback<int> NewRoundPlayerPauseChanged { get; set; }
    [Parameter] public string NewRoundBoardAssignment { get; set; } = "Dynamic";
    [Parameter] public EventCallback<string> NewRoundBoardAssignmentChanged { get; set; }
    [Parameter] public IReadOnlyList<BoardDto> Boards { get; set; } = [];

    [Parameter] public string? RoundError { get; set; }

    private IReadOnlyList<RoundGroupItem> VisibleRoundGroups =>
        RoundSettings
            .Where(r => ShowCompletedRounds || !IsRoundCompleted(r))
            .GroupBy(r => new RoundGameplayKey(
                r.BaseScore,
                r.InMode,
                r.OutMode,
                r.GameMode,
                r.Legs,
                r.Sets,
                r.MaxRounds,
                r.BullMode,
                r.BullOffMode,
                r.LegDurationSeconds,
                r.PauseBetweenMatchesMinutes,
                r.MinPlayerPauseMinutes,
                r.BoardAssignment,
                r.FixedBoardId))
            .Select(g => new RoundGroupItem(
                [.. g.OrderBy(r => r.Phase).ThenBy(r => r.RoundNumber)],
                g.First()))
            .OrderBy(g => g.Rounds.First().Phase)
            .ThenBy(g => g.Rounds.First().RoundNumber)
            .ToList();

    private string BuildGroupLabel(IReadOnlyList<TournamentRoundDto> rounds)
        => rounds.Count == 1
            ? RoundDisplayLabel(rounds[0])
            : string.Join(" + ", rounds.Select(RoundDisplayLabel));

    private Task HandleShowCompletedRoundsChanged(ChangeEventArgs args)
        => ShowCompletedRoundsChanged.InvokeAsync(args.Value is bool b && b);

    private Task HandleNewRoundPhaseChanged(ChangeEventArgs args)
        => NewRoundPhaseChanged.InvokeAsync(args.Value?.ToString() ?? "Knockout");

    private Task HandleNewRoundNumberChanged(ChangeEventArgs args)
        => NewRoundNumberChanged.InvokeAsync(ParseInt(args.Value, NewRoundNumber));

    private Task HandleNewRoundBaseScoreChanged(ChangeEventArgs args)
        => NewRoundBaseScoreChanged.InvokeAsync(ParseInt(args.Value, NewRoundBaseScore));

    private Task HandleNewRoundGameModeChanged(ChangeEventArgs args)
        => NewRoundGameModeChanged.InvokeAsync(args.Value?.ToString() ?? "Legs");

    private Task HandleNewRoundLegsChanged(ChangeEventArgs args)
        => NewRoundLegsChanged.InvokeAsync(ParseInt(args.Value, NewRoundLegs));

    private Task HandleNewRoundSetsChanged(ChangeEventArgs args)
    {
        var raw = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(raw))
            return NewRoundSetsChanged.InvokeAsync(null);

        return int.TryParse(raw, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed)
            ? NewRoundSetsChanged.InvokeAsync(parsed)
            : Task.CompletedTask;
    }

    private Task HandleNewRoundInModeChanged(ChangeEventArgs args)
        => NewRoundInModeChanged.InvokeAsync(args.Value?.ToString() ?? "Straight");

    private Task HandleNewRoundOutModeChanged(ChangeEventArgs args)
        => NewRoundOutModeChanged.InvokeAsync(args.Value?.ToString() ?? "Double");

    private Task HandleNewRoundMaxRoundsChanged(ChangeEventArgs args)
        => NewRoundMaxRoundsChanged.InvokeAsync(ParseInt(args.Value, NewRoundMaxRounds));

    private Task HandleNewRoundBullModeChanged(ChangeEventArgs args)
        => NewRoundBullModeChanged.InvokeAsync(args.Value?.ToString() ?? "25/50");

    private Task HandleNewRoundBullOffModeChanged(ChangeEventArgs args)
        => NewRoundBullOffModeChanged.InvokeAsync(args.Value?.ToString() ?? "Normal");

    private Task HandleNewRoundDurationChanged(ChangeEventArgs args)
        => NewRoundDurationChanged.InvokeAsync(ParseInt(args.Value, NewRoundDuration));

    private Task HandleNewRoundPauseChanged(ChangeEventArgs args)
        => NewRoundPauseChanged.InvokeAsync(ParseInt(args.Value, NewRoundPause));

    private Task HandleNewRoundPlayerPauseChanged(ChangeEventArgs args)
        => NewRoundPlayerPauseChanged.InvokeAsync(ParseInt(args.Value, NewRoundPlayerPause));

    private Task HandleNewRoundBoardAssignmentChanged(ChangeEventArgs args)
        => NewRoundBoardAssignmentChanged.InvokeAsync(args.Value?.ToString() ?? "Dynamic");

    private static int ParseInt(object? value, int fallback)
    {
        var raw = value?.ToString();
        return int.TryParse(raw, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : fallback;
    }

    private sealed record RoundGroupItem(IReadOnlyList<TournamentRoundDto> Rounds, TournamentRoundDto Representative);

    private sealed record RoundGameplayKey(
        int BaseScore,
        string InMode,
        string OutMode,
        string GameMode,
        int Legs,
        int? Sets,
        int MaxRounds,
        string BullMode,
        string BullOffMode,
        int LegDurationSeconds,
        int PauseBetweenMatchesMinutes,
        int MinPlayerPauseMinutes,
        string BoardAssignment,
        Guid? FixedBoardId);
}
