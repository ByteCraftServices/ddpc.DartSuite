@page "/boards"
@using ddpc.DartSuite.Application.Contracts.Boards
@using ddpc.DartSuite.Application.Contracts.Tournaments
@using ddpc.DartSuite.Web.Services
@inject DartSuiteApiService Api
@inject AppStateService AppState
@inject BoardHubService BoardHubService
@inject IUiHelpService UiHelp
@implements IDisposable

<PageTitle>Boards</PageTitle>

<h1>Boards <UiHelpIcon HelpKey="page.boards" /></h1>
@if (isRealtimeConnected)
{
    <div class="alert alert-success py-2">Echtzeit aktiv: Board-Updates werden direkt ueber SignalR empfangen.</div>
}
else
{
    <div class="alert alert-warning py-2">Echtzeit getrennt: Daten werden bei Aktionen/Navigation aktualisiert.</div>
}

<div class="card mt-3 shadow-sm">
    <div class="card-body">
        <EditForm Model="this" OnValidSubmit="CreateBoardAsync" FormName="create-board">
            <div class="row g-2">
                <div class="col-md-4">
                    <InputText @bind-Value="newBoardExternalId" class="form-control" placeholder="Board ID"
                               title="@UiHelp.GetTooltip("boards.external-id")" />
                </div>
                <div class="col-md-4">
                    <InputText @bind-Value="newBoardName" class="form-control" placeholder="Board Name"
                               title="@UiHelp.GetTooltip("boards.name")" />
                </div>
                <div class="col-md-4">
                    <button class="btn btn-primary w-100" type="submit" title="@UiHelp.GetTooltip("boards.create")">Add Board</button>
                </div>
            </div>
        </EditForm>
        @if (boardError is not null)
        {
            <div class="alert alert-danger py-2 mt-2 d-flex justify-content-between align-items-center">
                <span>@boardError</span>
                <button type="button" class="btn-close" @onclick="() => boardError = null"></button>
            </div>
        }
    </div>
</div>

@* ─── Board Edit Panel ─── *@
@if (editingBoard is not null)
{
    <div class="card mt-3 shadow-sm border-warning">
        <div class="card-header d-flex justify-content-between align-items-center bg-warning-subtle">
            <span class="fw-semibold">✎ Board bearbeiten: @editingBoard.Name</span>
            <button type="button" class="btn-close" @onclick="CancelEditBoard"></button>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" @bind="editBoardName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">External ID</label>
                    <input type="text" class="form-control" @bind="editBoardExternalId" />
                    <div class="form-text">Eindeutige Kennung des Boards (z.B. Autodarts Board-GUID).</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Owner (Account-Name)</label>
                    <input type="text" class="form-control" @bind="editBoardOwner" placeholder="—" />
                </div>
                <div class="col-md-6 d-flex align-items-end pb-1">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="editIsVirtual" @bind="editBoardIsVirtual" />
                        <label class="form-check-label" for="editIsVirtual">Virtuelles Board (kein physisches Gerät erforderlich)</label>
                    </div>
                </div>
                @if (!editBoardIsVirtual)
                {
                    <div class="col-md-6">
                        <label class="form-label">Lokale IP-Adresse</label>
                        <input type="text" class="form-control" @bind="editBoardLocalIp" placeholder="z.B. 192.168.1.10" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Board-Manager URL</label>
                        <input type="text" class="form-control" @bind="editBoardManagerUrl" placeholder="z.B. http://192.168.1.10:8080" />
                    </div>
                }
            </div>
            @if (editBoardError is not null)
            {
                <div class="alert alert-danger py-2 mt-3 d-flex justify-content-between align-items-center">
                    <span>@editBoardError</span>
                    <button type="button" class="btn-close" @onclick="() => editBoardError = null"></button>
                </div>
            }
            <div class="d-flex gap-2 mt-3">
                <button class="btn btn-warning" @onclick="SaveBoardAsync">Speichern</button>
                <button class="btn btn-outline-secondary" @onclick="CancelEditBoard">Abbrechen</button>
            </div>
        </div>
    </div>
}

@* ─── Virtual Board Management (Admin only) ─── *@
@if (AppState.IsAdmin)
{
    <div class="card mt-3 shadow-sm border-info">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">⚡ Virtuelle Boards</span>
            <button class="btn btn-outline-info btn-sm" @onclick="() => showVirtualBoardForm = !showVirtualBoardForm">
                @(showVirtualBoardForm ? "Abbrechen" : "+ Virtuelles Board erstellen")
            </button>
        </div>
        @if (showVirtualBoardForm)
        {
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-4">
                        <input type="text" class="form-control" placeholder="Name" @bind="newVirtualBoardName" />
                    </div>
                    <div class="col-md-4">
                        <input type="text" class="form-control" placeholder="Owner (Account-Name, optional)" @bind="newVirtualBoardOwner" />
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-info w-100" @onclick="CreateVirtualBoardAsync">Erstellen</button>
                    </div>
                </div>
                @if (virtualBoardError is not null)
                {
                    <div class="alert alert-danger py-2 mt-2 d-flex justify-content-between align-items-center">
                        <span>@virtualBoardError</span>
                        <button type="button" class="btn-close" @onclick="() => virtualBoardError = null"></button>
                    </div>
                }
            </div>
        }
        @if (virtualBoards.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Owner</th>
                            <th>Aktuelles Match</th>
                            <th>Turnier</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var vb in virtualBoards)
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-info me-1" title="Virtuelles Board ohne physisches Geraet">Virtual</span>
                                    @vb.Name
                                </td>
                                <td>
                                    @if (editingOwnerBoardId == vb.Id)
                                    {
                                        <div class="d-flex gap-1">
                                            <input type="text" class="form-control form-control-sm" style="max-width:180px" @bind="editOwnerValue" />
                                            <button class="btn btn-sm btn-success" @onclick="() => SaveOwnerAsync(vb.Id)">✓</button>
                                            <button class="btn btn-sm btn-secondary" @onclick="CancelEditOwner">✗</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@(vb.OwnerAccountName ?? "—")</span>
                                        <button class="btn btn-link btn-sm p-0 ms-1" title="Owner ändern" @onclick="() => StartEditOwner(vb)">✎</button>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(vb.CurrentMatchLabel))
                                    {
                                        <span class="small">@vb.CurrentMatchLabel</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>
                                    @if (vb.TournamentId.HasValue)
                                    {
                                        <span class="badge bg-success small" title="Virtuelles Board ist einem Turnier zugewiesen">Zugewiesen</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="text-nowrap">
                                    <button class="btn btn-outline-secondary btn-sm me-1" title="Stammdaten bearbeiten" @onclick="() => StartEditBoard(vb)">✎</button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteBoardAsync(vb.Id)">🗑</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

<div class="table-responsive">
<table class="table table-striped mt-3">
    <thead>
        <tr>
            <th></th>
            <th>Name</th>
            <th class="d-none d-md-table-cell">External ID</th>
            <th>Status</th>
            <th class="d-none d-sm-table-cell">Verbindung</th>
            <th>Aktuelles Match</th>
            <th class="d-none d-md-table-cell">Extension</th>
            <th class="d-none d-md-table-cell">Zeitplan</th>
            <th class="d-none d-lg-table-cell">IP</th>
            @if (CanConvertToVirtual)
            {
                <th>Aktionen</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var board in boards)
        {
            <tr>
                <td><BoardStatusIndicator Board="@board" ShowLabel="true" /></td>
                <td>
                    @if (board.IsVirtual)
                    {
                        <span class="badge bg-info me-1" title="Virtuelles Board ohne physisches Geraet">🖥 Virtual</span>
                    }
                    <a href="/tournaments?boardId=@board.Id"
                       class="text-primary fw-semibold"
                       style="text-decoration:underline dotted">@board.Name</a>
                </td>
                <td class="d-none d-md-table-cell"><code class="small">@board.ExternalBoardId</code></td>
                <td><span class="badge @StatusBadge(board.Status)" title="Aktueller Betriebsstatus des Boards">@board.Status</span></td>
                <td class="d-none d-sm-table-cell">
                    <span class="badge @ConnectionBadge(board.ConnectionState)" title="Verbindungsstatus zwischen Plattform und Board">@board.ConnectionState</span>
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(board.CurrentMatchLabel))
                    {
                        @if (board.CurrentMatchId.HasValue)
                        {
                            <a href="/matches?matchId=@board.CurrentMatchId.Value"
                               class="text-primary fw-semibold"
                               style="text-decoration:underline dotted"><span class="autodarts-icon"></span> @board.CurrentMatchLabel</a>
                        }
                        else
                        {
                            <span>@board.CurrentMatchLabel</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
                <td class="d-none d-md-table-cell">
                    @if (board.IsExtensionConnected)
                    {
                        <span class="badge bg-success" title="Browser-Extension meldet eine aktive Verbindung">Verbunden</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary" title="Browser-Extension ist aktuell nicht verbunden">Getrennt</span>
                    }
                </td>
                <td class="d-none d-md-table-cell">
                    <span class="badge @SchedulingBadge(board.SchedulingStatus)" title="Zeitplanstatus fuer Board-Einsaetze">@board.SchedulingStatus</span>
                </td>
                <td class="d-none d-lg-table-cell">@board.LocalIpAddress</td>
                @if (CanConvertToVirtual)
                {
                    <td class="text-nowrap">
                        <button class="btn btn-sm btn-outline-secondary me-1" title="Stammdaten bearbeiten" @onclick="() => StartEditBoard(board)">✎</button>
                        @if (!board.IsVirtual)
                        {
                            <button class="btn btn-sm btn-outline-info" title="Bestehendes Board als virtuelles Board markieren" @onclick="() => ConvertBoardToVirtualAsync(board)">Als virtuell</button>
                        }
                    </td>
                }
            </tr>
        }
    </tbody>
</table>
</div>

@code {
    private List<BoardDto> boards = new();
    private List<BoardDto> virtualBoards = new();
    private string newBoardExternalId = string.Empty;
    private string newBoardName = string.Empty;
    private string? boardError;
    private bool isRealtimeConnected;

    private bool CanConvertToVirtual
        => AppState.IsAdmin
            || (AppState.SelectedTournament is not null
                && !string.IsNullOrWhiteSpace(AppState.AutodartsProfile?.DisplayName)
                && string.Equals(AppState.SelectedTournament.OrganizerAccount, AppState.AutodartsProfile.DisplayName, StringComparison.OrdinalIgnoreCase));

    // Virtual board form
    private bool showVirtualBoardForm;
    private string newVirtualBoardName = string.Empty;
    private string newVirtualBoardOwner = string.Empty;
    private string? virtualBoardError;

    // Owner editing (virtual board table inline)
    private Guid? editingOwnerBoardId;
    private string editOwnerValue = string.Empty;

    // Board editing (full edit panel)
    private BoardDto? editingBoard;
    private string editBoardName = string.Empty;
    private string editBoardExternalId = string.Empty;
    private string editBoardOwner = string.Empty;
    private string editBoardLocalIp = string.Empty;
    private string editBoardManagerUrl = string.Empty;
    private bool editBoardIsVirtual;
    private string? editBoardError;

    private void StartEditBoard(BoardDto board)
    {
        editingBoard = board;
        editBoardName = board.Name;
        editBoardExternalId = board.ExternalBoardId;
        editBoardOwner = board.OwnerAccountName ?? string.Empty;
        editBoardLocalIp = board.LocalIpAddress ?? string.Empty;
        editBoardManagerUrl = board.BoardManagerUrl ?? string.Empty;
        editBoardIsVirtual = board.IsVirtual;
        editBoardError = null;
    }

    private void CancelEditBoard()
    {
        editingBoard = null;
        editBoardError = null;
    }

    private async Task SaveBoardAsync()
    {
        if (editingBoard is null) return;
        if (string.IsNullOrWhiteSpace(editBoardName))
        {
            editBoardError = "Name ist erforderlich.";
            return;
        }

        try
        {
            editBoardError = null;
            var request = new UpdateBoardRequest(
                editingBoard.Id,
                editBoardName.Trim(),
                string.IsNullOrWhiteSpace(editBoardExternalId) ? null : editBoardExternalId.Trim(),
                editBoardIsVirtual ? null : (string.IsNullOrWhiteSpace(editBoardLocalIp) ? null : editBoardLocalIp.Trim()),
                editBoardIsVirtual ? null : (string.IsNullOrWhiteSpace(editBoardManagerUrl) ? null : editBoardManagerUrl.Trim()),
                editBoardIsVirtual,
                string.IsNullOrWhiteSpace(editBoardOwner) ? null : editBoardOwner.Trim());
            await Api.UpdateBoardAsync(request);
            editingBoard = null;
            await LoadBoardsForCurrentScopeAsync();
            await LoadVirtualBoardsAsync();
        }
        catch (InvalidOperationException ex)
        {
            editBoardError = ex.Message;
        }
        catch
        {
            editBoardError = "Fehler beim Speichern des Boards.";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += OnAppStateChanged;
        await LoadBoardsForCurrentScopeAsync();
        await LoadVirtualBoardsAsync();

        try
        {
            BoardHubService.OnConnectionChanged += OnBoardHubConnectionChanged;
            BoardHubService.OnBoardAdded += OnBoardChanged;
            BoardHubService.OnBoardStatusChanged += OnBoardChanged;
            BoardHubService.OnBoardConnectionChanged += OnBoardChanged;
            BoardHubService.OnBoardExtensionStatusChanged += OnBoardChanged;
            BoardHubService.OnBoardCurrentMatchChanged += OnBoardChanged;
            BoardHubService.OnBoardManagedModeChanged += OnBoardChanged;
            BoardHubService.OnBoardRemoved += OnBoardRemoved;

            await BoardHubService.StartAsync();
        }
        catch
        {
            isRealtimeConnected = false;
        }
    }

    private async Task OnBoardHubConnectionChanged(bool connected)
    {
        isRealtimeConnected = connected;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnBoardChanged(BoardDto board)
    {
        await InvokeAsync(() =>
        {
            if (board.IsVirtual)
            {
                boards.RemoveAll(b => b.Id == board.Id);
                var vidx = virtualBoards.FindIndex(b => b.Id == board.Id);
                if (vidx >= 0)
                    virtualBoards[vidx] = board;
                else
                    virtualBoards.Add(board);
                StateHasChanged();
                return;
            }

            if (!IsBoardInCurrentScope(board))
            {
                boards.RemoveAll(b => b.Id == board.Id);
                StateHasChanged();
                return;
            }

            var index = boards.FindIndex(b => b.Id == board.Id);
            if (index >= 0)
                boards[index] = board;
            else
                boards.Add(board);

            StateHasChanged();
        });
    }

    private async Task OnBoardRemoved(Guid boardId)
    {
        await InvokeAsync(() =>
        {
            boards.RemoveAll(b => b.Id == boardId);
            virtualBoards.RemoveAll(b => b.Id == boardId);
            StateHasChanged();
        });
    }

    private async void OnAppStateChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadBoardsForCurrentScopeAsync();
            await LoadVirtualBoardsAsync();
            StateHasChanged();
        });
    }

    private async Task CreateBoardAsync()
    {
        if (string.IsNullOrWhiteSpace(newBoardExternalId) || string.IsNullOrWhiteSpace(newBoardName))
            return;

        try
        {
            boardError = null;
            await Api.AddBoardAsync(new CreateBoardRequest(newBoardExternalId, newBoardName, null, null));
            newBoardExternalId = string.Empty;
            newBoardName = string.Empty;
            await LoadBoardsForCurrentScopeAsync();
        }
        catch (InvalidOperationException ex)
        {
            boardError = ex.Message;
        }
        catch
        {
            boardError = "An unexpected error occurred. Please try again.";
        }
    }

    private async Task ConvertBoardToVirtualAsync(BoardDto board)
    {
        try
        {
            boardError = null;
            await Api.ConvertBoardToVirtualAsync(board.Id);
            await LoadBoardsForCurrentScopeAsync();
            await LoadVirtualBoardsAsync();
        }
        catch (InvalidOperationException ex)
        {
            boardError = ex.Message;
        }
        catch
        {
            boardError = "Fehler beim Konvertieren in virtuelles Board.";
        }
    }

    private async Task CreateVirtualBoardAsync()
    {
        if (string.IsNullOrWhiteSpace(newVirtualBoardName))
        {
            virtualBoardError = "Name ist erforderlich.";
            return;
        }

        try
        {
            virtualBoardError = null;
            await Api.CreateVirtualBoardAsync(new CreateVirtualBoardRequest(
                newVirtualBoardName,
                string.IsNullOrWhiteSpace(newVirtualBoardOwner) ? null : newVirtualBoardOwner.Trim()));
            newVirtualBoardName = string.Empty;
            newVirtualBoardOwner = string.Empty;
            showVirtualBoardForm = false;
            await LoadVirtualBoardsAsync();
        }
        catch (InvalidOperationException ex)
        {
            virtualBoardError = ex.Message;
        }
        catch
        {
            virtualBoardError = "Fehler beim Erstellen des virtuellen Boards.";
        }
    }

    private async Task DeleteBoardAsync(Guid boardId)
    {
        try
        {
            await Api.DeleteBoardAsync(boardId);
            await LoadBoardsForCurrentScopeAsync();
            await LoadVirtualBoardsAsync();
        }
        catch { }
    }

    private void StartEditOwner(BoardDto board)
    {
        editingOwnerBoardId = board.Id;
        editOwnerValue = board.OwnerAccountName ?? string.Empty;
    }

    private void CancelEditOwner()
    {
        editingOwnerBoardId = null;
        editOwnerValue = string.Empty;
    }

    private async Task SaveOwnerAsync(Guid boardId)
    {
        try
        {
            await Api.ChangeVirtualBoardOwnerAsync(boardId, string.IsNullOrWhiteSpace(editOwnerValue) ? null : editOwnerValue.Trim());
            await LoadVirtualBoardsAsync();
        }
        catch { }
        finally
        {
            editingOwnerBoardId = null;
            editOwnerValue = string.Empty;
        }
    }

    private async Task LoadBoardsForCurrentScopeAsync()
    {
        if (AppState.SelectedTournament is not null)
        {
            boards = (await Api.GetBoardsByTournamentAsync(AppState.SelectedTournament.Id)).ToList();
            return;
        }

        boards = (await Api.GetBoardsAsync())
            .Where(b => !b.TournamentId.HasValue && !b.IsVirtual)
            .ToList();
    }

    private async Task LoadVirtualBoardsAsync()
    {
        if (AppState.IsAdmin)
            virtualBoards = (await Api.GetVirtualBoardsAsync()).ToList();
    }

    private bool IsBoardInCurrentScope(BoardDto board)
    {
        if (AppState.SelectedTournament is null)
            return !board.TournamentId.HasValue;

        return !board.TournamentId.HasValue || board.TournamentId == AppState.SelectedTournament.Id;
    }

    private static string StatusBadge(string status) => status switch
    {
        "Running" => "bg-success",
        "Online" => "bg-info text-dark",
        "Starting" => "bg-warning text-dark",
        "Error" => "bg-danger",
        _ => "bg-secondary"
    };

    private static string ConnectionBadge(string state) => state switch
    {
        "Online" => "bg-success",
        "Offline" => "bg-danger",
        _ => "bg-secondary"
    };

    private static string SchedulingBadge(string status) => status switch
    {
        "InTime" => "bg-success",
        "Ahead" => "bg-info text-dark",
        "Delayed" => "bg-danger",
        _ => "bg-secondary"
    };

    public void Dispose()
    {
        AppState.OnChange -= OnAppStateChanged;
        BoardHubService.OnConnectionChanged -= OnBoardHubConnectionChanged;
        BoardHubService.OnBoardAdded -= OnBoardChanged;
        BoardHubService.OnBoardStatusChanged -= OnBoardChanged;
        BoardHubService.OnBoardConnectionChanged -= OnBoardChanged;
        BoardHubService.OnBoardExtensionStatusChanged -= OnBoardChanged;
        BoardHubService.OnBoardCurrentMatchChanged -= OnBoardChanged;
        BoardHubService.OnBoardManagedModeChanged -= OnBoardChanged;
        BoardHubService.OnBoardRemoved -= OnBoardRemoved;
    }
}