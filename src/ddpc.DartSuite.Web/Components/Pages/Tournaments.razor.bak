@page "/tournaments"
@rendermode InteractiveServer
@inject DartSuiteApiService Api
@using ddpc.DartSuite.Application.Contracts.Matches
@using ddpc.DartSuite.Application.Contracts.Boards
@using ddpc.DartSuite.Application.Contracts.Tournaments

<PageTitle>Turniere</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="mb-0">Turniere</h1>
    @if (!isCreating)
    {
        <button class="btn btn-primary" @onclick="StartWizard">+ Neues Turnier</button>
    }
</div>

@* ─── Create Wizard ─── *@
@if (isCreating)
{
    <div class="card shadow-sm mb-4 border-primary">
        <div class="card-header d-flex justify-content-between align-items-center bg-primary text-white">
            <span><strong>Neues Turnier</strong> — Schritt @wizardStep von 2</span>
            <button type="button" class="btn-close btn-close-white" @onclick="CancelWizard"></button>
        </div>
        <div class="card-body">
            @if (wizardStep == 1)
            {
                <h6 class="text-muted mb-3">Schritt 1: Grunddaten</h6>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Turniername <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="wizardName" placeholder="z.B. Frühlings-Cup 2026" maxlength="128" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Veranstalter-Account</label>
                    <input class="form-control" @bind="wizardOrganizer" placeholder="Autodarts Account-Name" />
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Startdatum <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" @bind="wizardStartDate" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Enddatum</label>
                        <input type="date" class="form-control" @bind="wizardEndDate" />
                        <div class="form-text">Leer lassen — entspricht dem Startdatum.</div>
                    </div>
                </div>
                @if (wizardError is not null)
                {
                    <div class="alert alert-danger py-2">@wizardError</div>
                }
                <button class="btn btn-primary" @onclick="WizardNext">Weiter →</button>
            }
            else if (wizardStep == 2)
            {
                <h6 class="text-muted mb-3">Schritt 2: Turniereinstellungen</h6>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Modus</label>
                    <select class="form-select" @bind="wizardMode">
                        <option value="Knockout">K.O.-Modus (klassisch)</option>
                        <option value="GroupAndKnockout">Gruppenphase + K.O.</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Variante</label>
                    <select class="form-select" @bind="wizardVariant">
                        <option value="OnSite">Vor-Ort (Boards werden zugewiesen)</option>
                        <option value="Online">Online</option>
                    </select>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="wizTeamplay" @bind="wizardTeamplay" />
                    <label class="form-check-label" for="wizTeamplay">Teamplay aktivieren</label>
                </div>
                @if (wizardError is not null)
                {
                    <div class="alert alert-danger py-2">@wizardError</div>
                }
                <button class="btn btn-secondary me-2" @onclick="() => wizardStep = 1">← Zurück</button>
                <button class="btn btn-success" @onclick="FinishWizardAsync" disabled="@isWorking">✓ Turnier erstellen</button>
            }
        </div>
    </div>
}

@* ─── Confirmation Modal ─── *@
@if (showConfirmation)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title">⚠ Turnierplan betroffen</h5>
                </div>
                <div class="modal-body">
                    <p>@confirmationMessage</p>
                    <p class="text-muted small mb-0">Der bestehende Turnierplan und Spielplan werden dadurch ungültig und müssen neu generiert werden.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="RejectConfirmation">Abbrechen</button>
                    <button class="btn btn-warning" @onclick="AcceptConfirmation">Änderung durchführen</button>
                </div>
            </div>
        </div>
    </div>
}

@* ─── Tournament List + Detail ─── *@
<div class="row g-3">
    <div class="@(selectedTournament is not null ? "col-lg-3" : "col-12")">
        @if (activeTournaments.Any())
        {
            <h6 class="mb-1 fw-semibold text-success">▶ Aktiv</h6>
            <ul class="list-group mb-3">
                @foreach (var t in activeTournaments)
                {
                    <li class="list-group-item list-group-item-action @(selectedTournament?.Id == t.Id ? "active" : "")"
                        style="cursor:pointer" @onclick="() => SelectTournamentAsync(t)">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>@t.Name @if (!string.IsNullOrEmpty(t.JoinCode)) { <span class="badge text-bg-primary font-monospace" style="font-size:0.65rem" title="Code">@t.JoinCode</span> } @if (t.IsLocked) { <span title="Gesperrt">🔒</span> }</span>
                            <span class="badge @(selectedTournament?.Id == t.Id ? "bg-light text-dark" : "bg-primary")">@t.ParticipantCount</span>
                        </div>
                        <small class="@(selectedTournament?.Id == t.Id ? "text-white-50" : "text-muted")">
                            @t.StartDate.ToString("dd.MM.yyyy") – @t.EndDate.ToString("dd.MM.yyyy")
                        </small>
                    </li>
                }
            </ul>
        }

        @if (upcomingTournaments.Any())
        {
            <h6 class="mb-1 fw-semibold text-primary">📅 Geplant</h6>
            <ul class="list-group mb-3">
                @foreach (var t in upcomingTournaments)
                {
                    <li class="list-group-item list-group-item-action @(selectedTournament?.Id == t.Id ? "active" : "")"
                        style="cursor:pointer" @onclick="() => SelectTournamentAsync(t)">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>@t.Name @if (t.IsLocked) { <span title="Gesperrt">🔒</span> }</span>
                            <span class="badge @(selectedTournament?.Id == t.Id ? "bg-light text-dark" : "bg-secondary")">@t.ParticipantCount</span>
                        </div>
                        <small class="@(selectedTournament?.Id == t.Id ? "text-white-50" : "text-muted")">
                            @t.StartDate.ToString("dd.MM.yyyy") – @t.EndDate.ToString("dd.MM.yyyy")
                        </small>
                    </li>
                }
            </ul>
        }

        @if (pastTournaments.Any())
        {
            <h6 class="mb-1 fw-semibold text-muted">✓ Vergangen</h6>
            <ul class="list-group mb-3">
                @foreach (var t in pastTournaments)
                {
                    <li class="list-group-item list-group-item-action @(selectedTournament?.Id == t.Id ? "active" : "")"
                        style="cursor:pointer" @onclick="() => SelectTournamentAsync(t)">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>@t.Name @if (t.IsLocked) { <span title="Gesperrt">🔒</span> }</span>
                            <span class="badge @(selectedTournament?.Id == t.Id ? "bg-light text-dark" : "bg-secondary")">@t.ParticipantCount</span>
                        </div>
                        <small class="@(selectedTournament?.Id == t.Id ? "text-white-50" : "text-muted")">
                            @t.StartDate.ToString("dd.MM.yyyy") – @t.EndDate.ToString("dd.MM.yyyy")
                        </small>
                    </li>
                }
            </ul>
        }

        @if (!tournaments.Any())
        {
            <p class="text-muted">Noch keine Turniere vorhanden.</p>
        }
    </div>

    @* ─── Tournament Detail Panel ─── *@
    @if (selectedTournament is not null)
    {
        <div class="col-lg-9">
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <span class="fw-semibold">@selectedTournament.Name</span>
                        @if (!string.IsNullOrEmpty(selectedTournament.JoinCode))
                        {
                            <span class="badge text-bg-primary ms-2 font-monospace" title="Turnier-Code">@selectedTournament.JoinCode</span>
                        }
                        @if (selectedTournament.TeamplayEnabled) { <span class="badge text-bg-warning ms-2">Teams</span> }
                        @if (selectedTournament.IsLocked) { <span class="badge text-bg-danger ms-2">🔒 Gesperrt</span> }
                    </div>
                    <div class="d-flex gap-1">
                        <span class="badge text-bg-secondary">@selectedTournament.Mode</span>
                        <span class="badge text-bg-info">@selectedTournament.Variant</span>
                        <button class="btn btn-sm @(selectedTournament.IsLocked ? "btn-outline-success" : "btn-outline-danger")"
                                @onclick="ToggleLockAsync" disabled="@isWorking" title="@(selectedTournament.IsLocked ? "Entsperren" : "Sperren")">
                            @(selectedTournament.IsLocked ? "🔓 Entsperren" : "🔒 Sperren")
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    @* ─── 5 Tabs ─── *@
                    <ul class="nav nav-tabs mb-3">
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == "general" ? "active" : "")" @onclick='() => activeTab = "general"'>
                                Allgemein
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == "boards-participants" ? "active" : "")" @onclick='() => activeTab = "boards-participants"'>
                                Boards &amp; Teilnehmer
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == "draw" ? "active" : "")" @onclick='() => activeTab = "draw"'>
                                Auslosung
                            </button>
                        </li>
                        @if (selectedTournament.Mode == "GroupAndKnockout")
                        {
                            <li class="nav-item">
                                <button class="nav-link @(activeTab == "groups" ? "active" : "")" @onclick='() => activeTab = "groups"'>
                                    Gruppenphase
                                </button>
                            </li>
                        }
                        <li class="nav-item">
                            <button class="nav-link @(activeTab == "knockout" ? "active" : "")" @onclick='() => activeTab = "knockout"'>
                                K.O.-Phase <span class="badge text-bg-secondary ms-1">@matches.Count</span>
                            </button>
                        </li>
                    </ul>

                    @* ═══════ Tab 1: Allgemein ═══════ *@
                    @if (activeTab == "general")
                    {
                        @if (selectedTournament.IsLocked)
                        {
                            <div class="alert alert-info py-2">🔒 Das Turnier ist gesperrt. Entsperren Sie es, um Änderungen vorzunehmen.</div>
                        }
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Turniername</label>
                            <input class="form-control" @bind="editName" disabled="@selectedTournament.IsLocked" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Veranstalter-Account</label>
                            <input class="form-control" @bind="editOrganizer" disabled="@selectedTournament.IsLocked" />
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Startdatum</label>
                                <input type="date" class="form-control" @bind="editStartDate" disabled="@selectedTournament.IsLocked" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Enddatum</label>
                                <input type="date" class="form-control" @bind="editEndDate" disabled="@selectedTournament.IsLocked" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Modus</label>
                            <select class="form-select" @bind="editMode" disabled="@selectedTournament.IsLocked">
                                <option value="Knockout">K.O.-Modus</option>
                                <option value="GroupAndKnockout">Gruppenphase + K.O.</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Variante</label>
                            <select class="form-select" @bind="editVariant" disabled="@selectedTournament.IsLocked">
                                <option value="OnSite">Vor-Ort</option>
                                <option value="Online">Online</option>
                            </select>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="editTeamplay" @bind="editTeamplay" disabled="@selectedTournament.IsLocked" />
                            <label class="form-check-label" for="editTeamplay">Teamplay aktivieren</label>
                        </div>
                        @if (editError is not null)
                        {
                            <div class="alert alert-danger py-2">@editError</div>
                        }
                        @if (editSuccess is not null)
                        {
                            <div class="alert alert-success py-2">@editSuccess</div>
                        }
                        @if (!selectedTournament.IsLocked)
                        {
                            <button class="btn btn-primary" @onclick="SaveTournamentAsync" disabled="@isWorking">💾 Speichern</button>
                        }
                    }

                    @* ═══════ Tab 2: Boards & Teilnehmer ═══════ *@
                    @if (activeTab == "boards-participants")
                    {
                        <h6 class="fw-semibold mb-2">Boards</h6>
                        @if (boards.Any())
                        {
                            <div class="table-responsive mb-4">
                                <table class="table table-sm table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Board</th>
                                            <th>Status</th>
                                            <th>Aktuelles Match</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var board in boards)
                                        {
                                            <tr>
                                                <td>@board.Name</td>
                                                <td>
                                                    <span class="badge @BoardStatusBadge(board.Status)">@board.Status</span>
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(board.CurrentMatchLabel))
                                                    {
                                                        <span class="text-primary">🎯 @board.CurrentMatchLabel</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">— Kein aktives Match</span>
                                                    }
                                                </td>
                                                <td>
                                                    <a href="https://play.autodarts.io/boards/@(board.ExternalBoardId)/follow"
                                                       target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary" title="Board-Follow öffnen">
                                                        📺 Follow
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small mb-4">Keine Boards konfiguriert. Boards können über die <a href="/boards">Boards-Seite</a> oder die Chrome-Extension hinzugefügt werden.</p>
                        }

                        <h6 class="fw-semibold mb-2">Teilnehmer <span class="badge text-bg-secondary">@participants.Count</span></h6>
                        @if (!selectedTournament.IsLocked)
                        {
                            <div class="row g-2 align-items-end mb-2">
                                <div class="col-md-4">
                                    <label class="form-label small mb-1">Anzeigename</label>
                                    <input class="form-control" @bind="participantName" @bind:event="oninput"
                                           placeholder="z.B. Max Mustermann"
                                           @onkeydown="HandleParticipantKeyAsync" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small mb-1">Account-Name</label>
                                    <input class="form-control" @bind="participantAccount" @bind:event="oninput"
                                           placeholder="Auto aus Anzeigename"
                                           @onkeydown="HandleParticipantKeyAsync" />
                                </div>
                                <div class="col-md-2">
                                    <div class="form-check mb-0">
                                        <input class="form-check-input" type="checkbox" id="isAuto" @bind="participantIsAutodarts" />
                                        <label class="form-check-label small" for="isAuto">Autodarts</label>
                                    </div>
                                </div>
                                <div class="col-md-1">
                                    <div class="form-check mb-0">
                                        <input class="form-check-input" type="checkbox" id="isMgr" @bind="participantIsManager" />
                                        <label class="form-check-label small" for="isMgr">Spielleiter</label>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <button class="btn btn-outline-primary btn-sm w-100" @onclick="AddParticipantAsync" disabled="@isWorking">Hinzufügen</button>
                                </div>
                            </div>
                        }
                        @if (participantError is not null)
                        {
                            <div class="alert alert-danger py-2 small d-flex justify-content-between align-items-center mb-2">
                                <span>@participantError</span>
                                <button type="button" class="btn-close btn-sm" @onclick="() => participantError = null"></button>
                            </div>
                        }
                        @if (participants.Any())
                        {
                            <ul class="list-group">
                                @foreach (var p in participants)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span>
                                            @p.DisplayName
                                            @if (p.IsManager)
                                            {
                                                <span class="badge text-bg-warning ms-1">Spielleiter</span>
                                            }
                                            @if (!p.IsAutodartsAccount)
                                            {
                                                <span class="badge text-bg-secondary ms-1">Lokal</span>
                                            }
                                        </span>
                                        <div class="d-flex align-items-center gap-2">
                                            <small class="text-muted">@p.AccountName</small>
                                            @if (!selectedTournament.IsLocked)
                                            {
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveParticipantAsync(p)"
                                                        title="Teilnehmer entfernen" disabled="@isWorking">✕</button>
                                            }
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted small">Noch keine Teilnehmer vorhanden.</p>
                        }
                    }

                    @* ═══════ Tab 3: Auslosung ═══════ *@
                    @if (activeTab == "draw")
                    {
                        <div class="mb-3">
                            @if (!matches.Any() && participants.Count >= 2 && !selectedTournament.IsLocked)
                            {
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <button class="btn btn-primary" @onclick="GenerateMatchesAsync" disabled="@isWorking">
                                        ⚡ K.O.-Plan generieren
                                    </button>
                                    @if (participants.Count < 2)
                                    {
                                        <small class="text-danger">Mindestens 2 Teilnehmer erforderlich.</small>
                                    }
                                </div>
                            }
                            else if (matches.Any() && !HasPlayedMatches() && !selectedTournament.IsLocked)
                            {
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <button class="btn btn-warning" @onclick="RegenerateMatchesAsync" disabled="@isWorking">
                                        🔄 Turnierplan neu generieren
                                    </button>
                                    <small class="text-muted">Alle bestehenden Paarungen werden gelöscht.</small>
                                </div>
                            }
                            else if (HasPlayedMatches())
                            {
                                <div class="alert alert-info py-2 mb-3">
                                    Es wurden bereits Matches gespielt. Der Turnierplan kann nicht mehr automatisch neu generiert werden.
                                </div>
                            }

                            @if (matches.Any())
                            {
                                <h6 class="fw-semibold">Paarungen (Runde 1)</h6>
                                <ul class="list-group">
                                    @foreach (var match in matches.Where(m => m.Round == 1).OrderBy(m => m.MatchNumber))
                                    {
                                        var homeP = participants.FirstOrDefault(p => p.Id == match.HomeParticipantId);
                                        var awayP = participants.FirstOrDefault(p => p.Id == match.AwayParticipantId);
                                        <li class="list-group-item">
                                            <span class="text-muted small me-1">M@(match.MatchNumber)</span>
                                            <strong>@(homeP?.DisplayName ?? "?")</strong>
                                            <span class="text-muted mx-1">vs</span>
                                            <strong>@(awayP?.DisplayName ?? "?")</strong>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="text-muted">Noch kein Turnierplan vorhanden. Fügen Sie mindestens 2 Teilnehmer hinzu und generieren Sie den Plan.</p>
                            }
                        </div>
                    }

                    @* ═══════ Tab 4: Gruppenphase ═══════ *@
                    @if (activeTab == "groups")
                    {
                        <p class="text-muted">Die Gruppenphase wird in einer zukünftigen Version umgesetzt.</p>
                    }

                    @* ═══════ Tab 5: K.O.-Phase ═══════ *@
                    @if (activeTab == "knockout")
                    {
                        @if (selectedTournament.Variant == "OnSite" && boards.Any() && matches.Any())
                        {
                            <div class="p-2 border rounded mb-3 bg-light">
                                <div class="small fw-semibold text-muted mb-2">Verfügbare Boards — auf Match ziehen zum Zuweisen</div>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var board in boards)
                                    {
                                        <div class="badge bg-dark p-2 user-select-none"
                                             draggable="true"
                                             @ondragstart="() => draggedBoardId = board.Id"
                                             style="cursor:grab; font-size:.85em">
                                            📋 @board.Name
                                            <span class="badge @BoardStatusBadge(board.Status) ms-1" style="font-size:.75em">@board.Status</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (matches.Any())
                        {
                            var rounds = matches.Select(m => m.Round).Distinct().OrderBy(r => r).ToList();
                            foreach (var round in rounds)
                            {
                                var roundLabel = GetRoundLabel(round, rounds.Count);
                                <div class="small fw-semibold text-muted mb-1 mt-2">@roundLabel</div>
                                <ul class="list-group mb-2">
                                    @foreach (var match in matches.Where(m => m.Round == round).OrderBy(m => m.MatchNumber))
                                    {
                                        var homeP = participants.FirstOrDefault(p => p.Id == match.HomeParticipantId);
                                        var awayP = participants.FirstOrDefault(p => p.Id == match.AwayParticipantId);
                                        var assignedBoard = boards.FirstOrDefault(b => b.Id == match.BoardId);
                                        var isTarget = dropTargetMatchId == match.Id;
                                        var isActive = match.WinnerParticipantId is null && match.FinishedUtc is null && match.BoardId is not null;
                                        <li class="list-group-item @(isTarget ? "border-primary border-2" : "") @(isActive ? "border-start border-success border-3" : "")"
                                            style="@(isTarget ? "background:rgba(13,110,253,.08)" : "")"
                                            @ondragover:preventDefault
                                            @ondragover="() => dropTargetMatchId = match.Id"
                                            @ondragleave="() => { if (dropTargetMatchId == match.Id) dropTargetMatchId = null; }"
                                            @ondrop="() => AssignBoardToMatchAsync(match.Id)">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span>
                                                    <span class="text-muted small me-1">M@(match.MatchNumber)</span>
                                                    <strong class="@(match.WinnerParticipantId == match.HomeParticipantId ? "text-success" : "")">@(homeP?.DisplayName ?? "?")</strong>
                                                    @if (match.FinishedUtc is not null)
                                                    {
                                                        <span class="text-muted mx-1">@match.HomeLegs : @match.AwayLegs</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted mx-1">vs</span>
                                                    }
                                                    <strong class="@(match.WinnerParticipantId == match.AwayParticipantId ? "text-success" : "")">@(awayP?.DisplayName ?? "?")</strong>
                                                </span>
                                                <div class="d-flex align-items-center gap-1">
                                                    @if (assignedBoard is not null)
                                                    {
                                                        <a href="https://play.autodarts.io/boards/@(assignedBoard.ExternalBoardId)/follow"
                                                           target="_blank" rel="noopener" class="badge text-bg-success text-decoration-none" title="Board-Follow öffnen">
                                                            📋 @assignedBoard.Name
                                                        </a>
                                                    }
                                                    else if (selectedTournament.Variant == "OnSite")
                                                    {
                                                        <span class="badge text-bg-light text-muted border" style="font-size:.75em">Board zuweisen</span>
                                                    }
                                                    @if (match.WinnerParticipantId.HasValue)
                                                    {
                                                        var winner = participants.FirstOrDefault(p => p.Id == match.WinnerParticipantId);
                                                        <span class="badge text-bg-warning">🏆 @(winner?.DisplayName ?? "?")</span>
                                                    }
                                                    @if (match.PlannedStartUtc is not null)
                                                    {
                                                        <span class="badge text-bg-light text-muted border" style="font-size:.75em"
                                                              title="Geplante Startzeit">⏰ @match.PlannedStartUtc.Value.LocalDateTime.ToString("HH:mm")</span>
                                                    }
                                                </div>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        }
                        else
                        {
                            <p class="text-muted">Noch keine Matches vorhanden. Wechseln Sie zum Tab „Auslosung", um den Turnierplan zu generieren.</p>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    // ─── Data State ───
    private List<TournamentDto> tournaments = new();
    private List<BoardDto> boards = new();
    private List<ParticipantDto> participants = new();
    private List<MatchDto> matches = new();
    private TournamentDto? selectedTournament;
    private string activeTab = "general";

    // ─── Create Wizard ───
    private bool isCreating;
    private int wizardStep = 1;
    private string wizardName = string.Empty;
    private string wizardOrganizer = "manager";
    private DateTime wizardStartDate = DateTime.Today;
    private DateTime? wizardEndDate;
    private string wizardMode = "Knockout";
    private string wizardVariant = "OnSite";
    private bool wizardTeamplay;
    private string? wizardError;

    // ─── Edit State ───
    private string editName = string.Empty;
    private string editOrganizer = string.Empty;
    private DateTime editStartDate;
    private DateTime editEndDate;
    private string editMode = "Knockout";
    private string editVariant = "OnSite";
    private bool editTeamplay;
    private string? editError;
    private string? editSuccess;

    // ─── Participant State ───
    private string participantName = string.Empty;
    private string participantAccount = string.Empty;
    private bool participantIsAutodarts = true;
    private bool participantIsManager;
    private string? participantError;
    private bool isWorking;

    // ─── Board Drag-Drop ───
    private Guid? draggedBoardId;
    private Guid? dropTargetMatchId;

    // ─── Confirmation Dialog ───
    private bool showConfirmation;
    private string confirmationMessage = string.Empty;
    private Func<Task>? confirmationAction;

    // ─── Computed ───
    private IEnumerable<TournamentDto> activeTournaments =>
        tournaments.Where(t => t.StartDate <= DateOnly.FromDateTime(DateTime.Today) && t.EndDate >= DateOnly.FromDateTime(DateTime.Today));
    private IEnumerable<TournamentDto> upcomingTournaments =>
        tournaments.Where(t => t.StartDate > DateOnly.FromDateTime(DateTime.Today));
    private IEnumerable<TournamentDto> pastTournaments =>
        tournaments.Where(t => t.EndDate < DateOnly.FromDateTime(DateTime.Today));

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadTournamentsAsync(), LoadBoardsAsync());
    }

    private async Task LoadTournamentsAsync()
        => tournaments = (await Api.GetTournamentsAsync()).ToList();

    private async Task LoadBoardsAsync()
        => boards = (await Api.GetBoardsAsync()).ToList();

    // ─── Wizard ───
    private void StartWizard()
    {
        isCreating = true;
        wizardStep = 1;
        wizardName = string.Empty;
        wizardOrganizer = "manager";
        wizardStartDate = DateTime.Today;
        wizardEndDate = null;
        wizardMode = "Knockout";
        wizardVariant = "OnSite";
        wizardTeamplay = false;
        wizardError = null;
    }

    private void CancelWizard() { isCreating = false; wizardError = null; }

    private void WizardNext()
    {
        if (string.IsNullOrWhiteSpace(wizardName)) { wizardError = "Turniername ist erforderlich."; return; }
        wizardError = null;
        wizardStep = 2;
    }

    private async Task FinishWizardAsync()
    {
        try
        {
            isWorking = true;
            wizardError = null;
            var start = DateOnly.FromDateTime(wizardStartDate);
            var end = wizardEndDate.HasValue ? DateOnly.FromDateTime(wizardEndDate.Value) : start;
            var created = await Api.CreateTournamentAsync(new CreateTournamentRequest(
                wizardName.Trim(), wizardOrganizer.Trim(), start, end, wizardTeamplay, wizardMode, wizardVariant));
            isCreating = false;
            await LoadTournamentsAsync();
            var t = tournaments.FirstOrDefault(x => x.Id == created.Id);
            if (t is not null) await SelectTournamentAsync(t);
        }
        catch (Exception ex) { wizardError = ex.Message; }
        finally { isWorking = false; }
    }

    // ─── Tournament Selection & Edit State ───
    private async Task SelectTournamentAsync(TournamentDto tournament)
    {
        selectedTournament = tournament;
        activeTab = "general";
        editError = null;
        editSuccess = null;
        participantError = null;
        PopulateEditFields(tournament);
        await Task.WhenAll(LoadParticipantsAsync(tournament.Id), LoadMatchesAsync(tournament.Id), LoadBoardsAsync());
    }

    private void PopulateEditFields(TournamentDto t)
    {
        editName = t.Name;
        editOrganizer = t.OrganizerAccount;
        editStartDate = t.StartDate.ToDateTime(TimeOnly.MinValue);
        editEndDate = t.EndDate.ToDateTime(TimeOnly.MinValue);
        editMode = t.Mode;
        editVariant = t.Variant;
        editTeamplay = t.TeamplayEnabled;
    }

    // ─── Save Tournament (with confirmation if plan affected) ───
    private async Task SaveTournamentAsync()
    {
        if (selectedTournament is null) return;
        editError = null;
        editSuccess = null;

        var t = selectedTournament;
        var planAffected = false;
        var reasons = new List<string>();

        var newStart = DateOnly.FromDateTime(editStartDate);
        var newEnd = DateOnly.FromDateTime(editEndDate);
        if (newStart != t.StartDate || newEnd != t.EndDate) { planAffected = true; reasons.Add("Datum"); }
        if (editMode != t.Mode) { planAffected = true; reasons.Add("Modus"); }
        if (editTeamplay != t.TeamplayEnabled) { planAffected = true; reasons.Add("Teamplay"); }

        if (planAffected && matches.Any())
        {
            confirmationMessage = $"Die Änderung von {string.Join(", ", reasons)} wirkt sich auf den bestehenden Turnierplan aus.";
            confirmationAction = ExecuteSaveTournamentAsync;
            showConfirmation = true;
            return;
        }

        await ExecuteSaveTournamentAsync();
    }

    private async Task ExecuteSaveTournamentAsync()
    {
        if (selectedTournament is null) return;
        try
        {
            isWorking = true;
            var start = DateOnly.FromDateTime(editStartDate);
            var end = DateOnly.FromDateTime(editEndDate);
            var updated = await Api.UpdateTournamentAsync(new UpdateTournamentRequest(
                selectedTournament.Id, editName.Trim(), editOrganizer.Trim(), start, end, editTeamplay, editMode, editVariant));
            await LoadTournamentsAsync();
            selectedTournament = tournaments.FirstOrDefault(x => x.Id == updated.Id) ?? updated;
            PopulateEditFields(selectedTournament);
            editSuccess = "Turnier gespeichert.";
        }
        catch (Exception ex) { editError = ex.Message; }
        finally { isWorking = false; }
    }

    // ─── Confirmation Dialog ───
    private async Task AcceptConfirmation()
    {
        showConfirmation = false;
        if (confirmationAction is not null) await confirmationAction();
        confirmationAction = null;
    }

    private void RejectConfirmation()
    {
        showConfirmation = false;
        confirmationAction = null;
        if (selectedTournament is not null) PopulateEditFields(selectedTournament);
    }

    // ─── Lock / Unlock ───
    private async Task ToggleLockAsync()
    {
        if (selectedTournament is null) return;
        try
        {
            isWorking = true;
            var updated = await Api.SetTournamentLockedAsync(selectedTournament.Id, !selectedTournament.IsLocked);
            await LoadTournamentsAsync();
            selectedTournament = tournaments.FirstOrDefault(x => x.Id == updated.Id) ?? updated;
            PopulateEditFields(selectedTournament);
        }
        finally { isWorking = false; }
    }

    // ─── Participants ───
    private async Task LoadParticipantsAsync(Guid tournamentId)
        => participants = (await Api.GetParticipantsAsync(tournamentId)).ToList();

    private async Task LoadMatchesAsync(Guid tournamentId)
        => matches = (await Api.GetMatchesAsync(tournamentId)).ToList();

    private async Task HandleParticipantKeyAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddParticipantAsync();
    }

    private async Task AddParticipantAsync()
    {
        if (selectedTournament is null || string.IsNullOrWhiteSpace(participantName)) return;

        var account = string.IsNullOrWhiteSpace(participantAccount)
            ? participantName.Trim().ToLowerInvariant().Replace(" ", ".")
            : participantAccount.Trim();

        try
        {
            isWorking = true;
            participantError = null;
            await Api.AddParticipantAsync(new AddParticipantRequest(
                selectedTournament.Id, participantName.Trim(), account,
                participantIsAutodarts, participantIsManager, participants.Count + 1));
            participantName = string.Empty;
            participantAccount = string.Empty;
            participantIsManager = false;
            await LoadParticipantsAsync(selectedTournament.Id);
            await LoadTournamentsAsync();
            selectedTournament = tournaments.FirstOrDefault(x => x.Id == selectedTournament.Id) ?? selectedTournament;
        }
        catch (InvalidOperationException ex) { participantError = ex.Message; }
        catch { participantError = "Ein unerwarteter Fehler ist aufgetreten."; }
        finally { isWorking = false; }
    }

    private async Task RemoveParticipantAsync(ParticipantDto p)
    {
        if (selectedTournament is null) return;

        if (matches.Any())
        {
            confirmationMessage = $"Durch das Entfernen von \"{p.DisplayName}\" wird der bestehende Turnierplan ungültig.";
            confirmationAction = async () =>
            {
                try
                {
                    isWorking = true;
                    await Api.RemoveParticipantAsync(selectedTournament.Id, p.Id);
                    await LoadParticipantsAsync(selectedTournament.Id);
                    await LoadTournamentsAsync();
                    selectedTournament = tournaments.FirstOrDefault(x => x.Id == selectedTournament.Id) ?? selectedTournament;
                }
                catch (Exception ex) { participantError = ex.Message; }
                finally { isWorking = false; }
            };
            showConfirmation = true;
            return;
        }

        try
        {
            isWorking = true;
            await Api.RemoveParticipantAsync(selectedTournament.Id, p.Id);
            await LoadParticipantsAsync(selectedTournament.Id);
            await LoadTournamentsAsync();
            selectedTournament = tournaments.FirstOrDefault(x => x.Id == selectedTournament.Id) ?? selectedTournament;
        }
        catch (Exception ex) { participantError = ex.Message; }
        finally { isWorking = false; }
    }

    // ─── Match Generation ───
    private async Task GenerateMatchesAsync()
    {
        if (selectedTournament is null) return;
        try
        {
            isWorking = true;
            matches = (await Api.GenerateMatchesAsync(selectedTournament.Id)).ToList();
            activeTab = "knockout";
        }
        finally { isWorking = false; }
    }

    private async Task RegenerateMatchesAsync()
    {
        confirmationMessage = "Der bestehende Turnierplan wird gelöscht und neu generiert.";
        confirmationAction = async () =>
        {
            if (selectedTournament is null) return;
            try
            {
                isWorking = true;
                matches = (await Api.GenerateMatchesAsync(selectedTournament.Id)).ToList();
                activeTab = "knockout";
            }
            finally { isWorking = false; }
        };
        showConfirmation = true;
    }

    // ─── Board Assignment ───
    private async Task AssignBoardToMatchAsync(Guid matchId)
    {
        if (draggedBoardId is null) return;
        var boardId = draggedBoardId.Value;
        draggedBoardId = null;
        dropTargetMatchId = null;
        await Api.AssignBoardToMatchAsync(matchId, boardId);
        if (selectedTournament is not null) await LoadMatchesAsync(selectedTournament.Id);
    }

    // ─── Helpers ───
    private bool HasPlayedMatches() => matches.Any(m => m.FinishedUtc is not null);

    private static string BoardStatusBadge(string status) => status switch
    {
        "Running" => "bg-success",
        "Starting" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private static string GetRoundLabel(int round, int totalRounds)
    {
        var remaining = totalRounds - round;
        return remaining switch
        {
            0 => "Finale",
            1 => "Halbfinale",
            2 => "Viertelfinale",
            3 => "Achtelfinale",
            _ => $"Runde {round}"
        };
    }
}
