@page "/settings"
@inject AppStateService AppState
@inject IUiHelpService UiHelp
@inject DartSuiteApiService Api
@inject NavigationManager Navigation
@using ddpc.DartSuite.Application.Contracts.Matches
@using System.Text.Json

<PageTitle>Einstellungen</PageTitle>

<h1 class="mb-3">Einstellungen <UiHelpIcon HelpKey="page.settings" /></h1>

<div class="btn-group mb-3" role="group">
        <button class="btn @(activeTab == "general" ? "btn-primary" : "btn-outline-primary")" @onclick='() => activeTab = "general"'
            title="@UiHelp.GetTooltip("settings.tab.general")">Allgemein</button>
        <button class="btn @(activeTab == "user" ? "btn-primary" : "btn-outline-primary")" @onclick='() => activeTab = "user"'
            title="@UiHelp.GetTooltip("settings.tab.user")">Benutzer</button>
</div>

@if (activeTab == "general")
{
    <details id="settings-general-fallback" class="card shadow-sm mb-3" open>
        <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
            <span class="fw-semibold">Realtime / Fallback-Polling</span>
            <span class="small text-muted">Benutzer-Einstellung</span>
        </summary>
        <div class="card-body">
            <p class="text-muted small mb-3">Diese Einstellungen gelten pro Benutzer und steuern das Polling als Fallback fuer Realtime.</p>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="border rounded p-3" id="settings-panel-fallback-tournaments">
                        <div class="fw-semibold mb-2">Turniere</div>
                        <label for="settingsTournamentFallback" class="form-label small mb-1">Fallback-Polling</label>
                        <select id="settingsTournamentFallback" class="form-select form-select-sm"
                                value="@tournamentsFallbackPollingSeconds"
                                @onchange="OnTournamentFallbackChanged"
                                disabled="@isSavingRealtimePreference">
                            <option value="2">2s</option>
                            <option value="3">3s</option>
                            <option value="5">5s (Standard)</option>
                            <option value="10">10s</option>
                            <option value="15">15s</option>
                            <option value="30">30s</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="border rounded p-3" id="settings-panel-fallback-matches">
                        <div class="fw-semibold mb-2">Matches</div>
                        <label for="settingsMatchesFallback" class="form-label small mb-1">Fallback-Polling</label>
                        <select id="settingsMatchesFallback" class="form-select form-select-sm"
                                value="@matchesFallbackPollingSeconds"
                                @onchange="OnMatchesFallbackChanged"
                                disabled="@isSavingRealtimePreference">
                            <option value="2">2s</option>
                            <option value="3">3s</option>
                            <option value="5">5s (Standard)</option>
                            <option value="10">10s</option>
                            <option value="15">15s</option>
                            <option value="30">30s</option>
                        </select>
                    </div>
                </div>
            </div>

            @if (isSavingRealtimePreference)
            {
                <div class="small text-muted mt-2">Speichere Polling-Einstellungen ...</div>
            }
            @if (realtimePreferenceError is not null)
            {
                <div class="alert alert-danger py-2 mt-2 mb-0">@realtimePreferenceError</div>
            }
        </div>
    </details>

    <details id="settings-general-matchcard" class="card shadow-sm" open>
        <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
            <span class="fw-semibold">MatchCard Konfiguration</span>
            <span class="small text-muted">Sektionen mit eindeutiger ID</span>
        </summary>
        <div class="card-body">
            <p class="text-muted small mb-3">Jede Sektion kann direkt ueber das Settings-Icon modal konfiguriert werden. Die Einstellungen werden persistent als Benutzereinstellung gespeichert.</p>

            @{
                var globalScopeKey = BuildMatchCardScopeKey(MatchCardScopeGlobalPage, MatchCardScopeSectionAll);
                var globalResolved = ResolveMatchCardSettingsForScope(globalScopeKey);
            }
            <details id="@BuildScopePanelId(globalScopeKey)" class="card mb-2" open>
                <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
                    <span>@GetScopeLabel(globalScopeKey)</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm"
                            title="Sektion modal bearbeiten"
                            @onclick:preventDefault
                            @onclick:stopPropagation
                            @onclick="() => OpenMatchCardEditor(globalScopeKey)">⚙</button>
                </summary>
                <div class="card-body py-2 small d-flex flex-wrap gap-2" id="@($"{BuildScopePanelId(globalScopeKey)}-body")">
                    <span class="badge text-bg-light border">Layout: @globalResolved.Layout</span>
                    <span class="badge text-bg-light border">Spielstand: @globalResolved.ScoreMode</span>
                    <span class="badge text-bg-light border">Spielernamen: @globalResolved.PlayerNameMode</span>
                    <span class="badge text-bg-light border">Groesse: @globalResolved.SizeLevel</span>
                    <span class="badge text-bg-light border">LiveScore: @(globalResolved.LiveScoreEnabled ? "An" : "Aus")</span>
                    <span class="badge text-bg-light border">Aktionen: @(globalResolved.ShowActionButtons ? "An" : "Aus")</span>
                    <span class="badge text-bg-light border">Spieler-Link: @(globalResolved.EnablePlayerLinks ? "An" : "Aus")</span>
                    <span class="badge text-bg-light border">Board-Link: @(globalResolved.EnableBoardLink ? "An" : "Aus")</span>
                </div>
            </details>

            @foreach (var overriddenKey in _userOverriddenScopeKeys
                .Where(k => !string.Equals(k, globalScopeKey, StringComparison.OrdinalIgnoreCase))
                .OrderBy(k => k))
            {
                var resolved = ResolveMatchCardSettingsForScope(overriddenKey);
                <details id="@BuildScopePanelId(overriddenKey)" class="card mb-2" open>
                    <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
                        <span>@GetScopeLabel(overriddenKey)</span>
                        <div class="d-flex gap-1" @onclick:stopPropagation @onclick:preventDefault>
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    title="Sektion modal bearbeiten"
                                    @onclick="() => OpenMatchCardEditor(overriddenKey)">⚙</button>
                            <button type="button" class="btn btn-outline-danger btn-sm"
                                    title="Überschreibung entfernen"
                                    @onclick="() => RemoveScopeOverrideAsync(overriddenKey)">×</button>
                        </div>
                    </summary>
                    <div class="card-body py-2 small d-flex flex-wrap gap-2" id="@($"{BuildScopePanelId(overriddenKey)}-body")">
                        <span class="badge text-bg-light border">Layout: @resolved.Layout</span>
                        <span class="badge text-bg-light border">Spielstand: @resolved.ScoreMode</span>
                        <span class="badge text-bg-light border">Spielernamen: @resolved.PlayerNameMode</span>
                        <span class="badge text-bg-light border">Groesse: @resolved.SizeLevel</span>
                        <span class="badge text-bg-light border">LiveScore: @(resolved.LiveScoreEnabled ? "An" : "Aus")</span>
                        <span class="badge text-bg-light border">Aktionen: @(resolved.ShowActionButtons ? "An" : "Aus")</span>
                        <span class="badge text-bg-light border">Spieler-Link: @(resolved.EnablePlayerLinks ? "An" : "Aus")</span>
                        <span class="badge text-bg-light border">Board-Link: @(resolved.EnableBoardLink ? "An" : "Aus")</span>
                    </div>
                </details>
            }

            <div class="mt-3 d-flex align-items-center gap-2">
                <button type="button" class="btn btn-outline-primary btn-sm" @onclick="OpenAddScopeModal">+ Sektion hinzufügen</button>
                <span class="small text-muted">Nicht konfigurierte Sektionen erben von der nächsthöheren Ebene.</span>
            </div>

            @if (isSavingMatchCardPreferences)
            {
                <div class="small text-muted mt-2">Speichere MatchCard-Einstellungen ...</div>
            }
            @if (matchCardPreferenceError is not null)
            {
                <div class="alert alert-danger py-2 mt-2 mb-0">@matchCardPreferenceError</div>
            }
        </div>
    </details>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Benutzer</h5>
            <p class="text-muted">Benachrichtigungs- und Anzeigeeinstellungen des eingeloggten Benutzers.</p>
            @if (AppState.AutodartsProfile is not null)
            {
                <div class="small text-muted">Aktiver Account: @AppState.AutodartsProfile.DisplayName</div>
            }
            else
            {
                <div class="alert alert-warning py-2">Kein aktiver Login erkannt.</div>
            }
        </div>
    </div>
}

@if (showSettingsModal)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="() => CloseSettingsModal()">
        <div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@settingsModalTitle</h5>
                    <button type="button" class="btn-close" @onclick="() => CloseSettingsModal()"></button>
                </div>
                <div class="modal-body">
                    @if (settingsModalKind == "matchcard")
                    {
                        <div id="settings-modal-matchcard">
                            <div class="small text-muted mb-2">Kontext: @GetScopeLabel(settingsModalScopeKey)</div>

                            @{
                                var isGlobalScope = string.Equals(settingsModalScopeKey, BuildMatchCardScopeKey(MatchCardScopeGlobalPage, MatchCardScopeSectionAll), StringComparison.OrdinalIgnoreCase);
                                var isExistingOverride = _userOverriddenScopeKeys.Contains(settingsModalScopeKey);
                            }
                            @if (!isGlobalScope && isExistingOverride)
                            {
                                <div class="form-check form-switch mb-3 border rounded p-2 d-flex align-items-start gap-2">
                                    <input class="form-check-input ms-0 me-1 float-none" type="checkbox" id="settingsModalUseDefaults"
                                           checked="@settingsModalUseDefaults"
                                         title="Ueberschreibung deaktivieren und geerbte Standardwerte verwenden"
                                           @onchange="args => settingsModalUseDefaults = ParseBoolChangeEvent(args)" />
                                     <label class="form-check-label fw-semibold" for="settingsModalUseDefaults" title="Setzt diese Sektion auf die vererbten Standardwerte zurueck">Standardwerte verwenden</label>
                                    @if (settingsModalUseDefaults)
                                    {
                                        <div class="small text-muted mt-1">Diese Sektion wird auf die vererbten Einstellungen zurückgesetzt.</div>
                                    }
                                </div>
                            }

                            <fieldset disabled="@settingsModalUseDefaults">
                            <div class="row g-2 small mb-3">
                                <div class="col-lg-3 col-md-4">
                                    <label class="form-label mb-1" title="Waehlt das Layout der MatchCard">Anzeige</label>
                                    <select class="form-select form-select-sm"
                                            value="@settingsModalMatchCard.Layout"
                                        title="Layouttyp fuer die MatchCard"
                                            @onchange="OnModalMatchCardLayoutChanged">
                                        <option value="Horizontal">Horizontal</option>
                                        <option value="Vertical">Vertikal</option>
                                        <option value="Card">Karte</option>
                                        <option value="List">Liste</option>
                                    </select>
                                </div>
                                <div class="col-lg-3 col-md-4">
                                    <label class="form-label mb-1" title="Waehlt die Darstellung des Spielstands">Spielstand</label>
                                    <select class="form-select form-select-sm"
                                            value="@settingsModalMatchCard.ScoreMode"
                                        title="Anzeigeoption fuer Live- und Endergebnis"
                                            @onchange="args => settingsModalMatchCard.ScoreMode = MatchCardViewSettings.NormalizeScoreMode(args.Value?.ToString())">
                                        <option value="FinalOnly">Nur Endresultat</option>
                                        <option value="CurrentNoPoints">Aktueller Spielstand</option>
                                        <option value="LiveScores">Live Scores</option>
                                    </select>
                                </div>
                                <div class="col-lg-3 col-md-4">
                                    <label class="form-label mb-1" title="Steuert, ob Namen mit Zusatzinfos angezeigt werden">Spielernamen</label>
                                    <select class="form-select form-select-sm"
                                            value="@settingsModalMatchCard.PlayerNameMode"
                                        title="Format fuer Spielernamen in der MatchCard"
                                            @onchange="args => settingsModalMatchCard.PlayerNameMode = MatchCardViewSettings.NormalizePlayerNameMode(args.Value?.ToString())">
                                        <option value="Name">Nur Name</option>
                                        <option value="NameAndPpr">Name und PPR</option>
                                    </select>
                                </div>
                                <div class="col-lg-3 col-md-4">
                                    <label class="form-label mb-1" title="Skaliert die gesamte MatchCard inklusive Schrift und Inhalt">Size Level</label>
                                    <select class="form-select form-select-sm"
                                            value="@settingsModalMatchCard.SizeLevel"
                                            title="Skalierungsstufe fuer die gesamte MatchCard"
                                            @onchange="args => settingsModalMatchCard.SizeLevel = MatchCardViewSettings.NormalizeSizeLevel(args.Value?.ToString())">
                                        <option value="50%">50%</option>
                                        <option value="75%">75%</option>
                                        <option value="100%">100%</option>
                                        <option value="150%">150%</option>
                                        <option value="200%">200%</option>
                                        <option value="300%">300%</option>
                                    </select>
                                </div>
                                <div class="col-lg-3 col-md-12 d-flex align-items-end">
                                    <div class="form-check" title="Startet das Detail-Expandpanel auf schmalen Ansichten eingeklappt"><input class="form-check-input" type="checkbox" id="settingsModalCollapse" checked="@settingsModalMatchCard.CollapseDetailsOnMobile" @onchange="args => settingsModalMatchCard.CollapseDetailsOnMobile = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalCollapse">Mobile eingeklappt</label></div>
                                </div>
                            </div>

                            <div class="border rounded p-2 mb-2">
                                <div class="fw-semibold small mb-2">Titelleiste</div>
                                <div class="d-flex flex-wrap gap-3 small">
                                    <div class="form-check" title="Zeigt die Matchnummer in der Titelleiste"><input class="form-check-input" type="checkbox" id="settingsModalHeaderMatchNumber" checked="@settingsModalMatchCard.ShowHeaderMatchNumber" @onchange="args => settingsModalMatchCard.ShowHeaderMatchNumber = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalHeaderMatchNumber">Matchnummer</label></div>
                                    <div class="form-check" title="Zeigt den Matchnamen in der Titelleiste"><input class="form-check-input" type="checkbox" id="settingsModalHeaderMatchName" checked="@settingsModalMatchCard.ShowHeaderMatchName" @onchange="args => settingsModalMatchCard.ShowHeaderMatchName = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalHeaderMatchName">Matchname</label></div>
                                    <div class="form-check" title="Zeigt die geplante Startzeit in der Titelleiste"><input class="form-check-input" type="checkbox" id="settingsModalHeaderStart" checked="@settingsModalMatchCard.ShowHeaderStartTime" @onchange="args => settingsModalMatchCard.ShowHeaderStartTime = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalHeaderStart">Startzeit</label></div>
                                    <div class="form-check" title="Markiert gesperrte Startzeiten in der Titelleiste"><input class="form-check-input" type="checkbox" id="settingsModalHeaderStartLock" checked="@settingsModalMatchCard.ShowHeaderStartTimeLock" @onchange="args => settingsModalMatchCard.ShowHeaderStartTimeLock = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalHeaderStartLock">Startzeit gesperrt</label></div>
                                    <div class="form-check" title="Zeigt den Boardnamen in der Titelleiste"><input class="form-check-input" type="checkbox" id="settingsModalHeaderBoard" checked="@settingsModalMatchCard.ShowHeaderBoardName" @onchange="args => settingsModalMatchCard.ShowHeaderBoardName = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalHeaderBoard">Boardname</label></div>
                                    <div class="form-check" title="Zeigt einen Hinweis, wenn das Board gesperrt ist"><input class="form-check-input" type="checkbox" id="settingsModalHeaderBoardLock" checked="@settingsModalMatchCard.ShowHeaderBoardLock" @onchange="args => settingsModalMatchCard.ShowHeaderBoardLock = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalHeaderBoardLock">Board gesperrt</label></div>
                                    <div class="form-check" title="Zeigt die Zeitdifferenz zur Planung"><input class="form-check-input" type="checkbox" id="settingsModalHeaderDelay" checked="@settingsModalMatchCard.ShowHeaderDelay" @onchange="args => settingsModalMatchCard.ShowHeaderDelay = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalHeaderDelay">Zeitdifferenz</label></div>
                                    <div class="form-check" title="Zeigt den aktuellen Matchstatus in der Titelleiste"><input class="form-check-input" type="checkbox" id="settingsModalHeaderStatus" checked="@settingsModalMatchCard.ShowHeaderMatchStatus" @onchange="args => settingsModalMatchCard.ShowHeaderMatchStatus = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalHeaderStatus">Matchstatus</label></div>
                                    <div class="form-check" title="Blendet ein Live-Badge in der Titelleiste ein"><input class="form-check-input" type="checkbox" id="settingsModalHeaderLive" checked="@settingsModalMatchCard.ShowHeaderLiveBadge" @onchange="args => settingsModalMatchCard.ShowHeaderLiveBadge = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalHeaderLive">Live-Badge</label></div>
                                    <div class="form-check" title="Zeigt ein Badge fuer laufende Spieldauer"><input class="form-check-input" type="checkbox" id="settingsModalRuntimeBadge" checked="@settingsModalMatchCard.ShowRuntimeBadge" @onchange="args => settingsModalMatchCard.ShowRuntimeBadge = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalRuntimeBadge">Spielzeit-Badge</label></div>
                                </div>
                            </div>

                            <div class="border rounded p-2 mb-2">
                                <div class="fw-semibold small mb-2">Body</div>
                                <div class="d-flex flex-wrap gap-3 small">
                                    <div class="form-check" title="Zeigt die Startzeit im Body-Bereich"><input class="form-check-input" type="checkbox" id="settingsModalBodyStart" checked="@settingsModalMatchCard.ShowBodyStartTime" @onchange="args => settingsModalMatchCard.ShowBodyStartTime = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalBodyStart">Startzeit</label></div>
                                    <div class="form-check" title="Markiert gesperrte Startzeiten im Body-Bereich"><input class="form-check-input" type="checkbox" id="settingsModalBodyStartLock" checked="@settingsModalMatchCard.ShowBodyStartTimeLock" @onchange="args => settingsModalMatchCard.ShowBodyStartTimeLock = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalBodyStartLock">Startzeit gesperrt</label></div>
                                    <div class="form-check" title="Zeigt die Zeitdifferenz im Body-Bereich"><input class="form-check-input" type="checkbox" id="settingsModalBodyDelay" checked="@settingsModalMatchCard.ShowBodyDelay" @onchange="args => settingsModalMatchCard.ShowBodyDelay = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalBodyDelay">Zeitdifferenz</label></div>
                                    <div class="form-check" title="Zeigt die Matchnummer im Body-Bereich"><input class="form-check-input" type="checkbox" id="settingsModalBodyMatchNumber" checked="@settingsModalMatchCard.ShowBodyMatchNumber" @onchange="args => settingsModalMatchCard.ShowBodyMatchNumber = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalBodyMatchNumber">Matchnummer</label></div>
                                    <div class="form-check" title="Zeigt den Matchnamen im Body-Bereich"><input class="form-check-input" type="checkbox" id="settingsModalBodyMatchName" checked="@settingsModalMatchCard.ShowBodyMatchName" @onchange="args => settingsModalMatchCard.ShowBodyMatchName = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalBodyMatchName">Matchname</label></div>
                                    <div class="form-check" title="Zeigt den Boardnamen im Body-Bereich"><input class="form-check-input" type="checkbox" id="settingsModalBodyBoard" checked="@settingsModalMatchCard.ShowBodyBoardName" @onchange="args => settingsModalMatchCard.ShowBodyBoardName = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalBodyBoard">Boardname</label></div>
                                    <div class="form-check" title="Zeigt den Board-Lock Status im Body-Bereich"><input class="form-check-input" type="checkbox" id="settingsModalBodyBoardLock" checked="@settingsModalMatchCard.ShowBodyBoardLock" @onchange="args => settingsModalMatchCard.ShowBodyBoardLock = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalBodyBoardLock">Board gesperrt</label></div>
                                    <div class="form-check" title="Zeigt den Matchstatus im Body-Bereich"><input class="form-check-input" type="checkbox" id="settingsModalBodyMatchStatus" checked="@settingsModalMatchCard.ShowBodyMatchStatus" @onchange="args => settingsModalMatchCard.ShowBodyMatchStatus = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalBodyMatchStatus">Matchstatus</label></div>
                                    <div class="form-check" title="Zeigt ein Live-Badge im Body-Bereich"><input class="form-check-input" type="checkbox" id="settingsModalBodyLiveBadge" checked="@settingsModalMatchCard.ShowBodyLiveBadge" @onchange="args => settingsModalMatchCard.ShowBodyLiveBadge = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalBodyLiveBadge">Live-Badge</label></div>
                                    <div class="form-check" title="Aktiviert LiveScore-Anzeige in der MatchCard"><input class="form-check-input" type="checkbox" id="settingsModalLive" checked="@settingsModalMatchCard.LiveScoreEnabled" @onchange="args => settingsModalMatchCard.LiveScoreEnabled = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalLive">LiveScore aktiv</label></div>
                                </div>
                            </div>

                            <div class="border rounded p-2 mb-2">
                                <div class="fw-semibold small mb-2">Buttons / Funktionen</div>
                                <div class="d-flex flex-wrap gap-3 small">
                                    <div class="form-check" title="Blendet die komplette Action-Leiste ein oder aus"><input class="form-check-input" type="checkbox" id="settingsModalActionBar" checked="@settingsModalMatchCard.ShowActionButtons" @onchange="args => settingsModalMatchCard.ShowActionButtons = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalActionBar">Action-Leiste</label></div>
                                    <div class="form-check" title="Zeigt den Sync-Button in der Action-Leiste"><input class="form-check-input" type="checkbox" id="settingsModalActionSync" checked="@settingsModalMatchCard.ShowSyncAction" @onchange="args => settingsModalMatchCard.ShowSyncAction = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalActionSync">Sync</label></div>
                                    <div class="form-check" title="Zeigt die Aktion Spiel folgen"><input class="form-check-input" type="checkbox" id="settingsModalActionFollow" checked="@settingsModalMatchCard.ShowFollowAction" @onchange="args => settingsModalMatchCard.ShowFollowAction = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalActionFollow">Spiel folgen</label></div>
                                    <div class="form-check" title="Zeigt die Aktion Match starten"><input class="form-check-input" type="checkbox" id="settingsModalActionStart" checked="@settingsModalMatchCard.ShowStartMatchAction" @onchange="args => settingsModalMatchCard.ShowStartMatchAction = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalActionStart">Match starten</label></div>
                                    <div class="form-check" title="Zeigt die Aktion Zuruecksetzen"><input class="form-check-input" type="checkbox" id="settingsModalActionReset" checked="@settingsModalMatchCard.ShowResetAction" @onchange="args => settingsModalMatchCard.ShowResetAction = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalActionReset">Zuruecksetzen</label></div>
                                    <div class="form-check" title="Zeigt die Aktion Listener starten"><input class="form-check-input" type="checkbox" id="settingsModalActionListener" checked="@settingsModalMatchCard.ShowListenerAction" @onchange="args => settingsModalMatchCard.ShowListenerAction = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalActionListener">Listener starten</label></div>
                                    <div class="form-check" title="Macht Spielernamen in der Karte klickbar"><input class="form-check-input" type="checkbox" id="settingsModalPlayerLinks" checked="@settingsModalMatchCard.EnablePlayerLinks" @onchange="args => settingsModalMatchCard.EnablePlayerLinks = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalPlayerLinks">Spieler-Links</label></div>
                                    <div class="form-check" title="Macht den Boardnamen in der Karte klickbar"><input class="form-check-input" type="checkbox" id="settingsModalBoardLink" checked="@settingsModalMatchCard.EnableBoardLink" @onchange="args => settingsModalMatchCard.EnableBoardLink = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalBoardLink">Board-Link</label></div>
                                    <div class="form-check" title="Blendet die gesamte Titelleiste aus"><input class="form-check-input" type="checkbox" id="settingsModalSuppressHeader" checked="@settingsModalMatchCard.SuppressHeader" @onchange="args => settingsModalMatchCard.SuppressHeader = ParseBoolChangeEvent(args)" /><label class="form-check-label" for="settingsModalSuppressHeader">Titelleiste ausblenden</label></div>
                                </div>
                                <div class="d-flex align-items-center gap-2 mt-2 small">
                                    <label class="form-label mb-0" title="Bestimmt, wo die Action-Buttons erscheinen">Buttons Position</label>
                                    <select class="form-select form-select-sm" style="width:auto" value="@settingsModalMatchCard.ActionButtonsLocation" title="Position der Action-Buttons in der MatchCard" @onchange="args => settingsModalMatchCard.ActionButtonsLocation = MatchCardViewSettings.NormalizeActionButtonsLocation(args.Value?.ToString())">
                                        <option value="Footer">Unten</option>
                                        <option value="Header">Oben (Titelleiste)</option>
                                    </select>
                                </div>
                            </div>

                            <div class="border rounded p-2">
                                <div class="fw-semibold small mb-2">Erweitert / Statistiken</div>
                                <div class="fw-semibold small mb-2">Details</div>
