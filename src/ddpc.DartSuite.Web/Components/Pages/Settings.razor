                                               MonitoringStatusCssClass="text-bg-success"
                                               ShowMatchStatus="@settingsModalMatchCard.ShowMatchStatus"
                                               ShowSchedulingStatus="@settingsModalMatchCard.ShowSchedulingStatus"
                                               ShowAverage="@settingsModalMatchCard.ShowAverage"
                                               ShowHighestPpr="@settingsModalMatchCard.ShowHighestPpr"
                                               ShowHighestCheckout="@settingsModalMatchCard.ShowHighestCheckout"
                                               ShowAverageDartsPerLeg="@settingsModalMatchCard.ShowAverageDartsPerLeg"
                                               ShowMinimalDartsPerLeg="@settingsModalMatchCard.ShowMinimalDartsPerLeg"
                                               ShowMatchPrediction="@settingsModalMatchCard.ShowMatchPrediction"
                                               HomeStatistic="@settingsModalDemoHomeStatistic"
                                               AwayStatistic="@settingsModalDemoAwayStatistic"
                                               ShowActionButtons="@settingsModalMatchCard.ShowActionButtons"
                                               ShowSyncAction="@settingsModalMatchCard.ShowSyncAction"
                                               ShowFollowAction="@settingsModalMatchCard.ShowFollowAction"
                                               ShowStartMatchAction="@settingsModalMatchCard.ShowStartMatchAction"
                                               ShowResetAction="@settingsModalMatchCard.ShowResetAction"
                                               ShowListenerAction="@settingsModalMatchCard.ShowListenerAction"
                                               EnablePlayerLinks="@settingsModalMatchCard.EnablePlayerLinks"
                                               EnableBoardLink="@settingsModalMatchCard.EnableBoardLink"
                                               CanSync="true"
                                               CanFollow="true"
                                               CanStartMatch="true"
                                               CanResetMatch="true"
                                               CanStartListener="true"
                                               OnSync="@EventCallback.Factory.Create(this, OnSettingsPreviewSyncAsync)"
                                               OnFollow="@EventCallback.Factory.Create(this, OnSettingsPreviewFollowAsync)"
                                               OnStartMatch="@EventCallback.Factory.Create(this, OnSettingsPreviewStartAsync)"
                                               OnResetMatch="@EventCallback.Factory.Create(this, OnSettingsPreviewResetAsync)"
                                               OnStartListener="@EventCallback.Factory.Create(this, OnSettingsPreviewListenerAsync)"
                                               EnableDetailPanel="true"
                                               DetailsExpandedByDefault="false" />
                                </div>
                            </div>
                        </div>
                    }
                    else if (settingsModalKind == "matchcard-add")
                    {
                        <div id="settings-modal-matchcard-add">
                            <div class="mb-3">
                                <label for="settingsModalAddScope" class="form-label fw-semibold">Sektion wählen</label>
                                <select id="settingsModalAddScope" class="form-select"
                                        value="@settingsModalScopeKey"
                                        @onchange="args => settingsModalScopeKey = args.Value?.ToString() ?? string.Empty">
                                    <option value="">-- Sektion wählen --</option>
                                    @foreach (var opt in GetAddableScopeOptions())
                                    {
                                        <option value="@opt.ScopeKey">@opt.Label</option>
                                    }
                                </select>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(settingsModalScopeKey))
                            {
                                <div class="small text-muted">Die Konfiguration startet mit den aktuell geerbten Einstellungen dieser Sektion.</div>
                            }
                            else
                            {
                                <div class="alert alert-info py-2 mb-0 small">Bitte eine Sektion auswählen.</div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => CloseSettingsModal()">Schliessen</button>
                    @if (settingsModalKind == "matchcard")
                    {
                        <button class="btn btn-primary" @onclick="SaveMatchCardFromModalAsync" disabled="@isSavingMatchCardPreferences">Speichern</button>
                    }
                    else if (settingsModalKind == "matchcard-add")
                    {
                        <button class="btn btn-primary" @onclick="CreateAndEditScope" disabled="@string.IsNullOrWhiteSpace(settingsModalScopeKey)">Weiter ›</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "tab")]
    public string? QueryTab { get; set; }

    [SupplyParameterFromQuery(Name = "edit")]
    public string? QueryEdit { get; set; }

    [SupplyParameterFromQuery(Name = "scope")]
    public string? QueryScope { get; set; }

    private string activeTab = "general";
    private bool hasLoadedGeneralPreferences;
    private string? lastHandledDeepLinkToken;
    private bool isAutodartsConnected;
    private string? autodartsDisplayName;

    private int tournamentsFallbackPollingSeconds = 5;
    private int matchesFallbackPollingSeconds = 5;
    private bool isSavingRealtimePreference;
    private string? realtimePreferenceError;

    private bool isSavingMatchCardPreferences;
    private string? matchCardPreferenceError;
    private readonly Dictionary<string, MatchCardViewSettings> matchCardSettingsByView = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _userOverriddenScopeKeys = new(StringComparer.OrdinalIgnoreCase);

    private bool showSettingsModal;
    private string settingsModalKind = string.Empty;
    private string settingsModalTitle = string.Empty;
    private string settingsModalScopeKey = BuildMatchCardScopeKey(MatchCardScopePageTournaments, MatchCardScopeSectionAll);
    private MatchCardViewSettings settingsModalMatchCard = MatchCardViewSettings.CreateDefault();
    private bool settingsModalUseDefaults;
    private MatchDto settingsModalDemoMatch = new(
        Guid.NewGuid(),
        Guid.NewGuid(),
        "Group",
        1,
        2,
        5,
        Guid.NewGuid(),
        Guid.NewGuid(),
        Guid.NewGuid(),
        2,
        1,
        0,
        0,
        null,
        DateTimeOffset.UtcNow.AddMinutes(15),
        false,
        false,
        DateTimeOffset.UtcNow.AddMinutes(-3),
        null,
        "Aktiv",
        null,
        DateTimeOffset.UtcNow.AddMinutes(45),
        DateTimeOffset.UtcNow.AddMinutes(48),
        3,
        "Delayed",
        null,
        null,
        null,
        "Max Mustermann",
        "Anna Schmidt",
        "Board 1");
    private readonly MatchPlayerStatisticDto settingsModalDemoHomeStatistic = new(
        Guid.NewGuid(), Guid.NewGuid(), Guid.NewGuid(), "Max Mustermann", 71.4, 81.2, 42, 2, 1, 0, 0,
        124, 42.5, 6, 14, 9, 4, 0, 1, 0, 18.2, 14, 27, 1, 41.3, 1234, 180);
    private readonly MatchPlayerStatisticDto settingsModalDemoAwayStatistic = new(
        Guid.NewGuid(), Guid.NewGuid(), Guid.NewGuid(), "Anna Schmidt", 66.8, 77.0, 45, 1, 2, 0, 0,
        96, 35.1, 4, 11, 7, 3, 0, 0, 0, 20.1, 15, 30, 0, 36.4, 1180, 140);
    private bool settingsModalDemoIsFollowing;
    private string settingsModalPreviewSize = "m";

    private const string TournamentRealtimePreferenceContext = "TournamentRealtime";
    private const string MatchesRealtimePreferenceContext = "MatchesRealtime";
    private const string MatchCardPreferenceContext = "MatchCardDisplay";
    private const string MatchCardLegacyViewKeyMatchesDetail = "matches-detail";
    private const string MatchCardScopeDelimiter = "::";
    private const string MatchCardScopeGlobalPage = "all";
    private const string MatchCardScopePageTournaments = "tournaments";
    private const string MatchCardScopePageMatches = "matches";
    private const string MatchCardScopeSectionAll = "all";
    private const string MatchCardSectionGeneral = "general";
    private const string MatchCardSectionGroups = "groups";
    private const string MatchCardSectionKnockout = "knockout";
    private const string MatchCardSectionSchedule = "schedule";
    private const string MatchCardSectionScheduleBoardsUpcoming = "schedule-boards-upcoming";
    private const string MatchCardSectionScheduleZeitplan = "schedule-zeitplan";
    private const string MatchCardSectionScheduleQueueLegacy = "schedule-queue";
    private const string MatchCardSectionScheduleTimelineLegacy = "schedule-timeline";
    private const string MatchCardSectionBoardDetail = "board-detail";
    private const string MatchCardSectionDetail = "detail";

    private sealed record RealtimeSettings(int FallbackPollingSeconds = 5);
    private sealed record MatchCardScopeOption(string ScopeKey, string Label);
    private sealed record PreviewSizeOption(string Key, string Label, string Width);

    private static readonly IReadOnlyList<PreviewSizeOption> SettingsPreviewSizeOptions =
    [
        new("xs", "XS", "300px"),
        new("s", "S", "500px"),
        new("m", "M", "800px"),
        new("l", "L", "1000px"),
        new("full", "Full", "100%")
    ];

    private static readonly IReadOnlyList<MatchCardScopeOption> MatchCardScopeOptions =
    [
        new(BuildMatchCardScopeKey(MatchCardScopeGlobalPage, MatchCardScopeSectionAll), "Global / Alle Seiten / Alle Sektionen"),
        new(BuildMatchCardScopeKey(MatchCardScopePageTournaments, MatchCardScopeSectionAll), "Turniere / Alle Sektionen"),
        new(BuildMatchCardScopeKey(MatchCardScopePageTournaments, MatchCardSectionGeneral), "Turniere / Allgemein"),
        new(BuildMatchCardScopeKey(MatchCardScopePageTournaments, MatchCardSectionGroups), "Turniere / Gruppenphase"),
        new(BuildMatchCardScopeKey(MatchCardScopePageTournaments, MatchCardSectionKnockout), "Turniere / K.O.-Phase"),
        new(BuildMatchCardScopeKey(MatchCardScopePageTournaments, MatchCardSectionSchedule), "Turniere / Spielplan (alle)"),
        new(BuildMatchCardScopeKey(MatchCardScopePageTournaments, MatchCardSectionScheduleBoardsUpcoming), "Turniere / Spielplan Boards & Anstehende Matches"),
        new(BuildMatchCardScopeKey(MatchCardScopePageTournaments, MatchCardSectionScheduleZeitplan), "Turniere / Spielplan Zeitplan"),
        new(BuildMatchCardScopeKey(MatchCardScopePageTournaments, MatchCardSectionBoardDetail), "Turniere / Board-Detail"),
        new(BuildMatchCardScopeKey(MatchCardScopePageMatches, MatchCardScopeSectionAll), "Matches / Alle Sektionen"),
        new(BuildMatchCardScopeKey(MatchCardScopePageMatches, MatchCardSectionDetail), "Matches / Detail"),
    ];

    protected override async Task OnInitializedAsync()
    {
        await TryLoadAutodartsSessionAsync();
        await LoadRealtimeSettingsAsync();
        await LoadMatchCardSettingsAsync();
        hasLoadedGeneralPreferences = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        activeTab = string.Equals(QueryTab, "user", StringComparison.OrdinalIgnoreCase) ? "user" : "general";

        if (!hasLoadedGeneralPreferences || !string.Equals(activeTab, "general", StringComparison.OrdinalIgnoreCase))
            return;

        var token = $"{QueryEdit}|{QueryScope}";
        if (string.Equals(token, lastHandledDeepLinkToken, StringComparison.Ordinal))
            return;

        lastHandledDeepLinkToken = token;

        if (string.Equals(QueryEdit, "matchcard", StringComparison.OrdinalIgnoreCase))
        {
            OpenMatchCardEditor(NormalizeMatchCardScopeKey(QueryScope ?? BuildMatchCardScopeKey(MatchCardScopePageTournaments, MatchCardScopeSectionAll)));
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task TryLoadAutodartsSessionAsync()
    {
        try
        {
            var status = await Api.GetAutodartsStatusAsync();
            isAutodartsConnected = status.IsConnected;
            autodartsDisplayName = status.Profile?.DisplayName;
        }
        catch
        {
            isAutodartsConnected = false;
            autodartsDisplayName = null;
        }
    }

    private async Task LoadRealtimeSettingsAsync()
    {
        tournamentsFallbackPollingSeconds = await LoadRealtimeSettingAsync(TournamentRealtimePreferenceContext, 5);
        matchesFallbackPollingSeconds = await LoadRealtimeSettingAsync(MatchesRealtimePreferenceContext, 5);
    }

    private async Task<int> LoadRealtimeSettingAsync(string context, int fallback)
    {
        if (string.IsNullOrWhiteSpace(autodartsDisplayName))
            return fallback;

        try
        {
            var preference = await Api.GetViewPreferenceAsync(autodartsDisplayName, context);
            if (preference is null || string.IsNullOrWhiteSpace(preference.SettingsJson))
                return fallback;

            var parsed = JsonSerializer.Deserialize<RealtimeSettings>(preference.SettingsJson);
            if (parsed is null)
                return fallback;

            return Math.Clamp(parsed.FallbackPollingSeconds, 2, 30);
        }
        catch
        {
            return fallback;
        }
    }

    private async Task OnTournamentFallbackChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var parsed))
            return;

        await SaveRealtimePreferenceAsync(TournamentRealtimePreferenceContext, parsed);
    }

    private async Task OnMatchesFallbackChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var parsed))
            return;

        await SaveRealtimePreferenceAsync(MatchesRealtimePreferenceContext, parsed);
    }

    private async Task SaveRealtimePreferenceAsync(string context, int seconds)
    {
        var normalizedSeconds = Math.Clamp(seconds, 2, 30);
        if (string.Equals(context, TournamentRealtimePreferenceContext, StringComparison.OrdinalIgnoreCase))
            tournamentsFallbackPollingSeconds = normalizedSeconds;
        else
            matchesFallbackPollingSeconds = normalizedSeconds;

        realtimePreferenceError = null;

        if (string.IsNullOrWhiteSpace(autodartsDisplayName))
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            isSavingRealtimePreference = true;
            var payload = JsonSerializer.Serialize(new RealtimeSettings(normalizedSeconds));
            await Api.SaveViewPreferenceAsync(autodartsDisplayName, context, payload);
        }
        catch (Exception ex)
        {
            realtimePreferenceError = $"Polling-Einstellung konnte nicht gespeichert werden: {ex.Message}";
        }
        finally
        {
            isSavingRealtimePreference = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadMatchCardSettingsAsync()
    {
        matchCardPreferenceError = null;
        matchCardSettingsByView.Clear();
        _userOverriddenScopeKeys.Clear();

        var globalScopeKey = BuildMatchCardScopeKey(MatchCardScopeGlobalPage, MatchCardScopeSectionAll);
        matchCardSettingsByView[globalScopeKey] = MatchCardViewSettings.CreateDefault(globalScopeKey);

        if (string.IsNullOrWhiteSpace(autodartsDisplayName))
            return;

        try
        {
            var preference = await Api.GetViewPreferenceAsync(autodartsDisplayName, MatchCardPreferenceContext);
            if (preference is null || string.IsNullOrWhiteSpace(preference.SettingsJson))
                return;

            var payload = JsonSerializer.Deserialize<MatchCardViewPreferencePayload>(preference.SettingsJson);
            if (payload?.Views is null)
                return;

            foreach (var (key, configured) in payload.Views)
            {
                if (string.IsNullOrWhiteSpace(key) || configured is null)
                    continue;

                var normalizedKey = string.Equals(key, MatchCardLegacyViewKeyMatchesDetail, StringComparison.OrdinalIgnoreCase)
                    ? BuildMatchCardScopeKey(MatchCardScopePageMatches, MatchCardSectionDetail)
                    : key.Contains(MatchCardScopeDelimiter, StringComparison.Ordinal)
                        ? NormalizeMatchCardScopeKey(key)
                        : BuildMatchCardScopeKey(MatchCardScopePageTournaments, NormalizeLegacyMatchCardViewKey(key));

                configured.Normalize();
                matchCardSettingsByView[normalizedKey] = configured;
                _userOverriddenScopeKeys.Add(normalizedKey);
            }
        }
        catch
        {
            // Fallback to defaults.
        }
    }

    private MatchCardViewSettings ResolveMatchCardSettingsForScope(string scopeKey)
    {
        var normalizedScopeKey = NormalizeMatchCardScopeKey(scopeKey);
        var candidates = new List<string> { normalizedScopeKey };

        if (TryParseMatchCardScopeKey(normalizedScopeKey, out var page, out var section))
        {
            if (section.StartsWith("schedule-", StringComparison.OrdinalIgnoreCase))
                candidates.Add(BuildMatchCardScopeKey(page, MatchCardSectionSchedule));

            if (!string.Equals(section, MatchCardScopeSectionAll, StringComparison.OrdinalIgnoreCase))
                candidates.Add(BuildMatchCardScopeKey(page, MatchCardScopeSectionAll));
        }

        candidates.Add(BuildMatchCardScopeKey(MatchCardScopeGlobalPage, MatchCardScopeSectionAll));

        foreach (var candidate in candidates)
        {
            if (matchCardSettingsByView.TryGetValue(candidate, out var found))
                return found;
        }

        return MatchCardViewSettings.CreateDefault(normalizedScopeKey);
    }

    private MatchCardViewSettings GetEditableMatchCardSettings(string scopeKey)
    {
        var normalizedScopeKey = NormalizeMatchCardScopeKey(scopeKey);
        if (!matchCardSettingsByView.TryGetValue(normalizedScopeKey, out var settings))
        {
            settings = ResolveMatchCardSettingsForScope(normalizedScopeKey).Clone();
            settings.Normalize();
            matchCardSettingsByView[normalizedScopeKey] = settings;
        }

        settings.Normalize();
        return settings;
    }

    private async Task PersistMatchCardSettingsAsync()
    {
        if (string.IsNullOrWhiteSpace(autodartsDisplayName))
            return;

        var payload = new MatchCardViewPreferencePayload
        {
            Views = matchCardSettingsByView
                .Where(entry => _userOverriddenScopeKeys.Contains(entry.Key))
                .ToDictionary(
                    entry => entry.Key,
                    entry => entry.Value.Clone(),
                    StringComparer.OrdinalIgnoreCase)
        };

        var json = JsonSerializer.Serialize(payload);
        await Api.SaveViewPreferenceAsync(autodartsDisplayName, MatchCardPreferenceContext, json);
    }

    private static string BuildMatchCardScopeKey(string page, string section)
    {
        var normalizedPage = string.IsNullOrWhiteSpace(page) ? MatchCardScopePageTournaments : page.Trim().ToLowerInvariant();
        var normalizedSection = NormalizeMatchCardSection(section);
        return $"{normalizedPage}{MatchCardScopeDelimiter}{normalizedSection}";
    }

    private static bool TryParseMatchCardScopeKey(string scopeKey, out string page, out string section)
    {
        page = MatchCardScopePageTournaments;
        section = MatchCardSectionGeneral;

        if (string.IsNullOrWhiteSpace(scopeKey))
            return false;

        var split = scopeKey.Split(MatchCardScopeDelimiter, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (split.Length != 2)
            return false;

        page = string.IsNullOrWhiteSpace(split[0]) ? MatchCardScopePageTournaments : split[0].Trim().ToLowerInvariant();
        section = NormalizeMatchCardSection(split[1]);
        return true;
    }

    private static string NormalizeMatchCardScopeKey(string scopeKey)
    {
        if (TryParseMatchCardScopeKey(scopeKey, out var page, out var section))
            return BuildMatchCardScopeKey(page, section);

        return BuildMatchCardScopeKey(MatchCardScopePageTournaments, NormalizeLegacyMatchCardViewKey(scopeKey));
    }

    private static string NormalizeLegacyMatchCardViewKey(string key)
    {
        var normalized = key.Trim().ToLowerInvariant();
        return normalized switch
        {
            MatchCardSectionGeneral => MatchCardSectionGeneral,
            MatchCardSectionGroups => MatchCardSectionGroups,
            MatchCardSectionKnockout => MatchCardSectionKnockout,
            MatchCardSectionSchedule => MatchCardSectionSchedule,
            MatchCardSectionBoardDetail => MatchCardSectionBoardDetail,
            MatchCardSectionDetail => MatchCardSectionDetail,
            _ => MatchCardSectionGeneral
        };
    }

    private static string NormalizeMatchCardSection(string? section)
    {
        var normalized = (section ?? string.Empty).Trim().ToLowerInvariant();
        return normalized switch
        {
            MatchCardScopeSectionAll => MatchCardScopeSectionAll,
            MatchCardSectionGeneral => MatchCardSectionGeneral,
            MatchCardSectionGroups => MatchCardSectionGroups,
            MatchCardSectionKnockout => MatchCardSectionKnockout,
            MatchCardSectionSchedule => MatchCardSectionSchedule,
            MatchCardSectionScheduleBoardsUpcoming => MatchCardSectionScheduleBoardsUpcoming,
            MatchCardSectionScheduleZeitplan => MatchCardSectionScheduleZeitplan,
            MatchCardSectionScheduleQueueLegacy => MatchCardSectionScheduleBoardsUpcoming,
            MatchCardSectionScheduleTimelineLegacy => MatchCardSectionScheduleZeitplan,
            MatchCardSectionBoardDetail => MatchCardSectionBoardDetail,
            MatchCardSectionDetail => MatchCardSectionDetail,
            _ => MatchCardSectionGeneral
        };
    }

    private static string BuildScopePanelId(string scopeKey)
    {
        var sanitized = NormalizeMatchCardScopeKey(scopeKey)
            .Replace(MatchCardScopeDelimiter, "-", StringComparison.Ordinal)
            .Replace(" ", "-", StringComparison.Ordinal);
        return $"settings-matchcard-section-{sanitized}";
    }

    private string GetScopeLabel(string scopeKey)
        => MatchCardScopeOptions.FirstOrDefault(x => x.ScopeKey == NormalizeMatchCardScopeKey(scopeKey))?.Label
           ?? NormalizeMatchCardScopeKey(scopeKey);

    private IEnumerable<MatchCardScopeOption> GetAddableScopeOptions()
    {
        var globalKey = BuildMatchCardScopeKey(MatchCardScopeGlobalPage, MatchCardScopeSectionAll);
        return MatchCardScopeOptions
            .Where(o => !string.Equals(o.ScopeKey, globalKey, StringComparison.OrdinalIgnoreCase)
                     && !_userOverriddenScopeKeys.Contains(o.ScopeKey));
    }

    private void CreateAndEditScope()
    {
        if (string.IsNullOrWhiteSpace(settingsModalScopeKey))
            return;

        var normalizedKey = NormalizeMatchCardScopeKey(settingsModalScopeKey);
        settingsModalScopeKey = normalizedKey;
        settingsModalMatchCard = ResolveMatchCardSettingsForScope(normalizedKey).Clone();
        settingsModalMatchCard.Normalize();
        settingsModalKind = "matchcard";
        settingsModalTitle = $"MatchCard bearbeiten ({GetScopeLabel(normalizedKey)})";
    }

    private void OpenAddScopeModal()
    {
        settingsModalKind = "matchcard-add";
        settingsModalTitle = "Sektion hinzufügen";
        settingsModalScopeKey = string.Empty;
        settingsModalMatchCard = MatchCardViewSettings.CreateDefault(BuildMatchCardScopeKey(MatchCardScopeGlobalPage, MatchCardScopeSectionAll));
        showSettingsModal = true;
    }

    private async Task RemoveScopeOverrideAsync(string scopeKey)
    {
        var normalizedKey = NormalizeMatchCardScopeKey(scopeKey);
        _userOverriddenScopeKeys.Remove(normalizedKey);
        matchCardSettingsByView.Remove(normalizedKey);

        matchCardPreferenceError = null;
        if (!string.IsNullOrWhiteSpace(autodartsDisplayName))
        {
            try
            {
                isSavingMatchCardPreferences = true;
                await PersistMatchCardSettingsAsync();
            }
            catch (Exception ex)
            {
                matchCardPreferenceError = $"MatchCard-Einstellungen konnten nicht gespeichert werden: {ex.Message}";
            }
            finally
            {
                isSavingMatchCardPreferences = false;
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private void OpenMatchCardEditor(string scopeKey)
    {
        settingsModalKind = "matchcard";
        settingsModalScopeKey = NormalizeMatchCardScopeKey(scopeKey);
        settingsModalMatchCard = GetEditableMatchCardSettings(settingsModalScopeKey).Clone();
        settingsModalMatchCard.Normalize();
        settingsModalUseDefaults = false;
        settingsModalTitle = $"MatchCard bearbeiten ({GetScopeLabel(settingsModalScopeKey)})";
        showSettingsModal = true;
    }

    private void CloseSettingsModal()
    {
        showSettingsModal = false;
        settingsModalDemoIsFollowing = false;
        settingsModalPreviewSize = "m";

        if (!string.IsNullOrWhiteSpace(QueryEdit))
            Navigation.NavigateTo("/settings?tab=general", replace: true);
    }

    private string GetSettingsPreviewWidth()
        => SettingsPreviewSizeOptions.FirstOrDefault(x => x.Key == settingsModalPreviewSize)?.Width ?? "100%";

    private async Task OnModalMatchCardLayoutChanged(ChangeEventArgs args)
    {
        settingsModalMatchCard.Layout = args.Value?.ToString() ?? "Mixed";
        settingsModalMatchCard.Normalize();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveMatchCardFromModalAsync()
    {
        if (settingsModalUseDefaults)
        {
            await RemoveScopeOverrideAsync(settingsModalScopeKey);
            CloseSettingsModal();
            return;
        }

        matchCardPreferenceError = null;
        settingsModalMatchCard.Normalize();
        matchCardSettingsByView[settingsModalScopeKey] = settingsModalMatchCard.Clone();
        _userOverriddenScopeKeys.Add(settingsModalScopeKey);

        if (string.IsNullOrWhiteSpace(autodartsDisplayName))
        {
            CloseSettingsModal();
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            isSavingMatchCardPreferences = true;
            await PersistMatchCardSettingsAsync();
            CloseSettingsModal();
        }
        catch (Exception ex)
        {
            matchCardPreferenceError = $"MatchCard-Einstellungen konnten nicht gespeichert werden: {ex.Message}";
        }
        finally
        {
            isSavingMatchCardPreferences = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static bool ParseBoolChangeEvent(ChangeEventArgs args)
        => args.Value switch
        {
            bool b => b,
            string s when bool.TryParse(s, out var parsed) => parsed,
            _ => false
        };

    private static int ParseIntChange(ChangeEventArgs args, int fallback, int min, int max)
    {
        if (!int.TryParse(args.Value?.ToString(), out var parsed))
            return fallback;

        return Math.Clamp(parsed, min, max);
    }

    private Task SetDemoStatePlanned()
    {
        settingsModalDemoMatch = settingsModalDemoMatch with
        {
            StartedUtc = null,
            FinishedUtc = null,
            Status = "Geplant"
        };
        return Task.CompletedTask;
    }

    private Task SetDemoStateRunning()
    {
        var now = DateTimeOffset.UtcNow;
        settingsModalDemoMatch = settingsModalDemoMatch with
        {
            StartedUtc = now.AddMinutes(-4),
            FinishedUtc = null,
            Status = "Aktiv"
        };
        return Task.CompletedTask;
    }

    private Task SetDemoStateFinished()
    {
        var now = DateTimeOffset.UtcNow;
        settingsModalDemoMatch = settingsModalDemoMatch with
        {
            StartedUtc = now.AddMinutes(-24),
            FinishedUtc = now,
            Status = "Beendet"
        };
        return Task.CompletedTask;
    }

    private Task OnSettingsPreviewSyncAsync()
    {
        var nextDelay = settingsModalDemoMatch.DelayMinutes > 0 ? 0 : 4;
        var nextScheduling = nextDelay > 0 ? "Delayed" : "OnTime";
        settingsModalDemoMatch = settingsModalDemoMatch with { DelayMinutes = nextDelay, SchedulingStatus = nextScheduling };
        return Task.CompletedTask;
    }

    private Task OnSettingsPreviewFollowAsync()
    {
        settingsModalDemoIsFollowing = !settingsModalDemoIsFollowing;
        return Task.CompletedTask;
    }

    private Task OnSettingsPreviewStartAsync()
    {
        var now = DateTimeOffset.UtcNow;
        settingsModalDemoMatch = settingsModalDemoMatch with
        {
            StartedUtc = now,
            FinishedUtc = null,
            Status = "Aktiv"
        };
        return Task.CompletedTask;
    }

    private Task OnSettingsPreviewResetAsync()
    {
        settingsModalDemoMatch = settingsModalDemoMatch with
        {
            HomeSets = 0,
            AwaySets = 0,
            HomeLegs = 0,
            AwayLegs = 0,
            StartedUtc = null,
            FinishedUtc = null,
            Status = "Geplant",
            DelayMinutes = 0,
            SchedulingStatus = "OnTime"
        };
        settingsModalDemoIsFollowing = false;
        return Task.CompletedTask;
    }

    private Task OnSettingsPreviewListenerAsync()
    {
        settingsModalDemoMatch = settingsModalDemoMatch with { IsBoardLocked = !settingsModalDemoMatch.IsBoardLocked };
        return Task.CompletedTask;
    }
}
