                            <div class="col-6 col-sm-3">
                                <div class="form-check mt-4">
                                    <input class="form-check-input" type="checkbox" id="editTimeLocked" @bind="editIsStartTimeLocked" />
                                    <label class="form-check-label small" for="editTimeLocked">Zeit gesperrt</label>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(editError))
                        {
                            <div class="alert alert-danger py-1 mt-2 small">@editError</div>
                        }

                        <div class="d-flex flex-wrap gap-2 justify-content-center mt-3">
                            <button class="btn btn-success btn-sm" @onclick="SaveMatchAsync" disabled="@isSaving">
                                @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Speichern
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEditing">Abbrechen</button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="ResetSingleMatchAsync">Zurücksetzen</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "matchId")]
    public string? QueryMatchId { get; set; }

    private List<MatchDto> matches = [];
    private List<ParticipantDto> participants = [];
    private List<TournamentRoundDto> roundSettings = [];
    private List<BoardDto> boards = [];
    private MatchDto? detailMatch;
    private Timer? _autoRefreshTimer;

    // Selection
    private HashSet<Guid> selectedMatchIds = [];

    // Filters
    private bool hideFinished;
    private bool hideTbd;
    private string statusFilter = "all";
    private string phaseFilter = "all";
    private string searchText = "";

    // Cleanup state
    private bool isCleanupRunning;
    private bool isCheckingExternal;
    private string? actionMessage;
    private bool actionIsError;

    // Edit state
