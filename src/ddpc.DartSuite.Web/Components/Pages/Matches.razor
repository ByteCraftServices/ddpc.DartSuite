@page "/matches"
@using ddpc.DartSuite.Application.Contracts.Boards
@using ddpc.DartSuite.Application.Contracts.Matches
@using ddpc.DartSuite.Application.Contracts.Tournaments
@using System.Text.Json
@using ddpc.DartSuite.Web.Components
@inject DartSuiteApiService Api
@inject AppStateService AppState
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IUiHelpService UiHelp
@implements IDisposable

<PageTitle>Matches</PageTitle>

<h1 class="mb-3">Matches <UiHelpIcon HelpKey="page.matches" /></h1>

@if (AppState.SelectedTournament is null)
{
    <div class="alert alert-info">Bitte wählen Sie ein Turnier in der Kopfzeile aus.</div>
}
else
{
    <div class="mb-3">
        <span class="badge @StatusBadgeClass(AppState.SelectedTournament.Status) me-2">@AppState.SelectedTournament.Status</span>
        <strong>@AppState.SelectedTournament.Name</strong>
    </div>

    @if (!CanManageSelectedTournament)
    {
        <div class="alert alert-info py-2">Read-only: Verwaltungsaktionen sind nur fuer Spielleiter verfuegbar.</div>
    }

    <details id="section-matches-fallback-polling" class="card shadow-sm mb-3" open>
        <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
            <span class="fw-semibold">Benutzer-Einstellung: Fallback-Polling</span>
            <a href="/settings?tab=general&edit=fallback&context=MatchesRealtime"
               class="btn btn-outline-secondary btn-sm"
               title="In zentralen Einstellungen bearbeiten"
               @onclick:stopPropagation>⚙</a>
        </summary>
        <div class="card-body py-3">
            <div class="d-flex flex-wrap align-items-center gap-2 small">
                <label for="matchesFallbackPollingSelect" class="fw-semibold mb-0">Fallback-Polling</label>
                <select id="matchesFallbackPollingSelect" class="form-select form-select-sm" style="width:auto"
                        value="@fallbackPollingIntervalSeconds" @onchange="OnFallbackPollingIntervalChanged" disabled="@isSavingRealtimePreference">
                    <option value="2">2s</option>
                    <option value="3">3s</option>
                    <option value="5">5s (Standard)</option>
                    <option value="10">10s</option>
                    <option value="15">15s</option>
                    <option value="30">30s</option>
                </select>
                @if (isSavingRealtimePreference)
                {
                    <span class="text-muted">Speichere ...</span>
                }
                else
                {
                    <span class="text-muted">Wird pro Benutzer gespeichert.</span>
                }
            </div>

            @if (realtimePreferenceError is not null)
            {
                <div class="alert alert-danger py-2 mt-2 mb-0">@realtimePreferenceError</div>
            }
        </div>
    </details>

    <details id="section-matches-matchcard-config" class="card shadow-sm mb-3" open>
        <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
            <span class="fw-semibold">MatchCard Konfiguration (Matches)</span>
            <a href="/settings?tab=general&edit=matchcard&scope=matches::detail"
               class="btn btn-outline-secondary btn-sm"
               title="In zentralen Einstellungen bearbeiten"
               @onclick:stopPropagation>⚙</a>
        </summary>
        <div class="card-body py-3">
            <div class="d-flex flex-wrap gap-2 mb-2">
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetGlobalDetailsExpansionAsync(true)">Alle Details auf</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetGlobalDetailsExpansionAsync(false)">Alle Details zu</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetGlobalDetailsExpansionAsync(null)">Lokal steuern</button>
            </div>

            <div class="row g-2 small">
                <div class="col-lg-2 col-md-3">
                    <label class="form-label mb-1">Layout</label>
                    <select class="form-select form-select-sm"
                            value="@DetailMatchCardSettings.Layout"
                            @onchange="UpdateDetailMatchCardLayoutAsync"
                            disabled="@isSavingMatchCardPreferences">
                        <option value="Horizontal">Horizontal</option>
                        <option value="Vertical">Vertical</option>
                        <option value="Card">Karte</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-3">
                    <label class="form-label mb-1">Spielstand</label>
                    <select class="form-select form-select-sm"
                            value="@DetailMatchCardSettings.ScoreMode"
                            @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ScoreMode = MatchCardViewSettings.NormalizeScoreMode(args.Value?.ToString()))"
                            disabled="@isSavingMatchCardPreferences">
                        <option value="FinalOnly">Nur Endresultat</option>
                        <option value="CurrentNoPoints">Aktuell (ohne Punkte)</option>
                        <option value="LiveScores">Live Scores</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-3">
                    <label class="form-label mb-1">Spielernamen</label>
                    <select class="form-select form-select-sm"
                            value="@DetailMatchCardSettings.PlayerNameMode"
                            @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.PlayerNameMode = MatchCardViewSettings.NormalizePlayerNameMode(args.Value?.ToString()))"
                            disabled="@isSavingMatchCardPreferences">
                        <option value="Name">Nur Name</option>
                        <option value="NameAndPpr">Name und PPR</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-3">
                    <label class="form-label mb-1">Buttons Position</label>
                    <select class="form-select form-select-sm"
                            value="@DetailMatchCardSettings.ActionButtonsLocation"
                            @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ActionButtonsLocation = MatchCardViewSettings.NormalizeActionButtonsLocation(args.Value?.ToString()))"
                            disabled="@isSavingMatchCardPreferences">
                        <option value="Footer">Unten</option>
                        <option value="Header">Oben (Titelleiste)</option>
                    </select>
                </div>
                <div class="col-lg-6 col-md-12 d-flex flex-wrap gap-3 align-items-end">
                    <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardLive" checked="@DetailMatchCardSettings.LiveScoreEnabled" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.LiveScoreEnabled = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardLive">LiveScore</label></div>
                    <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardCollapse" checked="@DetailMatchCardSettings.CollapseDetailsOnMobile" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.CollapseDetailsOnMobile = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardCollapse">Mobile eingeklappt</label></div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-3 small mt-2">
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardRuntimeBadge" checked="@DetailMatchCardSettings.ShowRuntimeBadge" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ShowRuntimeBadge = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardRuntimeBadge">Laufzeit-Badge</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardMonitoring" checked="@DetailMatchCardSettings.ShowMonitoringStatus" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ShowMonitoringStatus = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardMonitoring">Monitoring-Badge</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardActionBar" checked="@DetailMatchCardSettings.ShowActionButtons" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ShowActionButtons = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardActionBar">Action-Leiste</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardActionSync" checked="@DetailMatchCardSettings.ShowSyncAction" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ShowSyncAction = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardActionSync">Sync-Button</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardActionFollow" checked="@DetailMatchCardSettings.ShowFollowAction" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ShowFollowAction = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardActionFollow">Folgen-Button</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardPlayerLinks" checked="@DetailMatchCardSettings.EnablePlayerLinks" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.EnablePlayerLinks = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardPlayerLinks">Spieler-Links</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardBoardLink" checked="@DetailMatchCardSettings.EnableBoardLink" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.EnableBoardLink = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardBoardLink">Board-Link</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardSuppressHeader" checked="@DetailMatchCardSettings.SuppressHeader" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.SuppressHeader = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardSuppressHeader">Titelleiste ausblenden</label></div>
            </div>

            <div class="d-flex flex-wrap gap-3 small mt-2">
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardStatus" checked="@DetailMatchCardSettings.ShowMatchStatus" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ShowMatchStatus = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardStatus">MatchStatus</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardScheduling" checked="@DetailMatchCardSettings.ShowSchedulingStatus" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ShowSchedulingStatus = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardScheduling">SchedulingStatus</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardAverage" checked="@DetailMatchCardSettings.ShowAverage" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ShowAverage = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardAverage">Average</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardPpr" checked="@DetailMatchCardSettings.ShowHighestPpr" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ShowHighestPpr = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardPpr">Highest PPR</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardCheckout" checked="@DetailMatchCardSettings.ShowHighestCheckout" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ShowHighestCheckout = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardCheckout">Highest Checkout</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardAdpl" checked="@DetailMatchCardSettings.ShowAverageDartsPerLeg" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ShowAverageDartsPerLeg = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardAdpl">Average Darts/Leg</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="matchesCardMinDarts" checked="@DetailMatchCardSettings.ShowMinimalDartsPerLeg" @onchange="args => UpdateDetailMatchCardSettingsAsync(s => s.ShowMinimalDartsPerLeg = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="matchesCardMinDarts">Minimal Darts/Leg</label></div>
            </div>

            @if (isSavingMatchCardPreferences)
            {
                <div class="small text-muted mt-2">Speichere MatchCard-Einstellungen ...</div>
            }
            @if (matchCardPreferenceError is not null)
            {
                <div class="alert alert-danger py-1 px-2 small mt-2 mb-0">@matchCardPreferenceError</div>
            }
        </div>
    </details>

    @* ─── Filters ─── *@
    <div class="d-flex flex-wrap gap-2 align-items-center mb-3 small filter-bar">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="hideFinished" @bind="hideFinished" />
            <label class="form-check-label" for="hideFinished">Beendete ausblenden</label>
        </div>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="hideTbd" @bind="hideTbd" />
            <label class="form-check-label" for="hideTbd">TBD ausblenden</label>
        </div>
        <select class="form-select form-select-sm" style="width:auto" @bind="statusFilter"
            title="@UiHelp.GetTooltip("matches.filter.status")">
            <option value="all">Alle Status</option>
            <option value="running">Laufende Spiele</option>
            <option value="upcoming">Anstehende Spiele</option>
            <option value="inactive">Inaktive Spiele</option>
        </select>
        <select class="form-select form-select-sm" style="width:auto" @bind="phaseFilter"
            title="@UiHelp.GetTooltip("matches.filter.phase")">
            <option value="all">Alle Phasen</option>
            <option value="Group">Gruppenphase</option>
            <option value="Knockout">K.O.-Phase</option>
        </select>
         <input type="text" class="form-control form-control-sm" style="width:200px;min-width:120px"
               placeholder="Spieler suchen…"
             title="@UiHelp.GetTooltip("matches.search")"
               @bind="searchText" @bind:event="oninput" />
    </div>

    @* ─── Actions toolbar ─── *@
    <div class="d-flex flex-wrap gap-2 mb-3">
        @if (CanManageSelectedTournament)
        {
            <button class="btn btn-outline-secondary btn-sm" @onclick="SelectAll"
                    disabled="@(!FilteredMatches.Any())">Alle auswählen</button>
            <button class="btn btn-outline-warning btn-sm" @onclick="SelectInactive"
                    disabled="@(!matches.Any(m => m.Status == "Inaktiv"))">Inaktive auswählen</button>
            <button class="btn btn-outline-danger btn-sm" @onclick="DeselectAll"
                    disabled="@(!selectedMatchIds.Any())">Auswahl aufheben</button>
            @if (selectedMatchIds.Any())
            {
                <button class="btn btn-danger btn-sm" @onclick="BulkResetAsync" title="@UiHelp.GetTooltip("matches.bulk.reset")">
                    Auswahl zurücksetzen (@selectedMatchIds.Count)
                </button>
            }
            <div class="ms-auto d-flex flex-wrap gap-2">
                <button class="btn btn-outline-info btn-sm" @onclick="RunCleanupAsync" disabled="@isCleanupRunning">
                    @if (isCleanupRunning) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Auto-Cleanup
                </button>
                <button class="btn btn-outline-info btn-sm" @onclick="CheckExternalAsync" disabled="@isCheckingExternal">
                    @if (isCheckingExternal) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    ExternalIDs prüfen
                </button>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(actionMessage))
    {
        <div class="alert @(actionIsError ? "alert-danger" : "alert-success") py-2 d-flex justify-content-between align-items-center">
            <span>@actionMessage</span>
            <button type="button" class="btn-close" @onclick="() => actionMessage = null"></button>
        </div>
    }

    @if (FilteredMatches.Any())
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle">
                <thead>
                    <tr>
                        <th style="width:2rem">
                            <input type="checkbox" class="form-check-input"
                                   checked="@IsAllFilteredSelected()" @onchange="ToggleSelectAllFiltered" />
                        </th>
                        <th style="width:5rem" class="d-none d-md-table-cell">Uhrzeit</th>
                        <th style="width:3.5rem">Match</th>
                        <th>Heim</th>
                        <th style="width:3rem" class="text-center">Erg.</th>
                        <th>Gast</th>
                        <th class="d-none d-md-table-cell">Board</th>
                        <th style="width:5rem">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var match in FilteredMatches)
                    {
                        var assignedBoard = boards.FirstOrDefault(b => b.Id == match.BoardId);
                        var isDone = match.FinishedUtc is not null;
                        var isRunning = match.StartedUtc is not null && match.FinishedUtc is null;
                        var isInactive = match.Status == "Inaktiv";
                        var isSelected = selectedMatchIds.Contains(match.Id);
                        <tr class="@(isDone ? "table-light text-muted" : "") @(isRunning ? "table-info" : "") @(isInactive ? "table-warning" : "") @(isSelected ? "table-active" : "")">
                            <td @onclick:stopPropagation>
                                <input type="checkbox" class="form-check-input"
                                       checked="@isSelected" @onchange="() => ToggleSelect(match.Id)" />
                            </td>
                            <td class="small d-none d-md-table-cell" @onclick="() => OpenMatchDetail(match)" style="cursor:pointer">
                                @if (match.PlannedStartUtc is not null)
                                {
                                    @match.PlannedStartUtc.Value.LocalDateTime.ToString("HH:mm")
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td @onclick="() => OpenMatchDetail(match)" style="cursor:pointer">
                                <span class="badge text-bg-secondary">@MatchLabel(match)</span>
                            </td>
                            <td class="@(match.WinnerParticipantId == match.HomeParticipantId ? "fw-bold text-success" : "")"
                                @onclick="() => OpenMatchDetail(match)" style="cursor:pointer">
                                @ParticipantName(match.HomeParticipantId)
                            </td>
                            <td class="text-center small" @onclick="() => OpenMatchDetail(match)" style="cursor:pointer">
                                @if (isDone || isRunning)
                                {
                                    <span>@FormatScore(match)</span>
                                }
                                else
                                {
                                    <span class="text-muted">vs</span>
                                }
                            </td>
                            <td class="@(match.WinnerParticipantId == match.AwayParticipantId ? "fw-bold text-success" : "")"
                                @onclick="() => OpenMatchDetail(match)" style="cursor:pointer">
                                @ParticipantName(match.AwayParticipantId)
                            </td>
                            <td class="d-none d-md-table-cell" @onclick="() => OpenMatchDetail(match)" style="cursor:pointer">
                                @if (assignedBoard is not null)
                                {
                                    <span class="badge text-bg-success">@assignedBoard.Name</span>
                                }
                                else if (!isDone)
                                {
                                    <span class="badge text-bg-warning">⚠ kein Board</span>
                                }
                            </td>
                            <td @onclick="() => OpenMatchDetail(match)" style="cursor:pointer">
                                @MatchStatusBadgeHtml(match)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="text-muted small mt-2">
            @FilteredMatches.Count von @matches.Count Matches angezeigt
            @if (selectedMatchIds.Any())
            {
                <span>— @selectedMatchIds.Count ausgewählt</span>
            }
        </div>
    }
    else if (matches.Any())
    {
        <p class="text-muted">Keine Matches entsprechen den aktuellen Filtern.</p>
    }
    else
    {
        <p class="text-muted">Noch keine Matches vorhanden. Erstellen Sie zuerst den Spielplan im Turnier.</p>
    }
}

@* ─── Match Detail / Edit Modal ─── *@
@if (detailMatch is not null)
{
    var homeP = participants.FirstOrDefault(p => p.Id == detailMatch.HomeParticipantId);
    var awayP = participants.FirstOrDefault(p => p.Id == detailMatch.AwayParticipantId);
    var round = roundSettings.FirstOrDefault(r => r.Phase == detailMatch.Phase && r.RoundNumber == detailMatch.Round);
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="CloseModal">
        <div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title d-flex align-items-center gap-2">
                        <span>Match Details — @MatchLabel(detailMatch)</span>
                        <a href="/settings?tab=general&edit=matchcard&scope=matches::detail"
                           class="btn btn-outline-secondary btn-sm"
                           title="MatchCard-Detaileinstellungen bearbeiten"
                           @onclick:stopPropagation>⚙</a>
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <MatchCard Match="@detailMatch"
                               ViewSettings="@DetailMatchCardSettings"
                               Layout="@DetailMatchCardSettings.Layout"
                               Label="@MatchLabel(detailMatch)"
                               HomeName="@(homeP?.DisplayName ?? "TBD")"
                               AwayName="@(awayP?.DisplayName ?? "TBD")"
                               BoardName="@(boards.FirstOrDefault(b => b.Id == detailMatch.BoardId)?.Name)"
                               ShowRuntimeBadge="@DetailMatchCardSettings.ShowRuntimeBadge"
                               ShowMonitoringStatus="@MatchCardUiPolicy.ShowMonitoring(DetailMatchCardSettings, CanManageSelectedTournament)"
                               MonitoringStatusText="@GetMonitoringBadgeText(detailMatch)"
                               MonitoringStatusCssClass="@GetMonitoringBadgeCss(detailMatch)"
                               ShowActionButtons="@MatchCardUiPolicy.ShowActionBar(DetailMatchCardSettings)"
                               ShowSyncAction="@ShowMatchCardSyncAction(detailMatch)"
                               ShowFollowAction="@ShowMatchCardFollowAction()"
                               IsFollowing="@isFollowingDetailMatch"
                               CanSync="@CanSyncFromMatchCard(detailMatch)"
                               CanFollow="@CanFollowFromMatchCard(detailMatch)"
                               OnSync="SyncMatchFromExternalAsync"
                               OnFollow="ToggleFollowMatchAsync"
                               EnablePlayerLinks="@DetailMatchCardSettings.EnablePlayerLinks"
                               EnableBoardLink="@DetailMatchCardSettings.EnableBoardLink"
                               OnHomePlayerClick="BuildDetailPlayerNavigationCallback(detailMatch.HomeParticipantId)"
                               OnAwayPlayerClick="BuildDetailPlayerNavigationCallback(detailMatch.AwayParticipantId)"
                               OnBoardClick="BuildDetailBoardNavigationCallback()"
                               SlotOrigin="@BuildSlotOrigin(detailMatch)"
                               SetModeActive="@(round?.GameMode == "Sets")"
                               LiveScoreEnabled="@DetailMatchCardSettings.LiveScoreEnabled"
                               ShowMatchStatus="@DetailMatchCardSettings.ShowMatchStatus"
                               ShowSchedulingStatus="@DetailMatchCardSettings.ShowSchedulingStatus"
                               ShowAverage="@DetailMatchCardSettings.ShowAverage"
                               ShowHighestPpr="@DetailMatchCardSettings.ShowHighestPpr"
                               ShowHighestCheckout="@DetailMatchCardSettings.ShowHighestCheckout"
                               ShowAverageDartsPerLeg="@DetailMatchCardSettings.ShowAverageDartsPerLeg"
                               ShowMinimalDartsPerLeg="@DetailMatchCardSettings.ShowMinimalDartsPerLeg"
                               HomeStatistic="@DetailHomeStatistic"
                               AwayStatistic="@DetailAwayStatistic"
                               EnableDetailPanel="true"
                               DetailsExpandedByDefault="@(!DetailMatchCardSettings.CollapseDetailsOnMobile || !isCompactViewport)"
                               ForceDetailsExpanded="@forcedMatchDetailsExpanded"
                               EnableRealtimeConsumer="@(detailMatch.StartedUtc is not null && detailMatch.FinishedUtc is null)" />

                    @if (!isEditing)
                    {
                        @* ─── Read-only view ─── *@
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Status</dt>
                            <dd class="col-sm-8">
                                @if (CanManageSelectedTournament)
                                {
                                    <SplitButton PrimaryText="@MatchStatusText(detailMatch)"
                                                 ButtonStyle="@MatchStatusBadgeCss(detailMatch).Replace("bg-", "")"
                                                 Size="sm"
                                                 Disabled="@isSaving"
                                                 Items="@BuildMatchStatusItems(detailMatch)" />
                                }
                                else
                                {
                                    <span class="badge @MatchStatusBadgeCss(detailMatch)">@MatchStatusText(detailMatch)</span>
                                }
                            </dd>
                            <dt class="col-sm-4">Ergebnis</dt>
                            <dd class="col-sm-8">@FormatScore(detailMatch)</dd>
                            <dt class="col-sm-4">Phase</dt>
                            <dd class="col-sm-8">@(detailMatch.Phase == "Group" ? "Gruppenphase" : "K.O.-Phase") — Runde @detailMatch.Round</dd>
                            @if (round is not null)
                            {
                                <dt class="col-sm-4">Spielmodus</dt>
                                <dd class="col-sm-8">@round.BaseScore @round.OutMode | @(round.GameMode == "Sets" ? $"{round.Sets} Sets / {round.Legs} Legs" : $"{round.Legs} Legs")</dd>
                            }
                            <dt class="col-sm-4">Board</dt>
                            <dd class="col-sm-8">
                                @{ var board = boards.FirstOrDefault(b => b.Id == detailMatch.BoardId); }
                                @if (CanManageSelectedTournament)
                                {
                                    <SplitButton PrimaryText="@(board?.Name ?? "Nicht zugewiesen")"
                                                 ButtonStyle="outline-primary"
                                                 Size="sm"
                                                 Disabled="@isSaving"
                                                 Items="@BuildBoardSelectionItems(detailMatch)" />
                                    <div class="small text-muted mt-1">Empfohlene Alternative steht oben.</div>
                                }
                                else if (board is not null)
                                {
                                    <span>@board.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted">Nicht zugewiesen</span>
                                }
                            </dd>
                            <dt class="col-sm-4">Board gesperrt</dt>
                            <dd class="col-sm-8">@(detailMatch.IsBoardLocked ? "Ja" : "Nein")</dd>
                            <dt class="col-sm-4">Zeit gesperrt</dt>
                            <dd class="col-sm-8">@(detailMatch.IsStartTimeLocked ? "Ja" : "Nein")</dd>
                            @if (detailMatch.WinnerParticipantId.HasValue)
                            {
                                <dt class="col-sm-4">Gewinner</dt>
                                <dd class="col-sm-8 fw-bold text-success">@ParticipantName(detailMatch.WinnerParticipantId.Value)</dd>
                            }
                            @if (detailMatch.PlannedStartUtc.HasValue)
                            {
                                <dt class="col-sm-4">Geplant</dt>
                                <dd class="col-sm-8">@detailMatch.PlannedStartUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
                            }
                            @if (detailMatch.StartedUtc.HasValue)
                            {
                                <dt class="col-sm-4">Gestartet</dt>
                                <dd class="col-sm-8">@detailMatch.StartedUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
                            }
                            @if (detailMatch.FinishedUtc.HasValue)
                            {
                                <dt class="col-sm-4">Beendet</dt>
                                <dd class="col-sm-8">@detailMatch.FinishedUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
                            }
                            @if (round is not null && round.LegDurationSeconds > 0)
                            {
                                var plannedMinutes = (round.Sets ?? 1) * round.Legs * round.LegDurationSeconds / 60;
                                <dt class="col-sm-4">Spielzeit/Leg</dt>
                                <dd class="col-sm-8">@round.LegDurationSeconds s (min. @plannedMinutes min Spieldauer)</dd>
                            }
                            @if (detailMatch.StartedUtc.HasValue)
                            {
                                var elapsed = (detailMatch.FinishedUtc ?? DateTimeOffset.UtcNow) - detailMatch.StartedUtc.Value;
                                <dt class="col-sm-4">@(detailMatch.FinishedUtc.HasValue ? "Spieldauer" : "Spielzeit")</dt>
                                <dd class="col-sm-8">
                                    @($"{(int)elapsed.TotalMinutes} min")
                                    @if (detailMatch.FinishedUtc is null && round is not null && round.LegDurationSeconds > 0)
                                    {
                                        var plannedMins = (round.Sets ?? 1) * round.Legs * round.LegDurationSeconds / 60;
                                        var remaining = plannedMins - (int)elapsed.TotalMinutes;
                                        @if (remaining > 0)
                                        {
                                            <span class="text-muted ms-2">(~@remaining min verbleibend)</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger ms-2">(+@(Math.Abs(remaining)) min über geplanter Dauer)</span>
                                        }
                                    }
                                </dd>
                            }
                        </dl>
                        <div class="d-flex flex-wrap gap-2 justify-content-center mt-3">
                            @if (CanManageSelectedTournament)
                            {
                                <button class="btn btn-primary btn-sm" @onclick="StartEditing">Bearbeiten</button>
                            }
                            <button class="btn btn-outline-primary btn-sm" @onclick="GoToTournamentMatch">Im Turnier öffnen →</button>
                            @if (CanManageSelectedTournament && CanSetWalkover(detailMatch))
                            {
                                <button class="btn btn-outline-dark btn-sm" @onclick="OpenWalkoverDialog" disabled="@isSaving">Walkover setzen</button>
                            }
                        </div>

                        @if (CanManageSelectedTournament && showWalkoverConfirm)
                        {
                            <div class="alert alert-warning py-2 mt-3">
                                <div class="fw-semibold mb-2">Walkover bestaetigen</div>
                                <div class="small mb-2">Waehlen Sie den Teilnehmer, der als Gewinner fortgeschrieben wird.</div>
                                <select class="form-select form-select-sm mb-2" @bind="walkoverWinnerId" disabled="@isSaving">
                                    <option value="">-- Gewinner waehlen --</option>
                                    @if (detailMatch.HomeParticipantId != Guid.Empty)
                                    {
                                        <option value="@detailMatch.HomeParticipantId">@(homeP?.DisplayName ?? "Home")</option>
                                    }
                                    @if (detailMatch.AwayParticipantId != Guid.Empty)
                                    {
                                        <option value="@detailMatch.AwayParticipantId">@(awayP?.DisplayName ?? "Away")</option>
                                    }
                                </select>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-dark btn-sm" @onclick="ApplyWalkoverAsync" disabled="@isSaving">Walkover uebernehmen</button>
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelWalkoverDialog" disabled="@isSaving">Abbrechen</button>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        @* ─── Edit view ─── *@
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label class="form-label small">Status</label>
                                <select class="form-select form-select-sm" @bind="editStatus">
                                    <option value="Erstellt">Erstellt</option>
                                    <option value="Geplant">Geplant</option>
                                    <option value="Aktiv">Aktiv</option>
                                    <option value="Beendet">Beendet</option>
                                    <option value="Inaktiv">Inaktiv</option>
                                    <option value="WalkOver">WalkOver</option>
                                </select>
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label small">Board</label>
                                <select class="form-select form-select-sm" @bind="editBoardId">
                                    <option value="">— kein Board —</option>
                                    @foreach (var b in boards)
                                    {
                                        <option value="@b.Id">@b.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-6 col-sm-3">
                                <label class="form-label small">Home Legs</label>
                                <input type="number" class="form-control form-control-sm" min="0" @bind="editHomeLegs" />
                            </div>
                            <div class="col-6 col-sm-3">
                                <label class="form-label small">Away Legs</label>
                                <input type="number" class="form-control form-control-sm" min="0" @bind="editAwayLegs" />
                            </div>
                            <div class="col-6 col-sm-3">
                                <label class="form-label small">Home Sets</label>
                                <input type="number" class="form-control form-control-sm" min="0" @bind="editHomeSets" />
                            </div>
                            <div class="col-6 col-sm-3">
                                <label class="form-label small">Away Sets</label>
                                <input type="number" class="form-control form-control-sm" min="0" @bind="editAwaySets" />
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label small">Gewinner</label>
                                <select class="form-select form-select-sm" @bind="editWinnerId">
                                    <option value="">— kein Gewinner —</option>
                                    <option value="@detailMatch.HomeParticipantId">@(homeP?.DisplayName ?? "Home")</option>
                                    <option value="@detailMatch.AwayParticipantId">@(awayP?.DisplayName ?? "Away")</option>
                                </select>
