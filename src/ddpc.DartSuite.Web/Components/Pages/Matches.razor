    // ─── Detail modal ───

    private void OpenMatchDetail(MatchDto match)
    {
        detailMatch = match;
        detailMatchStatistics = [];
        isEditing = false;
        showWalkoverConfirm = false;
        walkoverWinnerId = string.Empty;
        editError = null;
        _ = LoadDetailMatchStatisticsAsync(match.Id);
        _ = LoadMatchListenersAsync();
        _ = CheckFollowStateAsync(match.Id);
    }

    private void CloseModal()
    {
        detailMatch = null;
        detailMatchStatistics = [];
        isEditing = false;
        showWalkoverConfirm = false;
        walkoverWinnerId = string.Empty;
        isFollowingDetailMatch = false;
        isFollowOperationInProgress = false;
        isSyncingDetailMatch = false;
    }

    private async Task CheckFollowStateAsync(Guid matchId)
    {
        if (string.IsNullOrWhiteSpace(autodartsDisplayName))
        {
            isFollowingDetailMatch = false;
            return;
        }

        try
        {
            var followers = await Api.GetMatchFollowersAsync(matchId);
            isFollowingDetailMatch = followers.Any(f =>
                string.Equals(f.UserAccountName, autodartsDisplayName, StringComparison.OrdinalIgnoreCase));
        }
        catch
        {
            isFollowingDetailMatch = false;
        }
    }

    private async Task ToggleFollowMatchAsync()
    {
        if (detailMatch is null)
            return;

        await ToggleFollowMatchAsync(detailMatch);
    }

    private async Task ToggleFollowMatchAsync(MatchDto match)
    {
        if (match.Id == Guid.Empty || string.IsNullOrWhiteSpace(autodartsDisplayName))
            return;

        if (!CanFollowFromMatchCard(match))
            return;

        try
        {
            isFollowOperationInProgress = true;

            var isFollowing = IsMatchFollowed(match.Id);
            if (isFollowing)
            {
                await Api.UnfollowMatchAsync(match.Id, autodartsDisplayName);
            }
            else
            {
                await Api.FollowMatchAsync(match.Id, autodartsDisplayName);
            }

            if (detailMatch?.Id == match.Id)
                isFollowingDetailMatch = !isFollowing;
        }
        catch
        {
            await CheckFollowStateAsync(match.Id);
        }
        finally
        {
            isFollowOperationInProgress = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SyncMatchFromExternalAsync()
    {
        if (detailMatch is null)
            return;

        await SyncMatchFromExternalAsync(detailMatch);
    }

    private async Task SyncMatchFromExternalAsync(MatchDto match)
    {
        if (!CanSyncFromMatchCard(match))
            return;

        try
        {
            isSyncingDetailMatch = true;
            editError = null;

            var synced = await Api.SyncMatchFromExternalAsync(match.Id);
            if (synced is null)
                return;

            if (detailMatch?.Id == synced.Id)
                detailMatch = synced;

            var index = matches.FindIndex(m => m.Id == synced.Id);
            if (index >= 0)
                matches[index] = synced;

            await LoadDetailMatchStatisticsAsync(synced.Id);
            await LoadMatchListenersAsync();
        }
        catch (Exception ex)
        {
            editError = $"Sync fehlgeschlagen: {ex.Message}";
        }
        finally
        {
            isSyncingDetailMatch = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadDetailMatchStatisticsAsync(Guid matchId)
    {
        try
        {
            detailMatchStatistics = (await Api.GetMatchStatisticsAsync(matchId)).ToList();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            detailMatchStatistics = [];
        }
    }

    private static bool CanSetWalkover(MatchDto match)
    {
        return match.StartedUtc is null
            && match.FinishedUtc is null
            && !string.Equals(match.Status, "WalkOver", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(match.Status, "Beendet", StringComparison.OrdinalIgnoreCase);
    }

    private void OpenWalkoverDialog()
    {
        if (!CanManageSelectedTournament)
            return;

        if (detailMatch is null || !CanSetWalkover(detailMatch))
            return;

        showWalkoverConfirm = true;
        walkoverWinnerId = GetDefaultWalkoverWinnerId(detailMatch);
        editError = null;
    }

    private void CancelWalkoverDialog()
    {
        showWalkoverConfirm = false;
        walkoverWinnerId = string.Empty;
    }

    private static string GetDefaultWalkoverWinnerId(MatchDto match)
    {
        if (match.HomeParticipantId == Guid.Empty && match.AwayParticipantId != Guid.Empty)
            return match.AwayParticipantId.ToString();

        if (match.AwayParticipantId == Guid.Empty && match.HomeParticipantId != Guid.Empty)
            return match.HomeParticipantId.ToString();

        return string.Empty;
    }

    private async Task ApplyWalkoverAsync()
    {
        if (!CanManageSelectedTournament)
            return;

        if (detailMatch is null)
            return;

        isSaving = true;
        editError = null;
        try
        {
            var winnerId = Guid.TryParse(walkoverWinnerId, out var parsedWinner)
                ? parsedWinner
                : (Guid?)null;

            if (!winnerId.HasValue)
                throw new InvalidOperationException("Bitte waehlen Sie einen Gewinner fuer den Walkover aus.");

            var request = new UpdateMatchRequest(
                detailMatch.Id,
                detailMatch.BoardId,
                detailMatch.HomeLegs,
                detailMatch.AwayLegs,
                detailMatch.HomeSets,
                detailMatch.AwaySets,
                "WalkOver",
                detailMatch.IsStartTimeLocked,
                detailMatch.IsBoardLocked,
                winnerId);

            var updated = await Api.UpdateMatchAsync(request);
            if (updated is not null)
            {
                detailMatch = updated;
                var idx = matches.FindIndex(m => m.Id == updated.Id);
                if (idx >= 0)
                    matches[idx] = updated;
            }

            showWalkoverConfirm = false;
        }
        catch (Exception ex)
        {
            editError = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void StartEditing()
    {
        if (!CanManageSelectedTournament) return;
        if (detailMatch is null) return;
        showWalkoverConfirm = false;
        editStatus = detailMatch.Status;
        editBoardId = detailMatch.BoardId?.ToString() ?? "";
        editHomeLegs = detailMatch.HomeLegs;
        editAwayLegs = detailMatch.AwayLegs;
        editHomeSets = detailMatch.HomeSets;
        editAwaySets = detailMatch.AwaySets;
        editWinnerId = detailMatch.WinnerParticipantId?.ToString() ?? "";
        editIsBoardLocked = detailMatch.IsBoardLocked;
        editIsStartTimeLocked = detailMatch.IsStartTimeLocked;
        editError = null;
        isEditing = true;
    }

    private void CancelEditing()
    {
        isEditing = false;
        editError = null;
    }

    private async Task SaveMatchAsync()
    {
        if (!CanManageSelectedTournament)
            return;

        if (detailMatch is null) return;
        isSaving = true;
        editError = null;
        try
        {
            Guid? boardId = Guid.TryParse(editBoardId, out var bid) ? bid : null;
            Guid? winnerId = Guid.TryParse(editWinnerId, out var wid) ? wid : null;

            var request = new UpdateMatchRequest(
                detailMatch.Id, boardId,
                editHomeLegs, editAwayLegs, editHomeSets, editAwaySets,
                editStatus, editIsStartTimeLocked, editIsBoardLocked, winnerId);

            var updated = await Api.UpdateMatchAsync(request);
            if (updated is not null)
            {
                detailMatch = updated;
                // Update in local list
                var idx = matches.FindIndex(m => m.Id == updated.Id);
                if (idx >= 0) matches[idx] = updated;
            }
            isEditing = false;
        }
        catch (Exception ex)
        {
            editError = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ResetSingleMatchAsync()
    {
        if (!CanManageSelectedTournament)
