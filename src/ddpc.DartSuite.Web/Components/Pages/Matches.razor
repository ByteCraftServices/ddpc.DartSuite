    private IReadOnlyList<SplitButton.SplitButtonItem> BuildMatchStatusItems(MatchDto match)
    {
        var statusCandidates = new[] { "Erstellt", "Geplant", "Aktiv", "Beendet", "Inaktiv", "WalkOver" };
        return statusCandidates.Select(status => new SplitButton.SplitButtonItem
        {
            Text = status,
            IsDisabled = string.Equals(match.Status, status, StringComparison.OrdinalIgnoreCase),
            IsDanger = status is "Inaktiv" or "WalkOver",
            OnClick = EventCallback.Factory.Create(this, () => QuickSetMatchStatusAsync(match, status))
        }).ToList();
    }

    private async Task QuickSetMatchStatusAsync(MatchDto match, string newStatus)
    {
        if (!CanManageSelectedTournament)
            return;

        try
        {
            isSaving = true;
            editError = null;

            var request = new UpdateMatchRequest(
                match.Id,
                match.BoardId,
                match.HomeLegs,
                match.AwayLegs,
                match.HomeSets,
                match.AwaySets,
                newStatus,
                match.IsStartTimeLocked,
                match.IsBoardLocked,
                match.WinnerParticipantId);

            var updated = await Api.UpdateMatchAsync(request);
            if (updated is null)
                return;

            var index = matches.FindIndex(m => m.Id == updated.Id);
            if (index >= 0)
                matches[index] = updated;

            if (detailMatch?.Id == updated.Id)
                detailMatch = updated;
        }
        catch (Exception ex)
        {
            editError = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private IReadOnlyList<SplitButton.SplitButtonItem> BuildBoardSelectionItems(MatchDto match)
    {
        var runningBoardIds = matches
            .Where(m => m.Id != match.Id && m.StartedUtc is not null && m.FinishedUtc is null && m.BoardId.HasValue)
            .Select(m => m.BoardId!.Value)
            .ToHashSet();

        var rankedBoards = boards
            .Select(board => new
            {
                Board = board,
                IsAvailable = !runningBoardIds.Contains(board.Id),
                QueueCount = matches.Count(m => m.Id != match.Id && m.BoardId == board.Id && m.FinishedUtc is null && m.StartedUtc is null)
            })
            .OrderByDescending(x => x.IsAvailable)
            .ThenBy(x => x.QueueCount)
            .ThenBy(x => x.Board.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        var items = rankedBoards
            .Select(x => new SplitButton.SplitButtonItem
            {
                Text = x.IsAvailable
                    ? $"{x.Board.Name} ({x.Board.Status}, Queue: {x.QueueCount})"
                    : $"{x.Board.Name} ({x.Board.Status}, belegt)",
                IsDisabled = x.Board.Id == match.BoardId || !x.IsAvailable,
                OnClick = EventCallback.Factory.Create(this, () => QuickAssignBoardAsync(match, x.Board.Id))
            })
            .ToList();

        items.Add(new SplitButton.SplitButtonItem { IsDivider = true });
        items.Add(new SplitButton.SplitButtonItem
        {
            Text = "Keine Zuweisung",
            IsDisabled = !match.BoardId.HasValue,
            OnClick = EventCallback.Factory.Create(this, () => QuickAssignBoardAsync(match, null))
        });

        return items;
    }

    private async Task QuickAssignBoardAsync(MatchDto match, Guid? boardId)
    {
        if (!CanManageSelectedTournament)
            return;

        try
        {
            isSaving = true;
            editError = null;

            MatchDto? updated;
            if (boardId.HasValue)
            {
                await Api.AssignBoardToMatchAsync(match.Id, boardId.Value);
                await LoadDataAsync();
                updated = matches.FirstOrDefault(m => m.Id == match.Id);
            }
            else
            {
                updated = await Api.UpdateMatchAsync(new UpdateMatchRequest(
                    match.Id,
                    null,
                    match.HomeLegs,
                    match.AwayLegs,
                    match.HomeSets,
                    match.AwaySets,
                    match.Status,
                    match.IsStartTimeLocked,
                    match.IsBoardLocked,
                    match.WinnerParticipantId));
            }

            if (updated is null)
                return;

            var index = matches.FindIndex(m => m.Id == updated.Id);
            if (index >= 0)
                matches[index] = updated;

            if (detailMatch?.Id == updated.Id)
                detailMatch = updated;
        }
        catch (Exception ex)
        {
            editError = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

