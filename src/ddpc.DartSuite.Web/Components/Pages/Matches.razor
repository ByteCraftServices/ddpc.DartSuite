    private int fallbackPollingIntervalSeconds = 5;
    private bool isSavingRealtimePreference;
    private string? realtimePreferenceError;
    private bool isSavingMatchCardPreferences;
    private string? matchCardPreferenceError;
    private List<MatchPlayerStatisticDto> detailMatchStatistics = [];
    private List<MatchListenerInfoDto> matchListeners = [];
    private MatchCardViewSettings detailMatchCardSettings = MatchCardViewSettings.CreateDefault("matches::detail");
    private readonly Dictionary<string, MatchCardViewSettings> matchCardSettingsByView = new(StringComparer.OrdinalIgnoreCase);
    private bool isSyncingDetailMatch;
    private bool isFollowingDetailMatch;
    private bool isFollowOperationInProgress;
    private string editStatus = "";
    private string editBoardId = "";
    private int editHomeLegs;
    private int editAwayLegs;
    private int editHomeSets;
    private int editAwaySets;
    private string editWinnerId = "";
    private bool editIsBoardLocked;
    private bool editIsStartTimeLocked;

    private const string RealtimePreferenceContext = "MatchesRealtime";
    private const string MatchCardPreferenceContext = "MatchCardDisplay";
    private const string MatchCardLegacyViewKey = "matches-detail";
    private const string MatchCardScopeDelimiter = "::";
    private const string MatchCardScopeGlobalPage = "all";
    private const string MatchCardScopePage = "matches";
    private const string MatchCardScopeSectionAll = "all";
    private const string MatchCardScopeSectionDetail = "detail";

    private sealed record MatchesRealtimeSettings(int FallbackPollingSeconds = 5);

    private string DetailMatchCardScopeKey => BuildMatchCardScopeKey(MatchCardScopePage, MatchCardScopeSectionDetail);
    private MatchCardViewSettings DetailMatchCardSettings => detailMatchCardSettings;

    private List<MatchDto> FilteredMatches
    {
        get
        {
            var query = matches.AsEnumerable();

            if (hideTbd)
                query = query.Where(m => m.HomeParticipantId != Guid.Empty && m.AwayParticipantId != Guid.Empty);

            if (hideFinished)
                query = query.Where(m => m.FinishedUtc is null);

            query = statusFilter switch
            {
                "running" => query.Where(m => m.StartedUtc is not null && m.FinishedUtc is null),
                "upcoming" => query.Where(m => m.StartedUtc is null && m.FinishedUtc is null),
                "inactive" => query.Where(m => m.Status == "Inaktiv"),
                _ => query
            };

            if (phaseFilter != "all")
                query = query.Where(m => m.Phase == phaseFilter);

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                var term = searchText.Trim();
                query = query.Where(m =>
                    ParticipantName(m.HomeParticipantId).Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    ParticipantName(m.AwayParticipantId).Contains(term, StringComparison.OrdinalIgnoreCase));
            }

            return query
                .OrderBy(m => m.PlannedStartUtc ?? DateTimeOffset.MaxValue)
                .ThenBy(m => m.Phase == "Group" ? 0 : 1)
                .ThenBy(m => m.Round)
                .ThenBy(m => m.MatchNumber)
                .ToList();
        }
    }

    private bool CanManageSelectedTournament =>
        AppState.SelectedTournament is not null
        && isAutodartsConnected
        && !string.IsNullOrWhiteSpace(autodartsDisplayName)
        && (
            string.Equals(AppState.SelectedTournament.OrganizerAccount, autodartsDisplayName, StringComparison.OrdinalIgnoreCase)
            || participants.Any(p => p.IsManager &&
                (string.Equals(p.AccountName, autodartsDisplayName, StringComparison.OrdinalIgnoreCase)
                 || string.Equals(p.DisplayName, autodartsDisplayName, StringComparison.OrdinalIgnoreCase)))
        );

    private bool ShowMatchCardSyncAction(MatchDto match)
        => MatchCardUiPolicy.ShowSyncAction(DetailMatchCardSettings, CanManageSelectedTournament, match.ExternalMatchId);

    private bool ShowMatchCardFollowAction()
        => MatchCardUiPolicy.ShowFollowActionForUser(DetailMatchCardSettings, isAutodartsConnected, autodartsDisplayName);

    private bool CanSyncFromMatchCard(MatchDto match)
        => MatchCardUiPolicy.CanSync(CanManageSelectedTournament, isSyncingDetailMatch, isSaving, match.ExternalMatchId);

    private bool CanFollowFromMatchCard(MatchDto match)
        => MatchCardUiPolicy.CanFollowForUser(isAutodartsConnected, autodartsDisplayName, IsFollowOperationBusy(match.Id));

    private bool IsMatchFollowed(Guid matchId)
        => detailMatch?.Id == matchId && isFollowingDetailMatch;

    private bool IsFollowOperationBusy(Guid matchId)
        => detailMatch?.Id == matchId && isFollowOperationInProgress;

    private EventCallback BuildDetailPlayerNavigationCallback(Guid participantId)
    {
        if (!MatchCardUiPolicy.CanOpenParticipant(participantId) || detailMatch is null)
            return default;

        return EventCallback.Factory.Create(this, GoToTournamentMatch);
    }

    private EventCallback BuildDetailBoardNavigationCallback()
    {
        if (!MatchCardUiPolicy.CanOpenBoard(detailMatch?.BoardId))
            return default;

        return EventCallback.Factory.Create(this, GoToTournamentBoardFromDetailMatch);
    }

    private MatchListenerInfoDto? GetMatchListener(Guid matchId)
        => matchListeners.FirstOrDefault(l => l.MatchId == matchId);

    private string GetMonitoringBadgeText(MatchDto match)
    {
        var listener = GetMatchListener(match.Id);
        return MatchCardUiPolicy.MonitoringBadgeText(listener);
    }

    private string GetMonitoringBadgeCss(MatchDto match)
    {
        var listener = GetMatchListener(match.Id);
        return MatchCardUiPolicy.MonitoringBadgeCss(listener);
    }

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += OnAppStateChanged;
        await Task.WhenAll(LoadDataAsync(), TryLoadAutodartsSessionAsync());
        await LoadRealtimeSettingsAsync();
        await LoadMatchCardSettingsAsync();
        await TryLoadCompactViewportAsync();

        forcedMatchDetailsExpanded = isCompactViewport ? false : true;

        if (!string.IsNullOrEmpty(QueryMatchId) && Guid.TryParse(QueryMatchId, out var qMatchId))
        {
            var found = matches.FirstOrDefault(m => m.Id == qMatchId);
            if (found is not null)
            {
                detailMatch = found;
                _ = LoadDetailMatchStatisticsAsync(found.Id);
            }
        }

        UpdateAutoRefreshTimer();
    }

    private async void OnAppStateChanged()
    {
        await InvokeAsync(async () =>
        {
            await Task.WhenAll(LoadDataAsync(), TryLoadAutodartsSessionAsync());
            await LoadRealtimeSettingsAsync();
            await LoadMatchCardSettingsAsync();
            await TryLoadCompactViewportAsync();
            UpdateAutoRefreshTimer();
            StateHasChanged();
        });
    }

    private async Task LoadRealtimeSettingsAsync()
    {
        fallbackPollingIntervalSeconds = 5;
        realtimePreferenceError = null;

        if (string.IsNullOrWhiteSpace(autodartsDisplayName))
            return;

        try
        {
            var preference = await Api.GetViewPreferenceAsync(autodartsDisplayName, RealtimePreferenceContext);
            if (preference is null || string.IsNullOrWhiteSpace(preference.SettingsJson))
                return;

            var parsed = JsonSerializer.Deserialize<MatchesRealtimeSettings>(preference.SettingsJson);
            if (parsed is null)
                return;

            fallbackPollingIntervalSeconds = Math.Clamp(parsed.FallbackPollingSeconds, 2, 30);
        }
        catch
        {
            fallbackPollingIntervalSeconds = 5;
        }
    }

    private async Task OnFallbackPollingIntervalChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var parsed))
            return;

        fallbackPollingIntervalSeconds = Math.Clamp(parsed, 2, 30);
        realtimePreferenceError = null;
        UpdateAutoRefreshTimer();

        if (string.IsNullOrWhiteSpace(autodartsDisplayName))
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            isSavingRealtimePreference = true;
            var payload = JsonSerializer.Serialize(new MatchesRealtimeSettings(fallbackPollingIntervalSeconds));
            await Api.SaveViewPreferenceAsync(autodartsDisplayName, RealtimePreferenceContext, payload);
        }
        catch (Exception ex)
        {
            realtimePreferenceError = $"Polling-Einstellung konnte nicht gespeichert werden: {ex.Message}";
        }
        finally
        {
            isSavingRealtimePreference = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task TryLoadCompactViewportAsync()
    {
        try
        {
            isCompactViewport = await JS.InvokeAsync<bool>("dartSuiteUi.isCompactViewport");
        }
        catch
        {
            isCompactViewport = false;
        }
    }

    private static string BuildMatchCardScopeKey(string page, string section)
    {
        var normalizedPage = string.IsNullOrWhiteSpace(page) ? MatchCardScopePage : page.Trim().ToLowerInvariant();
        var normalizedSection = NormalizeMatchCardSection(section);
        return $"{normalizedPage}{MatchCardScopeDelimiter}{normalizedSection}";
    }

    private static string NormalizeMatchCardScopeKey(string scopeKey)
    {
        if (string.IsNullOrWhiteSpace(scopeKey))
            return BuildMatchCardScopeKey(MatchCardScopePage, MatchCardScopeSectionDetail);

        var split = scopeKey.Split(MatchCardScopeDelimiter, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (split.Length != 2)
            return scopeKey.Trim();

        return BuildMatchCardScopeKey(split[0], split[1]);
    }

    private static string NormalizeMatchCardSection(string? section)
    {
        var normalized = (section ?? string.Empty).Trim().ToLowerInvariant();
        return normalized switch
        {
            MatchCardScopeSectionAll => MatchCardScopeSectionAll,
            MatchCardScopeSectionDetail => MatchCardScopeSectionDetail,
            _ => MatchCardScopeSectionDetail
        };
    }

    private MatchCardViewSettings ResolveDetailMatchCardSettings()
    {
        var candidates = new[]
        {
            DetailMatchCardScopeKey,
            BuildMatchCardScopeKey(MatchCardScopePage, MatchCardScopeSectionAll),
            BuildMatchCardScopeKey(MatchCardScopeGlobalPage, MatchCardScopeSectionAll),
            MatchCardLegacyViewKey
        };

        foreach (var candidate in candidates)
        {
            if (matchCardSettingsByView.TryGetValue(candidate, out var found))
                return found;
        }

        return MatchCardViewSettings.CreateDefault(DetailMatchCardScopeKey);
    }

    private MatchCardViewSettings GetEditableDetailMatchCardSettings()
    {
        if (!matchCardSettingsByView.TryGetValue(DetailMatchCardScopeKey, out var settings))
        {
            settings = ResolveDetailMatchCardSettings().Clone();
            settings.Normalize();
            matchCardSettingsByView[DetailMatchCardScopeKey] = settings;
        }

        settings.Normalize();
        return settings;
    }

    private async Task LoadMatchCardSettingsAsync()
    {
        matchCardPreferenceError = null;
        matchCardSettingsByView.Clear();

        var globalScopeKey = BuildMatchCardScopeKey(MatchCardScopeGlobalPage, MatchCardScopeSectionAll);
        var pageScopeKey = BuildMatchCardScopeKey(MatchCardScopePage, MatchCardScopeSectionAll);
        matchCardSettingsByView[globalScopeKey] = MatchCardViewSettings.CreateDefault(globalScopeKey);
        matchCardSettingsByView[pageScopeKey] = MatchCardViewSettings.CreateDefault(pageScopeKey);
        detailMatchCardSettings = GetEditableDetailMatchCardSettings();

        if (string.IsNullOrWhiteSpace(autodartsDisplayName))
            return;

        try
        {
            var preference = await Api.GetViewPreferenceAsync(autodartsDisplayName, MatchCardPreferenceContext);
            if (preference is null || string.IsNullOrWhiteSpace(preference.SettingsJson))
                return;

            var payload = JsonSerializer.Deserialize<MatchCardViewPreferencePayload>(preference.SettingsJson);
            if (payload?.Views is null)
                return;

            foreach (var (key, configured) in payload.Views)
            {
                if (string.IsNullOrWhiteSpace(key) || configured is null)
                    continue;

                var normalizedKey = string.Equals(key, MatchCardLegacyViewKey, StringComparison.OrdinalIgnoreCase)
                    ? DetailMatchCardScopeKey
                    : key.Contains(MatchCardScopeDelimiter, StringComparison.Ordinal)
                        ? NormalizeMatchCardScopeKey(key)
                        : key.Trim();

                configured.Normalize();
                matchCardSettingsByView[normalizedKey] = configured;
            }

            detailMatchCardSettings = GetEditableDetailMatchCardSettings();
        }
        catch
        {
            matchCardSettingsByView.Clear();
            var globalFallbackScopeKey = BuildMatchCardScopeKey(MatchCardScopeGlobalPage, MatchCardScopeSectionAll);
            var pageFallbackScopeKey = BuildMatchCardScopeKey(MatchCardScopePage, MatchCardScopeSectionAll);
            matchCardSettingsByView[globalFallbackScopeKey] = MatchCardViewSettings.CreateDefault(globalFallbackScopeKey);
            matchCardSettingsByView[pageFallbackScopeKey] = MatchCardViewSettings.CreateDefault(pageFallbackScopeKey);
            detailMatchCardSettings = MatchCardViewSettings.CreateDefault(DetailMatchCardScopeKey);
            matchCardSettingsByView[DetailMatchCardScopeKey] = detailMatchCardSettings;
        }
    }

    private async Task UpdateDetailMatchCardSettingsAsync(Action<MatchCardViewSettings> update)
    {
        matchCardPreferenceError = null;

        update(detailMatchCardSettings);
        detailMatchCardSettings.Normalize();
        matchCardSettingsByView.Remove(MatchCardLegacyViewKey);
        matchCardSettingsByView[DetailMatchCardScopeKey] = detailMatchCardSettings;

        if (string.IsNullOrWhiteSpace(autodartsDisplayName))
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            isSavingMatchCardPreferences = true;

            var payload = new MatchCardViewPreferencePayload
            {
                Views = matchCardSettingsByView.ToDictionary(
                    entry => entry.Key,
                    entry => entry.Value.Clone(),
                    StringComparer.OrdinalIgnoreCase)
            };

            var json = JsonSerializer.Serialize(payload);
            await Api.SaveViewPreferenceAsync(autodartsDisplayName, MatchCardPreferenceContext, json);
        }
        catch (Exception ex)
        {
            matchCardPreferenceError = $"MatchCard-Einstellungen konnten nicht gespeichert werden: {ex.Message}";
        }
        finally
        {
            isSavingMatchCardPreferences = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task UpdateDetailMatchCardLayoutAsync(ChangeEventArgs args)
        => UpdateDetailMatchCardSettingsAsync(s => s.Layout = args.Value?.ToString() ?? "Mixed");

    private async Task SetGlobalDetailsExpansionAsync(bool? expanded)
    {
        forcedMatchDetailsExpanded = expanded;
        await InvokeAsync(StateHasChanged);
    }

    private static bool ParseBoolChangeEvent(ChangeEventArgs args)
        => args.Value switch
        {
            bool b => b,
            string s when bool.TryParse(s, out var parsed) => parsed,
            _ => false
        };

    private void UpdateAutoRefreshTimer()
    {
        var refreshInterval = TimeSpan.FromSeconds(Math.Clamp(fallbackPollingIntervalSeconds, 2, 30));

        if (_autoRefreshTimer is null)
        {
            _autoRefreshTimer = new Timer(OnAutoRefresh, null, refreshInterval, refreshInterval);
            return;
        }

        _autoRefreshTimer.Change(refreshInterval, refreshInterval);
    }

    private async Task TryLoadAutodartsSessionAsync()
    {
        try
        {
            var status = await Api.GetAutodartsStatusAsync();
            isAutodartsConnected = status.IsConnected;
            autodartsDisplayName = status.Profile?.DisplayName;
        }
        catch
        {
            isAutodartsConnected = false;
            autodartsDisplayName = null;
        }
    }

    private async Task LoadMatchListenersAsync()
    {
        if (AppState.SelectedTournament is null)
        {
            matchListeners = [];
            return;
        }

        try
        {
            var allListeners = await Api.GetMatchListenersAsync();
            var matchIds = matches.Select(m => m.Id).ToHashSet();
            matchListeners = allListeners
                .Where(x => matchIds.Contains(x.MatchId))
                .ToList();
        }
        catch
        {
            matchListeners = [];
        }
    }

    private async void OnAutoRefresh(object? _)
    {
        if (AppState.SelectedTournament is null) return;
        try
        {
            var pageVisible = await JS.InvokeAsync<bool>("dartSuiteUi.isDocumentVisible");
            if (!pageVisible)
                return;

            matches = (await Api.GetMatchesAsync(AppState.SelectedTournament.Id)).ToList();

            if (detailMatch is not null)
            {
                detailMatch = matches.FirstOrDefault(m => m.Id == detailMatch.Id) ?? detailMatch;
                await LoadMatchListenersAsync();

                if (detailMatch.StartedUtc is not null && detailMatch.FinishedUtc is null)
                    await LoadDetailMatchStatisticsAsync(detailMatch.Id);
            }

            await InvokeAsync(StateHasChanged);
        }
        catch { /* ignore refresh errors */ }
    }

    private async Task LoadDataAsync()
    {
        if (AppState.SelectedTournament is not null)
        {
            var id = AppState.SelectedTournament.Id;
            matches = (await Api.GetMatchesAsync(id)).ToList();
            participants = (await Api.GetParticipantsAsync(id)).ToList();
            roundSettings = (await Api.GetRoundsAsync(id)).ToList();
            boards = (await Api.GetBoardsByTournamentAsync(id)).ToList();
            await LoadMatchListenersAsync();
        }
        else
        {
            matches = [];
            participants = [];
            roundSettings = [];
            boards = [];
            matchListeners = [];
        }
    }

    // ─── Selection ───

    private void ToggleSelect(Guid matchId)
    {
        if (!selectedMatchIds.Remove(matchId))
            selectedMatchIds.Add(matchId);
    }

    private void SelectAll()
    {
        foreach (var m in FilteredMatches)
            selectedMatchIds.Add(m.Id);
    }

    private void SelectInactive()
    {
        foreach (var m in matches.Where(m => m.Status == "Inaktiv"))
            selectedMatchIds.Add(m.Id);
    }

    private void DeselectAll() => selectedMatchIds.Clear();

    private bool IsAllFilteredSelected()
    {
        var filtered = FilteredMatches;
        return filtered.Count > 0 && filtered.All(m => selectedMatchIds.Contains(m.Id));
    }

    private void ToggleSelectAllFiltered()
    {
        if (IsAllFilteredSelected())
        {
            foreach (var m in FilteredMatches)
                selectedMatchIds.Remove(m.Id);
        }
        else
        {
            foreach (var m in FilteredMatches)
                selectedMatchIds.Add(m.Id);
        }
    }

    // ─── Bulk actions ───

    private async Task BulkResetAsync()
    {
        if (!CanManageSelectedTournament)
            return;

        if (!selectedMatchIds.Any()) return;
        try
        {
            actionMessage = null;
            var result = await Api.BatchResetMatchesAsync(selectedMatchIds.ToList());
            actionMessage = $"{result.Count} Matches wurden zurückgesetzt.";
            actionIsError = false;
            selectedMatchIds.Clear();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            actionMessage = $"Fehler: {ex.Message}";
            actionIsError = true;
        }
    }

    // ─── Auto-cleanup ───

    private async Task RunCleanupAsync()
    {
        if (!CanManageSelectedTournament)
            return;

        if (AppState.SelectedTournament is null) return;
        isCleanupRunning = true;
        try
        {
            var result = await Api.CleanupStaleMatchesAsync(AppState.SelectedTournament.Id, 120);
            actionMessage = result.Count > 0
                ? $"{result.Count} veraltete Matches wurden zurückgesetzt."
                : "Keine veralteten Matches gefunden.";
            actionIsError = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            actionMessage = $"Cleanup-Fehler: {ex.Message}";
            actionIsError = true;
        }
        finally
        {
            isCleanupRunning = false;
        }
    }

    private async Task CheckExternalAsync()
    {
        if (!CanManageSelectedTournament)
            return;

        if (AppState.SelectedTournament is null) return;
        isCheckingExternal = true;
        try
        {
            var result = await Api.CheckExternalMatchesAsync(AppState.SelectedTournament.Id);
            actionMessage = result.Count > 0
                ? $"{result.Count} Matches auf Inaktiv gesetzt (ExternalMatchId ungültig)."
                : "Alle ExternalMatchIds sind gültig.";
            actionIsError = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            actionMessage = $"Prüfungsfehler: {ex.Message}";
            actionIsError = true;
        }
        finally
        {
            isCheckingExternal = false;
        }
