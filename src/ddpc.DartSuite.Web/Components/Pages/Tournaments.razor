                                                                                                        @for (var teamIdx = 0; teamIdx < teamDrafts.Count; teamIdx++)
                                                                                                        {
                                                                                                            var idx = teamIdx;
                                                                                                            var team = teamDrafts[idx];
                                                                                                            var members = team.MemberParticipantIds
                                                                                                                .Select(id => EffectivePlayerParticipants.FirstOrDefault(p => p.Id == id))
                                                                                                                .Where(p => p is not null)
                                                                                                                .Cast<ParticipantDto>()
                                                                                                                .ToList();
                                                                                                            <div class="col-md-6">
                                                                                                                <div class="card @DrawTeamAnimationCss(idx) @(dropTargetTeamIndex == idx ? "draw-target-group" : "") @(draggedTeamParticipantId != null && IsTeamFull(idx) ? "team-slot-full" : "") @(draggedTeamParticipantId != null && !IsTeamFull(idx) && dropTargetTeamIndex != idx ? "team-slot-available" : "")"
                                                                                                                     @ondragover:preventDefault
                                                                                                                     @ondragover="() => { if (draggedTeamSeedIndex.HasValue) return; if (CanEditTournamentStructure && !IsTeamFull(idx)) dropTargetTeamIndex = idx; }"
                                                                                                                     @ondragleave="() => { if (dropTargetTeamIndex == idx) dropTargetTeamIndex = null; }"
                                                                                                                     @ondrop="async () => { if (draggedTeamSeedIndex.HasValue) await DropTeamSeedAtAsync(idx); else AssignDraggedParticipantToTeam(idx); }">
                                                                                                                    <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                                                                                                        <div class="d-flex align-items-center gap-2 flex-grow-1 team-name-editable-wrap"
