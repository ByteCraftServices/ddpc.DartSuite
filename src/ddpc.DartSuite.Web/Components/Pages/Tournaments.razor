                                                                                                                            @foreach (var member in members)
                                                                                                                            {
                                                                                                                                <div class="badge bg-dark p-2 me-1 mb-1 user-select-none @DrawParticipantAnimationCss(member.Id)" draggable="@(CanEditTournamentStructure ? "true" : "false")" @ondragstart="() => StartTeamParticipantDrag(member.Id)" style="cursor:grab; font-size:.85em">
                                                                                                                                    @member.DisplayName.ToUpperInvariant()
                                                                                                                                    <button class="btn btn-sm p-0 ms-1 text-white-50" style="font-size:.7em; line-height:1" @onclick="() => RemoveParticipantFromTeam(member.Id)" @onclick:stopPropagation disabled="@(isWorking || !CanEditTournamentStructure)" title="Aus Team entfernen">✕</button>
                                                                                                                                </div>
                                                                                                                            }
                                                                                                                            @if (!members.Any())
                                                                                                                            {
                                                                                                                                <div class="text-muted small text-center py-2">Teilnehmer hierher ziehen</div>
                                                                                                                            }
                                                                                                                        </div>
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            </div>
                                                                                                        }
                                                                                                    </div>
                                                                                                </div>
                                                                                            </div>
                                                                                        }

                                                                                        }

                                                                                        @* ═══════ Tab: Spielmodus ═══════ *@
                                                                                        @if (activeTab == "rounds")
                                                                                        {
                                                                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                                                                <h6 class="fw-semibold mb-0">Spielmodus je Runde</h6>
                                                                                                <button class="btn btn-sm @(editAreGameModesLocked ? "btn-outline-success" : "btn-outline-warning")"
                                                                                                        @onclick="ToggleGameModesLockAsync" disabled="@(isWorking || selectedTournament.IsLocked)">
                                                                                                    @(editAreGameModesLocked ? "🔓 Spielmodi entsperren" : "🔒 Spielmodi sperren")
                                                                                                </button>
                                                                                            </div>
                                                                                            @if (editAreGameModesLocked)
                                                                                            {
                                                                                                <div class="alert alert-info py-2 small">🔒 Spielmodi sind gesperrt. Entsperren Sie die Spielmodi, um Änderungen vorzunehmen.</div>
                                                                                            }
