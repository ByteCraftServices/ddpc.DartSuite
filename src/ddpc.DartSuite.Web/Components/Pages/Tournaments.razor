                                                    <span class="fw-semibold">@selectedTournament.Name</span>
                                                    @if (!string.IsNullOrEmpty(selectedTournament.JoinCode))
                                                    {
                                                        <span class="badge text-bg-primary ms-2 font-monospace">@selectedTournament.JoinCode</span>
                                                    }
                                                    @if (selectedTournament.IsLocked)
                                                    {
                                                        <span class="badge text-bg-danger ms-2">🔒 Gesperrt</span>
                                                    }
                                                </div>
                                                <div class="d-flex gap-1">
                                                    <span class="badge text-bg-secondary">@selectedTournament.Mode</span>
                                                    <span class="badge text-bg-info">@selectedTournament.Variant</span>
                                                    <span class="badge text-bg-warning">@selectedTournament.Status</span>
                                                    <button
                                                        class="btn btn-sm @(selectedTournament.IsLocked ? "btn-outline-success" : "btn-outline-danger")"
                                                        @onclick="ToggleLockAsync" disabled="@isWorking">
