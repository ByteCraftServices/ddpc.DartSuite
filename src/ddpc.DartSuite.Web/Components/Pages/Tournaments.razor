                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psBoardLink" checked="@ActiveMatchCardConfigSettings.EnableBoardLink" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.EnableBoardLink = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psBoardLink">Board-Link</label></div>
                                </div>
                            </div>

                            <div class="border rounded p-2">
                                <div class="fw-semibold small mb-2">Erweitert / Statistiken</div>
                                <div class="d-flex flex-wrap gap-3 small">
