                                                                                                                             @ondragstart="() => StartTeamSeedDrag(idx)">
                                                                                                                            @if (editSeedingEnabled)
                                                                                                                            {
                                                                                                                                <span class="badge text-bg-warning" title="Setzlistenposition Team">#@TeamSeedForDraft(team, idx + 1)</span>
