                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psActionSync" checked="@ActiveMatchCardConfigSettings.ShowSyncAction" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowSyncAction = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psActionSync">Sync</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psActionFollow" checked="@ActiveMatchCardConfigSettings.ShowFollowAction" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowFollowAction = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psActionFollow">Spiel folgen</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psActionStart" checked="@ActiveMatchCardConfigSettings.ShowStartMatchAction" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowStartMatchAction = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psActionStart">Match starten</label></div>
