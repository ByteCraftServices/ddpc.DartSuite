                                                                                                        <div class="card-body p-2" style="min-height:120px;max-height:360px;overflow-y:auto">
                                                                                                            @foreach (var p in TeamDraftUnassignedParticipants)
                                                                                                            {
                                                                                                                <div class="badge bg-dark p-2 me-1 mb-1 user-select-none @DrawParticipantAnimationCss(p.Id)" draggable="@(CanEditTournamentStructure ? "true" : "false")" @ondragstart="() => StartTeamParticipantDrag(p.Id)" style="cursor:grab; font-size:.85em">
                                                                                                                    @p.DisplayName.ToUpperInvariant()
