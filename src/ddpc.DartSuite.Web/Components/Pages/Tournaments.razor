@page "/tournaments"
@using ddpc.DartSuite.Application.Contracts.Matches

<PageTitle>Turniere</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="mb-0">Turniere <UiHelpIcon HelpKey="page.tournaments" /></h1>
    @if (!isCreating)
    {
        <div class="d-flex gap-2 align-items-center">
            @if (isAutodartsConnected)
            {
                <button class="btn btn-primary" @onclick="StartWizard">+ Neues Turnier</button>
            }
            else
            {
                <a href="/login" class="btn btn-outline-secondary">🔒 Login für Turniererstellung</a>
            }
            <div class="dropdown @(showPageSettingsDropdown ? "show" : "")">
                <button class="btn btn-outline-secondary" type="button" @onclick="() => showPageSettingsDropdown = !showPageSettingsDropdown" title="Seiteneinstellungen">⋮</button>
                <ul class="dropdown-menu dropdown-menu-end @(showPageSettingsDropdown ? "show" : "")" style="right: 0; left: auto;">
                    <li><button class="dropdown-item" @onclick="() => { showPageSettingsDropdown = false; showPageSettingsModal = true; }">Einstellungen</button></li>
                </ul>
            </div>
        </div>
    }
</div>

@if (IsRealtimeFallbackActive)
{
    <div class="alert alert-warning py-2 mb-3">Echtzeit eingeschraenkt: @RealtimeFallbackReason. @( $"{EffectiveFallbackPollingIntervalSeconds}s" )-Fallback-Polling ist aktiv.</div>
}



@if (showLegacyMatchCardPanel) /* matchcard-panel moved to page settings modal */
{
    <details id="section-tournaments-matchcard-config" class="card shadow-sm mb-3" open>
        <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
            <span class="fw-semibold">MatchCard Konfiguration</span>
            <a href="/settings?tab=general&edit=matchcard&scope=@activeMatchCardConfigScopeKey"
               class="btn btn-outline-secondary btn-sm"
               title="In zentralen Einstellungen bearbeiten"
               @onclick:stopPropagation>⚙</a>
        </summary>
        <div class="card-body py-3">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                <div>
                    <div class="fw-semibold">Kontext</div>
                    <div class="small text-muted">Aktiver Bereich: @ActiveMatchCardContextLabel</div>
                    <div class="small text-muted">Konfigurationsziel: @ActiveMatchCardConfigScopeLabel</div>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetGlobalDetailsExpansionAsync(true)">Alle Details auf</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetGlobalDetailsExpansionAsync(false)">Alle Details zu</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => SetGlobalDetailsExpansionAsync(null)">Lokal steuern</button>
                </div>
            </div>

            <div class="row g-2 small">
                <div class="col-lg-4 col-md-6">
                    <label class="form-label mb-1">Konfiguration</label>
                    <select class="form-select form-select-sm"
                            value="@activeMatchCardConfigScopeKey"
                            @onchange="OnMatchCardConfigScopeChanged"
                            disabled="@isSavingMatchCardPreferences">
                        @foreach (var scope in MatchCardScopeOptions)
                        {
                            <option value="@scope.ScopeKey">@scope.Label</option>
                        }
                    </select>
                </div>
                <div class="col-lg-2 col-md-3">
                    <label class="form-label mb-1">Layout</label>
                    <select class="form-select form-select-sm"
                            value="@ActiveMatchCardConfigSettings.Layout"
                            @onchange="UpdateActiveMatchCardLayoutAsync"
                            disabled="@isSavingMatchCardPreferences">
                        <option value="Horizontal">Horizontal</option>
                        <option value="Vertical">Vertical</option>
                        <option value="Card">Karte</option>
                        <option value="List">Liste</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-3">
                    <label class="form-label mb-1">Spielstand</label>
                    <select class="form-select form-select-sm"
                            value="@ActiveMatchCardConfigSettings.ScoreMode"
                            @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ScoreMode = MatchCardViewSettings.NormalizeScoreMode(args.Value?.ToString()))"
                            disabled="@isSavingMatchCardPreferences">
                        <option value="FinalOnly">Nur Endresultat</option>
                        <option value="CurrentNoPoints">Aktuell (ohne Punkte)</option>
                        <option value="LiveScores">Live Scores</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-3">
                    <label class="form-label mb-1">Spielernamen</label>
                    <select class="form-select form-select-sm"
                            value="@ActiveMatchCardConfigSettings.PlayerNameMode"
                            @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.PlayerNameMode = MatchCardViewSettings.NormalizePlayerNameMode(args.Value?.ToString()))"
                            disabled="@isSavingMatchCardPreferences">
                        <option value="Name">Nur Name</option>
                        <option value="NameAndPpr">Name und PPR</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-3">
                    <label class="form-label mb-1">Buttons Position</label>
                    <select class="form-select form-select-sm"
                            value="@ActiveMatchCardConfigSettings.ActionButtonsLocation"
                            @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ActionButtonsLocation = MatchCardViewSettings.NormalizeActionButtonsLocation(args.Value?.ToString()))"
                            disabled="@isSavingMatchCardPreferences">
                        <option value="Footer">Unten</option>
                        <option value="Header">Oben (Titelleiste)</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-12 d-flex flex-wrap gap-3 align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="mcLiveEnabled"
                               checked="@ActiveMatchCardConfigSettings.LiveScoreEnabled"
                               @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.LiveScoreEnabled = ParseBoolChangeEvent(args))" />
                        <label class="form-check-label" for="mcLiveEnabled">LiveScore</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="mcCollapseMobile"
                               checked="@ActiveMatchCardConfigSettings.CollapseDetailsOnMobile"
                               @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.CollapseDetailsOnMobile = ParseBoolChangeEvent(args))" />
                        <label class="form-check-label" for="mcCollapseMobile">Mobile eingeklappt</label>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-3 small mt-2">
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcRuntimeBadge" checked="@ActiveMatchCardConfigSettings.ShowRuntimeBadge" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowRuntimeBadge = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcRuntimeBadge">Laufzeit-Badge</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcMonitoringBadge" checked="@ActiveMatchCardConfigSettings.ShowMonitoringStatus" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowMonitoringStatus = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcMonitoringBadge">Monitoring-Badge</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcActionBar" checked="@ActiveMatchCardConfigSettings.ShowActionButtons" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowActionButtons = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcActionBar">Action-Leiste</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcActionSync" checked="@ActiveMatchCardConfigSettings.ShowSyncAction" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowSyncAction = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcActionSync">Sync-Button</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcActionFollow" checked="@ActiveMatchCardConfigSettings.ShowFollowAction" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowFollowAction = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcActionFollow">Folgen-Button</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcPlayerLinks" checked="@ActiveMatchCardConfigSettings.EnablePlayerLinks" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.EnablePlayerLinks = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcPlayerLinks">Spieler-Links</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcBoardLink" checked="@ActiveMatchCardConfigSettings.EnableBoardLink" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.EnableBoardLink = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcBoardLink">Board-Link</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcSuppressHeader" checked="@ActiveMatchCardConfigSettings.SuppressHeader" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.SuppressHeader = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcSuppressHeader">Titelleiste ausblenden</label></div>
            </div>

            <div class="d-flex flex-wrap gap-3 small mt-2">
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcFieldStatus" checked="@ActiveMatchCardConfigSettings.ShowMatchStatus" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowMatchStatus = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcFieldStatus">MatchStatus</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcFieldScheduling" checked="@ActiveMatchCardConfigSettings.ShowSchedulingStatus" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowSchedulingStatus = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcFieldScheduling">SchedulingStatus</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcFieldAverage" checked="@ActiveMatchCardConfigSettings.ShowAverage" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowAverage = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcFieldAverage">Average</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcFieldPpr" checked="@ActiveMatchCardConfigSettings.ShowHighestPpr" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHighestPpr = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcFieldPpr">Highest PPR</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcFieldCheckout" checked="@ActiveMatchCardConfigSettings.ShowHighestCheckout" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHighestCheckout = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcFieldCheckout">Highest Checkout</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcFieldAdpl" checked="@ActiveMatchCardConfigSettings.ShowAverageDartsPerLeg" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowAverageDartsPerLeg = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcFieldAdpl">Average Darts/Leg</label></div>
                <div class="form-check"><input class="form-check-input" type="checkbox" id="mcFieldMinDarts" checked="@ActiveMatchCardConfigSettings.ShowMinimalDartsPerLeg" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowMinimalDartsPerLeg = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="mcFieldMinDarts">Minimal Darts/Leg</label></div>
            </div>

            @if (isSavingMatchCardPreferences)
            {
                <div class="small text-muted mt-2">Speichere MatchCard-Einstellungen ...</div>
            }
            @if (matchCardPreferenceError is not null)
            {
                <div class="alert alert-danger py-1 px-2 small mt-2 mb-0">@matchCardPreferenceError</div>
            }
        </div>
    </details>
}

@* ─── Create Wizard ─── *@
@if (isCreating)
{
    <div class="card shadow-sm mb-4 border-primary">
        <div class="card-header d-flex justify-content-between align-items-center bg-primary text-white">
            <span><strong>Neues Turnier</strong> — Schritt @wizardStep von 2</span>
            <button type="button" class="btn-close btn-close-white" @onclick="CancelWizard"></button>
        </div>
        <div class="card-body">
            @if (wizardStep == 1)
            {
                <h6 class="text-muted mb-3">Schritt 1: Grunddaten</h6>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Turniername <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="wizardName" placeholder="z.B. Frühlings-Cup 2026" maxlength="128" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Veranstalter-Account</label>
                    <input class="form-control" @bind="wizardOrganizer" placeholder="Autodarts Account-Name" />
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Startdatum <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" @bind="wizardStartDate" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Enddatum</label>
                        <input type="date" class="form-control" @bind="wizardEndDate" />
                        <div class="form-text">Leer lassen — entspricht dem Startdatum.</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Startzeit</label>
                        <input type="time" class="form-control" @bind="wizardStartTimeInput" />
                    </div>
                </div>
                @if (wizardError is not null)
                {
                    <div class="alert alert-danger py-2">@wizardError</div>
                }
                <button class="btn btn-primary" @onclick="WizardNext">Weiter →</button>
            }
            else if (wizardStep == 2)
            {
                <h6 class="text-muted mb-3">Schritt 2: Turniereinstellungen</h6>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Modus</label>
                    <select class="form-select" @bind="wizardMode">
                        <option value="Knockout">K.O.-Modus (klassisch)</option>
                        <option value="GroupAndKnockout">Gruppenphase + K.O.</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Variante</label>
                    <select class="form-select" @bind="wizardVariant">
                        <option value="OnSite">Vor-Ort (Boards werden zugewiesen)</option>
                        <option value="Online">Online</option>
                    </select>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="wizTeamplay" @bind="wizardTeamplay" />
                    <label class="form-check-label" for="wizTeamplay">Teamplay aktivieren</label>
                </div>
                @if (wizardError is not null)
                {
                    <div class="alert alert-danger py-2">@wizardError</div>
                }
                <button class="btn btn-secondary me-2" @onclick="() => wizardStep = 1">← Zurück</button>
                <button class="btn btn-success" @onclick="FinishWizardAsync" disabled="@isWorking">✓ Turnier erstellen</button>
            }
        </div>
    </div>
}

@* ─── Confirmation Modal ─── *@
@if (showConfirmation)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title">⚠ Turnierplan betroffen</h5>
                </div>
                <div class="modal-body">
                    <p>@confirmationMessage</p>
                    @if (showConfirmationPlanImpact)
                    {
                        <p class="text-muted small mb-0">Der bestehende Turnierplan und Spielplan werden dadurch ungültig und
                            müssen neu generiert werden.</p>
                    }
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="RejectConfirmation">Abbrechen</button>
                        <button class="btn btn-warning" @onclick="AcceptConfirmation">Änderung durchführen</button>
                    </div>
                </div>
            </div>
        </div>
    }

@if (showInactiveActionInfoModal)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="CloseInactiveActionInfo">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header bg-info-subtle">
                    <h5 class="modal-title">@inactiveActionInfoTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseInactiveActionInfo"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">@inactiveActionInfoMessage</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="CloseInactiveActionInfo">Verstanden</button>
                </div>
            </div>
        </div>
    </div>
}

@* ─── Registration-Draw Confirmation Modal ─── *@
@if (showRegistrationDrawConfirmation)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title">⚠ Registrierung noch geöffnet</h5>
                </div>
                <div class="modal-body">
                    <p>Die Registrierung ist noch geöffnet. Soll die Registrierung jetzt abgeschlossen werden?</p>
                    <p class="text-muted small mb-0">Die Aktion wird nach dem Schließen der Registrierung fortgesetzt.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="RejectRegistrationDrawConfirmation">Abbrechen</button>
                    <button class="btn btn-warning" @onclick="AcceptRegistrationDrawConfirmationAsync">Registrierung schließen</button>
                </div>
            </div>
        </div>
    </div>
}

    @* ─── Match Detail / Result Edit Modal ─── *@
    @if (detailMatch is not null)
    {
        var homeP = participants.FirstOrDefault(p => p.Id == detailMatch.HomeParticipantId);
        var awayP = participants.FirstOrDefault(p => p.Id == detailMatch.AwayParticipantId);
        var assignedBoard = boards.FirstOrDefault(b => b.Id == detailMatch.BoardId);
        var detailCardSettings = ActiveMatchCardSettings;
        var gameplayText = FormatGameplay(detailMatch);
        var matchListener = matchListeners.FirstOrDefault(l => l.MatchId == detailMatch.Id);
        var showManualResultEditor = !(detailMatchOpenedFromSchedule && IsMatchMonitored(detailMatch));
        <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="CloseMatchDetail">
            <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation>
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@MatchLabel(detailMatch) — @(detailMatch.Phase == "Group" ? $"Gruppe {GroupLabel(detailMatch.GroupNumber ?? 1)}" : KoRoundLabel(detailMatch.Round, matches.Where(m =>
                                                m.Phase == detailMatch.Phase).Select(m => m.Round).DefaultIfEmpty(1).Max()))</h5>
                        @if (IsCurrentUserManager)
                        {
                            <div class="d-flex gap-1 me-2 ms-auto align-items-center">
                                @if (CanStartListener(detailMatch))
                                {
                                    <button type="button" class="btn btn-sm btn-outline-success" title="Listener starten" @onclick="() => EnsureListenerAsync(detailMatch)" disabled="@isWorking">🎧</button>
                                }
                                @if (!string.IsNullOrWhiteSpace(detailMatch.ExternalMatchId))
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary" title="Match aus autodarts.io synchronisieren" @onclick="() => SyncMatchFromExternalAsync(detailMatch)" disabled="@isWorking">↩</button>
                                }
                            </div>
                        }
                        <button type="button" class="btn-close" @onclick="CloseMatchDetail"></button>
                    </div>
                        <div class="modal-body">
                            <MatchCard Match="@detailMatch"
                                       ViewSettings="@detailCardSettings"
                                       Layout="@detailCardSettings.Layout"
                                       Label="@MatchLabel(detailMatch)"
                                       ShowRuntimeBadge="@detailCardSettings.ShowRuntimeBadge"
                                       ShowMonitoringStatus="@ShowMatchCardMonitoring(detailCardSettings)"
                                       MonitoringStatusText="@GetMonitoringBadgeText(detailMatch)"
                                       MonitoringStatusCssClass="@GetMonitoringBadgeCss(detailMatch)"
                                       ShowActionButtons="@ShowMatchCardActionBar(detailCardSettings)"
                                       ShowSyncAction="@ShowMatchCardSyncAction(detailCardSettings, detailMatch)"
                                       ShowFollowAction="@ShowMatchCardFollowAction(detailCardSettings)"
                                       IsFollowing="@IsMatchFollowed(detailMatch.Id)"
                                       CanFollow="@CanFollowFromMatchCard(detailMatch)"
                                       CanSync="@CanSyncFromMatchCard(detailMatch)"
                                       OnFollow="() => ToggleFollowMatchAsync(detailMatch)"
                                       OnSync="() => SyncMatchFromExternalAsync(detailMatch)"
                                       EnablePlayerLinks="@detailCardSettings.EnablePlayerLinks"
                                       EnableBoardLink="@detailCardSettings.EnableBoardLink"
                                       OnHomePlayerClick="BuildPlayerDetailCallback(detailMatch.HomeParticipantId)"
                                       OnAwayPlayerClick="BuildPlayerDetailCallback(detailMatch.AwayParticipantId)"
                                       OnBoardClick="() => { var m = detailMatch; var fromSchedule = detailMatchOpenedFromSchedule; _modalBackStack.Push(() => OpenMatchDetail(m!, fromSchedule)); CloseMatchDetail(); if (assignedBoard is not null) OpenBoardDetail(assignedBoard); }"
                                       HomeName="@(homeP?.DisplayName?.ToUpperInvariant() ?? "?")"
                                       AwayName="@(awayP?.DisplayName?.ToUpperInvariant() ?? "?")"
                                       BoardName="@assignedBoard?.Name"
                                       SlotOrigin="@BuildSlotOrigin(detailMatch)"
                                       SetModeActive="@IsSetMode(detailMatch)"
                                       LiveScoreEnabled="@detailCardSettings.LiveScoreEnabled"
                                       ShowMatchStatus="@detailCardSettings.ShowMatchStatus"
                                       ShowSchedulingStatus="@detailCardSettings.ShowSchedulingStatus"
                                       ShowAverage="@detailCardSettings.ShowAverage"
                                       ShowHighestPpr="@detailCardSettings.ShowHighestPpr"
                                       ShowHighestCheckout="@detailCardSettings.ShowHighestCheckout"
                                       ShowAverageDartsPerLeg="@detailCardSettings.ShowAverageDartsPerLeg"
                                       ShowMinimalDartsPerLeg="@detailCardSettings.ShowMinimalDartsPerLeg"
                                       HomeStatistic="@DetailHomeStatistic"
                                       AwayStatistic="@DetailAwayStatistic"
                                       EnableDetailPanel="true"
                                       DetailsExpandedByDefault="@(!detailCardSettings.CollapseDetailsOnMobile || !isCompactViewport)"
                                       ForceDetailsExpanded="@forcedMatchDetailsExpanded"
                                       EnableRealtimeConsumer="@(detailMatch.StartedUtc is not null && detailMatch.FinishedUtc is null)" />
                                    <div id="detailSection-planung" class="mt-2">
                                        <div class="small fw-semibold text-secondary text-uppercase mb-1">📅 Zeitplan</div>
                                    @if (detailMatch.PlannedStartUtc is not null)
                                    {
                                        <p class="small text-muted">⏰ Geplante Startzeit:
                                            @detailMatch.PlannedStartUtc.Value.LocalDateTime.ToString("dd.MM.yyyy HH:mm")
                                            @if (detailMatch.IsStartTimeLocked) { <span class="text-primary fw-semibold ms-1">🔒 Gesperrt</span> }</p>
                                        }
                                        @if (detailMatch.StartedUtc is not null)
                                        {
                                            <p class="small text-muted">▶ Gestartet: @detailMatch.StartedUtc.Value.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</p>
                                            var matchElapsed = (detailMatch.FinishedUtc ?? DateTimeOffset.UtcNow) - detailMatch.StartedUtc.Value;
                                            var matchRound = roundSettings.FirstOrDefault(r => r.Phase == detailMatch.Phase && r.RoundNumber == detailMatch.Round);
                                            <p class="small text-muted">⏱ @(detailMatch.FinishedUtc.HasValue ? "Spieldauer" : "Spielzeit"): @($"{(int)matchElapsed.TotalMinutes} min")
                                                @if (detailMatch.FinishedUtc is null && matchRound is not null && matchRound.LegDurationSeconds > 0)
                                                {
                                                    var plannedMins = (matchRound.Sets ?? 1) * matchRound.Legs * matchRound.LegDurationSeconds / 60;
                                                    var remaining = plannedMins - (int)matchElapsed.TotalMinutes;
                                                    @if (remaining > 0)
                                                    {
                                                        <span class="text-muted">(~@remaining min verbleibend)</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-danger">(+@(Math.Abs(remaining)) min über geplanter Dauer)</span>
                                                    }
                                                }
                                            </p>
                                        }
                                    </div>
                                    <div id="detailSection-allgemein" class="mt-2">
                                        <div class="small fw-semibold text-secondary text-uppercase mb-1">⚙️ Allgemein</div>
                                        <p class="small text-muted mb-2">🔗 ExternalMatchId: <span class="font-monospace">@(string.IsNullOrWhiteSpace(detailMatch.ExternalMatchId) ? "—" : detailMatch.ExternalMatchId)</span></p>
                                        @if (!string.IsNullOrWhiteSpace(detailMatch.ExternalMatchId) && matchListener is null && detailMatch.StartedUtc is not null && detailMatch.FinishedUtc is null)
                                        {
                                            <div class="alert alert-warning py-2 px-3 mb-2 small d-flex align-items-center gap-2 flex-wrap">
                                                <span>⚠️ Kein Listener aktiv — Match-Status unbekannt.</span>
                                                <div class="d-flex gap-1">
                                                    @if (CanStartListener(detailMatch))
                                                    {
                                                        <button class="btn btn-outline-success btn-sm" @onclick="() => EnsureListenerAsync(detailMatch)" disabled="@isWorking">🎧 Listener starten</button>
                                                    }
                                                    <button class="btn btn-outline-danger btn-sm" @onclick="ResetMatchAsync" disabled="@isWorking">↩ Zurücksetzen</button>
                                                </div>
                                            </div>
                                        }
                                        @if (assignedBoard is not null)
                                        {
                                            <p class="small">📋 Board: <strong role="button" style="cursor:pointer;text-decoration:underline dotted" @onclick="() => { var m = detailMatch; var fromSchedule = detailMatchOpenedFromSchedule; _modalBackStack.Push(() => OpenMatchDetail(m!, fromSchedule)); CloseMatchDetail(); OpenBoardDetail(assignedBoard); }">@assignedBoard.Name</strong>
                                                @if (detailMatch.IsBoardLocked) { <span class="text-primary fw-semibold ms-1">🔒 Gesperrt</span> }</p>
                                            @if (gameplayText is not null)
                                            {
                                                <p class="small text-muted mb-2">🎮 @gameplayText</p>
                                            }
                                            <div class="d-flex gap-2 mb-3">
                                                @if (!string.IsNullOrEmpty(detailMatch.ExternalMatchId))
                                                {
                                                    <a href="https://play.autodarts.io/boards/@(assignedBoard.ExternalBoardId)/follow" target="_blank"
                                                           rel="noopener" class="btn btn-outline-primary btn-sm">
                                                        <span class="autodarts-icon"></span> Spiel verfolgen
                                                    </a>
                                                }
                                                else if (CanSendUpcomingMatch(detailMatch))
                                                {
                                                    <button class="btn btn-success btn-sm" @onclick="() => SendUpcomingMatchAsync(detailMatch)" disabled="@isWorking">
                                                        ▶ Match starten
                                                    </button>
                                                }
                                            </div>
                                            <div class="d-flex flex-column gap-1 mb-2">
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="badge @GetMonitoringBadgeCss(detailMatch)">@GetMonitoringBadgeText(detailMatch)</span>
                                                    @if (matchListener?.LastUpdateUtc is not null)
                                                    {
                                                        <span class="small text-muted">Letztes Update: @matchListener.LastUpdateUtc.Value.LocalDateTime.ToString("HH:mm:ss")</span>
                                                    }
                                                    @if (CanStartListener(detailMatch))
                                                    {
                                                        <button class="btn btn-outline-success btn-sm" @onclick="() => EnsureListenerAsync(detailMatch)" disabled="@isWorking">
                                                            🎧 Listener starten
                                                        </button>
                                                    }
                                                </div>
                                                @if (matchListener?.LastError is not null && !_dismissedListenerErrors.Contains(detailMatch.Id))
                                                {
                                                    @if (string.Equals(matchListener.LastError, "Match not found on Autodarts", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <div class="alert alert-warning py-2 px-3 mb-0 small d-flex align-items-center gap-2 flex-wrap">
                                                            <span>⚠️ Das Spiel scheint nicht mehr online zu sein. Soll es zurückgesetzt werden?</span>
                                                            <div class="d-flex gap-1">
                                                                <button class="btn btn-danger btn-sm" @onclick="ResetMatchAsync" disabled="@isWorking">Ja, zurücksetzen</button>
                                                                <button class="btn btn-outline-secondary btn-sm" @onclick='() => DismissListenerError(detailMatch.Id)' disabled="@isWorking">Nein</button>
                                                            </div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="alert alert-danger py-1 px-2 mb-0 small">@matchListener.LastError</div>
                                                    }
                                                }
                                            </div>
                                        }
                                        @if (detailMatch.WinnerParticipantId.HasValue)
                                        {
                                            <p class="mt-2">🏆 Gewinner: <strong
                                                class="text-success">@ParticipantName(detailMatch.WinnerParticipantId)</strong></p>
                                        }

                                        @{
                                            var homeNextMatch = GetNextMatchInfo(detailMatch, detailMatch.HomeParticipantId);
                                            var awayNextMatch = GetNextMatchInfo(detailMatch, detailMatch.AwayParticipantId);
                                        }
                                        @if (homeNextMatch is not null || awayNextMatch is not null)
                                        {
                                            <div class="small text-muted mt-2">
                                                @if (homeNextMatch is not null)
                                                {
                                                    <p class="mb-1">➡ @(homeP?.DisplayName?.ToUpperInvariant() ?? "?"): @homeNextMatch</p>
                                                }
                                                @if (awayNextMatch is not null)
                                                {
                                                    <p class="mb-1">➡ @(awayP?.DisplayName?.ToUpperInvariant() ?? "?"): @awayNextMatch</p>
                                                }
                                            </div>
                                        }

                                        @* ─── Match Statistics (#18) ─── *@
                                        @if (detailMatchStatistics.Count > 0 || isLoadingStats)
                                        {
                                            <hr />
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <h6 class="fw-semibold mb-0">Statistiken</h6>
                                                <button class="btn btn-outline-secondary btn-sm" @onclick="SyncMatchStatisticsAsync" disabled="@isLoadingStats">
                                                    @if (isLoadingStats) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                    🔄 Aktualisieren
                                                </button>
                                            </div>
                                            <MatchStatistics Statistics="@detailMatchStatistics" />
                                        }

                                        @if (CanSetWalkover(detailMatch))
                                        {
                                            <div class="d-flex align-items-center gap-2 mt-2 mb-2">
                                                <button class="btn btn-outline-dark btn-sm" @onclick="() => OpenWalkoverDialog(detailMatch)" disabled="@isWorking">
                                                    ⚑ Walkover setzen
                                                </button>
                                                <span class="small text-muted">Nur zulaessig fuer noch nicht gestartete Matches.</span>
                                            </div>
                                        }

                                        @if (showWalkoverConfirm)
                                        {
                                            <div class="alert alert-warning py-2">
                                                <div class="fw-semibold mb-2">Walkover bestaetigen</div>
                                                <div class="small mb-2">Waehlen Sie den Teilnehmer, der als Gewinner fortgeschrieben werden soll.</div>
                                                <select class="form-select form-select-sm mb-2" @bind="walkoverWinnerId" disabled="@isWorking">
                                                    <option value="">-- Gewinner waehlen --</option>
                                                    @if (detailMatch.HomeParticipantId != Guid.Empty)
                                                    {
                                                        <option value="@detailMatch.HomeParticipantId">@(homeP?.DisplayName ?? "Heim")</option>
                                                    }
                                                    @if (detailMatch.AwayParticipantId != Guid.Empty)
                                                    {
                                                        <option value="@detailMatch.AwayParticipantId">@(awayP?.DisplayName ?? "Gast")</option>
                                                    }
                                                </select>
                                                <div class="d-flex gap-2">
                                                    <button class="btn btn-dark btn-sm" @onclick="ApplyWalkoverAsync" disabled="@isWorking">
                                                        Walkover uebernehmen
                                                    </button>
                                                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelWalkoverDialog" disabled="@isWorking">
                                                        Abbrechen
                                                    </button>
                                                </div>
                                            </div>
                                        }

                                        <hr />
                                        @if (showManualResultEditor)
                                        {
                                            <h6 class="fw-semibold">Ergebnis manuell eintragen / korrigieren</h6>
                                            @if (IsSetMode(detailMatch))
                                            {
                                                <div class="row g-2 align-items-end mb-2">
                                                    <div class="col">
                                                        <label class="form-label small score-player-label" title="@(homeP?.DisplayName?.ToUpperInvariant() ?? "Heim")">@(homeP?.DisplayName?.ToUpperInvariant() ?? "Heim") — Sets</label>
                                                        <input type="number" class="form-control" @bind="editHomeSets" min="0" />
                                                    </div>
                                                    <div class="col-auto pt-4">:</div>
                                                    <div class="col">
                                                        <label class="form-label small score-player-label" title="@(awayP?.DisplayName?.ToUpperInvariant() ?? "Gast")">@(awayP?.DisplayName?.ToUpperInvariant() ?? "Gast") — Sets</label>
                                                        <input type="number" class="form-control" @bind="editAwaySets" min="0" />
                                                    </div>
                                                </div>
                                            }
                                            <div class="row g-2 align-items-end mb-2">
                                                <div class="col">
                                                    <label class="form-label small score-player-label" title="@(homeP?.DisplayName?.ToUpperInvariant() ?? "Heim")">@(homeP?.DisplayName?.ToUpperInvariant() ?? "Heim") — Legs</label>
                                                    <input type="number" class="form-control" @bind="editHomeLegs" min="0" />
                                                </div>
                                                <div class="col-auto pt-4">:</div>
                                                <div class="col">
                                                    <label class="form-label small score-player-label" title="@(awayP?.DisplayName?.ToUpperInvariant() ?? "Gast")">@(awayP?.DisplayName?.ToUpperInvariant() ?? "Gast") — Legs</label>
                                                    <input type="number" class="form-control" @bind="editAwayLegs" min="0" />
                                                </div>
                                                <div class="col-auto">
                                                    <button class="btn btn-primary" @onclick="SaveResultAsync" disabled="@isWorking">Ergebnis speichern</button>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="alert alert-secondary py-2 small">
                                                Ergebnisfelder eingeklappt, weil dieses Match aus dem Spielplan geoeffnet wurde und ein aktiver Listener laeuft.
                                            </div>
                                        }
                                        @if (resultError is not null)
                                        {
                                            <div class="alert alert-danger py-2 small">@resultError</div>
                                        }
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button class="btn btn-outline-danger me-auto" @onclick="ResetMatchAsync" disabled="@isWorking"
                                            title="Spielstand, Start-/Endzeit und ExternalMatchId zurücksetzen">
                                        🗑 Zurücksetzen
                                    </button>
                                    <button class="btn btn-secondary" @onclick="CloseMatchDetail">Schließen</button>
                                </div>
                            </div>
                        </div>
                    </div>
            }

                            @* ─── Participant Edit Modal ─── *@
                            @if (editingParticipant is not null)
                            {
                                <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Teilnehmer bearbeiten</h5>
                                                <button type="button" class="btn-close" @onclick="CancelEditParticipant"></button>
                                            </div>
                                            <div class="modal-body">
                                                <div class="mb-3">
                                                    <label class="form-label fw-semibold">Anzeigename</label>
                                                    <input class="form-control" @bind="editPDisplayName" />
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label fw-semibold">Account-Name</label>
                                                    <input class="form-control" @bind="editPAccountName" />
                                                </div>
                                                <div class="form-check mb-2">
                                                    <input class="form-check-input" type="checkbox" id="editPIsAuto" @bind="editPIsAutodarts" />
                                                    <label class="form-check-label" for="editPIsAuto">Autodarts Account</label>
                                                </div>
                                                <div class="form-check mb-3">
                                                    <input class="form-check-input" type="checkbox" id="editPIsManager" @bind="editPIsManager" />
                                                    <label class="form-check-label" for="editPIsManager">Spielleiter</label>
                                                </div>
                                                @if (editPError is not null)
                                                {
                                                    <div class="alert alert-danger py-2">@editPError</div>
                                                }
                                            </div>
                                            <div class="modal-footer">
                                                <button class="btn btn-secondary" @onclick="CancelEditParticipant">Abbrechen</button>
                                                <button class="btn btn-primary" @onclick="SaveParticipantEditAsync"
                                                        disabled="@isWorking">Speichern</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            @* ─── Tournament List + Detail ─── *@

                            @* ─── Player Detail Modal ─── *@
                            @if (detailParticipant is not null)
                            {
                                <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="() => detailParticipant = null">
                                    <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation>
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">
                                                    @ParticipantDisplayName(detailParticipant)
                                                    @if (detailParticipant.IsAutodartsAccount) { <span class="autodarts-icon ms-1" title="Autodarts"></span> }
                                                    @if (detailParticipant.IsManager) { <span class="badge text-bg-warning ms-1">Spielleiter</span> }
                                                </h5>
                                                <button type="button" class="btn-close" @onclick="() => detailParticipant = null"></button>
                                            </div>
                                            <div class="modal-body">
                                                <ul class="nav nav-tabs mb-3">
                                                    <li class="nav-item">
                                                        <button class="nav-link @(playerDetailTab == "info" ? "active" : "")" @onclick='() => playerDetailTab = "info"'>Spielerinfo</button>
                                                    </li>
                                                    <li class="nav-item">
                                                        <button class="nav-link @(playerDetailTab == "results" ? "active" : "")" @onclick='() => playerDetailTab = "results"'>Ergebnisse</button>
                                                    </li>
                                                    <li class="nav-item">
                                                        <button class="nav-link @(playerDetailTab == "upcoming" ? "active" : "")" @onclick='() => playerDetailTab = "upcoming"'>Nächste Begegnungen</button>
                                                    </li>
                                                </ul>

                                                @if (playerDetailTab == "info")
                                                {
                                                    var pMatches = matches.Where(m => m.HomeParticipantId == detailParticipant.Id || m.AwayParticipantId == detailParticipant.Id).ToList();
                                                    var played = pMatches.Where(m => m.FinishedUtc is not null && m.HomeParticipantId != Guid.Empty && m.AwayParticipantId != Guid.Empty).ToList();
                                                    var wins = played.Count(m => m.WinnerParticipantId == detailParticipant.Id);
                                                    var losses = played.Count - wins;
                                                    var legsWon = played.Sum(m => m.HomeParticipantId == detailParticipant.Id ? m.HomeLegs : m.AwayLegs);
                                                    var legsLost = played.Sum(m => m.HomeParticipantId == detailParticipant.Id ? m.AwayLegs : m.HomeLegs);
                                                    var last5 = played.OrderByDescending(m => m.FinishedUtc).Take(5).ToList();

                                                    <dl class="row mb-3">
                                                        <dt class="col-sm-4">Account</dt>
                                                        <dd class="col-sm-8">@if (detailParticipant.IsAutodartsAccount) { <span class="autodarts-icon me-1"></span> } @detailParticipant.AccountName @if (!detailParticipant.IsAutodartsAccount) { <span>(Lokal)</span> }</dd>
                                                        <dt class="col-sm-4">Setzposition</dt>
                                                        <dd class="col-sm-8">@ParticipantSeedLabel(detailParticipant)</dd>
                                                        <dt class="col-sm-4">Gesamt</dt>
                                                        <dd class="col-sm-8">@played.Count Spiele — @wins S / @losses N</dd>
                                                        <dt class="col-sm-4">Legs</dt>
                                                        <dd class="col-sm-8">@legsWon : @legsLost (Diff: @(legsWon - legsLost > 0 ? "+" : "")@(legsWon - legsLost))</dd>
                                                        @if (played.Count > 0)
                                                        {
                                                            <dt class="col-sm-4">Siegquote</dt>
                                                            <dd class="col-sm-8">@((wins * 100.0 / played.Count).ToString("F0")) %</dd>
                                                        }
                                                    </dl>

                                                    @if (last5.Any())
                                                    {
                                                        <h6 class="fw-semibold small">Letzte 5 Spiele</h6>
                                                        <div class="d-flex gap-1 mb-2">
                                                            @foreach (var m in last5)
                                                            {
                                                                var isWin = m.WinnerParticipantId == detailParticipant.Id;
                                                                <span class="badge @(isWin ? "bg-success" : "bg-danger")">@(isWin ? "S" : "N")</span>
                                                            }
                                                        </div>
                                                    }
                                                }

                                                @if (playerDetailTab == "results")
                                                {
                                                    var pPlayed = matches.Where(m => m.FinishedUtc is not null && (m.HomeParticipantId == detailParticipant.Id || m.AwayParticipantId == detailParticipant.Id) && m.HomeParticipantId != Guid.Empty && m.AwayParticipantId != Guid.Empty)
                                                        .OrderByDescending(m => m.FinishedUtc).ToList();

                                                    @if (pPlayed.Any())
                                                    {
                                                        <table class="table table-sm">
                                                            <thead>
                                                                <tr><th>Match</th><th>Gegner</th><th>Ergebnis</th><th></th></tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var m in pPlayed)
                                                                {
                                                                    var isHome = m.HomeParticipantId == detailParticipant.Id;
                                                                    var opponentId = isHome ? m.AwayParticipantId : m.HomeParticipantId;
                                                                    var myLegs = isHome ? m.HomeLegs : m.AwayLegs;
                                                                    var oppLegs = isHome ? m.AwayLegs : m.HomeLegs;
                                                                    var isWin = m.WinnerParticipantId == detailParticipant.Id;
                                                                    <tr>
                                                                        <td class="small">@MatchLabel(m)</td>
                                                                        <td>@ParticipantNameWithSeed(opponentId)</td>
                                                                        <td>@myLegs : @oppLegs</td>
                                                                        <td><span class="badge @(isWin ? "bg-success" : "bg-danger")">@(isWin ? "S" : "N")</span></td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    }
                                                    else
                                                    {
                                                        <p class="text-muted small">Noch keine Ergebnisse.</p>
                                                    }
                                                }

                                                @if (playerDetailTab == "upcoming")
                                                {
                                                    var pUpcoming = matches.Where(m => m.FinishedUtc is null && (m.HomeParticipantId == detailParticipant.Id || m.AwayParticipantId == detailParticipant.Id) && m.HomeParticipantId != Guid.Empty && m.AwayParticipantId != Guid.Empty)
                                                        .OrderBy(m => m.PlannedStartUtc ?? DateTimeOffset.MaxValue).ToList();

                                                    @if (pUpcoming.Any())
                                                    {
                                                        <table class="table table-sm">
                                                            <thead>
                                                                <tr><th>Match</th><th>Gegner</th><th>Startzeit</th><th>Board</th></tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var m in pUpcoming)
                                                                {
                                                                    var isHome = m.HomeParticipantId == detailParticipant.Id;
                                                                    var opponentId = isHome ? m.AwayParticipantId : m.HomeParticipantId;
                                                                    var board = boards.FirstOrDefault(b => b.Id == m.BoardId);
                                                                    <tr>
                                                                        <td class="small">@MatchLabel(m)</td>
                                                                        <td>@ParticipantNameWithSeed(opponentId)</td>
                                                                        <td class="small">@(m.PlannedStartUtc?.LocalDateTime.ToString("HH:mm") ?? "—")</td>
                                                                        <td class="small">@(board?.Name ?? "—")</td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    }
                                                    else
                                                    {
                                                        <p class="text-muted small">Keine anstehenden Begegnungen.</p>
                                                    }
                                                }
                                            </div>
                                            <div class="modal-footer">
                                                <button class="btn btn-secondary" @onclick="() => detailParticipant = null">Schließen</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            @* ─── Tournament List + Detail ─── *@
                            <div class="row g-3 tournaments-main-row @(selectedTournament is not null ? "has-detail" : string.Empty) @(tournamentListCollapsed ? "is-collapsed" : string.Empty) @((tournamentListMobileOpen || !tournamentListCollapsed) ? "is-mobile-open" : string.Empty)">
                                @if (selectedTournament is not null && IsTournamentListPanelOpen)
                                {
                                    <button type="button"
                                            class="tournament-list-backdrop"
                                            title="Turnierliste schließen"
                                            @onclick="CloseTournamentListMobileAsync"></button>
                                }

                                @if (selectedTournament is not null && tournamentListCollapsed)
