                                                                                                            </div>
                                                                                                        </div>
                                                                                                        <div class="d-flex gap-2 flex-wrap">
                                                                                                            <button class="btn btn-primary btn-sm" @onclick="SaveRoundAsync" disabled="@(isWorking || !CanEditTournamentStructure)">Runde speichern</button>
                                                                                                            <button class="btn btn-outline-secondary btn-sm" @onclick="ApplyRoundToAllAsync" disabled="@(isWorking || !CanEditTournamentStructure)">Für alle Runden festlegen</button>
                                                                                                            <button class="btn btn-outline-secondary btn-sm" @onclick="ApplyRoundToSubsequentAsync" disabled="@(isWorking || !CanEditTournamentStructure)">Für alle nachfolgenden Runden festlegen</button>
                                                                                                        </div>
                                                                                                        @if (roundError is not null)
                                                                                                        {
                                                                                                            <div class="alert alert-danger py-1 mt-2 small">@roundError</div>
                                                                                                        }
                                                                                                    </div>
                                                                                                </div>
                                                                                            }
                                                                                        }

                                                                                                        @* ═══════ Tab: Auslosung ═══════ *@
                                                                                                        @if (activeTab == "draw")
                                                                                                        {
                                                                                                            @if (!CanEditTournamentStructure && HasProgressedMatches)
                                                                                                            {
                                                                                                                <div class="alert alert-warning py-2 small mb-3">
                                                                                                                    Die Turnierstruktur ist gesperrt, weil bereits ein Match gestartet oder beendet wurde. Auslosung und Paarungen sind nur noch read-only.
                                                                                                                </div>
                                                                                                            }

                                                                                                            <div class="d-flex align-items-center gap-2 mb-2">
                                                                                                                <span class="badge text-bg-secondary">Auslosung</span>
                                                                                                                <span class="small text-muted">Fortschritt: @EffectiveDrawParticipants.Count(p => p.GroupNumber.HasValue && p.GroupNumber > 0)/@EffectiveDrawParticipants.Count (@TeamFormationProgressPercent%)</span>
                                                                                                            </div>

                                                                                                            @* ─── Group/Draw Settings (moved from Gruppenphase) ─── *@
                                                                                                            @if (ShowGroupSettingsSection())
                                                                                                            {
                                                                                                                <details class="card mb-3" open>
                                                                                                                    <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
                                                                                                                        <span>
                                                                                                                            Gruppenphase-Einstellungen
                                                                                                                            @if (HasGroupSettingsRequiredMissing())
                                                                                                                            {
                                                                                                                                <span class="text-danger ms-2" title="Pflichteinstellungen fehlen">⚠</span>
                                                                                                                            }
                                                                                                                        </span>
                                                                                                                        <span class="d-none d-md-inline small text-muted">@GroupSettingsSummary()</span>
                                                                                                                    </summary>
                                                                                                                    <div class="card-body">
                                                                                                                        @if (CanEditGroupConfig)
                                                                                                                        {
                                                                                                                            <div class="row g-2 mb-3">
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Anzahl Gruppen für die Gruppenphase.">Anzahl Gruppen</label>
                                                                                                                                    <select class="form-select form-select-sm @(editGroupCount < 1 ? "border-danger" : "")" @bind="editGroupCount" @bind:after="AutoSaveSettingAsync">
                                                                                                                                        @for (var i = 1; i <= 16; i++)
                                                                                                                                        {
                                                                                                                                            <option value="@i">@i</option>
                                                                                                                                        }
                                                                                                                                    </select>
                                                                                                                                </div>
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Anzahl qualifizierter Spieler je Gruppe für die K.O.-Phase.">Playoff-Aufsteiger</label>
                                                                                                                                    <input type="number" class="form-control form-control-sm @(editPlayoffAdvancers < 1 ? "border-danger" : "")" @bind="editPlayoffAdvancers" @bind:after="AutoSaveSettingAsync" min="1" />
                                                                                                                                </div>
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Wie oft jeder Teilnehmer gegen denselben Gegner spielt.">Matches/Gegner</label>
                                                                                                                                    <select class="form-select form-select-sm @(editMatchesPerOpponent < 1 ? "border-danger" : "")" @bind="editMatchesPerOpponent" @bind:after="AutoSaveSettingAsync">
                                                                                                                                        @for (var i = 1; i <= 12; i++)
                                                                                                                                        {
                                                                                                                                            <option value="@i">@i Runde@(i > 1 ? "n" : "")</option>
                                                                                                                                        }
                                                                                                                                    </select>
                                                                                                                                </div>
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Anzahl parallel gespielter K.O.-Matches je Runde nach der Gruppenphase.">Knockouts/Runde</label>
                                                                                                                                    <input type="number" class="form-control form-control-sm @(editKnockoutsPerRound < 0 ? "border-danger" : "")" @bind="editKnockoutsPerRound" @bind:after="AutoSaveSettingAsync" min="0" />
                                                                                                                                </div>
                                                                                                                            </div>
                                                                                                                            <div class="row g-2 mb-0">
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Jeder gegen jeden oder alternative Gruppenlogik.">Gruppenmodus</label>
                                                                                                                                    <select class="form-select form-select-sm" @bind="editGroupMode" @bind:after="AutoSaveSettingAsync">
                                                                                                                                        <option value="RoundRobin">Jeder gegen Jeden</option>
                                                                                                                                        <option value="Knockout">Knockout</option>
                                                                                                                                        <option value="GroupTournament">Gruppenturnier</option>
                                                                                                                                    </select>
                                                                                                                                </div>
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Zufällig, manuell oder per Lostopf (SeededPots) auslosen.">Auslosungsmodus</label>
                                                                                                                                    <select class="form-select form-select-sm" @bind="editGroupDrawMode" @bind:after="AutoSaveSettingAsync">
                                                                                                                                        <option value="Manual">Manuell</option>
                                                                                                                                        <option value="Random">Zufällig</option>
                                                                                                                                        @if (editSeedingEnabled)
                                                                                                                                        {
                                                                                                                                            <option value="SeededPots">Lostopf</option>
                                                                                                                                        }
                                                                                                                                    </select>
                                                                                                                                </div>
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Erzeugt Gruppenrunden blockweise oder rundenweise über alle Gruppen.">Planungsvariante</label>
                                                                                                                                    <select class="form-select form-select-sm" @bind="editPlanningVariant" @bind:after="AutoSaveSettingAsync">
                                                                                                                                        <option value="GroupByGroup">Gruppe für Gruppe</option>
                                                                                                                                        <option value="RoundByRound">Runde für Runde</option>
                                                                                                                                    </select>
                                                                                                                                </div>
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Reihenfolge der Matches pro Runde innerhalb einer Gruppe.">Reihenfolge</label>
                                                                                                                                    <select class="form-select form-select-sm" @bind="editGroupOrderMode" @bind:after="AutoSaveSettingAsync">
                                                                                                                                        <option value="ReverseEachRound">Folgerunde absteigend</option>
                                                                                                                                        <option value="SameOrder">Immer gleich</option>
                                                                                                                                        <option value="RandomPerRound">Runde zufällig</option>
                                                                                                                                        <option value="AllRandom">Alle zufällig</option>
                                                                                                                                    </select>
                                                                                                                                </div>
                                                                                                                            </div>
                                                                                                                        }
                                                                                                                        else
                                                                                                                        {
                                                                                                                            <div class="small text-muted d-flex flex-wrap gap-2">
                                                                                                                                <span class="badge text-bg-light border">Gruppen: @editGroupCount</span>
                                                                                                                                <span class="badge text-bg-light border">Aufsteiger: @editPlayoffAdvancers</span>
                                                                                                                                <span class="badge text-bg-light border">Matches/Gegner: @editMatchesPerOpponent</span>
                                                                                                                                <span class="badge text-bg-light border">Modus: @editGroupMode</span>
                                                                                                                                <span class="badge text-bg-light border">Auslosung: @editGroupDrawMode</span>
                                                                                                                            </div>
                                                                                                                        }
                                                                                                                    </div>
                                                                                                                </details>

                                                                                                                <details class="card mb-3">
                                                                                                                    <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
                                                                                                                        <span>
                                                                                                                            Punktemodus
                                                                                                                            @if (HasScoringRequiredMissing())
                                                                                                                            {
                                                                                                                                <span class="text-danger ms-2" title="Pflichteinstellungen fehlen">⚠</span>
                                                                                                                            }
                                                                                                                        </span>
                                                                                                                        <span class="d-none d-md-inline small text-muted">@ScoringSummary()</span>
                                                                                                                    </summary>
                                                                                                                    <div class="card-body">
                                                                                                                        @if (CanEditScoring)
                                                                                                                        {
                                                                                                                            <div class="row g-2 mb-0">
                                                                                                                                <div class="col-md-6">
                                                                                                                                    <label class="form-label small" title="Punkte je Sieg in der Gruppentabelle.">Punkte für Sieg</label>
                                                                                                                                    <input type="number" class="form-control form-control-sm @(editWinPoints < 1 ? "border-danger" : "")" @bind="editWinPoints" @bind:after="AutoSaveSettingAsync" min="1" />
                                                                                                                                </div>
                                                                                                                                <div class="col-md-6">
                                                                                                                                    <label class="form-label small" title="Gewichtung gewonnener Legs für Ranking/Tiebreak.">Faktor gewonnene Legs</label>
                                                                                                                                    <input type="number" class="form-control form-control-sm @(editLegFactor < 0 ? "border-danger" : "")" @bind="editLegFactor" @bind:after="AutoSaveSettingAsync" min="0" />
                                                                                                                                </div>
                                                                                                                            </div>

                                                                                                                            <hr class="my-3" />
                                                                                                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                                                                                                <label class="form-label small fw-semibold mb-0">Tiebreaker-Reihenfolge</label>
                                                                                                                                <button class="btn btn-outline-primary btn-sm" @onclick="SaveScoringCriteriaAsync" disabled="@(isSavingScoringCriteria || isWorking)">Speichern</button>
                                                                                                                            </div>
                                                                                                                            <div class="small text-muted mb-2">Aktivieren und per Pfeilen sortieren. Die Reihenfolge wird serverseitig fuer die Gruppenwertung genutzt.</div>
                                                                                                                            @for (var idx = 0; idx < scoringCriteria.Count; idx++)
                                                                                                                            {
                                                                                                                                var criterion = scoringCriteria[idx];
                                                                                                                                <div class="d-flex align-items-center gap-2 mb-1">
                                                                                                                                    <span class="badge text-bg-light border" style="min-width:2rem">@(idx + 1)</span>
                                                                                                                                    <input class="form-check-input" type="checkbox" @bind="criterion.IsEnabled" />
                                                                                                                                    <span class="small flex-grow-1">@ScoringCriterionLabel(criterion.Type)</span>
                                                                                                                                    <button class="btn btn-outline-secondary btn-sm py-0 px-2" title="Nach oben" @onclick="() => MoveScoringCriterionUp(idx)" disabled="@(idx == 0)">↑</button>
                                                                                                                                    <button class="btn btn-outline-secondary btn-sm py-0 px-2" title="Nach unten" @onclick="() => MoveScoringCriterionDown(idx)" disabled="@(idx == scoringCriteria.Count - 1)">↓</button>
                                                                                                                                </div>
                                                                                                                            }
                                                                                                                            @if (scoringCriteriaError is not null)
                                                                                                                            {
                                                                                                                                <div class="alert alert-danger py-1 mt-2 mb-0 small">@scoringCriteriaError</div>
                                                                                                                            }
                                                                                                                        }
                                                                                                                        else
                                                                                                                        {
                                                                                                                            @if (HasStartedGroupMatch)
                                                                                                                            {
                                                                                                                                <div class="alert alert-info py-1 small">Punkte- und Tiebreaker-Logik ist gesperrt, weil die Gruppenphase bereits gestartet wurde.</div>
                                                                                                                            }
                                                                                                                            <div class="small text-muted d-flex flex-wrap gap-2">
                                                                                                                                <span class="badge text-bg-light border">Siegpunkte: @editWinPoints</span>
                                                                                                                                <span class="badge text-bg-light border">Leg-Faktor: @editLegFactor</span>
                                                                                                                            </div>
                                                                                                                            @if (scoringCriteria.Any(c => c.IsEnabled))
                                                                                                                            {
                                                                                                                                <div class="small text-muted d-flex flex-wrap gap-2 mt-2">
                                                                                                                                    @foreach (var criterion in scoringCriteria.Where(c => c.IsEnabled).OrderBy(c => c.Priority))
                                                                                                                                    {
                                                                                                                                        <span class="badge text-bg-light border">@criterion.Priority. @ScoringCriterionLabel(criterion.Type)</span>
                                                                                                                                    }
                                                                                                                                </div>
                                                                                                                            }
                                                                                                                        }
                                                                                                                    </div>
                                                                                                                </details>
                                                                                                            }

                                                                                                            @* ─── Auto-Draw Actions (GroupAndKnockout) ─── *@
                                                                                                            @if (ShowGroupSettingsSection() && IsCurrentUserManager && !selectedTournament.IsLocked
                                                                                                                 && selectedTournament.Status is "Erstellt" or "Geplant")
                                                                                                            {
                                                                                                                <div class="d-flex flex-wrap gap-2 mb-3">
                                                                                                                    <div class="d-flex align-items-center gap-2 me-2">
                                                                                                                        <label class="small text-muted mb-0">Animation</label>
                                                                                                                        <select class="form-select form-select-sm" style="width: 140px;" @bind="drawAnimationMode" disabled="@(isWorking || isDrawAnimating || !CanEditTournamentStructure)">
                                                                                                                            <option value="Off">Aus</option>
                                                                                                                            <option value="Exciting">Spannend</option>
                                                                                                                            <option value="Moderate">Moderat</option>
                                                                                                                        </select>
                                                                                                                    </div>
                                                                                                                    @if (editGroupDrawMode is "Random" or "SeededPots")
                                                                                                                    {
                                                                                                                        <span class="@(CanEditTournamentStructure ? "" : "btn-reason-wrap")" title="@CannotEditStructureReason">
                                                                                                                            <button class="btn btn-primary btn-sm" @onclick="AutoDrawAsync" disabled="@(isWorking || isDrawAnimating || !CanEditTournamentStructure)">⚡ Automatisch auslosen</button>
                                                                                                                        </span>
                                                                                                                    }
                                                                                                                    @if (editGroupDrawMode == "SeededPots" && editSeedingEnabled)
                                                                                                                    {
                                                                                                                        <button class="btn btn-outline-secondary btn-sm" @onclick="AssignSeedPotsAndDistributeAsync" disabled="@(isWorking || !CanEditTournamentStructure)">🎲 Lostöpfe zuteilen</button>
                                                                                                                    }
                                                                                                                    @if (HasDrawAssignments())
                                                                                                                    {
                                                                                                                        <button class="btn btn-outline-warning btn-sm" @onclick="ResetDrawAsync" disabled="@(isWorking || isDrawAnimating || !CanEditTournamentStructure)">↩ Auslosung zurücksetzen</button>
                                                                                                                    }
                                                                                                                </div>
                                                                                                                @if (isDrawAnimating)
                                                                                                                {
                                                                                                                    <div class="alert alert-secondary py-1 small">Auslosung läuft…</div>
                                                                                                                }
                                                                                                            }

                                                                                                                @if (editGroupDrawMode == "SeededPots" && editSeedingEnabled && participants.Any(p => p.SeedPot > 0))
                                                                                                                {
                                                                                                                    <div class="small text-muted mb-2">
                                                                                                                        @foreach (var pot in participants.Where(p => p.SeedPot > 0).GroupBy(p => p.SeedPot).OrderBy(g => g.Key))
                                                                                                                        {
                                                                                                                            <span class="badge @PotBadgeCss(pot.Key) me-1">Topf @pot.Key: @pot.Count()</span>
                                                                                                                        }
                                                                                                                    </div>
                                                                                                                }

                                                                                                                <div class="row g-3">
                                                                                                                    @* ─── Left: Unassigned Participants ─── *@
                                                                                                                    @{ var unassigned = UnassignedParticipants; }
                                                                                                                    @if (unassigned.Any())
                                                                                                                    {
                                                                                                                        <div class="col-md-4">
                                                                                                                            @if (editGroupDrawMode == "SeededPots" && editSeedingEnabled)
                                                                                                                            {
                                                                                                                                var unassignedByPot = unassigned.Where(p => p.SeedPot > 0).GroupBy(p => p.SeedPot).OrderBy(g => g.Key).ToList();
                                                                                                                                <div class="d-flex flex-column gap-2" style="max-height:500px; overflow-y:auto">
                                                                                                                                    @if (unassignedByPot.Any())
                                                                                                                                    {
                                                                                                                                        @foreach (var pot in unassignedByPot)
                                                                                                                                        {
                                                                                                                                            <div class="card border-2 @DrawPotAnimationCss(pot.Key)">
                                                                                                                                                <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                                                                                                                                    <strong class="small">Topf @pot.Key</strong>
                                                                                                                                                    <span class="badge @PotBadgeCss(pot.Key)">@pot.Count()</span>
                                                                                                                                                </div>
                                                                                                                                                <div class="card-body p-2">
                                                                                                                                                    @foreach (var p in pot.OrderBy(p => p.Seed > 0 ? p.Seed : int.MaxValue).ThenBy(p => p.DisplayName))
                                                                                                                                                    {
                                                                                                                                                          <div class="badge bg-dark p-2 me-1 mb-1 user-select-none @DrawParticipantAnimationCss(p.Id)" draggable="@(CanEditTournamentStructure ? "true" : "false")"
                                                                                                                                                             @ondragstart="() => draggedParticipantId = p.Id" style="cursor:grab; font-size:.85em">
                                                                                                                                                            @if (editSeedingEnabled && p.Seed > 0 && p.Seed <= editSeedTopCount)
                                                                                                                                                            {
                                                                                                                                                                <span class="badge text-bg-warning me-1">#@p.Seed</span>
                                                                                                                                                            }
                                                                                                                                                            <span class="badge @PotBadgeCss(p.SeedPot) me-1">Topf @p.SeedPot</span>
                                                                                                                                                            @p.DisplayName.ToUpperInvariant()
                                                                                                                                                        </div>
                                                                                                                                                    }
                                                                                                                                                </div>
                                                                                                                                            </div>
                                                                                                                                        }
                                                                                                                                    }
                                                                                                                                    else
                                                                                                                                    {
                                                                                                                                        <div class="alert alert-info py-2 small mb-0">Keine Lostöpfe vorhanden. Bitte zuerst "Lostöpfe zuteilen" ausführen.</div>
                                                                                                                                    }
                                                                                                                                </div>
                                                                                                                            }
                                                                                                                            else
                                                                                                                            {
                                                                                                                                <div class="card">
                                                                                                                                    <div class="card-header py-2">
                                                                                                                                            <strong class="small">@(IsTeamplayActive ? "Teams" : "Teilnehmer")</strong>
                                                                                                                                        <span class="badge text-bg-secondary ms-1">@unassigned.Count</span>
                                                                                                                                    </div>
                                                                                                                                    <div class="card-body p-2" style="max-height:500px; overflow-y:auto">
                                                                                                                                        @foreach (var p in unassigned.OrderBy(p => p.Seed > 0 ? p.Seed : int.MaxValue).ThenBy(p => p.DisplayName))
                                                                                                                                        {
                                                                                                                                            <div class="badge bg-dark p-2 me-1 mb-1 user-select-none @DrawParticipantAnimationCss(p.Id)" draggable="@(CanEditTournamentStructure ? "true" : "false")"
                                                                                                                                                 @ondragstart="() => draggedParticipantId = p.Id" style="cursor:grab; font-size:.85em">
                                                                                                                                                @if (editSeedingEnabled && p.Seed > 0 && p.Seed <= editSeedTopCount)
                                                                                                                                                {
                                                                                                                                                    <span class="badge text-bg-warning me-1">#@p.Seed</span>
                                                                                                                                                }
                                                                                                                                                @p.DisplayName.ToUpperInvariant()
                                                                                                                                            </div>
                                                                                                                                        }
                                                                                                                                    </div>
                                                                                                                                </div>
                                                                                                                            }
                                                                                                                        </div>
                                                                                                                    }

                                                                                                                    @* ─── Right: Group Containers ─── *@
                                                                                                                    <div class="@(unassigned.Any() ? "col-md-8" : "col-12")">
                                                                                                                        <div class="row g-2">
                                                                                                                            @for (var g = 1; g <= editGroupCount; g++)
                                                                                                                            {
                                                                                                                                var groupNum = g;
                                                                                                                                var groupParts = GroupParticipants(groupNum);
                                                                                                                                var isDropTarget = dropTargetGroupNumber == groupNum;
                                                                                                                                var highlightCss = GroupDropHighlightCss(groupNum);
                                                                                                                                <div class="col-md-6 col-lg-4">
                                                                                                                                                                                  <div class="card @(isDropTarget ? highlightCss : "") @DrawGroupAnimationCss(groupNum)"
                                                                                                                                         @ondragover:preventDefault
                                                                                                                                                                                      @ondragover="() => { if (CanEditTournamentStructure) dropTargetGroupNumber = groupNum; }"
                                                                                                                                                                                      @ondragleave="() => { if (CanEditTournamentStructure && dropTargetGroupNumber == groupNum) dropTargetGroupNumber = null; }"
                                                                                                                                         @ondrop="() => AssignParticipantToGroupAsync(groupNum)">
                                                                                                                                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                                                                                                                            <strong class="small">Gruppe @GroupLabel(groupNum)</strong>
                                                                                                                                            <span class="badge text-bg-secondary">@groupParts.Count / @IdealGroupSize</span>
                                                                                                                                        </div>
                                                                                                                                        <div class="card-body p-2" style="min-height:60px">
                                                                                                                                            @foreach (var p in groupParts)
                                                                                                                                            {
                                                                                                                                                    <div class="badge bg-dark p-2 me-1 mb-1 user-select-none @DrawParticipantAnimationCss(p.Id)" draggable="@(CanEditTournamentStructure ? "true" : "false")"
                                                                                                                                                     @ondragstart="() => draggedParticipantId = p.Id" style="cursor:grab; font-size:.85em">
                                                                                                                                                    @if (editSeedingEnabled && p.Seed > 0 && p.Seed <= editSeedTopCount)
                                                                                                                                                    {
                                                                                                                                                          <span class="badge text-bg-warning me-1">#@p.Seed</span>
                                                                                                                                                    }
                                                                                                                                                        @if (editGroupDrawMode == "SeededPots" && p.SeedPot > 0)
                                                                                                                                                        {
                                                                                                                                                          <span class="badge @PotBadgeCss(p.SeedPot) me-1">Topf @p.SeedPot</span>
                                                                                                                                                        }
                                                                                                                                                    @p.DisplayName.ToUpperInvariant()
                                                                                                                                                        <button class="btn btn-sm p-0 ms-1 text-white-50" style="font-size:.7em; line-height:1"
                                                                                                                                                            @onclick="() => UnassignParticipantFromGroupAsync(p.Id)" @onclick:stopPropagation
                                                                                                                                                            disabled="@(isWorking || !CanEditTournamentStructure)"
                                                                                                                                                            title="Aus Gruppe entfernen">✕</button>
                                                                                                                                                </div>
                                                                                                                                            }
                                                                                                                                            @if (!groupParts.Any())
                                                                                                                                            {
                                                                                                                                                <div class="text-muted small text-center py-2">Teilnehmer hierher ziehen</div>
                                                                                                                                            }
                                                                                                                                        </div>
                                                                                                                                    </div>
                                                                                                                                </div>
                                                                                                                            }
                                                                                                                        </div>
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            }

                                                                                                            @* ─── Draw Area: Knockout mode ─── *@
                                                                                                            @if (selectedTournament.Mode == "Knockout" && IsCurrentUserManager && !selectedTournament.IsLocked
                                                                                                                 && selectedTournament.Status is "Erstellt" or "Geplant")
                                                                                                            {
                                                                                                                <div class="d-flex flex-wrap gap-2 mb-3">
                                                                                                                    <div class="d-flex align-items-center gap-2 me-2">
                                                                                                                        <label class="small text-muted mb-0">Animation</label>
                                                                                                                        <select class="form-select form-select-sm" style="width: 140px;" @bind="drawAnimationMode" disabled="@(isWorking || isDrawAnimating || !CanEditTournamentStructure)">
                                                                                                                            <option value="Off">Aus</option>
                                                                                                                            <option value="Exciting">Spannend</option>
                                                                                                                            <option value="Moderate">Moderat</option>
                                                                                                                        </select>
                                                                                                                    </div>
                                                                                                                    <span class="@(CanEditTournamentStructure ? "" : "btn-reason-wrap")" title="@CannotEditStructureReason">
                                                                                                                        <button class="btn btn-primary btn-sm" @onclick="AutoDrawAsync" disabled="@(isWorking || isDrawAnimating || !CanEditTournamentStructure)">⚡ Auslosung starten</button>
                                                                                                                    </span>
                                                                                                                    @if (KnockoutAssignedParticipants.Any())
                                                                                                                    {
                                                                                                                        <button class="btn btn-outline-warning btn-sm" @onclick="ResetKnockoutDrawCards" disabled="@(isWorking || isDrawAnimating || !CanEditTournamentStructure)">↩ Auslosung zurücksetzen</button>
                                                                                                                    }
                                                                                                                </div>
                                                                                                                @if (isDrawAnimating)
                                                                                                                {
                                                                                                                    <div class="alert alert-secondary py-1 small">Auslosung läuft…</div>
                                                                                                                }

                                                                                                                <div class="row g-3">
                                                                                                                    <div class="col-md-4">
                                                                                                                        <div class="card">
                                                                                                                            <div class="card-header py-2">
                                                                                                                                <strong class="small">@(IsTeamplayActive ? "Teams" : "Teilnehmer")</strong>
                                                                                                                                <span class="badge text-bg-secondary ms-1">@KnockoutUnassignedParticipants.Count</span>
                                                                                                                            </div>
                                                                                                                            <div class="card-body p-2" style="max-height:500px; overflow-y:auto">
                                                                                                                                @foreach (var p in KnockoutUnassignedParticipants)
                                                                                                                                {
                                                                                                                                      <div class="badge bg-dark p-2 me-1 mb-1 user-select-none @DrawParticipantAnimationCss(p.Id)" draggable="@(CanEditTournamentStructure ? "true" : "false")"
                                                                                                                                         @ondragstart="() => StartKnockoutDrag(p.Id)" style="cursor:grab; font-size:.85em">
                                                                                                                                        @if (editSeedingEnabled && p.Seed > 0 && p.Seed <= editSeedTopCount)
                                                                                                                                        {
                                                                                                                                            <span class="badge text-bg-warning me-1">#@p.Seed</span>
                                                                                                                                        }
                                                                                                                                        @p.DisplayName.ToUpperInvariant()
                                                                                                                                    </div>
                                                                                                                                }
                                                                                                                            </div>
                                                                                                                        </div>
                                                                                                                    </div>

                                                                                                                    <div class="col-md-8">
                                                                                                                        <div id="ko-draw-grid" class="position-relative">
                                                                                                                            <div class="row g-2">
                                                                                                                            @foreach (var card in knockoutDrawCards.OrderBy(c => c.MatchNumber))
                                                                                                                            {
                                                                                                                                var home = FindParticipant(card.HomeParticipantId);
                                                                                                                                var away = FindParticipant(card.AwayParticipantId);
                                                                                                                                <div class="col-md-6">
                                                                                                                                    <div class="card">
                                                                                                                                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                                                                                                                            <strong class="small">Match @card.MatchNumber</strong>
                                                                                                                                        </div>
                                                                                                                                        <div class="card-body p-2">
                                                                                                                                            <div id="ko-slot-@card.MatchNumber-home" class="ko-draw-slot mb-2 @DrawKnockoutSlotCss(card.MatchNumber, true)"
                                                                                                                                                 @ondragover:preventDefault
                                                                                                                                                 @ondrop="() => AssignDraggedToKnockoutCard(card.MatchNumber, true)">
                                                                                                                                                @if (home is not null)
                                                                                                                                                {
                                                                                                                                                    <span class="badge bg-dark @DrawParticipantAnimationCss(home.Id)">
                                                                                                                                                        @ParticipantDisplayName(home)
                                                                                                                                                        <button class="btn btn-sm p-0 ms-1 text-white-50" @onclick="() => ClearKnockoutCardSlot(card.MatchNumber, true)" @onclick:stopPropagation disabled="@(isWorking || !CanEditTournamentStructure)">✕</button>
                                                                                                                                                    </span>
                                                                                                                                                }
                                                                                                                                                else
                                                                                                                                                {
                                                                                                                                                    <span class="text-muted small">Spieler 1 hier ablegen</span>
                                                                                                                                                }
                                                                                                                                            </div>

                                                                                                                                            <div id="ko-slot-@card.MatchNumber-away" class="ko-draw-slot @DrawKnockoutSlotCss(card.MatchNumber, false)"
                                                                                                                                                 @ondragover:preventDefault
                                                                                                                                                 @ondrop="() => AssignDraggedToKnockoutCard(card.MatchNumber, false)">
                                                                                                                                                @if (away is not null)
                                                                                                                                                {
                                                                                                                                                    <span class="badge bg-dark @DrawParticipantAnimationCss(away.Id)">
                                                                                                                                                        @ParticipantDisplayName(away)
                                                                                                                                                        <button class="btn btn-sm p-0 ms-1 text-white-50" @onclick="() => ClearKnockoutCardSlot(card.MatchNumber, false)" @onclick:stopPropagation disabled="@(isWorking || !CanEditTournamentStructure)">✕</button>
                                                                                                                                                    </span>
                                                                                                                                                }
                                                                                                                                                else
                                                                                                                                                {
                                                                                                                                                    <span class="text-muted small">Spieler 2 hier ablegen</span>
                                                                                                                                                }
                                                                                                                                            </div>
                                                                                                                                        </div>
                                                                                                                                    </div>
                                                                                                                                </div>
                                                                                                                            }
                                                                                                                            </div>
                                                                                                                            <div class="ko-draw-token @(showKoDrawToken ? "show" : "")" style="@koDrawTokenStyle">🎯</div>
                                                                                                                        </div>
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            }

                                                                                                            @* ─── Plan Create/Delete Buttons ─── *@
                                                                                                            <div class="mt-3">
                                                                                                                @if (!CanProceedWithTeamDraw)
                                                                                                                {
                                                                                                                    <div class="alert alert-warning py-2 small mb-2">Turnierplan kann erst erstellt werden, wenn die Teamzuordnung vollständig und gespeichert ist.</div>
                                                                                                                }
                                                                                                                <div class="d-flex flex-wrap align-items-center gap-2">
                                                                                                                    @if (selectedTournament.Mode == "GroupAndKnockout" && editGroupDrawMode is "Random" or "SeededPots")
                                                                                                                    {
                                                                                                                        <span class="@(CanEditTournamentStructure ? "" : "btn-reason-wrap")" title="@CannotEditStructureReason">
                                                                                                                            <button class="btn btn-primary btn-sm" @onclick="AutoDrawAsync" disabled="@(isWorking || isDrawAnimating || !CanEditTournamentStructure)">⚡ Automatisch auslosen</button>
                                                                                                                        </span>
                                                                                                                    }
                                                                                                                    @if (selectedTournament.Mode == "GroupAndKnockout" && HasDrawAssignments())
                                                                                                                    {
                                                                                                                        <button class="btn btn-outline-warning btn-sm" @onclick="ResetDrawAsync" disabled="@(isWorking || isDrawAnimating || !CanEditTournamentStructure)">↩ Auslosung zurücksetzen</button>
                                                                                                                    }
                                                                                                                    @if (selectedTournament.Mode == "Knockout" && KnockoutAssignedParticipants.Any())
                                                                                                                    {
                                                                                                                        <button class="btn btn-outline-warning btn-sm" @onclick="ResetKnockoutDrawCards" disabled="@(isWorking || isDrawAnimating || !CanEditTournamentStructure)">↩ Auslosung zurücksetzen</button>
                                                                                                                    }

                                                                                                                    @if (!matches.Any() && participants.Count >= 2 && !selectedTournament.IsLocked && IsCurrentUserManager)
                                                                                                                    {
                                                                                                                        <button class="btn btn-success btn-sm" @onclick="CreateTournamentPlanAsync" disabled="@(isWorking || !CanProceedWithTeamDraw || !CanEditTournamentStructure)">✓ Turnierplan erstellen</button>
                                                                                                                    }
                                                                                                                    else if (matches.Any() && !selectedTournament.IsLocked && IsCurrentUserManager)
                                                                                                                    {
                                                                                                                        <button class="btn btn-outline-danger btn-sm" @onclick="DeleteTournamentPlanAsync" disabled="@(isWorking || !CanEditTournamentStructure)">🗑 Turnierplan löschen</button>
                                                                                                                        <button class="btn btn-warning btn-sm" @onclick="RegenerateMatchesAsync" disabled="@(isWorking || !CanEditTournamentStructure)">🔄 Turnierplan neu generieren</button>
                                                                                                                    }
                                                                                                                </div>

                                                                                                                @if (!matches.Any() && selectedTournament.Mode == "GroupAndKnockout" && UnassignedParticipants.Count > 0)
                                                                                                                {
                                                                                                                    <div class="alert alert-info py-2 small mt-2">Alle Teilnehmer müssen einer Gruppe zugewiesen sein, bevor der Turnierplan erstellt werden kann. Noch @UnassignedParticipants.Count nicht zugewiesen.</div>
                                                                                                                }
                                                                                                                @if (!matches.Any() && selectedTournament.Mode == "Knockout" && editGroupDrawMode == "Manual" && !IsKnockoutDrawComplete)
                                                                                                                {
                                                                                                                    <div class="alert alert-info py-2 small mt-2">Bei manueller K.O.-Auslosung müssen alle Teilnehmer einem Match-Slot zugewiesen werden.</div>
                                                                                                                }
                                                                                                                @if (matches.Any() && HasPlayedMatches())
                                                                                                                {
                                                                                                                    <div class="alert alert-warning py-2 mt-2">⚠ Es wurden bereits Matches gespielt. Beim Neugenerieren werden alle Ergebnisse gelöscht.</div>
                                                                                                                }

                                                                                                                @if (!matches.Any() && participants.Count < 2)
                                                                                                                {
                                                                                                                    <p class="text-muted">Mindestens 2 Teilnehmer erforderlich.</p>
                                                                                                                }
                                                                                                            </div>
                                                                                                        }

                                                                                                        @* ═══════ Tab: Gruppenphase ═══════ *@
                                                                                                        @if (activeTab == "groups")
                                                                                                        {
                                                                                                            var groupMatches = matches.Where(m => m.Phase == "Group").ToList();
                                                                                                                            @if (groupMatches.Any())
                                                                                                                            {
                                                                                                                                <div id="section-tournaments-groups" class="d-flex justify-content-between align-items-center mb-2">
                                                                                                                                    <h6 class="fw-semibold mb-0">Gruppenphase</h6>
                                                                                                                                    <div class="d-flex gap-2">
                                                                                                                                        <button class="btn btn-sm btn-outline-secondary"
                                                                                                                                                title="MatchCard-Einstellungen fuer Gruppenphase"
                                                                                                                                                @onclick='() => OpenMatchCardScopeEditor("tournaments::groups")'
                                                                                                                                                @onclick:stopPropagation>⚙</button>
                                                                                                                                        <div class="btn-group btn-group-sm" role="group" aria-label="Gruppenansicht">
                                                                                                                                            <button class="btn @(EffectiveGroupMatchesViewMode == "vertical" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SetGroupMatchesViewModeAsync("vertical")'>Vertikal</button>
                                                                                                                                            <button class="btn @(EffectiveGroupMatchesViewMode == "horizontal" ? "btn-primary" : "btn-outline-primary")" @onclick='() => SetGroupMatchesViewModeAsync("horizontal")' disabled="@isCompactViewport">Horizontal</button>
                                                                                                                                        </div>
                                                                                                                                        <button class="btn btn-sm @(showFlashTable ? "btn-warning" : "btn-outline-warning")"
                                                                                                                                            @onclick="() => showFlashTable = !showFlashTable">
                                                                                                                                            ⚡ @(showFlashTable ? "Blitztabelle ausblenden" : "Blitztabelle anzeigen")
                                                                                                                                        </button>
                                                                                                                                    </div>
                                                                                                                                </div>
                                                                                                                                @if (isCompactViewport)
                                                                                                                                {
                                                                                                                                    <div class="small text-muted mb-2">Mobil ist die Matchliste immer vertikal.</div>
                                                                                                                                }
                                                                                                                                var groups = groupMatches.Select(m => m.GroupNumber ?? 0).Distinct().OrderBy(g => g).ToList();
                                                                                                                                @foreach (var groupNum in groups)
                                                                                                                                {
                                                                                                                                    var groupComplete = IsGroupCompleted(groupNum);
                                                                                                                                    <h6 class="fw-semibold mt-3">Gruppe @GroupLabel(groupNum)
                                                                                                                                        @if (groupComplete) { <span class="badge text-bg-success ms-1">✓</span> }
                                                                                                                                    </h6>
                                                                                                                                    @if (groupStandings.Any(s => s.GroupNumber == groupNum))
                                                                                                                                    {
                                                                                                                                        var standingsData = showFlashTable
                                                                                                                                            ? GetFlashStandings(groupNum)
                                                                                                                                            : groupStandings.Where(x => x.GroupNumber == groupNum).OrderBy(x => x.Rank > 0 ? x.Rank : int.MaxValue).ThenByDescending(x => x.Points).ThenByDescending(x => x.LegDifference).ToList();
                                                                                                                                        @if (showFlashTable)
                                                                                                                                        {
                                                                                                                                            <div class="alert alert-warning py-1 small mb-1">⚡ Blitztabelle — enthält vorläufige Wertungen laufender Matches</div>
                                                                                                                                        }
                                                                                                                                        <GroupTable Standings="@standingsData" QualificationSlots="@selectedTournament.PlayoffAdvancers"
                                                                                                                                                    ShowExtendedStats="true" ShowTiebreaker="true" />
                                                                                                                                    }
                                                                                                                                    @* Collapsed match list — toggle *@
                                                                                                                                    <button class="btn btn-sm btn-outline-secondary mb-2"
                                                                                                                                            @onclick="() => showGroupMatches = !showGroupMatches">
                                                                                                                                        @(showGroupMatches ? "▼ Matches ausblenden" : "▶ Matches anzeigen")
                                                                                                                                    </button>
                                                                                                                                    @if (showGroupMatches)
                                                                                                                                    {
                                                                                                                                        var groupListCardSettings = GetMatchCardSettings("groups");
                                                                                                                                            <div class="@(EffectiveGroupMatchesViewMode == "horizontal" ? "groups-match-horizontal mb-2" : "d-flex flex-column gap-2 mb-2")">
                                                                                                                                            @foreach (var match in groupMatches.Where(m => m.GroupNumber == groupNum).OrderBy(m =>
                                                                                                                                                                m.Round).ThenBy(m => m.MatchNumber))
                                                                                                                                            {
                                                                                                                                                    <div class="@(EffectiveGroupMatchesViewMode == "horizontal" ? "groups-match-horizontal-item" : string.Empty)">
                                                                                                                                                        <MatchCard Match="@match"
                                                                                                                                                           ViewSettings="@groupListCardSettings"
                                                                                                                                                           Layout="@groupListCardSettings.Layout"
                                                                                                                                                           Label="@MatchLabel(match)"
                                                                                                                                                           ShowRuntimeBadge="@groupListCardSettings.ShowRuntimeBadge"
                                                                                                                                                           ShowMonitoringStatus="@ShowMatchCardMonitoring(groupListCardSettings)"
                                                                                                                                                           MonitoringStatusText="@GetMonitoringBadgeText(match)"
                                                                                                                                                           MonitoringStatusCssClass="@GetMonitoringBadgeCss(match)"
                                                                                                                                                           EnablePlayerLinks="@groupListCardSettings.EnablePlayerLinks"
                                                                                                                                                           EnableBoardLink="@groupListCardSettings.EnableBoardLink"
                                                                                                                                                           HomeName="@ParticipantName(match.HomeParticipantId)"
                                                                                                                                                           AwayName="@ParticipantName(match.AwayParticipantId)"
                                                                                                                                                           BoardName="@MatchBoardName(match)"
                                                                                                                                                           SlotOrigin="@BuildSlotOrigin(match)"
                                                                                                                                                           SetModeActive="@IsSetMode(match)"
                                                                                                                                                           LiveScoreEnabled="@groupListCardSettings.LiveScoreEnabled"
                                                                                                                                                           ShowMatchStatus="@groupListCardSettings.ShowMatchStatus"
                                                                                                                                                           ShowSchedulingStatus="@groupListCardSettings.ShowSchedulingStatus"
                                                                                                                                                           ShowAverage="@groupListCardSettings.ShowAverage"
                                                                                                                                                           ShowHighestPpr="@groupListCardSettings.ShowHighestPpr"
                                                                                                                                                           ShowHighestCheckout="@groupListCardSettings.ShowHighestCheckout"
                                                                                                                                                           ShowAverageDartsPerLeg="@groupListCardSettings.ShowAverageDartsPerLeg"
                                                                                                                                                           ShowMinimalDartsPerLeg="@groupListCardSettings.ShowMinimalDartsPerLeg"
                                                                                                                                                          OnHomePlayerClick="BuildPlayerDetailCallback(match.HomeParticipantId)"
                                                                                                                                                          OnAwayPlayerClick="BuildPlayerDetailCallback(match.AwayParticipantId)"
                                                                                                                                                          OnBoardClick="BuildMatchBoardDetailCallback(match)"
                                                                                                                                                           EnableDetailPanel="true"
                                                                                                                                                           DetailsExpandedByDefault="@MatchCardDetailsExpandedByDefault(groupListCardSettings)"
                                                                                                                                                           ForceDetailsExpanded="@forcedMatchDetailsExpanded"
                                                                                                                                                           EnableRealtimeConsumer="@(match.StartedUtc is not null && match.FinishedUtc is null)"
                                                                                                                                                           OnClick="() => OpenMatchDetail(match)" />
                                                                                                                                                    </div>
                                                                                                                                                }
                                                                                                                                        </div>
                                                                                                                                        }
                                                                                                                                    }
                                                                                                                                }
                else
                                                                                                                                {
                                                                                                                                    <p class="text-muted">Keine Gruppenmatches vorhanden. Generieren Sie den Plan im Tab „Auslosung".</p>
                                                                                                                                }
                                                                                                                            }

                                                                                                                            @* ═══════ Tab: K.O.-Phase ═══════ *@
                                                                                                                            @if (activeTab == "knockout")
                                                                                                                            {
                                                                                                                                @if (selectedTournament.Variant == "OnSite" && boards.Any() && matches.Any())
                                                                                                                                {
                                                                                                                                    <div class="p-2 border rounded mb-3 bg-light">
                                                                                                                                        <div class="small fw-semibold text-muted mb-2">Verfügbare Boards — auf Match ziehen zum Zuweisen
                                                                                                                                        </div>
                                                                                                                                        <div class="d-flex flex-wrap gap-2">
                                                                                                                                            @foreach (var board in boards)
                                                                                                                                            {
                                                                                                                                                <div class="badge bg-dark p-2 user-select-none" draggable="true"
                                                                                                                                                     @ondragstart="() => draggedBoardId = board.Id" style="cursor:grab; font-size:.85em">
                                                                                                                                                    📋 @board.Name
                                                                                                                                                    <span class="badge @BoardStatusBadge(board.Status) ms-1"
                                                                                                                                                          style="font-size:.75em">@board.Status</span>
                                                                                                                                                </div>
                                                                                                                                            }
                                                                                                                                        </div>
                                                                                                                                    </div>
                                                                                                                                }

                                                                                                                                var koMatches = matches.Where(m => m.Phase == "Knockout").ToList();
                                                                                                                                var koMaxRound = koMatches.Select(m => m.Round).DefaultIfEmpty(1).Max();
                                                                                                                                @if (koMatches.Any())
                                                                                                                                {
                                                                                                                                    <div id="section-tournaments-knockout" class="d-flex gap-2 mb-3">
                                                                                                                                        <button class="btn btn-sm @(koViewMode == "tree" ? "btn-primary" : "btn-outline-primary")" @onclick='() => koViewMode = "tree"'>🌳 Bracket</button>
                                                                                                                                        <button class="btn btn-sm @(koViewMode == "round" ? "btn-primary" : "btn-outline-primary")" @onclick='() => koViewMode = "round"'>📋 Rundenliste</button>
                                                                                                                                        <button class="btn btn-sm btn-outline-secondary"
                                                                                                                                                title="MatchCard-Einstellungen fuer K.O.-Phase"
                                                                                                                                                @onclick='() => OpenMatchCardScopeEditor("tournaments::knockout")'
                                                                                                                                                @onclick:stopPropagation>⚙</button>
                                                                                                                                    </div>

                                                                                                                                    @if (koViewMode == "tree")
                                                                                                                                    {
                                                                                                                                        <BracketView Matches="@koMatches"
                                                                                                                                                     ResolvePlayerName="id => ParticipantName(id)"
                                                                                                                                                     OnMatchClick="OpenMatchDetail"
                                                                                                                                                     OnBoardClick="OpenBoardDetailFromMatch" />
                                                                                                                                    }
                                                                                                                                    else
                                                                                                                                    {
                                                                                                                                    var koRounds = koMatches.Select(m => m.Round).Distinct().OrderBy(r => r).ToList();
                                                                                                                                    @foreach (var round in koRounds)
                                                                                                                                    {
                                                                                                                                        <div class="small fw-semibold text-muted mb-1 mt-2">@KoRoundLabel(round, koMaxRound)</div>
                                                                                                                                        <ul class="list-group mb-2">
                                                                                                                                            @foreach (var match in koMatches.Where(m => m.Round == round).OrderBy(m => m.MatchNumber))
                                                                                                                                            {
                                                                                                                                                var assignedBoard = boards.FirstOrDefault(b => b.Id == match.BoardId);
                                                                                                                                                var isTarget = dropTargetMatchId == match.Id;
                                                                                                                                                var isActive = match.WinnerParticipantId is null && match.FinishedUtc is null && match.BoardId is
                                                                                                                                                not null;
                                                                                                                                                var isBye = match.Status == "WalkOver";
                                                                                                                                                var roundListCardSettings = MatchCardSettingsForMatchList(match);
                                                                                                                                                <li class="list-group-item @(isTarget ? "border-primary border-2" : "") @(isActive ? "border-start border-success border-3" : "") @(isBye ? "list-group-item-light" : "")"
                                                                                                                                                    style="cursor:pointer; @(isTarget ? "background:rgba(13,110,253,.08)" : "")"
                                                                                                                                                    @ondragover:preventDefault @ondragover="() => dropTargetMatchId = match.Id"
                                                                                                                                                    @ondragleave="() => { if (dropTargetMatchId == match.Id) dropTargetMatchId = null; }"
                                                                                                                                                    @ondrop="() => AssignBoardToMatchAsync(match.Id)" @onclick="() => OpenMatchDetail(match)">
                                                                                                                                                    <MatchCard Match="@match"
                                                                                                                                                               ViewSettings="@roundListCardSettings"
                                                                                                                                                               Layout="@roundListCardSettings.Layout"
                                                                                                                                                               Label="@KoMatchLabel(match)"
                                                                                                                                                               ShowRuntimeBadge="@roundListCardSettings.ShowRuntimeBadge"
                                                                                                                                                               ShowMonitoringStatus="@ShowMatchCardMonitoring(roundListCardSettings)"
                                                                                                                                                               MonitoringStatusText="@GetMonitoringBadgeText(match)"
                                                                                                                                                               MonitoringStatusCssClass="@GetMonitoringBadgeCss(match)"
                                                                                                                                                               EnablePlayerLinks="@roundListCardSettings.EnablePlayerLinks"
                                                                                                                                                               EnableBoardLink="@roundListCardSettings.EnableBoardLink"
                                                                                                                                                               HomeName="@(match.HomeParticipantId == Guid.Empty && match.WinnerParticipantId is null ? KoParticipantLabel(match.HomeParticipantId, match, true) : ParticipantName(match.HomeParticipantId))"
                                                                                                                                                               AwayName="@(match.AwayParticipantId == Guid.Empty && match.WinnerParticipantId is null ? KoParticipantLabel(match.AwayParticipantId, match, false) : ParticipantName(match.AwayParticipantId))"
                                                                                                                                                               BoardName="@assignedBoard?.Name"
                                                                                                                                                               SlotOrigin="@BuildSlotOrigin(match)"
                                                                                                                                                               SetModeActive="@IsSetMode(match)"
                                                                                                                                                               LiveScoreEnabled="@roundListCardSettings.LiveScoreEnabled"
                                                                                                                                                               ShowMatchStatus="@roundListCardSettings.ShowMatchStatus"
                                                                                                                                                               ShowSchedulingStatus="@roundListCardSettings.ShowSchedulingStatus"
                                                                                                                                                               ShowAverage="@roundListCardSettings.ShowAverage"
                                                                                                                                                               ShowHighestPpr="@roundListCardSettings.ShowHighestPpr"
                                                                                                                                                               ShowHighestCheckout="@roundListCardSettings.ShowHighestCheckout"
                                                                                                                                                               ShowAverageDartsPerLeg="@roundListCardSettings.ShowAverageDartsPerLeg"
                                                                                                                                                               ShowMinimalDartsPerLeg="@roundListCardSettings.ShowMinimalDartsPerLeg"
                                                                                                                                                              OnHomePlayerClick="BuildPlayerDetailCallback(match.HomeParticipantId)"
                                                                                                                                                              OnAwayPlayerClick="BuildPlayerDetailCallback(match.AwayParticipantId)"
                                                                                                                                                              OnBoardClick="BuildMatchBoardDetailCallback(match)"
                                                                                                                                                               EnableDetailPanel="true"
                                                                                                                                                               DetailsExpandedByDefault="@MatchCardDetailsExpandedByDefault(roundListCardSettings)"
                                                                                                                                                               ForceDetailsExpanded="@forcedMatchDetailsExpanded"
                                                                                                                                                               EnableRealtimeConsumer="@(match.StartedUtc is not null && match.FinishedUtc is null)"
                                                                                                                                                               OnClick="() => OpenMatchDetail(match)" />

                                                                                                                                                    <div class="d-flex align-items-center gap-1 mt-2">
                                                                                                                                                        @if (assignedBoard is not null)
                                                                                                                                                        {
                                                                                                                                                            <a href="https://play.autodarts.io/boards/@(assignedBoard.ExternalBoardId)/follow"
                                                                                                                                                               target="_blank" rel="noopener" class="badge text-bg-success text-decoration-none"
                                                                                                                                                               @onclick:stopPropagation>📋 @assignedBoard.Name</a>
                                                                                                                                                        }
                                                                                                                                                        else if (selectedTournament.Variant == "OnSite")
                                                                                                                                                        {
                                                                                                                                                            <span class="badge text-bg-light text-muted border" style="font-size:.75em">Board zuweisen</span>
                                                                                                                                                        }

                                                                                                                                                        @if (match.IsBoardLocked)
                                                                                                                                                        {
                                                                                                                                                            <span class="badge text-bg-primary">🔒 Board</span>
                                                                                                                                                        }

                                                                                                                                                        @if (match.WinnerParticipantId.HasValue)
                                                                                                                                                        {
                                                                                                                                                            <span class="badge text-bg-warning">🏆 @ParticipantName(match.WinnerParticipantId)</span>
                                                                                                                                                        }
                                                                                                                                                    </div>
                                                                                                                                                                </li>
                                                                                                                                                            }
                                                                                                                                                        </ul>
                                                                                                                                                    }
                                                                                                                                                } @* end else (round list view) *@
                                                                                                                                                }
                else
                                                                                                                                                {
                                                                                                                                                    <p class="text-muted">Noch keine K.O.-Matches vorhanden.</p>
                                                                                                                                                }
                                                                                                                                            }

                                                                                                                                            @* ═══════ Tab: Spielplan (chronologisch) ═══════ *@
                                                                                                                                            @if (activeTab == "schedule")
                                                                                                                                            {
                                                                                                                                                <div id="section-tournaments-schedule" class="d-flex justify-content-between align-items-center mb-3">
                                                                                                                                                    <h6 class="fw-semibold mb-0">Spielplan — Chronologische Übersicht</h6>
                                                                                                                                                    <div class="d-flex gap-2">
                                                                                                                                                        <button class="btn btn-sm btn-outline-secondary"
                                                                                                                                                                title="MatchCard-Einstellungen fuer Spielplan"
                                                                                                                                                                @onclick='() => OpenMatchCardScopeEditor("tournaments::schedule")'
                                                                                                                                                                @onclick:stopPropagation>⚙</button>
                                                                                                                                                        @if (matches.Any() && !selectedTournament.IsLocked && IsCurrentUserManager &&
                                                                                                                                                                            !string.IsNullOrEmpty(selectedTournament.StartTime))
                                                                                                                                                        {
                                                                                                                                                            <span class="@(IsCurrentUserManager && !selectedTournament.IsLocked ? "" : "btn-reason-wrap")" title="@(IsCurrentUserManager ? (selectedTournament.IsLocked ? "Turnier ist gesperrt." : "") : "Nur Spielleiter können den Spielplan generieren.")">
                                                                                                                                                                <button class="btn btn-primary btn-sm" @onclick="GenerateScheduleAsync" disabled="@isWorking">⏰ Spielplan generieren</button>
                                                                                                                                                            </span>
                                                                                                                                                        }
                                                                                                                                                    </div>
                                                                                                                                                    </div>

                                                                                                                                                    @* Spielplan Filters *@
                                                                                                                                                    <div class="d-flex flex-wrap gap-3 align-items-center mb-3 small">
                                                                                                                                                        <div class="form-check">
                                                                                                                                                            <input class="form-check-input" type="checkbox" id="schedHideFinished" @bind="scheduleHideFinished" />
                                                                                                                                                            <label class="form-check-label" for="schedHideFinished">Beendete ausblenden</label>
                                                                                                                                                        </div>
                                                                                                                                                        <div class="form-check">
                                                                                                                                                            <input class="form-check-input" type="checkbox" id="schedNoBoard" @bind="scheduleShowNoBoard" />
                                                                                                                                                            <label class="form-check-label" for="schedNoBoard">Nur ohne Board</label>
                                                                                                                                                        </div>
                                                                                                                                                        <select class="form-select form-select-sm" style="width:auto" @bind="scheduleStatusFilter">
                                                                                                                                                            <option value="all">Alle Status</option>
                                                                                                                                                            <option value="running">Laufende Spiele</option>
                                                                                                                                                            <option value="upcoming">Anstehende Spiele</option>
                                                                                                                                                        </select>
                                                                                                                                                    </div>

@* Unassigned matches warning *@
                                                                                                                                                    @if (UnassignedUpcoming.Any())
                                                                                                                                                    {
                                                                                                                                                        <div class="alert alert-warning py-2 small mb-3">
                                                                                                                                                            ⚠ <strong>@UnassignedUpcoming.Count</strong> anstehende Matches ohne Board-Zuweisung:
                                                                                                                                                            @foreach (var m in UnassignedUpcoming.Take(10))
                                                                                                                                                            {
                                                                                                                                                                <span class="badge text-bg-warning me-1" style="cursor:pointer"
                                                                                                                                                                     @onclick="() => OpenMatchDetail(m, true)">@MatchLabel(m)</span>
                                                                                                                                                            }
                                                                                                                                                            @if (UnassignedUpcoming.Count > 10)
                                                                                                                                                            {
                                                                                                                                                                <span class="text-muted">… und @(UnassignedUpcoming.Count -
                                                                                                                                                                                            10) weitere</span>
                                                                                                                                                                }
                                                                                                                                                            </div>
                                                                                                                                                        }

                                                                                                                                                        @* Boards & Anstehende Matches *@
                                                                                                                                                        @if (selectedTournament.Variant == "OnSite" && boards.Any())
                                                                                                                                                        {
                                                                                                                                                            <div id="section-tournaments-schedule-boards-upcoming" class="d-flex justify-content-between align-items-center mb-2">
                                                                                                                                                                <h6 class="fw-semibold text-muted small mb-0">Boards &amp; Anstehende Matches</h6>
                                                                                                                                                                <button class="btn btn-sm btn-outline-secondary"
                                                                                                                                                                        title="MatchCard-Einstellungen fuer Boards &amp; Anstehende Matches"
                                                                                                                                                                        @onclick='() => OpenMatchCardScopeEditor("tournaments::schedule-boards-upcoming")'
                                                                                                                                                                        @onclick:stopPropagation>⚙</button>
                                                                                                                                                            </div>
                                                                                                                                                            <div class="row g-2 mb-3 schedule-board-strip">
                                                                                                                                                                @foreach (var board in boards)
                                                                                                                                                                {
                                                                                                                                                                    var queue = BoardQueues.GetValueOrDefault(board.Id) ?? [];
                                                                                                                                                                    var boardCount = boards.Count;
                                                                                                                                                                    var colClass = boardCount == 1 ? "col-md-12 col-lg-12" : boardCount == 2 ? "col-md-6 col-lg-6" : "col-md-4 col-lg-3";
                                                                                                                                                                    <div class="@(colClass) schedule-board-item">
                                                                                                                                                                        <div class="card h-100">
                                                                                                                                                                            <div class="@BuildScheduleBoardHeaderCss(board.Id)"
                                                                                                                                                                                 draggable="true"
                                                                                                                                                                                 @ondragstart="() => { draggedBoardId = board.Id; EndScheduleMatchDrag(); }"
                                                                                                                                                                                 @ondragover:preventDefault
                                                                                                                                                                                 @ondragover="() => MarkScheduleDropTargetBoard(board.Id)"
                                                                                                                                                                                 @ondragleave="() => ClearScheduleDropTargetBoard(board.Id)"
                                                                                                                                                                                 @ondrop="() => DropOnBoardHeaderAsync(board.Id)"
                                                                                                                                                                                 style="cursor:grab">
                                                                                                                                                                                <span class="small fw-semibold">📋 @board.Name</span>
                                                                                                                                                                                <span class="badge @BoardStatusBadge(board.Status)">@board.Status</span>
                                                                                                                                                                            </div>
                                                                                                                                                                            <div class="card-body p-2 @ScheduleBoardDropZoneCss(board.Id)"
                                                                                                                                                                                 @ondragover:preventDefault
                                                                                                                                                                                 @ondragover="() => MarkScheduleDropTargetBoard(board.Id)"
                                                                                                                                                                                 @ondragleave="() => ClearScheduleDropTargetBoard(board.Id)"
                                                                                                                                                                                 @ondrop="() => DropOnBoardHeaderAsync(board.Id)">
                                                                                                                                                                                @if (queue.Any())
                                                                                                                                                                                {
                                                                                                                                                                                    var scheduleListCardSettings = GetMatchCardSettings("schedule-boards-upcoming");
                                                                                                                                                                                    @foreach (var m in queue.Take(5))
                                                                                                                                                                                    {
                                                                                                                                                                                        <div class="@BuildScheduleMatchCardCss(m, includeBoardDropTarget: false)"
                                                                                                                                                                                             draggable="@(CanDragScheduleMatch(m) ? "true" : "false")"
                                                                                                                                                                                             @ondragstart="() => StartScheduleMatchDrag(m.Id)"
                                                                                                                                                                                             @ondragend="EndScheduleMatchDrag"
                                                                                                                                                                                             @ondragover:preventDefault
                                                                                                                                                                                             @ondragover="() => MarkScheduleDropTargetMatch(m.Id)"
                                                                                                                                                                                             @ondragleave="() => ClearScheduleDropTargetMatch(m.Id)"
                                                                                                                                                                                             @ondrop="() => DropOnTimelineMatchAsync(m.Id)">
                                                                                                                                                                                            <MatchCard Match="@m"
                                                                                                                                                                                                   ViewSettings="@scheduleListCardSettings"
                                                                                                                                                                                                   Layout="@scheduleListCardSettings.Layout"
                                                                                                                                                                                                   Label="@MatchLabel(m)"
                                                                                                                                   ShowRuntimeBadge="@scheduleListCardSettings.ShowRuntimeBadge"
                                                                                                                                   ShowMonitoringStatus="@ShowMatchCardMonitoring(scheduleListCardSettings)"
                                                                                                                                                                                                   MonitoringStatusText="@GetMonitoringBadgeText(m)"
                                                                                                                                                                                                   MonitoringStatusCssClass="@GetMonitoringBadgeCss(m)"
                                                                                                                                   EnablePlayerLinks="@scheduleListCardSettings.EnablePlayerLinks"
                                                                                                                                   EnableBoardLink="@scheduleListCardSettings.EnableBoardLink"
                                                                                                                                                                                                   HomeName="@ParticipantName(m.HomeParticipantId)"
                                                                                                                                                                                                   AwayName="@ParticipantName(m.AwayParticipantId)"
                                                                                                                                                                                                   BoardName="@board.Name"
                                                                                                                                                                                                   SlotOrigin="@BuildSlotOrigin(m)"
                                                                                                                                                                                                   SetModeActive="@IsSetMode(m)"
                                                                                                                                                                                                   LiveScoreEnabled="@scheduleListCardSettings.LiveScoreEnabled"
                                                                                                                                                                                                   ShowMatchStatus="@scheduleListCardSettings.ShowMatchStatus"
                                                                                                                                                                                                   ShowSchedulingStatus="@scheduleListCardSettings.ShowSchedulingStatus"
                                                                                                                                                                                                   ShowAverage="@scheduleListCardSettings.ShowAverage"
                                                                                                                                                                                                   ShowHighestPpr="@scheduleListCardSettings.ShowHighestPpr"
                                                                                                                                                                                                   ShowHighestCheckout="@scheduleListCardSettings.ShowHighestCheckout"
                                                                                                                                                                                                   ShowAverageDartsPerLeg="@scheduleListCardSettings.ShowAverageDartsPerLeg"
                                                                                                                                                                                                   ShowMinimalDartsPerLeg="@scheduleListCardSettings.ShowMinimalDartsPerLeg"
                                                                                                                                                                                                  OnHomePlayerClick="BuildPlayerDetailCallback(m.HomeParticipantId)"
                                                                                                                                                                                                  OnAwayPlayerClick="BuildPlayerDetailCallback(m.AwayParticipantId)"
                                                                                                                                                                                                  OnBoardClick="BuildBoardDetailCallback(board.Id)"
                                                                                                                                                                                                   EnableDetailPanel="false"
                                                                                                                                                                                                   DetailsExpandedByDefault="@MatchCardDetailsExpandedByDefault(scheduleListCardSettings)"
                                                                                                                                                                                                   ForceDetailsExpanded="@forcedMatchDetailsExpanded"
                                                                                                                                                                                                   EnableRealtimeConsumer="@(m.StartedUtc is not null && m.FinishedUtc is null)"
                                                                                                                                                                                                   OnClick="() => OpenMatchDetail(m, true)" />
                                                                                                                                                                                            @if (ShowScheduleLockedMarker(m))
                                                                                                                                                                                            {
                                                                                                                                                                                                <div class="small text-muted px-1 pb-1">🔒 Gesperrt für Drag &amp; Drop</div>
                                                                                                                                                                                            }
                                                                                                                                                                                        </div>
                                                                                                                                                                                    }
                                                                                                                                                                                    @if (queue.Count > 5)
                                                                                                                                                                                    {
                                                                                                                                                                                        <div class="small text-muted">… +@(queue.Count - 5) weitere
                                                                                                                                                                                        </div>
                                                                                                                                                                                    }
                                                                                                                                                                                }
                                                                                                                                                                                else
                                                                                                                                                                                {
                                                                                                                                                                                    <span class="small text-muted">Keine Matches in der Queue</span>
                                                                                                                                                                                }
                                                                                                                                                                            </div>
                                                                                                                                                                        </div>
                                                                                                                                                                    </div>
                                                                                                                                                                }
                                                                                                                                                            </div>
                                                                                                                                                        }

                                                                                                                                                        @* Full chronological match list *@
                                                                                                                                                        @if (ScheduledMatches.Any())
                                                                                                                                                        {
                                                                                                                                                            <div id="section-tournaments-schedule-zeitplan" class="d-flex justify-content-between align-items-center mb-2">
                                                                                                                                                                <h6 class="fw-semibold text-muted small mb-0">Zeitplan</h6>
                                                                                                                                                                <button class="btn btn-sm btn-outline-secondary"
                                                                                                                                                                        title="MatchCard-Einstellungen fuer Zeitplan"
                                                                                                                                                                        @onclick='() => OpenMatchCardScopeEditor("tournaments::schedule-zeitplan")'
                                                                                                                                                                        @onclick:stopPropagation>⚙</button>
                                                                                                                                                            </div>
                                                                                                                                                                var timelineCardSettings = GetMatchCardSettings(MatchCardSectionScheduleZeitplan);
                                                                                                                                                            <div class="d-flex flex-column gap-1">
                                                                                                                                                                        @foreach (var match in ScheduledMatches)
                                                                                                                                                                        {
                                                                                                                                                                            var assignedBoard = boards.FirstOrDefault(b => b.Id == match.BoardId);
                                                                                                                                                                            var isDone = match.FinishedUtc is not null;
                                                                                                                                                                            <div class="@BuildScheduleMatchCardCss(match, includeBoardDropTarget: true)"
                                                                                                                                                                                draggable="@(CanDragScheduleMatch(match) ? "true" : "false")"
                                                                                                                                                                                @ondragstart="() => StartScheduleMatchDrag(match.Id)"
                                                                                                                                                                                @ondragend="EndScheduleMatchDrag"
                                                                                                                                                                                @ondragover:preventDefault
                                                                                                                                                                                @ondragover="() => { if (draggedBoardId.HasValue) dropTargetMatchId = match.Id; MarkScheduleDropTargetMatch(match.Id); }"
                                                                                                                                                                                @ondragleave="() => { if (dropTargetMatchId == match.Id) dropTargetMatchId = null; ClearScheduleDropTargetMatch(match.Id); }"
                                                                                                                                                                                @ondrop="() => DropOnTimelineMatchAsync(match.Id)">
                                                                                                                                                                                <MatchCard Match="@match"
                                                                                                                                                                                           ViewSettings="@timelineCardSettings"
                                                                                                                                                                                           Layout="@timelineCardSettings.Layout"
                                                                                                                                                                                           Label="@MatchLabel(match)"
                                                                                                                                                                                           ShowRuntimeBadge="@timelineCardSettings.ShowRuntimeBadge"
                                                                                                                                                                                           ShowMonitoringStatus="@ShowMatchCardMonitoring(timelineCardSettings)"
                                                                                                                                                                                           MonitoringStatusText="@GetMonitoringBadgeText(match)"
                                                                                                                                                                                           MonitoringStatusCssClass="@GetMonitoringBadgeCss(match)"
                                                                                                                                                                                           EnablePlayerLinks="@timelineCardSettings.EnablePlayerLinks"
                                                                                                                                                                                           EnableBoardLink="@timelineCardSettings.EnableBoardLink"
                                                                                                                                                                                           HomeName="@ParticipantName(match.HomeParticipantId)"
                                                                                                                                                                                           AwayName="@ParticipantName(match.AwayParticipantId)"
                                                                                                                                                                                           BoardName="@MatchBoardName(match)"
                                                                                                                                                                                           SetModeActive="@IsSetMode(match)"
                                                                                                                                                                                           LiveScoreEnabled="@timelineCardSettings.LiveScoreEnabled"
                                                                                                                                                                                           ShowMatchStatus="@timelineCardSettings.ShowMatchStatus"
                                                                                                                                                                                           ShowSchedulingStatus="@timelineCardSettings.ShowSchedulingStatus"
                                                                                                                                                                                           ShowAverage="@timelineCardSettings.ShowAverage"
                                                                                                                                                                                           ShowHighestPpr="@timelineCardSettings.ShowHighestPpr"
                                                                                                                                                                                           ShowHighestCheckout="@timelineCardSettings.ShowHighestCheckout"
                                                                                                                                                                                           ShowAverageDartsPerLeg="@timelineCardSettings.ShowAverageDartsPerLeg"
                                                                                                                                                                                           ShowMinimalDartsPerLeg="@timelineCardSettings.ShowMinimalDartsPerLeg"
                                                                                                                                                                                           OnHomePlayerClick="BuildPlayerDetailCallback(match.HomeParticipantId)"
                                                                                                                                                                                           OnAwayPlayerClick="BuildPlayerDetailCallback(match.AwayParticipantId)"
                                                                                                                                                                                           OnBoardClick="BuildMatchBoardDetailCallback(match)"
                                                                                                                                                                                           ShowActionButtons="@IsCurrentUserManager"
                                                                                                                                                                                           OnStartMatch="() => SendUpcomingMatchAsync(match)"
                                                                                                                                                                                           CanStartMatch="@(CanSendUpcomingMatch(match) && !isWorking)"
                                                                                                                                                                                           EnableDetailPanel="false"
                                                                                                                                                                                           EnableRealtimeConsumer="@(match.StartedUtc is not null && match.FinishedUtc is null)"
                                                                                                                                                                                           OnClick="() => OpenMatchDetail(match, true)" />
                                                                                                                                                                                @if (ShowScheduleLockedMarker(match))
                                                                                                                                                                                {
                                                                                                                                                                                    <div class="small text-muted px-1 pb-1">🔒 Gesperrt für Drag &amp; Drop</div>
                                                                                                                                                                                }
                                                                                                                                                                                @if (IsCurrentUserManager && !selectedTournament.IsLocked && !isDone)
                                                                                                                                                                                {
                                                                                                                                                                                    <div class="d-flex gap-2 align-items-center ps-2 pb-1 small flex-wrap" @onclick:stopPropagation>
                                                                                                                                                                                        @if (editingMatchTimeId == match.Id)
                                                                                                                                                                                        {
                                                                                                                                                                                            <div class="d-flex gap-1 align-items-center">
                                                                                                                                                                                                <input type="text" class="form-control form-control-sm" style="width:5rem" placeholder="HH:mm" @bind="editMatchTimeValue" />
                                                                                                                                                                                                <button class="btn btn-sm btn-success py-0 px-1" @onclick="() => SaveMatchTimeAsync(match)" disabled="@isWorking">✓</button>
                                                                                                                                                                                                <button class="btn btn-sm btn-secondary py-0 px-1" @onclick="CancelEditMatchTime">✕</button>
                                                                                                                                                                                            </div>
                                                                                                                                                                                        }
                                                                                                                                                                                        else
                                                                                                                                                                                        {
                                                                                                                                                                                            <span @onclick="() => StartEditMatchTime(match)" style="cursor:text"
                                                                                                                                                                                                  class="@(match.IsStartTimeLocked ? "text-primary fw-semibold" : "text-muted")">
                                                                                                                                                                                                @if (match.PlannedStartUtc is not null)
                                                                                                                                                                                                {
                                                                                                                                                                                                    @match.PlannedStartUtc.Value.LocalDateTime.ToString("HH:mm")
                                                                                                                                                                                                }
                                                                                                                                                                                                else
                                                                                                                                                                                                {
                                                                                                                                                                                                    <span>—</span>
                                                                                                                                                                                                }
                                                                                                                                                                                            </span>
                                                                                                                                                                                            <button class="btn btn-link btn-sm p-0 @(match.IsStartTimeLocked ? "text-primary" : "text-muted")"
                                                                                                                                                                                                    @onclick="() => ToggleTimeLockAsync(match)"
                                                                                                                                                                                                    title="@(match.IsStartTimeLocked ? "Startzeit entsperren" : "Startzeit sperren")">
                                                                                                                                                                                                @(match.IsStartTimeLocked ? "🔓" : "🔒")
                                                                                                                                                                                            </button>
                                                                                                                                                                                        }
                                                                                                                                                                                        @if (assignedBoard is not null)
                                                                                                                                                                                        {
                                                                                                                                                                                            <button class="btn btn-link btn-sm p-0 @(match.IsBoardLocked ? "text-primary" : "text-muted")"
                                                                                                                                                                                                    @onclick="() => ToggleBoardLockAsync(match)"
                                                                                                                                                                                                    title="@(match.IsBoardLocked ? "Board entsperren" : "Board sperren")">
                                                                                                                                                                                                @(match.IsBoardLocked ? "🔓" : "🔒") @assignedBoard.Name
                                                                                                                                                                                            </button>
                                                                                                                                                                                        }
                                                                                                                                                                                    </div>
                                                                                                                                                                                }
                                                                                                                                                            </div>
                                                                                                                                                        }
                                                                                                                                                            </div>
                                                                                                                                                                }
                else
                                                                                                                                                                {
                                                                                                                                                                    <p class="text-muted">Noch kein Spielplan vorhanden. Generieren Sie zuerst den Turnierplan im Tab
                                                                                                                                                                        „Auslosung" und danach den Spielplan.</p>
                                                                                                                                                                    }
                                                                                                                                                                }
                                                                                                                                                            </div>
                                                                                                                                                        </div>
                                                                                                                                                    </div>
                                                                                                                                                }
                                                                                                                                            </div>

@if (selectedTournament is not null)
{
    <div class="tournament-tab-footer-nav d-lg-none">
        <button class="btn btn-outline-secondary btn-sm" @onclick="GoToPreviousTabAsync" disabled="@(isWorking || !CanGoToPreviousTab)">← @PreviousTabDisplayName</button>
        <span class="small text-muted px-2">@ActiveTabDisplayName</span>
        <button class="btn btn-primary btn-sm" @onclick="GoToNextTabAsync" disabled="@(isWorking || !CanGoToNextTab)">@NextTabDisplayName →</button>
    </div>
}

@* ─── Board Detail Modal ─── *@
@if (detailBoard is not null)
{
    var currentMatch = CurrentMatchOnBoard(detailBoard.Id);
    var upcomingOnBoard = UpcomingMatchesOnBoard(detailBoard.Id);
    var boardMatchListener = currentMatch is not null ? matchListeners.FirstOrDefault(l => l.MatchId == currentMatch.Id) : null;
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="CloseBoardDetail">
        <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">📋 @detailBoard.Name</h5>
                    <button type="button" class="btn-close" @onclick="CloseBoardDetail"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="badge @BoardStatusBadge(detailBoard.Status)">@detailBoard.Status</span>
                        @if (detailBoard.IsExtensionConnected)
                        {
                            <span class="badge text-bg-success">🔗 Extension verbunden</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">⛓️‍💥 Extension nicht verbunden</span>
                        }
                        <a href="https://play.autodarts.io/boards/@(detailBoard.ExternalBoardId)/follow" target="_blank"
                           rel="noopener" class="btn btn-outline-primary btn-sm"><span class="autodarts-icon"></span> Board verfolgen</a>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => RequestBoardSyncAsync(detailBoard)"
                                disabled="@(isWorking || !detailBoard.IsExtensionConnected)">
                            🔄 Sync
                        </button>
                    </div>
                    @if (boardSyncInfo is not null)
                    {
                        <div class="alert alert-info py-2 small">@boardSyncInfo</div>
                    }
                    @if (boardSyncError is not null)
                    {
                        <div class="alert alert-danger py-2 small">@boardSyncError</div>
                    }
                    @if (IsDevelopmentEnvironment)
                    {
                        <details class="card border-warning-subtle mb-3">
                            <summary class="card-header py-2 d-flex justify-content-between align-items-center" style="cursor:pointer">
                                <span class="small fw-semibold">Dev: Board Sync Debug</span>
                                <span class="small text-muted">@(boardSyncDebug?.Matched is true ? "gematcht" : boardSyncDebug?.ReportedAtUtc is not null ? "reportet" : "eingeklappt")</span>
                            </summary>
                            <div class="card-body py-2">
                                <div class="d-flex justify-content-end mb-2">
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshBoardSyncDebugAsync" disabled="@isBoardSyncDebugLoading">
                                        @(isBoardSyncDebugLoading ? "Lade..." : "Aktualisieren")
                                    </button>
                                </div>
                                @if (boardSyncDebug is null)
                                {
                                    <div class="small text-muted">Noch keine Sync-Daten vorhanden.</div>
                                }
                                else
                                {
                                    <div class="row g-2 small">
                                        <div class="col-md-6"><strong>RequestId:</strong> @boardSyncDebug.RequestId</div>
                                        <div class="col-md-6"><strong>ShouldSync:</strong> @boardSyncDebug.ShouldSync</div>
                                        <div class="col-md-6"><strong>Requested:</strong> @(boardSyncDebug.RequestedAtUtc?.LocalDateTime.ToString("HH:mm:ss") ?? "—")</div>
                                        <div class="col-md-6"><strong>Consumed:</strong> @(boardSyncDebug.ConsumedAtUtc?.LocalDateTime.ToString("HH:mm:ss") ?? "—")</div>
                                        <div class="col-md-6"><strong>Reported:</strong> @(boardSyncDebug.ReportedAtUtc?.LocalDateTime.ToString("HH:mm:ss") ?? "—")</div>
                                        <div class="col-md-6"><strong>Matched:</strong> @boardSyncDebug.Matched</div>
                                        <div class="col-md-6"><strong>MatchedBy:</strong> @(string.IsNullOrWhiteSpace(boardSyncDebug.MatchedBy) ? "—" : boardSyncDebug.MatchedBy)</div>
                                        <div class="col-md-6"><strong>MatchId:</strong> @(boardSyncDebug.MatchId?.ToString() ?? "—")</div>
                                        <div class="col-md-6"><strong>DerivedStatus:</strong> @boardSyncDebug.DerivedStatus</div>
                                        <div class="col-md-6"><strong>ExternalMatchId:</strong> @boardSyncDebug.ExternalMatchId</div>
                                        <div class="col-md-6"><strong>TournamentId:</strong> @(boardSyncDebug.TournamentId?.ToString() ?? "—")</div>
                                        <div class="col-md-6"><strong>Player1:</strong> @(string.IsNullOrWhiteSpace(boardSyncDebug.Player1) ? "—" : boardSyncDebug.Player1)</div>
                                        <div class="col-md-6"><strong>Player2:</strong> @(string.IsNullOrWhiteSpace(boardSyncDebug.Player2) ? "—" : boardSyncDebug.Player2)</div>
                                        <div class="col-12"><strong>SourceUrl:</strong> @(string.IsNullOrWhiteSpace(boardSyncDebug.SourceUrl) ? "—" : boardSyncDebug.SourceUrl)</div>
                                    </div>
                                }
                            </div>
                        </details>
                    }
                    @if (currentMatch is not null)
                    {
                        var boardCardSettings = BoardDetailMatchCardSettings;
                        <div id="section-tournaments-board-detail-current" class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="fw-semibold mb-0">▶ Laufendes Match</h6>
                            <button class="btn btn-sm btn-outline-secondary"
                                    title="MatchCard-Einstellungen fuer Board-Detail"
                                    @onclick='() => OpenMatchCardScopeEditor("tournaments::board-detail")'
                                    @onclick:stopPropagation>⚙</button>
                        </div>
                        <MatchCard Match="@currentMatch"
                                   ViewSettings="@boardCardSettings"
                                   Layout="@boardCardSettings.Layout"
                                   Label="@MatchLabel(currentMatch)"
                                   ShowRuntimeBadge="@boardCardSettings.ShowRuntimeBadge"
                                   ShowMonitoringStatus="@ShowMatchCardMonitoring(boardCardSettings)"
                                   MonitoringStatusText="@GetMonitoringBadgeText(currentMatch)"
                                   MonitoringStatusCssClass="@GetMonitoringBadgeCss(currentMatch)"
                                   ShowActionButtons="@ShowMatchCardActionBar(boardCardSettings)"
                                   ShowSyncAction="@ShowMatchCardSyncAction(boardCardSettings, currentMatch)"
                                   ShowFollowAction="@ShowMatchCardFollowAction(boardCardSettings)"
                                   IsFollowing="@IsMatchFollowed(currentMatch.Id)"
                                   CanFollow="@CanFollowFromMatchCard(currentMatch)"
                                   CanSync="@CanSyncFromMatchCard(currentMatch)"
                                   OnFollow="() => ToggleFollowMatchAsync(currentMatch)"
                                   OnSync="() => SyncMatchFromExternalAsync(currentMatch)"
                                   EnablePlayerLinks="@boardCardSettings.EnablePlayerLinks"
                                   EnableBoardLink="@boardCardSettings.EnableBoardLink"
                                   OnHomePlayerClick="BuildPlayerDetailCallback(currentMatch.HomeParticipantId)"
                                   OnAwayPlayerClick="BuildPlayerDetailCallback(currentMatch.AwayParticipantId)"
                                   OnBoardClick="BuildMatchBoardDetailCallback(currentMatch)"
                                   HomeName="@ParticipantName(currentMatch.HomeParticipantId)"
                                   AwayName="@ParticipantName(currentMatch.AwayParticipantId)"
                                   BoardName="@detailBoard.Name"
                                   SetModeActive="@IsSetMode(currentMatch)"
                                   LiveScoreEnabled="@boardCardSettings.LiveScoreEnabled"
                                   ShowMatchStatus="@boardCardSettings.ShowMatchStatus"
                                   ShowSchedulingStatus="@boardCardSettings.ShowSchedulingStatus"
                                   ShowAverage="@boardCardSettings.ShowAverage"
                                   ShowHighestPpr="@boardCardSettings.ShowHighestPpr"
                                   ShowHighestCheckout="@boardCardSettings.ShowHighestCheckout"
                                   ShowAverageDartsPerLeg="@boardCardSettings.ShowAverageDartsPerLeg"
                                   ShowMinimalDartsPerLeg="@boardCardSettings.ShowMinimalDartsPerLeg"
                                   EnableDetailPanel="true"
                                   DetailsExpandedByDefault="@(!boardCardSettings.CollapseDetailsOnMobile || !isCompactViewport)"
                                   ForceDetailsExpanded="@forcedMatchDetailsExpanded"
                                   EnableRealtimeConsumer="@(currentMatch.StartedUtc is not null && currentMatch.FinishedUtc is null)"
                                   OnClick="() => { var m = currentMatch; var b = detailBoard; CloseBoardDetail(); if (b is not null) _modalBackStack.Push(() => OpenBoardDetail(b)); OpenMatchDetail(m); }" />
                        <div class="d-flex flex-column gap-1 mb-3">
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge @GetMonitoringBadgeCss(currentMatch)">@GetMonitoringBadgeText(currentMatch)</span>
                                @if (boardMatchListener?.LastUpdateUtc is not null)
                                {
                                    <span class="small text-muted">Letztes Update: @boardMatchListener.LastUpdateUtc.Value.LocalDateTime.ToString("HH:mm:ss")</span>
                                }
                                @if (CanStartListener(currentMatch))
                                {
                                    <button class="btn btn-outline-success btn-sm" @onclick="() => EnsureListenerAsync(currentMatch)" disabled="@isWorking">
                                        🎧 Listener starten
                                    </button>
                                }
                            </div>
                            @if (boardMatchListener?.LastError is not null && !_dismissedListenerErrors.Contains(currentMatch.Id))
                            {
                                @if (string.Equals(boardMatchListener.LastError, "Match not found on Autodarts", StringComparison.OrdinalIgnoreCase))
                                {
                                    <div class="alert alert-warning py-2 px-3 mb-0 small d-flex align-items-center gap-2 flex-wrap">
                                        <span>⚠️ Das Spiel scheint nicht mehr online zu sein. Soll es zurückgesetzt werden?</span>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-danger btn-sm" @onclick="() => ResetMatchByIdAsync(currentMatch.Id)" disabled="@isWorking">Ja, zurücksetzen</button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick='() => DismissListenerError(currentMatch.Id)' disabled="@isWorking">Nein</button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-danger py-1 px-2 mb-0 small">@boardMatchListener.LastError</div>
                                }
                            }
                        </div>
                    }
                    @if (upcomingOnBoard.Any())
                    {
                        var boardQueueCardSettings = BoardDetailMatchCardSettings;
                        <div id="section-tournaments-board-detail-queue" class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="fw-semibold mb-0">📋 Warteschlange (@upcomingOnBoard.Count Matches)</h6>
                            <button class="btn btn-sm btn-outline-secondary"
                                    title="MatchCard-Einstellungen fuer Board-Detail"
                                    @onclick='() => OpenMatchCardScopeEditor("tournaments::board-detail")'
                                    @onclick:stopPropagation>⚙</button>
                        </div>
                        <div class="d-flex flex-column gap-2 mb-3">
                            @foreach (var m in upcomingOnBoard)
                            {
                                <MatchCard Match="@m"
                                           ViewSettings="@boardQueueCardSettings"
                                           Layout="@boardQueueCardSettings.Layout"
                                           Label="@MatchLabel(m)"
                                           ShowRuntimeBadge="@boardQueueCardSettings.ShowRuntimeBadge"
                                           ShowMonitoringStatus="@ShowMatchCardMonitoring(boardQueueCardSettings)"
                                           MonitoringStatusText="@GetMonitoringBadgeText(m)"
                                           MonitoringStatusCssClass="@GetMonitoringBadgeCss(m)"
                                           EnablePlayerLinks="@boardQueueCardSettings.EnablePlayerLinks"
                                           EnableBoardLink="@boardQueueCardSettings.EnableBoardLink"
                                           HomeName="@ParticipantName(m.HomeParticipantId)"
                                           AwayName="@ParticipantName(m.AwayParticipantId)"
                                           BoardName="@detailBoard.Name"
                                           SlotOrigin="@BuildSlotOrigin(m)"
                                           SetModeActive="@IsSetMode(m)"
                                           LiveScoreEnabled="@boardQueueCardSettings.LiveScoreEnabled"
                                           ShowMatchStatus="@boardQueueCardSettings.ShowMatchStatus"
                                           ShowSchedulingStatus="@boardQueueCardSettings.ShowSchedulingStatus"
                                           ShowAverage="@boardQueueCardSettings.ShowAverage"
                                           ShowHighestPpr="@boardQueueCardSettings.ShowHighestPpr"
                                           ShowHighestCheckout="@boardQueueCardSettings.ShowHighestCheckout"
                                           ShowAverageDartsPerLeg="@boardQueueCardSettings.ShowAverageDartsPerLeg"
                                           ShowMinimalDartsPerLeg="@boardQueueCardSettings.ShowMinimalDartsPerLeg"
                                           OnHomePlayerClick="BuildPlayerDetailCallback(m.HomeParticipantId)"
                                           OnAwayPlayerClick="BuildPlayerDetailCallback(m.AwayParticipantId)"
                                           EnableDetailPanel="false"
                                           DetailsExpandedByDefault="@MatchCardDetailsExpandedByDefault(boardQueueCardSettings)"
                                           ForceDetailsExpanded="@forcedMatchDetailsExpanded"
                                           EnableRealtimeConsumer="@(m.StartedUtc is not null && m.FinishedUtc is null)"
                                           OnClick="() => { detailBoard = null; _modalBackStack.Clear(); OpenMatchDetail(m); }" />
                            }
                        </div>
                    }
                    else if (currentMatch is null)
                    {
                        <p class="text-muted">Keine Matches auf diesem Board geplant.</p>
                    }
                    @if (selectedTournament is not null && !selectedTournament.IsLocked)
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="GenerateScheduleAsync" disabled="@isWorking">
                            ⏰ Spielplan neu berechnen
                        </button>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseBoardDetail">Schließen</button>
                </div>
            </div>
        </div>
    </div>
}

@* ─── Round Detail Modal ─── *@
@if (detailRound is not null && selectedTournament is not null)
{
    var roundStarted = IsRoundStarted(detailRound.Phase, detailRound.RoundNumber);
    var roundCompleted = IsRoundCompleted(detailRound.Phase, detailRound.RoundNumber);
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="CloseRoundDetail">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@RoundDisplayLabel(detailRound)
                        @if (roundCompleted) { <span class="badge text-bg-success ms-2">✓ Abgeschlossen</span> }
                        else if (roundStarted) { <span class="badge text-bg-warning ms-2">▶ Gestartet</span> }
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseRoundDetail"></button>
                </div>
                <div class="modal-body">
                    @if (roundCompleted)
                    {
                        <div class="alert alert-success py-2 small">Diese Runde ist abgeschlossen und kann nicht mehr bearbeitet werden.</div>
                    }
                    else if (roundStarted)
                    {
                        <div class="alert alert-warning py-2 small">⚠ Diese Runde wurde bereits gestartet. Änderungen können laufende Matches beeinflussen.</div>
                    }
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Base Score</label>
                        <select class="form-select form-select-sm" @bind="newRoundBaseScore" disabled="@(roundCompleted || editAreGameModesLocked)">
                            <option value="121">121</option>
                            <option value="170">170</option>
                            <option value="301">301</option>
                            <option value="501">501</option>
                            <option value="701">701</option>
                            <option value="901">901</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Spielmodus</label>
                        <select class="form-select form-select-sm" @bind="newRoundGameMode" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                            <option value="Legs">Legs</option>
                            <option value="Sets">Sets</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Legs (First to)</label>
                        @if (newRoundGameMode == "Sets")
                        {
                            <select class="form-select form-select-sm" @bind="newRoundLegs" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                                <option value="2">2</option>
                                <option value="3">3</option>
                            </select>
                        }
                        else
                        {
                            <input type="number" class="form-control form-control-sm" @bind="newRoundLegs" min="1" max="11" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)" />
                        }
                    </div>
                    @if (newRoundGameMode == "Sets")
                    {
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Sets (First to)</label>
                            <input type="number" class="form-control form-control-sm" @bind="newRoundSets" min="2" max="7" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)" />
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">In-Modus</label>
                        <select class="form-select form-select-sm" @bind="newRoundInMode" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                            <option value="Straight">Straight In (SI)</option>
                            <option value="Double">Double In (DI)</option>
                            <option value="Master">Master In (MI)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Out-Modus</label>
                        <select class="form-select form-select-sm" @bind="newRoundOutMode" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                            <option value="Straight">Straight Out (SO)</option>
                            <option value="Double">Double Out (DO)</option>
                            <option value="Master">Master Out (MO)</option>
                        </select>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label class="form-label small">Max Runden</label>
                            <select class="form-select form-select-sm" @bind="newRoundMaxRounds" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                                <option value="15">15</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                                <option value="80">80</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Bull Mode</label>
                            <select class="form-select form-select-sm" @bind="newRoundBullMode" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                                <option value="25/50">25/50</option>
                                <option value="50/50">50/50</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Bull-off</label>
                            <select class="form-select form-select-sm" @bind="newRoundBullOffMode" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                                <option value="Off">Off</option>
                                <option value="Normal">Normal</option>
                                <option value="Official">Official</option>
                            </select>
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label class="form-label small">Spielzeit pro Leg (s)</label>
                            <input type="number" class="form-control form-control-sm" @bind="newRoundDuration" min="0" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Pause (min)</label>
                            <input type="number" class="form-control form-control-sm" @bind="newRoundPause" min="0" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Min. Spielerpause (min)</label>
                            <input type="number" class="form-control form-control-sm" @bind="newRoundPlayerPause" min="0" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Boardauswahl</label>
                        <select class="form-select form-select-sm" @bind="newRoundBoardAssignment" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                            <option value="Dynamic">Dynamisch</option>
                            @foreach (var b in boards)
                            {
                                <option value="Fixed:@b.Id">@b.Name (fix)</option>
                            }
                        </select>
                    </div>
                    @if (roundError is not null)
                    {
                        <div class="alert alert-danger py-1 small">@roundError</div>
                    }
                </div>
                <div class="modal-footer">
                    @if (!roundStarted && !roundCompleted && !editAreGameModesLocked && !selectedTournament.IsLocked && CanEditTournamentStructure)
                    {
                        <button class="btn btn-outline-danger me-auto" @onclick="DeleteRoundAsync" disabled="@(isWorking || !CanEditTournamentStructure)"
                                title="Spielrunde löschen">
                            🗑 Löschen
                        </button>
                    }
                    <button class="btn btn-secondary" @onclick="CloseRoundDetail">Abbrechen</button>
                    @if (!roundCompleted && !editAreGameModesLocked && !selectedTournament.IsLocked && CanEditTournamentStructure)
                    {
                        <button class="btn btn-primary" @onclick="async () => { await SaveRoundAsync(); CloseRoundDetail(); }" disabled="@(isWorking || !CanEditTournamentStructure)">Speichern</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ─── Page Settings Modal ─── *@
@if (showPageSettingsModal)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="() => showPageSettingsModal = false">
        <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Seiteneinstellungen</h5>
                    <button type="button" class="btn-close" @onclick="() => showPageSettingsModal = false"></button>
                </div>
                <div class="modal-body">

                    <div class="mb-4">
                        <div class="fw-semibold small mb-2">Realtime / Fallback-Polling</div>
                        <label for="modalTournamentFallback" class="form-label small mb-1">Fallback-Polling</label>
                        <select id="modalTournamentFallback" class="form-select form-select-sm w-auto"
                                value="@fallbackPollingIntervalSeconds"
                                @onchange="OnFallbackPollingIntervalChanged"
                                disabled="@isSavingRealtimePreference">
                            <option value="2">2s</option>
                            <option value="3">3s</option>
                            <option value="5">5s (Standard)</option>
                            <option value="10">10s</option>
                            <option value="15">15s</option>
                            <option value="30">30s</option>
                        </select>
                        @if (isSavingRealtimePreference)
                        {
                            <div class="small text-muted mt-1">Speichere ...</div>
                        }
                        @if (realtimePreferenceError is not null)
                        {
                            <div class="alert alert-danger py-1 px-2 small mt-1 mb-0">@realtimePreferenceError</div>
                        }
                    </div>

                    <div class="border-top pt-3">
                        <div class="fw-semibold mb-2">MatchCard Konfiguration</div>
                        <div class="small text-muted mb-3">Kontext: @ActiveMatchCardContextLabel / @ActiveMatchCardConfigScopeLabel</div>

                        <div class="mb-3">
                            <label class="form-label small mb-1">Konfiguration</label>
                            <select class="form-select form-select-sm"
                                    value="@activeMatchCardConfigScopeKey"
                                    @onchange="OnMatchCardConfigScopeChanged"
                                    disabled="@isSavingMatchCardPreferences">
                                @foreach (var scope in MatchCardScopeOptions)
                                {
                                    <option value="@scope.ScopeKey">@scope.Label</option>
                                }
                            </select>
                        </div>

                        <fieldset disabled="@isSavingMatchCardPreferences">
                            <div class="row g-2 small mb-3">
                                <div class="col-lg-3 col-md-4">
                                    <label class="form-label mb-1">Anzeige</label>
                                    <select class="form-select form-select-sm"
                                            value="@ActiveMatchCardConfigSettings.Layout"
                                            @onchange="UpdateActiveMatchCardLayoutAsync">
                                        <option value="Horizontal">Horizontal</option>
                                        <option value="Vertical">Vertikal</option>
                                        <option value="Card">Karte</option>
                                        <option value="List">Liste</option>
                                    </select>
                                </div>
                                <div class="col-lg-3 col-md-4">
                                    <label class="form-label mb-1">Spielstand</label>
                                    <select class="form-select form-select-sm"
                                            value="@ActiveMatchCardConfigSettings.ScoreMode"
                                            @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ScoreMode = MatchCardViewSettings.NormalizeScoreMode(args.Value?.ToString()))">
                                        <option value="FinalOnly">Nur Endresultat</option>
                                        <option value="CurrentNoPoints">Aktueller Spielstand</option>
                                        <option value="LiveScores">Live Scores</option>
                                    </select>
                                </div>
                                <div class="col-lg-3 col-md-4">
                                    <label class="form-label mb-1">Spielernamen</label>
                                    <select class="form-select form-select-sm"
                                            value="@ActiveMatchCardConfigSettings.PlayerNameMode"
                                            @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.PlayerNameMode = MatchCardViewSettings.NormalizePlayerNameMode(args.Value?.ToString()))">
                                        <option value="Name">Nur Name</option>
                                        <option value="NameAndPpr">Name und PPR</option>
                                    </select>
                                </div>
                                <div class="col-lg-3 col-md-12 d-flex align-items-end">
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psCollapseMobile" checked="@ActiveMatchCardConfigSettings.CollapseDetailsOnMobile" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.CollapseDetailsOnMobile = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psCollapseMobile">Mobile eingeklappt</label></div>
                                </div>
                            </div>

                            <div class="border rounded p-2 mb-2">
                                <div class="fw-semibold small mb-2">Titelleiste</div>
                                <div class="d-flex flex-wrap gap-3 small">
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderMatchNumber" checked="@ActiveMatchCardConfigSettings.ShowHeaderMatchNumber" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderMatchNumber = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderMatchNumber">Matchnummer</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderMatchName" checked="@ActiveMatchCardConfigSettings.ShowHeaderMatchName" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderMatchName = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderMatchName">Matchname</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderStart" checked="@ActiveMatchCardConfigSettings.ShowHeaderStartTime" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderStartTime = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderStart">Startzeit</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderStartLock" checked="@ActiveMatchCardConfigSettings.ShowHeaderStartTimeLock" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderStartTimeLock = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderStartLock">Startzeit gesperrt</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderBoard" checked="@ActiveMatchCardConfigSettings.ShowHeaderBoardName" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderBoardName = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderBoard">Boardname</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderBoardLock" checked="@ActiveMatchCardConfigSettings.ShowHeaderBoardLock" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderBoardLock = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderBoardLock">Board gesperrt</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderDelay" checked="@ActiveMatchCardConfigSettings.ShowHeaderDelay" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderDelay = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderDelay">Zeitdifferenz</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderStatus" checked="@ActiveMatchCardConfigSettings.ShowHeaderMatchStatus" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderMatchStatus = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderStatus">Matchstatus</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderLive" checked="@ActiveMatchCardConfigSettings.ShowHeaderLiveBadge" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderLiveBadge = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderLive">Live-Badge</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psRuntimeBadge" checked="@ActiveMatchCardConfigSettings.ShowRuntimeBadge" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowRuntimeBadge = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psRuntimeBadge">Spielzeit-Badge</label></div>
                                </div>
                            </div>

                            <div class="border rounded p-2 mb-2">
                                <div class="fw-semibold small mb-2">Body</div>
                                <div class="d-flex flex-wrap gap-3 small">
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psBodyStart" checked="@ActiveMatchCardConfigSettings.ShowBodyStartTime" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowBodyStartTime = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psBodyStart">Startzeit</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psBodyStartLock" checked="@ActiveMatchCardConfigSettings.ShowBodyStartTimeLock" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowBodyStartTimeLock = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psBodyStartLock">Startzeit gesperrt</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psBodyDelay" checked="@ActiveMatchCardConfigSettings.ShowBodyDelay" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowBodyDelay = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psBodyDelay">Zeitdifferenz</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psBodyMatchNumber" checked="@ActiveMatchCardConfigSettings.ShowBodyMatchNumber" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowBodyMatchNumber = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psBodyMatchNumber">Matchnummer</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psBodyBoard" checked="@ActiveMatchCardConfigSettings.ShowBodyBoardName" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowBodyBoardName = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psBodyBoard">Boardname</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psLiveEnabled" checked="@ActiveMatchCardConfigSettings.LiveScoreEnabled" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.LiveScoreEnabled = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psLiveEnabled">LiveScore aktiv</label></div>
                                </div>
                            </div>

                            <div class="border rounded p-2 mb-2">
                                <div class="fw-semibold small mb-2">Buttons / Funktionen</div>
                                <div class="d-flex flex-wrap gap-3 small">
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psActionBar" checked="@ActiveMatchCardConfigSettings.ShowActionButtons" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowActionButtons = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psActionBar">Action-Leiste</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psActionSync" checked="@ActiveMatchCardConfigSettings.ShowSyncAction" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowSyncAction = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psActionSync">Sync</label></div>
