                                                                                            </div>
                                                                                            @if (roundSettings.Any())
                                                                                            {
                                                                                                @foreach (var rnd in roundSettings.OrderBy(r => r.Phase).ThenBy(r => r.RoundNumber))
                                                                                                {
                                                                                                    var started = IsRoundStarted(rnd.Phase, rnd.RoundNumber);
                                                                                                    var completed = IsRoundCompleted(rnd.Phase, rnd.RoundNumber);
                                                                                                    @if (!completed || showCompletedRounds)
                                                                                                    {
                                                                                                        <div class="card mb-2 @(completed ? "border-success" : started ? "border-warning" : "")" style="cursor:pointer" @onclick="() => OpenRoundDetail(rnd)">
                                                                                                            <div class="card-body py-2">
                                                                                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                                                                                    <span>
                                                                                                                        <strong class="small">@RoundDisplayLabel(rnd)</strong>
                                                                                                                        @if (completed) { <span class="badge text-bg-success ms-1">✓ Abgeschlossen</span> }
                                                                                                                        else if (started) { <span class="badge text-bg-warning ms-1">▶ Gestartet</span> }
                                                                                                                    </span>
                                                                                                                    <span class="badge text-bg-light">First to @rnd.Legs Legs | @rnd.BaseScore @rnd.OutMode</span>
                                                                                                                </div>
                                                                                                                <div class="small text-muted">
                                                                                                                    Spielzeit/Leg: @rnd.LegDurationSeconds s | Pause: @rnd.PauseBetweenMatchesMinutes min | Spielerpause: @rnd.MinPlayerPauseMinutes min | Board: @rnd.BoardAssignment
                                                                                                                </div>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    }
                                                                                                }
                                                                                            }
                                                                                            @if (!selectedTournament.IsLocked && !editAreGameModesLocked && CanEditTournamentStructure)
                                                                                            {
                                                                                                <div class="card border-primary mt-3">
                                                                                                    <div class="card-header bg-primary text-white py-2"><strong class="small">Runde hinzufügen / bearbeiten</strong></div>
                                                                                                    <div class="card-body">
                                                                                                        <div class="row g-2 mb-2">
                                                                                                            <div class="col-md-3">
                                                                                                                <label class="form-label small">Phase</label>
                                                                                                                <select class="form-select form-select-sm" @bind="newRoundPhase">
                                                                                                                    <option value="Knockout">Knockout</option>
                                                                                                                    <option value="Group">Gruppe</option>
                                                                                                                </select>
                                                                                                            </div>
                                                                                                            <div class="col-md-2">
                                                                                                                <label class="form-label small">Rundennr.</label>
                                                                                                                <input type="number" class="form-control form-control-sm" @bind="newRoundNumber" min="1" />
                                                                                                            </div>
                                                                                                            <div class="col-md-2">
                                                                                                                <label class="form-label small">Base Score</label>
                                                                                                                <select class="form-select form-select-sm" @bind="newRoundBaseScore">
                                                                                                                    <option value="121">121</option>
                                                                                                                    <option value="170">170</option>
                                                                                                                    <option value="301">301</option>
                                                                                                                    <option value="501">501</option>
                                                                                                                    <option value="701">701</option>
                                                                                                                    <option value="901">901</option>
                                                                                                                </select>
                                                                                                            </div>
                                                                                                            <div class="col-md-2">
                                                                                                                <label class="form-label small">Spielmodus</label>
                                                                                                                <select class="form-select form-select-sm" @bind="newRoundGameMode">
                                                                                                                    <option value="Legs">Legs</option>
                                                                                                                    <option value="Sets">Sets</option>
                                                                                                                </select>
                                                                                                            </div>
                                                                                                            <div class="col-md-2">
                                                                                                                <label class="form-label small">Legs (First to)</label>
                                                                                                                @if (newRoundGameMode == "Sets")
                                                                                                                {
                                                                                                                    <select class="form-select form-select-sm" @bind="newRoundLegs">
                                                                                                                        <option value="2">2</option>
                                                                                                                        <option value="3">3</option>
                                                                                                                    </select>
                                                                                                                }
                                                                                                                else
                                                                                                                {
                                                                                                                    <input type="number" class="form-control form-control-sm" @bind="newRoundLegs" min="1" max="11" />
                                                                                                                }
                                                                                                            </div>
                                                                                                            @if (newRoundGameMode == "Sets")
                                                                                                            {
                                                                                                                <div class="col-md-2">
                                                                                                                    <label class="form-label small">Sets (First to)</label>
                                                                                                                    <input type="number" class="form-control form-control-sm" @bind="newRoundSets" min="2" max="7" />
                                                                                                                </div>
                                                                                                            }
                                                                                                            <div class="col-md-2">
                                                                                                                <label class="form-label small">In-Modus</label>
                                                                                                                <select class="form-select form-select-sm" @bind="newRoundInMode">
                                                                                                                    <option value="Straight">Straight In (SI)</option>
                                                                                                                    <option value="Double">Double In (DI)</option>
                                                                                                                    <option value="Master">Master In (MI)</option>
                                                                                                                </select>
                                                                                                            </div>
                                                                                                            <div class="col-md-3">
                                                                                                                <label class="form-label small">Out-Modus</label>
                                                                                                                <select class="form-select form-select-sm" @bind="newRoundOutMode">
                                                                                                                    <option value="Straight">Straight Out (SO)</option>
                                                                                                                    <option value="Double">Double Out (DO)</option>
                                                                                                                    <option value="Master">Master Out (MO)</option>
                                                                                                                </select>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                        <div class="row g-2 mb-2">
                                                                                                            <div class="col-md-2">
                                                                                                                <label class="form-label small">Max Runden</label>
                                                                                                                <select class="form-select form-select-sm" @bind="newRoundMaxRounds">
                                                                                                                    <option value="15">15</option>
                                                                                                                    <option value="20">20</option>
                                                                                                                    <option value="50">50</option>
                                                                                                                    <option value="80">80</option>
                                                                                                                </select>
                                                                                                            </div>
                                                                                                            <div class="col-md-2">
                                                                                                                <label class="form-label small">Bull Mode</label>
                                                                                                                <select class="form-select form-select-sm" @bind="newRoundBullMode">
                                                                                                                    <option value="25/50">25/50</option>
                                                                                                                    <option value="50/50">50/50</option>
                                                                                                                </select>
                                                                                                            </div>
                                                                                                            <div class="col-md-2">
                                                                                                                <label class="form-label small">Bull-off</label>
                                                                                                                <select class="form-select form-select-sm" @bind="newRoundBullOffMode">
                                                                                                                    <option value="Off">Off</option>
                                                                                                                    <option value="Normal">Normal</option>
                                                                                                                    <option value="Official">Official</option>
                                                                                                                </select>
                                                                                                            </div>
                                                                                                            <div class="col-md-3">
                                                                                                                <label class="form-label small">Spielzeit pro Leg (s)</label>
                                                                                                                <input type="number" class="form-control form-control-sm" @bind="newRoundDuration" min="0" />
                                                                                                            </div>
                                                                                                            <div class="col-md-3">
                                                                                                                <label class="form-label small">Pause (min)</label>
                                                                                                                <input type="number" class="form-control form-control-sm" @bind="newRoundPause" min="0" />
                                                                                                            </div>
                                                                                                            <div class="col-md-3">
                                                                                                                <label class="form-label small">Min. Spielerpause (min)</label>
                                                                                                                <input type="number" class="form-control form-control-sm" @bind="newRoundPlayerPause" min="0" />
                                                                                                            </div>
                                                                                                            <div class="col-md-3">
                                                                                                                <label class="form-label small">Boardauswahl</label>
                                                                                                                <select class="form-select form-select-sm" @bind="newRoundBoardAssignment">
