@* ─── Board Detail Modal ─── *@
@if (detailBoard is not null)
{
    var currentMatch = CurrentMatchOnBoard(detailBoard.Id);
    var upcomingOnBoard = UpcomingMatchesOnBoard(detailBoard.Id);
    var boardMatchListener = currentMatch is not null ? matchListeners.FirstOrDefault(l => l.MatchId == currentMatch.Id) : null;
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="CloseBoardDetail">
        <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">📋 @detailBoard.Name</h5>
                    <button type="button" class="btn-close" @onclick="CloseBoardDetail"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="badge @BoardStatusBadge(detailBoard.Status)">@detailBoard.Status</span>
                        @if (detailBoard.IsExtensionConnected)
                        {
                            <span class="badge text-bg-success">🔗 Extension verbunden</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">⛓️‍💥 Extension nicht verbunden</span>
                        }
                        <a href="https://play.autodarts.io/boards/@(detailBoard.ExternalBoardId)/follow" target="_blank"
                           rel="noopener" class="btn btn-outline-primary btn-sm"><span class="autodarts-icon"></span> Board verfolgen</a>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => RequestBoardSyncAsync(detailBoard)"
                                disabled="@(isWorking || !detailBoard.IsExtensionConnected)">
                            🔄 Sync
                        </button>
                    </div>
                    @if (boardSyncInfo is not null)
                    {
                        <div class="alert alert-info py-2 small">@boardSyncInfo</div>
                    }
                    @if (boardSyncError is not null)
                    {
                        <div class="alert alert-danger py-2 small">@boardSyncError</div>
                    }
                    @if (IsDevelopmentEnvironment)
                    {
                        <details class="card border-warning-subtle mb-3">
                            <summary class="card-header py-2 d-flex justify-content-between align-items-center" style="cursor:pointer">
                                <span class="small fw-semibold">Dev: Board Sync Debug</span>
                                <span class="small text-muted">@(boardSyncDebug?.Matched is true ? "gematcht" : boardSyncDebug?.ReportedAtUtc is not null ? "reportet" : "eingeklappt")</span>
                            </summary>
                            <div class="card-body py-2">
                                <div class="d-flex justify-content-end mb-2">
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshBoardSyncDebugAsync" disabled="@isBoardSyncDebugLoading">
                                        @(isBoardSyncDebugLoading ? "Lade..." : "Aktualisieren")
                                    </button>
                                </div>
                                @if (boardSyncDebug is null)
                                {
                                    <div class="small text-muted">Noch keine Sync-Daten vorhanden.</div>
                                }
                                else
                                {
                                    <div class="row g-2 small">
                                        <div class="col-md-6"><strong>RequestId:</strong> @boardSyncDebug.RequestId</div>
                                        <div class="col-md-6"><strong>ShouldSync:</strong> @boardSyncDebug.ShouldSync</div>
                                        <div class="col-md-6"><strong>Requested:</strong> @(boardSyncDebug.RequestedAtUtc?.LocalDateTime.ToString("HH:mm:ss") ?? "—")</div>
                                        <div class="col-md-6"><strong>Consumed:</strong> @(boardSyncDebug.ConsumedAtUtc?.LocalDateTime.ToString("HH:mm:ss") ?? "—")</div>
                                        <div class="col-md-6"><strong>Reported:</strong> @(boardSyncDebug.ReportedAtUtc?.LocalDateTime.ToString("HH:mm:ss") ?? "—")</div>
                                        <div class="col-md-6"><strong>Matched:</strong> @boardSyncDebug.Matched</div>
                                        <div class="col-md-6"><strong>MatchedBy:</strong> @(string.IsNullOrWhiteSpace(boardSyncDebug.MatchedBy) ? "—" : boardSyncDebug.MatchedBy)</div>
                                        <div class="col-md-6"><strong>MatchId:</strong> @(boardSyncDebug.MatchId?.ToString() ?? "—")</div>
                                        <div class="col-md-6"><strong>DerivedStatus:</strong> @boardSyncDebug.DerivedStatus</div>
                                        <div class="col-md-6"><strong>ExternalMatchId:</strong> @boardSyncDebug.ExternalMatchId</div>
                                        <div class="col-md-6"><strong>TournamentId:</strong> @(boardSyncDebug.TournamentId?.ToString() ?? "—")</div>
                                        <div class="col-md-6"><strong>Player1:</strong> @(string.IsNullOrWhiteSpace(boardSyncDebug.Player1) ? "—" : boardSyncDebug.Player1)</div>
                                        <div class="col-md-6"><strong>Player2:</strong> @(string.IsNullOrWhiteSpace(boardSyncDebug.Player2) ? "—" : boardSyncDebug.Player2)</div>
                                        <div class="col-12"><strong>SourceUrl:</strong> @(string.IsNullOrWhiteSpace(boardSyncDebug.SourceUrl) ? "—" : boardSyncDebug.SourceUrl)</div>
                                    </div>
                                }
                            </div>
                        </details>
                    }
                    @if (currentMatch is not null)
                    {
                        var boardCardSettings = BoardDetailMatchCardSettings;
                        <div id="section-tournaments-board-detail-current" class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="fw-semibold mb-0">▶ Laufendes Match</h6>
                            <button class="btn btn-sm btn-outline-secondary"
                                    title="MatchCard-Einstellungen fuer Board-Detail"
                                    @onclick='() => OpenMatchCardScopeEditor("tournaments::board-detail")'
                                    @onclick:stopPropagation>⚙</button>
                        </div>
                        <MatchCard Match="@currentMatch"
                                   ViewSettings="@boardCardSettings"
                                   Layout="@boardCardSettings.Layout"
                                   Label="@MatchLabel(currentMatch)"
                                   ShowRuntimeBadge="@boardCardSettings.ShowRuntimeBadge"
                                   ShowMonitoringStatus="@ShowMatchCardMonitoring(boardCardSettings)"
                                   MonitoringStatusText="@GetMonitoringBadgeText(currentMatch)"
                                   MonitoringStatusCssClass="@GetMonitoringBadgeCss(currentMatch)"
                                   ShowActionButtons="@ShowMatchCardActionBar(boardCardSettings)"
                                   ShowSyncAction="@ShowMatchCardSyncAction(boardCardSettings, currentMatch)"
                                   ShowFollowAction="@ShowMatchCardFollowAction(boardCardSettings)"
                                   IsFollowing="@IsMatchFollowed(currentMatch.Id)"
                                   CanFollow="@CanFollowFromMatchCard(currentMatch)"
                                   CanSync="@CanSyncFromMatchCard(currentMatch)"
                                   OnFollow="() => ToggleFollowMatchAsync(currentMatch)"
                                   OnSync="() => SyncMatchFromExternalAsync(currentMatch)"
                                   EnablePlayerLinks="@boardCardSettings.EnablePlayerLinks"
                                   EnableBoardLink="@boardCardSettings.EnableBoardLink"
                                   OnHomePlayerClick="BuildPlayerDetailCallback(currentMatch.HomeParticipantId)"
                                   OnAwayPlayerClick="BuildPlayerDetailCallback(currentMatch.AwayParticipantId)"
                                   OnBoardClick="BuildMatchBoardDetailCallback(currentMatch)"
                                   HomeName="@ParticipantName(currentMatch.HomeParticipantId)"
                                   AwayName="@ParticipantName(currentMatch.AwayParticipantId)"
                                   BoardName="@detailBoard.Name"
                                   SetModeActive="@IsSetMode(currentMatch)"
                                   LiveScoreEnabled="@boardCardSettings.LiveScoreEnabled"
                                   ShowMatchStatus="@boardCardSettings.ShowMatchStatus"
                                   ShowSchedulingStatus="@boardCardSettings.ShowSchedulingStatus"
                                   ShowAverage="@boardCardSettings.ShowAverage"
                                   ShowHighestPpr="@boardCardSettings.ShowHighestPpr"
                                   ShowHighestCheckout="@boardCardSettings.ShowHighestCheckout"
                                   ShowAverageDartsPerLeg="@boardCardSettings.ShowAverageDartsPerLeg"
                                   ShowMinimalDartsPerLeg="@boardCardSettings.ShowMinimalDartsPerLeg"
                                   EnableDetailPanel="true"
                                   DetailsExpandedByDefault="@(!boardCardSettings.CollapseDetailsOnMobile || !isCompactViewport)"
                                   ForceDetailsExpanded="@forcedMatchDetailsExpanded"
                                   EnableRealtimeConsumer="@(currentMatch.StartedUtc is not null && currentMatch.FinishedUtc is null)"
                                   OnClick="() => { var m = currentMatch; var b = detailBoard; CloseBoardDetail(); if (b is not null) _modalBackStack.Push(() => OpenBoardDetail(b)); OpenMatchDetail(m); }" />
                        <div class="d-flex flex-column gap-1 mb-3">
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge @GetMonitoringBadgeCss(currentMatch)">@GetMonitoringBadgeText(currentMatch)</span>
                                @if (boardMatchListener?.LastUpdateUtc is not null)
                                {
                                    <span class="small text-muted">Letztes Update: @boardMatchListener.LastUpdateUtc.Value.LocalDateTime.ToString("HH:mm:ss")</span>
                                }
                                @if (CanStartListener(currentMatch))
                                {
                                    <button class="btn btn-outline-success btn-sm" @onclick="() => EnsureListenerAsync(currentMatch)" disabled="@isWorking">
                                        🎧 Listener starten
                                    </button>
                                }
                            </div>
                            @if (boardMatchListener?.LastError is not null && !_dismissedListenerErrors.Contains(currentMatch.Id))
                            {
                                @if (string.Equals(boardMatchListener.LastError, "Match not found on Autodarts", StringComparison.OrdinalIgnoreCase))
                                {
                                    <div class="alert alert-warning py-2 px-3 mb-0 small d-flex align-items-center gap-2 flex-wrap">
                                        <span>⚠️ Das Spiel scheint nicht mehr online zu sein. Soll es zurückgesetzt werden?</span>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-danger btn-sm" @onclick="() => ResetMatchByIdAsync(currentMatch.Id)" disabled="@isWorking">Ja, zurücksetzen</button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick='() => DismissListenerError(currentMatch.Id)' disabled="@isWorking">Nein</button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-danger py-1 px-2 mb-0 small">@boardMatchListener.LastError</div>
                                }
                            }
                        </div>
                    }
                    @if (upcomingOnBoard.Any())
                    {
                        var boardQueueCardSettings = BoardDetailMatchCardSettings;
                        <div id="section-tournaments-board-detail-queue" class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="fw-semibold mb-0">📋 Warteschlange (@upcomingOnBoard.Count Matches)</h6>
                            <button class="btn btn-sm btn-outline-secondary"
                                    title="MatchCard-Einstellungen fuer Board-Detail"
                                    @onclick='() => OpenMatchCardScopeEditor("tournaments::board-detail")'
                                    @onclick:stopPropagation>⚙</button>
                        </div>
                        <div class="d-flex flex-column gap-2 mb-3">
                            @foreach (var m in upcomingOnBoard)
                            {
                                <MatchCard Match="@m"
                                           ViewSettings="@boardQueueCardSettings"
                                           Layout="@boardQueueCardSettings.Layout"
                                           Label="@MatchLabel(m)"
                                           ShowRuntimeBadge="@boardQueueCardSettings.ShowRuntimeBadge"
                                           ShowMonitoringStatus="@ShowMatchCardMonitoring(boardQueueCardSettings)"
                                           MonitoringStatusText="@GetMonitoringBadgeText(m)"
                                           MonitoringStatusCssClass="@GetMonitoringBadgeCss(m)"
                                           EnablePlayerLinks="@boardQueueCardSettings.EnablePlayerLinks"
                                           EnableBoardLink="@boardQueueCardSettings.EnableBoardLink"
                                           HomeName="@ParticipantName(m.HomeParticipantId)"
                                           AwayName="@ParticipantName(m.AwayParticipantId)"
                                           BoardName="@detailBoard.Name"
                                           SlotOrigin="@BuildSlotOrigin(m)"
                                           SetModeActive="@IsSetMode(m)"
                                           LiveScoreEnabled="@boardQueueCardSettings.LiveScoreEnabled"
                                           ShowMatchStatus="@boardQueueCardSettings.ShowMatchStatus"
                                           ShowSchedulingStatus="@boardQueueCardSettings.ShowSchedulingStatus"
                                           ShowAverage="@boardQueueCardSettings.ShowAverage"
                                           ShowHighestPpr="@boardQueueCardSettings.ShowHighestPpr"
                                           ShowHighestCheckout="@boardQueueCardSettings.ShowHighestCheckout"
                                           ShowAverageDartsPerLeg="@boardQueueCardSettings.ShowAverageDartsPerLeg"
                                           ShowMinimalDartsPerLeg="@boardQueueCardSettings.ShowMinimalDartsPerLeg"
                                           OnHomePlayerClick="BuildPlayerDetailCallback(m.HomeParticipantId)"
                                           OnAwayPlayerClick="BuildPlayerDetailCallback(m.AwayParticipantId)"
                                           EnableDetailPanel="false"
                                           DetailsExpandedByDefault="@MatchCardDetailsExpandedByDefault(boardQueueCardSettings)"
                                           ForceDetailsExpanded="@forcedMatchDetailsExpanded"
                                           EnableRealtimeConsumer="@(m.StartedUtc is not null && m.FinishedUtc is null)"
                                           OnClick="() => { detailBoard = null; _modalBackStack.Clear(); OpenMatchDetail(m); }" />
                            }
                        </div>
                    }
                    else if (currentMatch is null)
                    {
                        <p class="text-muted">Keine Matches auf diesem Board geplant.</p>
                    }
                    @if (selectedTournament is not null && !selectedTournament.IsLocked)
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="GenerateScheduleAsync" disabled="@isWorking">
                            ⏰ Spielplan neu berechnen
                        </button>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseBoardDetail">Schließen</button>
                </div>
            </div>
        </div>
    </div>
}

@* ─── Round Detail Modal ─── *@
@if (detailRound is not null && selectedTournament is not null)
{
    var roundStarted = IsRoundStarted(detailRound.Phase, detailRound.RoundNumber);
    var roundCompleted = IsRoundCompleted(detailRound.Phase, detailRound.RoundNumber);
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="CloseRoundDetail">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@RoundDisplayLabel(detailRound)
                        @if (roundCompleted) { <span class="badge text-bg-success ms-2">✓ Abgeschlossen</span> }
                        else if (roundStarted) { <span class="badge text-bg-warning ms-2">▶ Gestartet</span> }
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseRoundDetail"></button>
                </div>
                <div class="modal-body">
                    @if (roundCompleted)
                    {
                        <div class="alert alert-success py-2 small">Diese Runde ist abgeschlossen und kann nicht mehr bearbeitet werden.</div>
                    }
                    else if (roundStarted)
                    {
                        <div class="alert alert-warning py-2 small">⚠ Diese Runde wurde bereits gestartet. Änderungen können laufende Matches beeinflussen.</div>
                    }
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Base Score</label>
                        <select class="form-select form-select-sm" @bind="newRoundBaseScore" disabled="@(roundCompleted || editAreGameModesLocked)">
                            <option value="121">121</option>
                            <option value="170">170</option>
                            <option value="301">301</option>
                            <option value="501">501</option>
                            <option value="701">701</option>
                            <option value="901">901</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Spielmodus</label>
                        <select class="form-select form-select-sm" @bind="newRoundGameMode" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                            <option value="Legs">Legs</option>
                            <option value="Sets">Sets</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Legs (First to)</label>
                        @if (newRoundGameMode == "Sets")
                        {
                            <select class="form-select form-select-sm" @bind="newRoundLegs" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                                <option value="2">2</option>
                                <option value="3">3</option>
                            </select>
                        }
                        else
                        {
                            <input type="number" class="form-control form-control-sm" @bind="newRoundLegs" min="1" max="11" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)" />
                        }
                    </div>
                    @if (newRoundGameMode == "Sets")
                    {
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Sets (First to)</label>
                            <input type="number" class="form-control form-control-sm" @bind="newRoundSets" min="2" max="7" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)" />
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">In-Modus</label>
                        <select class="form-select form-select-sm" @bind="newRoundInMode" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                            <option value="Straight">Straight In (SI)</option>
                            <option value="Double">Double In (DI)</option>
                            <option value="Master">Master In (MI)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Out-Modus</label>
                        <select class="form-select form-select-sm" @bind="newRoundOutMode" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                            <option value="Straight">Straight Out (SO)</option>
                            <option value="Double">Double Out (DO)</option>
                            <option value="Master">Master Out (MO)</option>
                        </select>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label class="form-label small">Max Runden</label>
                            <select class="form-select form-select-sm" @bind="newRoundMaxRounds" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                                <option value="15">15</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                                <option value="80">80</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Bull Mode</label>
                            <select class="form-select form-select-sm" @bind="newRoundBullMode" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                                <option value="25/50">25/50</option>
                                <option value="50/50">50/50</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Bull-off</label>
                            <select class="form-select form-select-sm" @bind="newRoundBullOffMode" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                                <option value="Off">Off</option>
                                <option value="Normal">Normal</option>
                                <option value="Official">Official</option>
                            </select>
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label class="form-label small">Spielzeit pro Leg (s)</label>
                            <input type="number" class="form-control form-control-sm" @bind="newRoundDuration" min="0" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Pause (min)</label>
                            <input type="number" class="form-control form-control-sm" @bind="newRoundPause" min="0" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Min. Spielerpause (min)</label>
                            <input type="number" class="form-control form-control-sm" @bind="newRoundPlayerPause" min="0" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Boardauswahl</label>
                        <select class="form-select form-select-sm" @bind="newRoundBoardAssignment" disabled="@(roundCompleted || editAreGameModesLocked || !CanEditTournamentStructure)">
                            <option value="Dynamic">Dynamisch</option>
                            @foreach (var b in boards)
                            {
                                <option value="Fixed:@b.Id">@b.Name (fix)</option>
                            }
                        </select>
                    </div>
                    @if (roundError is not null)
                    {
                        <div class="alert alert-danger py-1 small">@roundError</div>
                    }
                </div>
                <div class="modal-footer">
                    @if (!roundStarted && !roundCompleted && !editAreGameModesLocked && !selectedTournament.IsLocked && CanEditTournamentStructure)
                    {
                        <button class="btn btn-outline-danger me-auto" @onclick="DeleteRoundAsync" disabled="@(isWorking || !CanEditTournamentStructure)"
                                title="Spielrunde löschen">
                            🗑 Löschen
                        </button>
                    }
                    <button class="btn btn-secondary" @onclick="CloseRoundDetail">Abbrechen</button>
                    @if (!roundCompleted && !editAreGameModesLocked && !selectedTournament.IsLocked && CanEditTournamentStructure)
                    {
                        <button class="btn btn-primary" @onclick="async () => { await SaveRoundAsync(); CloseRoundDetail(); }" disabled="@(isWorking || !CanEditTournamentStructure)">Speichern</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ─── Page Settings Modal ─── *@
@if (showPageSettingsModal)
{
