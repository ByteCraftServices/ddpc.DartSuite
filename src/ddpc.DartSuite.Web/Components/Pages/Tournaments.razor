                                                                                                <label class="form-label fw-semibold" title="Vor-Ort: Board-Zuweisung und lokale Steuerung; Online: ohne Board-Zwang.">Variante</label>
                                                                                                <select class="form-select" @bind="editVariant" @bind:after="AutoSaveSettingAsync">
                                                                                                    <option value="OnSite">Vor-Ort</option>
                                                                                                    <option value="Online">Online</option>
                                                                                                </select>
                                                                                            </div>
                                                                                            <div class="form-check mb-0">
                                                                                                <input class="form-check-input" type="checkbox" id="editThirdPlace" @bind="editThirdPlaceMatch" @bind:after="AutoSaveSettingAsync" />
