                                                    <span class="fw-semibold">@selectedTournament!.Name</span>
                                                </div>
                                                
                                                <!-- Badge + Button row -->
                                                <div class="d-flex justify-content-between align-items-center gap-1 flex-wrap">
                                                    <!-- Left section: badges -->
                                                    <div class="tournament-badges-row">
                                                        <!-- Left badges: Code, Role, Status -->
