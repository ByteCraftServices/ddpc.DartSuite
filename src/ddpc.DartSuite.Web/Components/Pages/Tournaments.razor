                                                        <span class="badge @(selectedTournament?.Id == t.Id ? "bg-light text-dark" : "bg-primary")">@t.ParticipantCount</span>
                                                    </div>
                                                    <small class="@(selectedTournament?.Id == t.Id ? "text-white-50" : "text-muted")">@t.StartDate.ToString("dd.MM.yyyy") – @t.EndDate.ToString("dd.MM.yyyy")</small>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    @if (UpcomingTournaments.Any())
                                    {
                                        <h6 class="mb-1 fw-semibold text-primary">📅 Geplant</h6>
                                        <ul class="list-group mb-3">
                                            @foreach (var t in UpcomingTournaments)
                                            {
                                                <li class="list-group-item list-group-item-action @(selectedTournament?.Id == t.Id ? "active" : "")"
                                                    style="cursor:pointer" @onclick="() => SelectTournamentAsync(t)">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <span class="list-group-item-name" title="@t.Name">
                                                            @t.Name
                                                            @if (t.IsLocked)
                                                            {
                                                                <span>🔒</span>
                                                            }
                                                        </span>
                                                        <span class="badge @(selectedTournament?.Id == t.Id ? "bg-light text-dark" : "bg-secondary")">@t.ParticipantCount</span>
                                                    </div>
                                                    <small class="@(selectedTournament?.Id == t.Id ? "text-white-50" : "text-muted")">@t.StartDate.ToString("dd.MM.yyyy") – @t.EndDate.ToString("dd.MM.yyyy")</small>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    @if (PastTournaments.Any())
                                    {
                                        <h6 class="mb-1 fw-semibold text-muted">✓ Vergangen</h6>
                                        <ul class="list-group mb-3">
                                            @foreach (var t in PastTournaments)
                                            {
                                                <li class="list-group-item list-group-item-action @(selectedTournament?.Id == t.Id ? "active" : "")"
                                                    style="cursor:pointer" @onclick="() => SelectTournamentAsync(t)">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <span class="list-group-item-name" title="@t.Name">@t.Name</span>
                                                        <span
                                                        class="badge @(selectedTournament?.Id == t.Id ? "bg-light text-dark" : "bg-secondary")">@t.ParticipantCount</span>
                                                    </div>
                                                    <small
                                                    class="@(selectedTournament?.Id == t.Id ? "text-white-50" : "text-muted")">@t.StartDate.ToString("dd.MM.yyyy")</small>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    @if (!tournaments.Any())
                                    {
                                        <p class="text-muted">Noch keine Turniere vorhanden.</p>
                                    }
                                </div>

                                @* ─── Detail Panel ─── *@
                                @if (selectedTournament is not null)
                                {
                                    <div class="@(tournamentListCollapsed ? "col-12 col-lg tournament-detail-pane" : "col-12 col-lg-9 tournament-detail-pane")">
