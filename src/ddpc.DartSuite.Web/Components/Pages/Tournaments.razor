                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psFieldStatus" checked="@ActiveMatchCardConfigSettings.ShowMatchStatus" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowMatchStatus = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psFieldStatus">MatchStatus</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psFieldScheduling" checked="@ActiveMatchCardConfigSettings.ShowSchedulingStatus" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowSchedulingStatus = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psFieldScheduling">SchedulingStatus</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psFieldAverage" checked="@ActiveMatchCardConfigSettings.ShowAverage" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowAverage = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psFieldAverage">Average</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psFieldPpr" checked="@ActiveMatchCardConfigSettings.ShowHighestPpr" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHighestPpr = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psFieldPpr">Highest PPR</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psFieldCheckout" checked="@ActiveMatchCardConfigSettings.ShowHighestCheckout" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHighestCheckout = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psFieldCheckout">Highest Checkout</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psFieldAdpl" checked="@ActiveMatchCardConfigSettings.ShowAverageDartsPerLeg" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowAverageDartsPerLeg = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psFieldAdpl">Average Darts/Leg</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psFieldMinDarts" checked="@ActiveMatchCardConfigSettings.ShowMinimalDartsPerLeg" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowMinimalDartsPerLeg = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psFieldMinDarts">Minimal Darts/Leg</label></div>
                                </div>
                            </div>
                        </fieldset>

                        @if (isSavingMatchCardPreferences)
                        {
                            <div class="small text-muted mt-2">Speichere MatchCard-Einstellungen ...</div>
                        }
                        @if (matchCardPreferenceError is not null)
                        {
                            <div class="alert alert-danger py-1 px-2 small mt-2 mb-0">@matchCardPreferenceError</div>
                        }
                    </div>

                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showPageSettingsModal = false">Schließen</button>
                </div>
            </div>
        </div>
    </div>
}

<MatchCardSettingsModal Visible="@showMatchCardScopeModal"
                        ScopeKey="@matchCardScopeModalKey"
                        OnClosed="OnMatchCardScopeModalClosedAsync" />

<style>
    .page > main {
        min-width: 0 !important;
        max-width: 100%;
    }

    .page > main > article.content {
        display: flex;
        flex-direction: column;
        min-height: calc(100dvh - 3.5rem);
        max-width: 100%;
        overflow: visible;
    }

    details > summary {
        list-style: none;
        position: relative;
        padding-left: 1.25rem;
    }

    details > summary::-webkit-details-marker {
        display: none;
    }

    details > summary::before {
        content: "▸";
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        transition: transform 0.18s ease;
        opacity: 0.85;
    }

    details[open] > summary::before {
        transform: translateY(-50%) rotate(90deg);
    }

    .team-name-editable-wrap .team-name-actions {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.16s ease;
    }

    .team-name-editable-wrap:hover .team-name-actions,
    .team-name-editable-wrap:focus-within .team-name-actions {
        opacity: 1;
        pointer-events: auto;
    }

    .team-name-menu-toggle {
        line-height: 1;
        text-decoration: none;
        font-size: 1.15rem;
    }

    .team-name-menu-toggle:hover,
    .team-name-menu-toggle:focus {
        text-decoration: none;
    }

    .team-name-actions-menu {
        right: 0;
        left: auto;
        width: min(14rem, calc(100vw - 1rem));
        max-width: calc(100vw - 1rem);
    }

    .team-name-actions-menu .dropdown-item {
        white-space: normal;
    }

    .team-seed-card-drag-source .team-name-editable-wrap {
        outline: 2px solid rgba(13, 110, 253, 0.65);
        outline-offset: 2px;
        border-radius: 0.35rem;
    }

    .team-seed-badge-mobile {
        cursor: pointer;
        touch-action: none;
    }

    .team-seed-selected {
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.35);
    }

    .team-seed-tap-target {
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.22);
    }

    .team-seed-card-drag-hover {
        box-shadow: 0 0 0 0.16rem rgba(13, 110, 253, 0.22);
    }

    .team-seed-insert-marker {
        height: 0;
        margin-bottom: 0;
