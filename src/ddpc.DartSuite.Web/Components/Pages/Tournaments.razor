                                                                                                        <input class="form-control"
                                                                                                               value="@participantName"
                                                                                                               @oninput="OnParticipantNameInput"
                                                                                                               placeholder="z.B. Max Mustermann"
                                                                                                               @onkeydown="HandleParticipantKeyAsync"
                                                                                                               @onfocusout="() => { Task.Delay(200).ContinueWith(_ => InvokeAsync(() => { showParticipantSuggestions = false; StateHasChanged(); })); }" />
                                                                                                        @if (showParticipantSuggestions && participantSuggestions.Any())
                                                                                                        {
                                                                                                            <div class="list-group position-absolute w-100 shadow-sm" style="z-index:1050; max-height:200px; overflow-y:auto; top:100%">
                                                                                                                @foreach (var s in participantSuggestions)
                                                                                                                {
                                                                                                                    <button type="button"
                                                                                                                            class="list-group-item list-group-item-action small py-1"
                                                                                                                            @onmousedown="() => SelectParticipantSuggestion(s)"
                                                                                                                            @onmousedown:preventDefault>
                                                                                                                        @s.DisplayName <span class="text-muted">(@s.AccountName)</span>
                                                                                                                        @if (s.IsAutodartsAccount)
                                                                                                                        {
                                                                                                                            <span class="autodarts-icon"></span>
                                                                                                                        }
                                                                                                                    </button>
                                                                                                                }
                                                                                                            </div>
                                                                                                        }
