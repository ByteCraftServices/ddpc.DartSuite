                                                                                                        </div>
                                                                                                    </div>
                                                                                                    <div class="col-md-3">
                                                                                                        <label class="form-label small mb-1">Account-Name</label>
                                                                                                        <input class="form-control"
                                                                                                               @bind="participantAccount"
                                                                                                               @bind:event="oninput"
                                                                                                               placeholder="@(participantIsAutodarts ? "= Anzeigename" : "Optional")"
                                                                                                               readonly="@participantIsAutodarts"
                                                                                                               @onkeydown="HandleParticipantKeyAsync" />
