                                                                                                                            }
                                                                                                                            else
                                                                                                                            {
                                                                                                                                <strong class="small text-truncate team-name-editable" style="max-width:220px" @onclick="() => BeginTeamNameEdit(idx)">@(string.IsNullOrWhiteSpace(team.Name) ? $"Team {idx + 1}" : team.Name)</strong>
                                                                                                                                <span class="team-name-actions">
                                                                                                                                    <button class="btn btn-sm btn-link p-0 text-muted" title="Teamnamen bearbeiten" @onclick="() => BeginTeamNameEdit(idx)" @onclick:stopPropagation disabled="@(isWorking || !CanEditTournamentStructure)">✎</button>
                                                                                                                                    <button class="btn btn-sm btn-link p-0 text-muted ms-1" title="Namen automatisch aus Mitgliedern erzeugen" @onclick="async () => await ResetTeamDraftNameToAutoAsync(idx)" @onclick:stopPropagation disabled="@(isWorking || !CanEditTournamentStructure)">↺</button>
