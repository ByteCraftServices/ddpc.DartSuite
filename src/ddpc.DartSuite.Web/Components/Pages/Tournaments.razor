                                            <button type="button"
                                                    class="btn btn-sm tournament-list-rail-item @(selectedTournament?.Id == t.Id ? "active" : string.Empty)"
                                                    style="--rail-item-height:@GetTournamentRailItemHeight(t);"
                                                    title="@t.Name"
                                                    @onclick="() => SelectTournamentAsync(t)">
                                                <span class="tournament-list-rail-label">@t.Name</span>
                                            </button>
                                        }
                                    </div>
                                }

                                <div id="tournament-list-panel" class="@(selectedTournament is not null ? "col-12 col-lg-3 tournament-list-pane" : "col-12")">
                                    @if (ActiveTournaments.Any())
                                    {
                                        <h6 class="mb-1 fw-semibold text-success">▶ Aktiv</h6>
                                        <ul class="list-group mb-3">
                                            @foreach (var t in ActiveTournaments)
                                            {
                                                <li class="list-group-item list-group-item-action @(selectedTournament?.Id == t.Id ? "active" : "")"
                                                    style="cursor:pointer" @onclick="() => SelectTournamentAsync(t)">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <span class="list-group-item-name" title="@t.Name">
                                                            @t.Name
                                                            @if (!string.IsNullOrEmpty(t.JoinCode))
                                                            {
                                                                <span class="badge text-bg-primary font-monospace" style="font-size:0.65rem">@t.JoinCode</span>
                                                            }
