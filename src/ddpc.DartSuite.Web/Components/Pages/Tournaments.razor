                                                            @if (!string.IsNullOrEmpty(selectedTournament.JoinCode))
                                                            {
                                                                <span class="badge text-bg-primary font-monospace" title="Code zum Turnierbeitritt">@selectedTournament.JoinCode</span>
                                                            }
                                                            <span class="badge text-bg-dark" title="@(IsCurrentUserManager ? "Ihrer Rolle im Turnier" : "Ihrer Rolle im Turnier")">
                                                                @(IsCurrentUserManager ? "Spielleiter" : "Teilnehmer")
                                                            </span>
                                                            @if (selectedTournament.IsLocked)
                                                            {
                                                                <span class="badge text-bg-danger" title="Turnier ist gesperrt">🔒 Gesperrt</span>
                                                            }
                                                        </div>
                                                        
                                                        <!-- Right badges -->
                                                        <div class="tournament-badges-right">
                                                            <span class="badge text-bg-secondary" title="Turnierformat">@ModeDisplay(selectedTournament.Mode)</span>
                                                            <span class="badge text-bg-info" title="Turniervariante">@VariantDisplay(selectedTournament.Variant)</span>
                                                        </div>
                                                    </div>
                                                    
                                                    <!-- Right section: function buttons -->
                                                    <div class="d-flex gap-1">
                                                        @if (IsCurrentUserManager)
                                                        {
                                                            <div class="ms-1">
                                                                <SplitButton PrimaryText="@selectedTournament.Status"
                                                                             ButtonStyle="@StatusBadgeCss(selectedTournament.Status).Replace("text-bg-", "")"
                                                                             Size="sm"
                                                                             Disabled="@isWorking"
                                                                             Items="@BuildTournamentStatusItems()" />
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge @StatusBadgeCss(selectedTournament.Status)">@selectedTournament.Status</span>
                                                        }
                                                        @if (IsCurrentUserManager)
                                                        {
                                                            <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleLockAsync" title="@(selectedTournament.IsLocked ? "Entsperren" : "Sperren")">
                                                                @(selectedTournament.IsLocked ? "🔒" : "🔓")
                                                            </button>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="card-body" id="tournament-tab-content">
                                                @* ─── Tabs ─── *@
                                                <TournamentTabNav ActiveTab="@activeTab"
                                                                  ShowGroupsTab="@(selectedTournament.Mode == "GroupAndKnockout")"
                                                                  HasMissingRoundConfig="@HasMissingRoundConfig()"
                                                                  MissingRoundConfigCount="@MissingRoundConfigCount()"
                                                                  DrawStatusBadgeCss="@DrawStatusBadgeCss"
                                                                  DrawProgressText="@DrawProgressText"
                                                                  DrawProgressTitle="@DrawProgressTitle"
                                                                  GroupPhaseBadgeCss="@PhaseBadgeCss("Group")"
                                                                  GroupPhaseBadgeText="@PhaseBadgeText("Group")"
                                                                  KnockoutPhaseBadgeCss="@PhaseBadgeCss("Knockout")"
                                                                  KnockoutPhaseBadgeText="@PhaseBadgeText("Knockout")"
                                                                  ScheduleBadgeCss="@ScheduleBadgeCss"
                                                                  ScheduleBadgeText="@ScheduleBadgeText"
                                                                  OnTabSelected="HandleTabSelectionAsync" />

                                                                            @* ═══════ Tab: Allgemein ═══════ *@
                                                                            @if (activeTab == "general")
                                                                            {
                                                                                <TournamentGeneralTab TournamentId="@selectedTournament.Id"
                                                                                                    IsLocked="@selectedTournament.IsLocked"
                                                                                                    HasGeneralRequiredMissing="@HasGeneralRequiredMissing()"
                                                                                                    GeneralSettingsSummary="@GeneralSettingsSummary()"
                                                                                                    CanEditBasicSettings="@CanEditBasicSettings"
                                                                                                    EditName="@editName"
                                                                                                    EditNameChanged="OnEditNameChangedAsync"
                                                                                                    EditOrganizer="@editOrganizer"
                                                                                                    EditOrganizerChanged="OnEditOrganizerChangedAsync"
                                                                                                    AutodartsDisplayName="@autodartsDisplayName"
                                                                                                    Participants="@participants"
                                                                                                    EditStartDate="@editStartDate"
                                                                                                    EditStartDateChanged="OnEditStartDateChangedAsync"
                                                                                                    EditEndDate="@editEndDate"
                                                                                                    EditEndDateChanged="OnEditEndDateChangedAsync"
                                                                                                    EditStartTimeInput="@editStartTimeInput"
                                                                                                    EditStartTimeInputChanged="OnEditStartTimeInputChangedAsync"
                                                                                                    EditMode="@editMode"
                                                                                                    EditModeChanged="OnEditModeChangedAsync"
                                                                                                    EditVariant="@editVariant"
                                                                                                    EditVariantChanged="OnEditVariantChangedAsync"
                                                                                                    EditThirdPlaceMatch="@editThirdPlaceMatch"
                                                                                                    EditThirdPlaceMatchChanged="OnEditThirdPlaceMatchChangedAsync"
                                                                                                    EditModeDisplay="@ModeDisplay(editMode)"
                                                                                                    EditVariantDisplay="@VariantDisplay(editVariant)"
                                                                                                    JoinCode="@selectedTournament.JoinCode"
                                                                                                    TournamentLink="@TournamentLink"
                                                                                                    CanEditTournamentSettings="@CanEditTournamentSettings"
                                                                                                    OnCopyTournamentLink="CopyTournamentLink"
                                                                                                    EditDiscordWebhookUrl="@editDiscordWebhookUrl"
                                                                                                    EditDiscordWebhookUrlChanged="OnEditDiscordWebhookUrlChangedAsync"
                                                                                                    OnTestDiscordWebhook="TestDiscordWebhookAsync"
                                                                                                    EditDiscordWebhookDisplayText="@editDiscordWebhookDisplayText"
                                                                                                    EditDiscordWebhookDisplayTextChanged="OnEditDiscordWebhookDisplayTextChangedAsync"
                                                                                                    DiscordTestResult="@discordTestResult"
                                                                                                    DiscordTestSuccess="@discordTestSuccess"
                                                                                                    IsWorking="@isWorking"
                                                                                                    IsCurrentUserManager="@IsCurrentUserManager"
                                                                                                    OnDeleteTournament="RequestDeleteTournamentAsync"
                                                                                                    EditError="@editError"
                                                                                                    EditSuccess="@editSuccess" />
                                                                            }

                                                                                    @* ═══════ Tab: Boards ═══════ *@
                                                                                    @if (activeTab == "boards")
                                                                                    {
                                                                                        @if (boards.Any())
                                                                                        {
                                                                                            <div class="table-responsive mb-4">
                                                                                                <table class="table table-sm table-hover mb-0">
                                                                                                    <thead>
                                                                                                        <tr>
                                                                                                            <th>Board</th>
                                                                                                            <th>Status</th>
                                                                                                            <th>Aktuelles Match</th>
                                                                                                            <th></th>
                                                                                                        </tr>
                                                                                                    </thead>
                                                                                                    <tbody>
                                                                                                        @foreach (var board in boards)
                                                                                                        {
                                                                                                            <tr>
                                                                                                                <td><span role="button" @onclick="() => OpenBoardDetail(board)" class="text-decoration-none fw-semibold" style="cursor:pointer">@board.Name</span></td>
                                                                                                                <td><span class="badge @BoardStatusBadge(board.Status)">@board.Status</span></td>
                                                                                                                <td>
                                                                                                                    @if (!string.IsNullOrEmpty(board.CurrentMatchLabel))
                                                                                                                    {
                                                                                                                        var boardMatch = board.CurrentMatchId.HasValue
                                                                                                                            ? matches.FirstOrDefault(m => m.Id == board.CurrentMatchId.Value)
                                                                                                                            : null;
                                                                                                                        @if (boardMatch is not null)
                                                                                                                        {
                                                                                                                            <span role="button" class="text-primary fw-semibold" style="cursor:pointer;text-decoration:underline dotted"
                                                                                                                                  @onclick="() => OpenMatchDetail(boardMatch)"><span class="autodarts-icon"></span> @board.CurrentMatchLabel</span>
                                                                                                                        }
                                                                                                                        else
                                                                                                                        {
                                                                                                                            <span>@board.CurrentMatchLabel</span>
                                                                                                                        }
                                                                                                                    }
                                                                                                                    else
                                                                                                                    {
                                                                                                                        <span>—</span>
                                                                                                                    }
                                                                                                                </td>
                                                                                                                <td class="d-flex gap-1">
                                                                                                                    <a href="https://play.autodarts.io/boards/@(board.ExternalBoardId)/follow"
                                                                                                                       target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary">📺</a>
                                                                                                                    @if (!selectedTournament.IsLocked)
                                                                                                                    {
                                                                                                                        <button class="btn btn-sm btn-outline-danger"
                                                                                                                                @onclick="() => DeleteBoardAsync(board.Id)" disabled="@isWorking">✕</button>
                                                                                                                    }
                                                                                                                </td>
                                                                                                            </tr>
                                                                                                        }
                                                                                                    </tbody>
                                                                                                </table>
                                                                                            </div>
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <p class="text-muted small mb-4">Keine Boards konfiguriert. Boards können über die <a href="/boards">Boards-Seite</a> oder die Chrome-Extension hinzugefügt werden.</p>
                                                                                        }
                                                                                    }

                                                                                    @* ═══════ Tab: Teilnehmer ═══════ *@
                                                                                    @if (activeTab == "participants")
                                                                                    {
                                                                                        <SettingsPanel TournamentId="@selectedTournament?.Id" PanelId="teamplay-setzliste" SummaryText="@TeamplaySeedingSummary()" DefaultExpanded="true">
                                                                                            <TitleContent>
                                                                                                Teamplay &amp; Setzliste
                                                                                                @if (HasTeamplayRequiredMissing() || HasSeedingRequiredMissing())
                                                                                                {
                                                                                                    <span class="text-danger ms-2" title="Pflichteinstellungen fehlen">⚠</span>
                                                                                                }
                                                                                            </TitleContent>
                                                                                            <ChildContent>
                                                                                                @if (CanEditParticipantSettings)
                                                                                                {
                                                                                                    <div class="form-check mb-2">
                                                                                                        <input class="form-check-input" type="checkbox" id="editTeamplay" @bind="editTeamplay" @bind:after="AutoSaveSettingAsync" />
                                                                                                        <label class="form-check-label" for="editTeamplay" title="Aktiviert Teams statt Einzelspielern. Spieler pro Team muss gesetzt werden.">Teamplay aktivieren</label>
                                                                                                    </div>
                                                                                                    <div class="mb-3">
                                                                                                        <label class="form-label small" title="Anzahl Spieler pro Team; bei Teamplay mindestens 2 empfohlen.">Spieler pro Team</label>
                                                                                                        <input type="number" class="form-control form-control-sm @(HasTeamplayRequiredMissing() ? "border-danger" : "")" @bind="editPlayersPerTeam" @bind:after="OnPlayersPerTeamChangedAsync" min="1" disabled="@(!editTeamplay)" />
                                                                                                        @if (editTeamplay)
                                                                                                        {
                                                                                                            <div class="form-text">Aktuell: @EffectivePlayerCount Spieler ergeben @RequiredTeamCount Teams.</div>
                                                                                                        }
                                                                                                    </div>

                                                                                                    <div class="form-check mb-2">
                                                                                                        <input class="form-check-input" type="checkbox" id="editSeedingEnabled" @bind="editSeedingEnabled" @bind:after="OnSeedingEnabledChangedAsync" />
                                                                                                        <label class="form-check-label" for="editSeedingEnabled" title="Aktiviert Setzliste für Auslosung und Lostopf-Verfahren.">Setzliste aktivieren</label>
                                                                                                    </div>
                                                                                                    @if (editSeedingEnabled)
                                                                                                    {
                                                                                                        <div class="mb-0">
                                                                                                            <label class="form-label small" title="Anzahl gesetzter Spieler; beeinflusst Bracket- und Gruppenverteilung.">@(IsTeamplayActive ? "Anzahl gesetzter Teams" : "Anzahl gesetzter Spieler")</label>
                                                                                                            <input type="number" class="form-control form-control-sm @(HasSeedingRequiredMissing() ? "border-danger" : "")" @bind="editSeedTopCount" @bind:after="OnSeedTopCountChangedAsync" min="0" max="@EffectiveDrawParticipants.Count" />
                                                                                                        </div>
                                                                                                    }
                                                                                                }
                                                                                                else
                                                                                                {
                                                                                                    <div class="small text-muted d-flex flex-wrap gap-2">
                                                                                                        <span class="badge @(editTeamplay ? "text-bg-info" : "text-bg-light")">Teamplay: @(editTeamplay ? "Aktiv" : "Aus")</span>
                                                                                                        <span class="badge text-bg-light border">Spieler/Team: @editPlayersPerTeam</span>
                                                                                                        <span class="badge @(editSeedingEnabled ? "text-bg-info" : "text-bg-light")">Setzliste: @(editSeedingEnabled ? "Aktiv" : "Aus")</span>
                                                                                                        @if (editSeedingEnabled)
                                                                                                        {
                                                                                                            <span class="badge text-bg-light border">Gesetzt: @editSeedTopCount</span>
                                                                                                        }
                                                                                                    </div>
                                                                                                }
                                                                                            </ChildContent>
                                                                                        </SettingsPanel>

                                                                                        <SettingsPanel TournamentId="@selectedTournament?.Id" PanelId="registrierung" SummaryText="@RegistrationSummary()" DefaultExpanded="true">
                                                                                            <TitleContent>
                                                                                                Registrierung
                                                                                                @if (HasRegistrationRequiredMissing())
                                                                                                {
                                                                                                    <span class="text-danger ms-2" title="Pflichteinstellungen fehlen">⚠</span>
                                                                                                }
                                                                                            </TitleContent>
                                                                                            <ChildContent>
                                                                                                @if (CanEditParticipantSettings)
                                                                                                {
                                                                                                    <div class="form-check mb-2">
                                                                                                        <input class="form-check-input" type="checkbox" id="editRegistrationOpen" @bind="editIsRegistrationOpen" @bind:after="OnRegistrationOpenChangedAsync" />
                                                                                                        <label class="form-check-label" for="editRegistrationOpen" title="Steuert, ob Teilnehmer sich vor Turnierstart registrieren dürfen.">Registrierung offen</label>
                                                                                                    </div>
                                                                                                    <div class="row g-2 mb-0">
                                                                                                        <div class="col-md-6">
                                                                                                            <label class="form-label small" title="Beginn der Registrierungsphase.">Registrierung Start</label>
                                                                                                            <input type="datetime-local" class="form-control form-control-sm @(HasRegistrationRequiredMissing() && !editRegistrationStart.HasValue ? "border-danger" : "")" @bind="editRegistrationStart" @bind:after="AutoSaveSettingAsync" disabled="@(!editIsRegistrationOpen)" />
                                                                                                        </div>
                                                                                                        <div class="col-md-6">
                                                                                                            <label class="form-label small" title="Ende der Registrierungsphase; muss nach dem Start liegen.">Registrierung Ende</label>
                                                                                                            <input type="datetime-local" class="form-control form-control-sm @(HasRegistrationRequiredMissing() && (!editRegistrationEnd.HasValue || editRegistrationEnd <= editRegistrationStart) ? "border-danger" : "")" @bind="editRegistrationEnd" @bind:after="AutoSaveSettingAsync" disabled="@(!editIsRegistrationOpen)" />
                                                                                                        </div>
                                                                                                    </div>
                                                                                                }
                                                                                                else
                                                                                                {
                                                                                                    <div class="small text-muted d-flex flex-wrap gap-2">
                                                                                                        <span class="badge @(editIsRegistrationOpen ? "text-bg-info" : "text-bg-light")">Registrierung: @(editIsRegistrationOpen ? "Offen" : "Geschlossen")</span>
                                                                                                        @if (editRegistrationStart.HasValue)
                                                                                                        {
                                                                                                            <span class="badge text-bg-light border">Start: @editRegistrationStart.Value.ToString("dd.MM HH:mm")</span>
                                                                                                        }
                                                                                                        @if (editRegistrationEnd.HasValue)
                                                                                                        {
                                                                                                            <span class="badge text-bg-light border">Ende: @editRegistrationEnd.Value.ToString("dd.MM HH:mm")</span>
                                                                                                        }
                                                                                                    </div>
                                                                                                }
                                                                                            </ChildContent>
                                                                                        </SettingsPanel>

                                                                                        <ul class="nav nav-pills nav-fill nav-sm mb-3 border rounded p-1 bg-body-tertiary">
                                                                                            <li class="nav-item">
                                                                                                <button class="nav-link @(activeBoardsParticipantsSubTab == "spieler" ? "active" : "")"
                                                                                                        @onclick='() => activeBoardsParticipantsSubTab = "spieler"'>
                                                                                                    @(IsTeamplayActive ? "Spielerpool" : "Spieler") <span class="badge text-bg-secondary ms-1">@EffectivePlayerCount</span>
                                                                                                </button>
                                                                                            </li>
                                                                                            @if (editTeamplay)
                                                                                            {
                                                                                                <li class="nav-item">
                                                                                                    <button class="nav-link @(activeBoardsParticipantsSubTab == "teams" ? "active" : "")"
                                                                                                            @onclick='() => activeBoardsParticipantsSubTab = "teams"'>
                                                                                                        Teams <span class="badge @(IsTeamFormationComplete ? "text-bg-success" : "text-bg-secondary") ms-1">@(teams.Count(t => t.Members.Count == editPlayersPerTeam))/@RequiredTeamCount</span>
                                                                                                    </button>
                                                                                                </li>
                                                                                            }
                                                                                        </ul>

                                                                                        @if (activeBoardsParticipantsSubTab == "spieler")
                                                                                        {
                                                                                            <h6 class="fw-semibold mb-2">@(IsTeamplayActive ? "Spielerpool" : "Teilnehmer") <span class="badge text-bg-secondary">@EffectivePlayerCount</span>
                                                                                                @if (IsTeamplayActive && AppState.IsAdmin)
                                                                                                {
                                                                                                    <button class="btn btn-sm @(showAdminTeamMembers ? "btn-info" : "btn-outline-secondary") ms-2" style="font-size:0.75em"
                                                                                                            @onclick="() => showAdminTeamMembers = !showAdminTeamMembers"
                                                                                                            title="TeamMember-Einträge einblenden">Teams anzeigen</button>
                                                                                                }
                                                                                            </h6>
                                                                                            @if (participants.Any(p => !IsTeamMember(p)))
                                                                                            {
                                                                                                var showPlayerSeedInPlayersSubTab = editSeedingEnabled && !IsTeamplayActive;
                                                                                                var baseParticipants = (IsTeamplayActive && AppState.IsAdmin && showAdminTeamMembers)
                                                                                                    ? participants
                                                                                                    : participants.Where(p => !IsTeamMember(p));
                                                                                                var sortedParticipants = showPlayerSeedInPlayersSubTab
                                                                                                    ? baseParticipants.OrderBy(p => p.Seed > 0 ? p.Seed : int.MaxValue).ThenBy(p => p.DisplayName).ToList()
                                                                                                    : baseParticipants.ToList();
                                                                                                <div class="table-responsive mb-3">
                                                                                                    <table class="table table-sm table-hover align-middle mb-0">
                                                                                                        <thead>
                                                                                                            <tr>
                                                                                                                <th>@(IsTeamplayActive ? "Spieler" : "Teilnehmer")</th>
                                                                                                                <th class="d-none d-xl-table-cell">Account</th>
                                                                                                                <th class="d-none d-lg-table-cell">Gruppe</th>
                                                                                                                @if (editTeamplay)
                                                                                                                {
                                                                                                                    <th class="d-none d-lg-table-cell">Team</th>
                                                                                                                }
                                                                                                                <th></th>
                                                                                                            </tr>
                                                                                                        </thead>
                                                                                                        <tbody>
                                                                                                            @foreach (var p in sortedParticipants)
                                                                                                            {
                                                                                                                var isSeedTarget = showPlayerSeedInPlayersSubTab && p.Seed > 0 && p.Seed <= editSeedTopCount;
                                                                                                                var teamName = GetTeamNameForParticipant(p.TeamId);
                                                                                                                <tr draggable="@(showPlayerSeedInPlayersSubTab && CanEditParticipantSettings ? "true" : "false")"
                                                                                                                    @ondragstart="() => draggedSeedIndex = p.Seed"
                                                                                                                    @ondragover:preventDefault
                                                                                                                    @ondrop="async () => { if (draggedSeedIndex.HasValue && draggedSeedIndex != p.Seed) { var dragP = participants.FirstOrDefault(x => x.Seed == draggedSeedIndex.Value); if (dragP is not null) { await UpdateParticipantSeedAsync(dragP.Id, p.Seed); await UpdateParticipantSeedAsync(p.Id, draggedSeedIndex.Value); } draggedSeedIndex = null; } }">
                                                                                                                    <td>
                                                                                                                        <span class="d-flex align-items-center gap-2 flex-wrap">
                                                                                                                            @if (showPlayerSeedInPlayersSubTab)
                                                                                                                            {
                                                                                                                                @if (isSeedTarget)
                                                                                                                                {
                                                                                                                                    <span class="badge text-bg-warning" style="min-width:34px; cursor:grab" title="Setzlistenrang — per Drag & Drop ändern">#@p.Seed</span>
                                                                                                                                }
                                                                                                                                else
                                                                                                                                {
                                                                                                                                    <span class="badge text-bg-light text-muted border" style="min-width:34px">@(p.Seed > 0 ? $"#{p.Seed}" : "—")</span>
                                                                                                                                }
                                                                                                                            }
                                                                                                                            @if (editGroupDrawMode == "SeededPots" && p.SeedPot > 0)
                                                                                                                            {
                                                                                                                                <span class="badge @PotBadgeCss(p.SeedPot)" title="Lostopf">Topf @p.SeedPot</span>
                                                                                                                            }
                                                                                                                            @if (p.IsAutodartsAccount)
                                                                                                                            {
                                                                                                                                <span class="autodarts-icon d-xl-none" title="Autodarts"></span>
                                                                                                                            }
                                                                                                                            <span role="button" style="cursor:pointer;text-decoration:underline dotted" @onclick="() => OpenPlayerDetail(p.Id)">@p.DisplayName.ToUpperInvariant()</span>
                                                                                                                            @if (p.IsManager)
                                                                                                                            {
                                                                                                                                <span class="badge text-bg-warning">Spielleiter</span>
                                                                                                                            }
                                                                                                                            @if (p.GroupNumber.HasValue && p.GroupNumber > 0)
                                                                                                                            {
                                                                                                                                <span class="badge text-bg-info d-md-none">Gr. @GroupLabel(p.GroupNumber.Value)</span>
                                                                                                                            }
                                                                                                                            @if (!string.IsNullOrWhiteSpace(teamName))
                                                                                                                            {
                                                                                                                                <span class="badge text-bg-secondary d-md-none">@teamName</span>
                                                                                                                            }
                                                                                                                        </span>
                                                                                                                    </td>
                                                                                                                    <td class="d-none d-xl-table-cell">
                                                                                                                        @if (p.IsAutodartsAccount)
                                                                                                                        {
                                                                                                                            <span class="autodarts-icon me-1" title="Autodarts"></span>
                                                                                                                            <small class="text-muted">@p.AccountName</small>
                                                                                                                        }
                                                                                                                        else
                                                                                                                        {
                                                                                                                            <small class="text-muted">@p.AccountName</small>
                                                                                                                            <span class="badge text-bg-secondary ms-1">Lokal</span>
                                                                                                                        }
                                                                                                                    </td>
                                                                                                                    <td class="d-none d-lg-table-cell">
                                                                                                                        @if (p.GroupNumber.HasValue && p.GroupNumber > 0)
                                                                                                                        {
                                                                                                                            <span class="badge text-bg-info">Gr. @GroupLabel(p.GroupNumber.Value)</span>
                                                                                                                        }
                                                                                                                        else
                                                                                                                        {
                                                                                                                            <span class="text-muted small">—</span>
                                                                                                                        }
                                                                                                                    </td>
                                                                                                                    @if (editTeamplay)
                                                                                                                    {
                                                                                                                        <td class="d-none d-lg-table-cell">
                                                                                                                            @if (!string.IsNullOrWhiteSpace(teamName))
                                                                                                                            {
                                                                                                                                <span class="badge text-bg-secondary">@teamName</span>
                                                                                                                            }
                                                                                                                            else
                                                                                                                            {
                                                                                                                                <span class="text-muted small">—</span>
                                                                                                                            }
                                                                                                                        </td>
                                                                                                                    }
                                                                                                                    <td>
                                                                                                                        <div class="d-flex gap-1 justify-content-end">
                                                                                                                            @if (!selectedTournament.IsLocked)
                                                                                                                            {
                                                                                                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEditParticipant(p)" disabled="@isWorking">✏️</button>
                                                                                                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveParticipantAsync(p)" disabled="@(!CanRemoveParticipant(p))" title="@RemoveParticipantDisabledReason(p)">✕</button>
                                                                                                                            }
                                                                                                                        </div>
                                                                                                                    </td>
                                                                                                                </tr>
                                                                                                            }
                                                                                                        </tbody>
                                                                                                    </table>
                                                                                                </div>
                                                                                            }
                                                                                            else
                                                                                            {
                                                                                                <p class="text-muted small">@(IsTeamplayActive ? "Noch keine Spieler im Pool vorhanden." : "Noch keine Teilnehmer vorhanden.")</p>
                                                                                            }

                                                                                            @if (participantError is not null)
                                                                                            {
                                                                                                <div class="alert alert-danger py-2 small mb-3">@participantError</div>
                                                                                            }

                                                                                            @if (CanEditParticipantSettings)
                                                                                            {
                                                                                                <div class="row g-2 align-items-end mb-2">
                                                                                                    <div class="col-md-3 position-relative">
                                                                                                        <label class="form-label small mb-1">Anzeigename</label>
