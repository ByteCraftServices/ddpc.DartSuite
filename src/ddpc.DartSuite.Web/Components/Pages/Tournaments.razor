                                                                                                    <div class="col-md-2">
                                                                                                        <div class="form-check mb-0">
                                                                                                            <input class="form-check-input" type="checkbox" id="isMgr" @bind="participantIsManager" />
                                                                                                            <label class="form-check-label small" for="isMgr">Spielleiter</label>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                    <div class="col-md-2">
                                                                                                        <button class="btn btn-outline-primary btn-sm w-100" @onclick="AddParticipantAsync" disabled="@isWorking">Hinzufügen</button>
                                                                                                    </div>
                                                                                                </div>
                                                                                            }
                                                                                        }

                                                                                        @if (activeBoardsParticipantsSubTab == "teams" && editTeamplay)
