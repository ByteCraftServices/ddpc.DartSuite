                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderMatchName" checked="@ActiveMatchCardConfigSettings.ShowHeaderMatchName" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderMatchName = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderMatchName">Matchname</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderStart" checked="@ActiveMatchCardConfigSettings.ShowHeaderStartTime" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderStartTime = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderStart">Startzeit</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderStartLock" checked="@ActiveMatchCardConfigSettings.ShowHeaderStartTimeLock" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderStartTimeLock = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderStartLock">Startzeit gesperrt</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderBoard" checked="@ActiveMatchCardConfigSettings.ShowHeaderBoardName" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderBoardName = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderBoard">Boardname</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderBoardLock" checked="@ActiveMatchCardConfigSettings.ShowHeaderBoardLock" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderBoardLock = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderBoardLock">Board gesperrt</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderDelay" checked="@ActiveMatchCardConfigSettings.ShowHeaderDelay" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderDelay = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderDelay">Zeitdifferenz</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderStatus" checked="@ActiveMatchCardConfigSettings.ShowHeaderMatchStatus" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderMatchStatus = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderStatus">Matchstatus</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psHeaderLive" checked="@ActiveMatchCardConfigSettings.ShowHeaderLiveBadge" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowHeaderLiveBadge = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psHeaderLive">Live-Badge</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psRuntimeBadge" checked="@ActiveMatchCardConfigSettings.ShowRuntimeBadge" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowRuntimeBadge = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psRuntimeBadge">Spielzeit-Badge</label></div>
                                </div>
                            </div>

                            <div class="border rounded p-2 mb-2">
                                <div class="fw-semibold small mb-2">Body</div>
                                <div class="d-flex flex-wrap gap-3 small">
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psBodyStart" checked="@ActiveMatchCardConfigSettings.ShowBodyStartTime" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowBodyStartTime = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psBodyStart">Startzeit</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psBodyStartLock" checked="@ActiveMatchCardConfigSettings.ShowBodyStartTimeLock" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowBodyStartTimeLock = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psBodyStartLock">Startzeit gesperrt</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psBodyDelay" checked="@ActiveMatchCardConfigSettings.ShowBodyDelay" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowBodyDelay = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psBodyDelay">Zeitdifferenz</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psBodyMatchNumber" checked="@ActiveMatchCardConfigSettings.ShowBodyMatchNumber" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowBodyMatchNumber = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psBodyMatchNumber">Matchnummer</label></div>
                                    <div class="form-check"><input class="form-check-input" type="checkbox" id="psBodyBoard" checked="@ActiveMatchCardConfigSettings.ShowBodyBoardName" @onchange="args => UpdateActiveMatchCardSettingsAsync(s => s.ShowBodyBoardName = ParseBoolChangeEvent(args))" /><label class="form-check-label" for="psBodyBoard">Boardname</label></div>
