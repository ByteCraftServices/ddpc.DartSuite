                                                                                                <div class="d-flex align-items-center gap-2 ms-auto">
                                                                                                    <label class="small text-muted mb-0">Animation</label>
                                                                                                    <select class="form-select form-select-sm" style="width:140px" @bind="drawAnimationMode" disabled="@(isWorking || isDrawAnimating)">
                                                                                                        <option value="Off">Aus</option>
                                                                                                        <option value="Exciting">Spannend</option>
                                                                                                        <option value="Moderate">Moderat</option>
                                                                                                    </select>
                                                                                                </div>
                                                                                            </div>
                                                                                            @if (!CanProceedWithTeamDraw)
                                                                                            {
                                                                                                <div class="alert alert-info py-2 small mb-2">Der Turnierplan bleibt gesperrt, bis alle Teams vollständig gebildet sind.</div>
                                                                                            }
                                                                                            @if (teamDraftError is not null)
                                                                                            {
                                                                                                <div class="alert alert-danger py-2 small mb-2">@teamDraftError</div>
                                                                                            }
                                                                                            <div class="row g-3">
                                                                                                <div class="col-md-4">
                                                                                                    <div class="card">
                                                                                                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                                                                                            <strong class="small">Nicht zugewiesen</strong>
                                                                                                            <span class="badge text-bg-secondary">@TeamDraftUnassignedParticipants.Count</span>
