@page "/tournaments"
@using ddpc.DartSuite.Application.Contracts.Matches

<PageTitle>Turniere</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="mb-0">Turniere</h1>
    @if (!isCreating)
    {
        @if (isAutodartsConnected)
        {
            <button class="btn btn-primary" @onclick="StartWizard">+ Neues Turnier</button>
        }
        else
        {
            <a href="/login" class="btn btn-outline-secondary">🔒 Login für Turniererstellung</a>
        }
    }
</div>

@if (IsRealtimeFallbackActive)
{
    <div class="alert alert-warning py-2 mb-3">Echtzeit eingeschraenkt: @RealtimeFallbackReason. 10s-Fallback-Polling ist aktiv.</div>
}
else
{
    <div class="alert alert-success py-2 mb-3">Echtzeit aktiv: Turnier- und Board-Updates laufen ueber SignalR.</div>
}

@* ─── Create Wizard ─── *@
@if (isCreating)
{
    <div class="card shadow-sm mb-4 border-primary">
        <div class="card-header d-flex justify-content-between align-items-center bg-primary text-white">
            <span><strong>Neues Turnier</strong> — Schritt @wizardStep von 2</span>
            <button type="button" class="btn-close btn-close-white" @onclick="CancelWizard"></button>
        </div>
        <div class="card-body">
            @if (wizardStep == 1)
            {
                <h6 class="text-muted mb-3">Schritt 1: Grunddaten</h6>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Turniername <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="wizardName" placeholder="z.B. Frühlings-Cup 2026" maxlength="128" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Veranstalter-Account</label>
                    <input class="form-control" @bind="wizardOrganizer" placeholder="Autodarts Account-Name" />
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Startdatum <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" @bind="wizardStartDate" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Enddatum</label>
                        <input type="date" class="form-control" @bind="wizardEndDate" />
                        <div class="form-text">Leer lassen — entspricht dem Startdatum.</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Startzeit</label>
                        <input type="time" class="form-control" @bind="wizardStartTimeInput" />
                    </div>
                </div>
                @if (wizardError is not null)
                {
                    <div class="alert alert-danger py-2">@wizardError</div>
                }
                <button class="btn btn-primary" @onclick="WizardNext">Weiter →</button>
            }
            else if (wizardStep == 2)
            {
                <h6 class="text-muted mb-3">Schritt 2: Turniereinstellungen</h6>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Modus</label>
                    <select class="form-select" @bind="wizardMode">
                        <option value="Knockout">K.O.-Modus (klassisch)</option>
                        <option value="GroupAndKnockout">Gruppenphase + K.O.</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Variante</label>
                    <select class="form-select" @bind="wizardVariant">
                        <option value="OnSite">Vor-Ort (Boards werden zugewiesen)</option>
                        <option value="Online">Online</option>
                    </select>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="wizTeamplay" @bind="wizardTeamplay" />
                    <label class="form-check-label" for="wizTeamplay">Teamplay aktivieren</label>
                </div>
                @if (wizardError is not null)
                {
                    <div class="alert alert-danger py-2">@wizardError</div>
                }
                <button class="btn btn-secondary me-2" @onclick="() => wizardStep = 1">← Zurück</button>
                <button class="btn btn-success" @onclick="FinishWizardAsync" disabled="@isWorking">✓ Turnier erstellen</button>
            }
        </div>
    </div>
}

@* ─── Confirmation Modal ─── *@
@if (showConfirmation)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title">⚠ Turnierplan betroffen</h5>
                </div>
                <div class="modal-body">
                    <p>@confirmationMessage</p>
                    <p class="text-muted small mb-0">Der bestehende Turnierplan und Spielplan werden dadurch ungültig und
                        müssen neu generiert werden.</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="RejectConfirmation">Abbrechen</button>
                        <button class="btn btn-warning" @onclick="AcceptConfirmation">Änderung durchführen</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ─── Match Detail / Result Edit Modal ─── *@
    @if (detailMatch is not null)
    {
        var homeP = participants.FirstOrDefault(p => p.Id == detailMatch.HomeParticipantId);
        var awayP = participants.FirstOrDefault(p => p.Id == detailMatch.AwayParticipantId);
        var assignedBoard = boards.FirstOrDefault(b => b.Id == detailMatch.BoardId);
        var gameplayText = FormatGameplay(detailMatch);
        var matchListener = matchListeners.FirstOrDefault(l => l.MatchId == detailMatch.Id);
        var showManualResultEditor = !(detailMatchOpenedFromSchedule && matchListener is not null && matchListener.IsRunning);
        <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="CloseMatchDetail">
            <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation>
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@MatchLabel(detailMatch) — @(detailMatch.Phase == "Group" ? $"Gruppe {GroupLabel(detailMatch.GroupNumber ?? 1)}" : KoRoundLabel(detailMatch.Round, matches.Where(m =>
                                                m.Phase == detailMatch.Phase).Select(m => m.Round).DefaultIfEmpty(1).Max()))</h5>
                            <button type="button" class="btn-close" @onclick="CloseMatchDetail"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row mb-3">
                                <div class="col text-center">
                                    <h5 role="button"
                                        class="@(detailMatch.WinnerParticipantId == detailMatch.HomeParticipantId ? "text-success fw-bold" : "")" style="cursor:pointer;text-decoration:underline dotted"
                                        @onclick="() => OpenPlayerDetail(detailMatch.HomeParticipantId)">
                                        @(homeP?.DisplayName?.ToUpperInvariant() ?? "?")
                                        @if (homeP?.IsAutodartsAccount == true) { <span class="autodarts-icon ms-1" style="font-size:0.7em"></span> }
                                    </h5>
                                    </div>
                                    <div class="col-auto text-center">
                                        @if (detailMatch.FinishedUtc is not null)
                                        {
                                            <h4>@FormatScore(detailMatch)</h4>
                                        }
                                        else
                                        {
                                            <h4 class="text-muted">vs</h4>
                                        }
                                    </div>
                                    <div class="col text-center">
                                        <h5 role="button"
                                            class="@(detailMatch.WinnerParticipantId == detailMatch.AwayParticipantId ? "text-success fw-bold" : "")" style="cursor:pointer;text-decoration:underline dotted"
                                            @onclick="() => OpenPlayerDetail(detailMatch.AwayParticipantId)">
                                            @(awayP?.DisplayName?.ToUpperInvariant() ?? "?")
                                            @if (awayP?.IsAutodartsAccount == true) { <span class="autodarts-icon ms-1" style="font-size:0.7em"></span> }
                                        </h5>
                                        </div>
                                    </div>
                                    @if (detailMatch.PlannedStartUtc is not null)
                                    {
                                        <p class="small text-muted">⏰ Geplante Startzeit:
                                            @detailMatch.PlannedStartUtc.Value.LocalDateTime.ToString("dd.MM.yyyy HH:mm")
                                            @if (detailMatch.IsStartTimeLocked) { <span class="text-primary fw-semibold ms-1">🔒 Gesperrt</span> }</p>
                                        }
                                        @if (detailMatch.StartedUtc is not null)
                                        {
                                            <p class="small text-muted">▶ Gestartet: @detailMatch.StartedUtc.Value.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</p>
                                            var matchElapsed = (detailMatch.FinishedUtc ?? DateTimeOffset.UtcNow) - detailMatch.StartedUtc.Value;
                                            var matchRound = roundSettings.FirstOrDefault(r => r.Phase == detailMatch.Phase && r.RoundNumber == detailMatch.Round);
                                            <p class="small text-muted">⏱ @(detailMatch.FinishedUtc.HasValue ? "Spieldauer" : "Spielzeit"): @($"{(int)matchElapsed.TotalMinutes} min")
                                                @if (detailMatch.FinishedUtc is null && matchRound is not null && matchRound.MatchDurationMinutes > 0)
                                                {
                                                    var remaining = matchRound.MatchDurationMinutes - (int)matchElapsed.TotalMinutes;
                                                    @if (remaining > 0)
                                                    {
                                                        <span class="text-muted">(~@remaining min verbleibend)</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-danger">(+@(Math.Abs(remaining)) min über geplanter Dauer)</span>
                                                    }
                                                }
                                            </p>
                                        }
                                        <p class="small text-muted mb-2">🔗 ExternalMatchId: <span class="font-monospace">@(string.IsNullOrWhiteSpace(detailMatch.ExternalMatchId) ? "—" : detailMatch.ExternalMatchId)</span></p>
                                        @if (assignedBoard is not null)
                                        {
                                            <p class="small">📋 Board: <strong role="button" style="cursor:pointer;text-decoration:underline dotted" @onclick="() => { var m = detailMatch; var fromSchedule = detailMatchOpenedFromSchedule; _modalBackStack.Push(() => OpenMatchDetail(m!, fromSchedule)); CloseMatchDetail(); OpenBoardDetail(assignedBoard); }">@assignedBoard.Name</strong>
                                                @if (detailMatch.IsBoardLocked) { <span class="text-primary fw-semibold ms-1">🔒 Gesperrt</span> }</p>
                                            @if (gameplayText is not null)
                                            {
                                                <p class="small text-muted mb-2">🎮 @gameplayText</p>
                                            }
                                            <div class="d-flex gap-2 mb-3">
                                                @if (!string.IsNullOrEmpty(detailMatch.ExternalMatchId))
                                                {
                                                    <a href="https://play.autodarts.io/boards/@(assignedBoard.ExternalBoardId)/follow" target="_blank"
                                                           rel="noopener" class="btn btn-outline-primary btn-sm">
                                                        <span class="autodarts-icon"></span> Spiel verfolgen
                                                    </a>
                                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => SyncMatchFromExternalAsync(detailMatch)" disabled="@isSyncing">
                                                        @if (isSyncing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                        🔄 Sync
                                                    </button>
                                                }
                                                else if (CanSendUpcomingMatch(detailMatch))
                                                {
                                                    <button class="btn btn-success btn-sm" @onclick="() => SendUpcomingMatchAsync(detailMatch)" disabled="@isWorking">
                                                        ▶ Match starten
                                                    </button>
                                                }
                                            </div>
                                            @if (matchListener is not null && matchListener.IsRunning)
                                            {
                                                <div class="d-flex flex-column gap-1 mb-2">
                                                    <div class="d-flex align-items-center gap-2">
                                                        @if (matchListener.LastError is not null)
                                                        {
                                                            <span class="badge text-bg-danger">❌ Listener Fehler</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge text-bg-success">🎧 Listener aktiv</span>
                                                        }
                                                        @if (matchListener.LastUpdateUtc is not null)
                                                        {
                                                            <span class="small text-muted">Letztes Update: @matchListener.LastUpdateUtc.Value.LocalDateTime.ToString("HH:mm:ss")</span>
                                                        }
                                                    </div>
                                                    @if (matchListener.LastError is not null)
                                                    {
                                                        <div class="alert alert-danger py-1 px-2 mb-0 small">@matchListener.LastError</div>
                                                    }
                                                </div>
                                            }
                                            else if (!string.IsNullOrEmpty(detailMatch.ExternalMatchId) && detailMatch.FinishedUtc is null)
                                            {
                                                <div class="d-flex align-items-center gap-2 mb-2">
                                                    <span class="badge text-bg-warning">⚠ Kein Listener</span>
                                                    <button class="btn btn-outline-success btn-sm" @onclick="() => EnsureListenerAsync(detailMatch)" disabled="@isWorking">
                                                        🎧 Listener starten
                                                    </button>
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(detailMatch.ExternalMatchId) && detailMatch.FinishedUtc is null && (detailMatch.HomeLegs > 0 || detailMatch.AwayLegs > 0 || detailMatch.HomeSets > 0 || detailMatch.AwaySets > 0))
                                            {
                                                <div class="alert alert-info py-2 mb-3">
                                                    <strong>Live:</strong> @(homeP?.DisplayName?.ToUpperInvariant() ?? "Heim") <strong>@FormatLiveScore(detailMatch)</strong> @(awayP?.DisplayName?.ToUpperInvariant() ?? "Gast")
                                                </div>
                                            }
                                        }
                                        @if (detailMatch.WinnerParticipantId.HasValue)
                                        {
                                            <p class="mt-2">🏆 Gewinner: <strong
                                                class="text-success">@ParticipantName(detailMatch.WinnerParticipantId)</strong></p>
                                            }

                                            @{
                                                var homeNextMatch = GetNextMatchInfo(detailMatch, detailMatch.HomeParticipantId);
                                                var awayNextMatch = GetNextMatchInfo(detailMatch, detailMatch.AwayParticipantId);
                                            }
                                            @if (homeNextMatch is not null || awayNextMatch is not null)
                                            {
                                                <div class="small text-muted mt-2">
                                                    @if (homeNextMatch is not null)
                                                    {
                                                        <p class="mb-1">➡ @(homeP?.DisplayName?.ToUpperInvariant() ?? "?"): @homeNextMatch</p>
                                                    }
                                                    @if (awayNextMatch is not null)
                                                    {
                                                        <p class="mb-1">➡ @(awayP?.DisplayName?.ToUpperInvariant() ?? "?"): @awayNextMatch</p>
                                                    }
                                                </div>
                                            }

                                            @* ─── Match Statistics (#18) ─── *@
                                            @if (detailMatchStatistics.Count > 0 || isLoadingStats)
                                            {
                                                <hr />
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <h6 class="fw-semibold mb-0">Statistiken</h6>
                                                    <button class="btn btn-outline-secondary btn-sm" @onclick="SyncMatchStatisticsAsync" disabled="@isLoadingStats">
                                                        @if (isLoadingStats) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                        🔄 Aktualisieren
                                                    </button>
                                                </div>
                                                <MatchStatistics Statistics="@detailMatchStatistics" />
                                            }

                                            @* ─── Match Follow (#14) ─── *@
                                            @if (isAutodartsConnected)
                                            {
                                                <div class="d-flex align-items-center gap-2 mt-2 mb-2">
                                                    <button class="btn btn-sm @(isFollowingDetailMatch ? "btn-warning" : "btn-outline-warning")"
                                                            @onclick="ToggleFollowMatchAsync">
                                                        @(isFollowingDetailMatch ? "⭐ Match nicht mehr verfolgen" : "☆ Match verfolgen")
                                                    </button>
                                                </div>
                                            }

                                            @if (CanSetWalkover(detailMatch))
                                            {
                                                <div class="d-flex align-items-center gap-2 mt-2 mb-2">
                                                    <button class="btn btn-outline-dark btn-sm" @onclick="() => OpenWalkoverDialog(detailMatch)" disabled="@isWorking">
                                                        ⚑ Walkover setzen
                                                    </button>
                                                    <span class="small text-muted">Nur zulaessig fuer noch nicht gestartete Matches.</span>
                                                </div>
                                            }

                                            @if (showWalkoverConfirm)
                                            {
                                                <div class="alert alert-warning py-2">
                                                    <div class="fw-semibold mb-2">Walkover bestaetigen</div>
                                                    <div class="small mb-2">Waehlen Sie den Teilnehmer, der als Gewinner fortgeschrieben werden soll.</div>
                                                    <select class="form-select form-select-sm mb-2" @bind="walkoverWinnerId" disabled="@isWorking">
                                                        <option value="">-- Gewinner waehlen --</option>
                                                        @if (detailMatch.HomeParticipantId != Guid.Empty)
                                                        {
                                                            <option value="@detailMatch.HomeParticipantId">@(homeP?.DisplayName ?? "Heim")</option>
                                                        }
                                                        @if (detailMatch.AwayParticipantId != Guid.Empty)
                                                        {
                                                            <option value="@detailMatch.AwayParticipantId">@(awayP?.DisplayName ?? "Gast")</option>
                                                        }
                                                    </select>
                                                    <div class="d-flex gap-2">
                                                        <button class="btn btn-dark btn-sm" @onclick="ApplyWalkoverAsync" disabled="@isWorking">
                                                            Walkover uebernehmen
                                                        </button>
                                                        <button class="btn btn-outline-secondary btn-sm" @onclick="CancelWalkoverDialog" disabled="@isWorking">
                                                            Abbrechen
                                                        </button>
                                                    </div>
                                                </div>
                                            }

                                            <hr />
                                            @if (showManualResultEditor)
                                            {
                                                <h6 class="fw-semibold">Ergebnis manuell eintragen / korrigieren</h6>
                                                @if (IsSetMode(detailMatch))
                                                {
                                                    <div class="row g-2 align-items-end mb-2">
                                                        <div class="col">
                                                            <label class="form-label small">@(homeP?.DisplayName?.ToUpperInvariant() ?? "Heim") — Sets</label>
                                                            <input type="number" class="form-control" @bind="editHomeSets" min="0" />
                                                        </div>
                                                        <div class="col-auto pt-4">:</div>
                                                        <div class="col">
                                                            <label class="form-label small">@(awayP?.DisplayName?.ToUpperInvariant() ?? "Gast") — Sets</label>
                                                            <input type="number" class="form-control" @bind="editAwaySets" min="0" />
                                                        </div>
                                                    </div>
                                                }
                                                <div class="row g-2 align-items-end mb-2">
                                                    <div class="col">
                                                        <label class="form-label small">@(homeP?.DisplayName?.ToUpperInvariant() ?? "Heim") — Legs</label>
                                                        <input type="number" class="form-control" @bind="editHomeLegs" min="0" />
                                                    </div>
                                                    <div class="col-auto pt-4">:</div>
                                                    <div class="col">
                                                        <label class="form-label small">@(awayP?.DisplayName?.ToUpperInvariant() ?? "Gast") — Legs</label>
                                                        <input type="number" class="form-control" @bind="editAwayLegs" min="0" />
                                                    </div>
                                                    <div class="col-auto">
                                                        <button class="btn btn-primary" @onclick="SaveResultAsync" disabled="@isWorking">Ergebnis
                                                            speichern</button>
                                                        </div>
                                                    </div>
                                            }
                                            else
                                            {
                                                <div class="alert alert-secondary py-2 small">
                                                    Ergebnisfelder eingeklappt, weil dieses Match aus dem Spielplan geoeffnet wurde und ein aktiver Listener laeuft.
                                                </div>
                                            }
                                            @if (resultError is not null)
                                            {
                                                <div class="alert alert-danger py-2 small">@resultError</div>
                                            }
                                            </div>
                                            <div class="modal-footer">
                                                <button class="btn btn-outline-danger me-auto" @onclick="ResetMatchAsync" disabled="@isWorking"
                                                        title="Spielstand, Start-/Endzeit und ExternalMatchId zurücksetzen">
                                                    🗑 Zurücksetzen
                                                </button>
                                                <button class="btn btn-secondary" @onclick="CloseMatchDetail">Schließen</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            @* ─── Participant Edit Modal ─── *@
                            @if (editingParticipant is not null)
                            {
                                <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Teilnehmer bearbeiten</h5>
                                                <button type="button" class="btn-close" @onclick="CancelEditParticipant"></button>
                                            </div>
                                            <div class="modal-body">
                                                <div class="mb-3">
                                                    <label class="form-label fw-semibold">Anzeigename</label>
                                                    <input class="form-control" @bind="editPDisplayName" />
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label fw-semibold">Account-Name</label>
                                                    <input class="form-control" @bind="editPAccountName" />
                                                </div>
                                                <div class="form-check mb-2">
                                                    <input class="form-check-input" type="checkbox" id="editPIsAuto" @bind="editPIsAutodarts" />
                                                    <label class="form-check-label" for="editPIsAuto">Autodarts Account</label>
                                                </div>
                                                <div class="form-check mb-3">
                                                    <input class="form-check-input" type="checkbox" id="editPIsManager" @bind="editPIsManager" />
                                                    <label class="form-check-label" for="editPIsManager">Spielleiter</label>
                                                </div>
                                                @if (editPError is not null)
                                                {
                                                    <div class="alert alert-danger py-2">@editPError</div>
                                                }
                                            </div>
                                            <div class="modal-footer">
                                                <button class="btn btn-secondary" @onclick="CancelEditParticipant">Abbrechen</button>
                                                <button class="btn btn-primary" @onclick="SaveParticipantEditAsync"
                                                        disabled="@isWorking">Speichern</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            @* ─── Tournament List + Detail ─── *@

                            @* ─── Player Detail Modal ─── *@
                            @if (detailParticipant is not null)
                            {
                                <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="() => detailParticipant = null">
                                    <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation>
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">
                                                    @ParticipantDisplayName(detailParticipant)
                                                    @if (detailParticipant.IsAutodartsAccount) { <span class="autodarts-icon ms-1" title="Autodarts"></span> }
                                                    @if (detailParticipant.IsManager) { <span class="badge text-bg-warning ms-1">Spielleiter</span> }
                                                </h5>
                                                <button type="button" class="btn-close" @onclick="() => detailParticipant = null"></button>
                                            </div>
                                            <div class="modal-body">
                                                <ul class="nav nav-tabs mb-3">
                                                    <li class="nav-item">
                                                        <button class="nav-link @(playerDetailTab == "info" ? "active" : "")" @onclick='() => playerDetailTab = "info"'>Spielerinfo</button>
                                                    </li>
                                                    <li class="nav-item">
                                                        <button class="nav-link @(playerDetailTab == "results" ? "active" : "")" @onclick='() => playerDetailTab = "results"'>Ergebnisse</button>
                                                    </li>
                                                    <li class="nav-item">
                                                        <button class="nav-link @(playerDetailTab == "upcoming" ? "active" : "")" @onclick='() => playerDetailTab = "upcoming"'>Nächste Begegnungen</button>
                                                    </li>
                                                </ul>

                                                @if (playerDetailTab == "info")
                                                {
                                                    var pMatches = matches.Where(m => m.HomeParticipantId == detailParticipant.Id || m.AwayParticipantId == detailParticipant.Id).ToList();
                                                    var played = pMatches.Where(m => m.FinishedUtc is not null && m.HomeParticipantId != Guid.Empty && m.AwayParticipantId != Guid.Empty).ToList();
                                                    var wins = played.Count(m => m.WinnerParticipantId == detailParticipant.Id);
                                                    var losses = played.Count - wins;
                                                    var legsWon = played.Sum(m => m.HomeParticipantId == detailParticipant.Id ? m.HomeLegs : m.AwayLegs);
                                                    var legsLost = played.Sum(m => m.HomeParticipantId == detailParticipant.Id ? m.AwayLegs : m.HomeLegs);
                                                    var last5 = played.OrderByDescending(m => m.FinishedUtc).Take(5).ToList();

                                                    <dl class="row mb-3">
                                                        <dt class="col-sm-4">Account</dt>
                                                        <dd class="col-sm-8">@detailParticipant.AccountName @if (detailParticipant.IsAutodartsAccount) { <span class="autodarts-icon"></span> } else { <span>(Lokal)</span> }</dd>
                                                        <dt class="col-sm-4">Setzposition</dt>
                                                        <dd class="col-sm-8">@ParticipantSeedLabel(detailParticipant)</dd>
                                                        <dt class="col-sm-4">Gesamt</dt>
                                                        <dd class="col-sm-8">@played.Count Spiele — @wins S / @losses N</dd>
                                                        <dt class="col-sm-4">Legs</dt>
                                                        <dd class="col-sm-8">@legsWon : @legsLost (Diff: @(legsWon - legsLost > 0 ? "+" : "")@(legsWon - legsLost))</dd>
                                                        @if (played.Count > 0)
                                                        {
                                                            <dt class="col-sm-4">Siegquote</dt>
                                                            <dd class="col-sm-8">@((wins * 100.0 / played.Count).ToString("F0")) %</dd>
                                                        }
                                                    </dl>

                                                    @if (last5.Any())
                                                    {
                                                        <h6 class="fw-semibold small">Letzte 5 Spiele</h6>
                                                        <div class="d-flex gap-1 mb-2">
                                                            @foreach (var m in last5)
                                                            {
                                                                var isWin = m.WinnerParticipantId == detailParticipant.Id;
                                                                <span class="badge @(isWin ? "bg-success" : "bg-danger")">@(isWin ? "S" : "N")</span>
                                                            }
                                                        </div>
                                                    }
                                                }

                                                @if (playerDetailTab == "results")
                                                {
                                                    var pPlayed = matches.Where(m => m.FinishedUtc is not null && (m.HomeParticipantId == detailParticipant.Id || m.AwayParticipantId == detailParticipant.Id) && m.HomeParticipantId != Guid.Empty && m.AwayParticipantId != Guid.Empty)
                                                        .OrderByDescending(m => m.FinishedUtc).ToList();

                                                    @if (pPlayed.Any())
                                                    {
                                                        <table class="table table-sm">
                                                            <thead>
                                                                <tr><th>Match</th><th>Gegner</th><th>Ergebnis</th><th></th></tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var m in pPlayed)
                                                                {
                                                                    var isHome = m.HomeParticipantId == detailParticipant.Id;
                                                                    var opponentId = isHome ? m.AwayParticipantId : m.HomeParticipantId;
                                                                    var myLegs = isHome ? m.HomeLegs : m.AwayLegs;
                                                                    var oppLegs = isHome ? m.AwayLegs : m.HomeLegs;
                                                                    var isWin = m.WinnerParticipantId == detailParticipant.Id;
                                                                    <tr>
                                                                        <td class="small">@MatchLabel(m)</td>
                                                                        <td>@ParticipantNameWithSeed(opponentId)</td>
                                                                        <td>@myLegs : @oppLegs</td>
                                                                        <td><span class="badge @(isWin ? "bg-success" : "bg-danger")">@(isWin ? "S" : "N")</span></td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    }
                                                    else
                                                    {
                                                        <p class="text-muted small">Noch keine Ergebnisse.</p>
                                                    }
                                                }

                                                @if (playerDetailTab == "upcoming")
                                                {
                                                    var pUpcoming = matches.Where(m => m.FinishedUtc is null && (m.HomeParticipantId == detailParticipant.Id || m.AwayParticipantId == detailParticipant.Id) && m.HomeParticipantId != Guid.Empty && m.AwayParticipantId != Guid.Empty)
                                                        .OrderBy(m => m.PlannedStartUtc ?? DateTimeOffset.MaxValue).ToList();

                                                    @if (pUpcoming.Any())
                                                    {
                                                        <table class="table table-sm">
                                                            <thead>
                                                                <tr><th>Match</th><th>Gegner</th><th>Startzeit</th><th>Board</th></tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var m in pUpcoming)
                                                                {
                                                                    var isHome = m.HomeParticipantId == detailParticipant.Id;
                                                                    var opponentId = isHome ? m.AwayParticipantId : m.HomeParticipantId;
                                                                    var board = boards.FirstOrDefault(b => b.Id == m.BoardId);
                                                                    <tr>
                                                                        <td class="small">@MatchLabel(m)</td>
                                                                        <td>@ParticipantNameWithSeed(opponentId)</td>
                                                                        <td class="small">@(m.PlannedStartUtc?.LocalDateTime.ToString("HH:mm") ?? "—")</td>
                                                                        <td class="small">@(board?.Name ?? "—")</td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    }
                                                    else
                                                    {
                                                        <p class="text-muted small">Keine anstehenden Begegnungen.</p>
                                                    }
                                                }
                                            </div>
                                            <div class="modal-footer">
                                                <button class="btn btn-secondary" @onclick="() => detailParticipant = null">Schließen</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            @* ─── Tournament List + Detail ─── *@
                            <div class="row g-3">
                                <div class="@(selectedTournament is not null ? "col-lg-3" : "col-12")">
                                    @if (ActiveTournaments.Any())
                                    {
                                        <h6 class="mb-1 fw-semibold text-success">▶ Aktiv</h6>
                                        <ul class="list-group mb-3">
                                            @foreach (var t in ActiveTournaments)
                                            {
                                                <li class="list-group-item list-group-item-action @(selectedTournament?.Id == t.Id ? "active" : "")"
                                                    style="cursor:pointer" @onclick="() => SelectTournamentAsync(t)">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <span>@t.Name @if (!string.IsNullOrEmpty(t.JoinCode)) {
                                                            <span
                                                            class="badge text-bg-primary font-monospace" style="font-size:0.65rem">@t.JoinCode</span>
                                                        }
                                                        @if (t.IsLocked)
                                                        {
                                                            <span>🔒</span>
                                                        }
                                                    </span>
                                                    <span
                                                    class="badge @(selectedTournament?.Id == t.Id ? "bg-light text-dark" : "bg-primary")">@t.ParticipantCount</span>
                                                </div>
                                                <small
                                                    class="@(selectedTournament?.Id == t.Id ? "text-white-50" : "text-muted")">@t.StartDate.ToString("dd.MM.yyyy")
                                                    – @t.EndDate.ToString("dd.MM.yyyy")</small>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    @if (UpcomingTournaments.Any())
                                    {
                                        <h6 class="mb-1 fw-semibold text-primary">📅 Geplant</h6>
                                        <ul class="list-group mb-3">
                                            @foreach (var t in UpcomingTournaments)
                                            {
                                                <li class="list-group-item list-group-item-action @(selectedTournament?.Id == t.Id ? "active" : "")"
                                                    style="cursor:pointer" @onclick="() => SelectTournamentAsync(t)">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <span>@t.Name @if (t.IsLocked) {
                                                            <span>🔒</span>
                                                        }
                                                    </span>
                                                    <span
                                                    class="badge @(selectedTournament?.Id == t.Id ? "bg-light text-dark" : "bg-secondary")">@t.ParticipantCount</span>
                                                </div>
                                                <small
                                                    class="@(selectedTournament?.Id == t.Id ? "text-white-50" : "text-muted")">@t.StartDate.ToString("dd.MM.yyyy")
                                                    – @t.EndDate.ToString("dd.MM.yyyy")</small>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    @if (PastTournaments.Any())
                                    {
                                        <h6 class="mb-1 fw-semibold text-muted">✓ Vergangen</h6>
                                        <ul class="list-group mb-3">
                                            @foreach (var t in PastTournaments)
                                            {
                                                <li class="list-group-item list-group-item-action @(selectedTournament?.Id == t.Id ? "active" : "")"
                                                    style="cursor:pointer" @onclick="() => SelectTournamentAsync(t)">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <span>@t.Name</span>
                                                        <span
                                                        class="badge @(selectedTournament?.Id == t.Id ? "bg-light text-dark" : "bg-secondary")">@t.ParticipantCount</span>
                                                    </div>
                                                    <small
                                                    class="@(selectedTournament?.Id == t.Id ? "text-white-50" : "text-muted")">@t.StartDate.ToString("dd.MM.yyyy")</small>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    @if (!tournaments.Any())
                                    {
                                        <p class="text-muted">Noch keine Turniere vorhanden.</p>
                                    }
                                </div>

                                @* ─── Detail Panel ─── *@
                                @if (selectedTournament is not null)
                                {
                                    <div class="col-lg-9">
                                        <div class="card shadow-sm">
                                            <div class="card-header d-flex justify-content-between align-items-center">
                                                <div>
                                                    <span class="fw-semibold">@selectedTournament.Name</span>
                                                    @if (!string.IsNullOrEmpty(selectedTournament.JoinCode))
                                                    {
                                                        <span class="badge text-bg-primary ms-2 font-monospace">@selectedTournament.JoinCode</span>
                                                    }
                                                    @if (selectedTournament.IsLocked)
                                                    {
                                                        <span class="badge text-bg-danger ms-2">🔒 Gesperrt</span>
                                                    }
                                                </div>
                                                <div class="d-flex gap-1">
                                                    <span class="badge text-bg-secondary">@ModeDisplay(selectedTournament.Mode)</span>
                                                    <span class="badge text-bg-info">@VariantDisplay(selectedTournament.Variant)</span>
                                                    @if (IsCurrentUserManager)
                                                    {
                                                        <div class="btn-group ms-1">
                                                            <button class="btn btn-sm badge @StatusBadgeCss(selectedTournament.Status)"
                                                                    disabled="@(!IsCurrentUserManager)">
                                                                @selectedTournament.Status
                                                            </button>
                                                            <button class="btn btn-sm badge @StatusBadgeCss(selectedTournament.Status) dropdown-toggle dropdown-toggle-split"
                                                                    type="button" @onclick="ToggleStatusDropdown" @onclick:stopPropagation
                                                                    disabled="@isWorking">
                                                                <span class="visually-hidden">Status ändern</span>
                                                            </button>
                                                            <ul class="dropdown-menu @(showStatusDropdown ? "show" : "")">
                                                                <li><button class="dropdown-item @(selectedTournament.Status == "Erstellt" ? "active" : "")"
                                                                            @onclick='() => UpdateTournamentStatusAndCloseAsync("Erstellt")'>Erstellt</button></li>
                                                                <li><button class="dropdown-item @(selectedTournament.Status == "Geplant" ? "active" : "")"
                                                                            @onclick='() => UpdateTournamentStatusAndCloseAsync("Geplant")'>Geplant</button></li>
                                                                <li><button class="dropdown-item @(selectedTournament.Status == "Gestartet" ? "active" : "")"
                                                                            @onclick='() => UpdateTournamentStatusAndCloseAsync("Gestartet")'>Gestartet</button></li>
                                                                <li><button class="dropdown-item @(selectedTournament.Status == "Beendet" ? "active" : "")"
                                                                            @onclick='() => UpdateTournamentStatusAndCloseAsync("Beendet")'>Beendet</button></li>
                                                                <li><hr class="dropdown-divider" /></li>
                                                                <li><button class="dropdown-item text-danger @(selectedTournament.Status == "Abgebrochen" ? "active" : "")"
                                                                            @onclick='() => UpdateTournamentStatusAndCloseAsync("Abgebrochen")'>Abgebrochen</button></li>
                                                            </ul>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge @StatusBadgeCss(selectedTournament.Status)">@selectedTournament.Status</span>
                                                    }
                                                    @if (IsCurrentUserManager)
                                                    {
                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleLockAsync" title="@(selectedTournament.IsLocked ? "Entsperren" : "Sperren")">
                                                            @(selectedTournament.IsLocked ? "🔒" : "🔓")
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-danger" @onclick="DeleteTournamentAsync" title="Turnier löschen">🗑</button>
                                                    }
                                                </div>
                                            </div>
                                            <div class="card-body">
                                                @* ─── Tabs ─── *@
                                                <ul class="nav nav-tabs mb-3">
                                                    <li class="nav-item"><button class="nav-link @(activeTab == "general" ? "active" : "")"
                                                                                     @onclick='() => activeTab = "general"'>Allgemein</button></li>
                                                        <li class="nav-item"><button class="nav-link @(activeTab == "boards-participants" ? "active" : "")"
                                                                                         @onclick='() => activeTab = "boards-participants"'>Boards &amp; Teilnehmer</button></li>
                                                            <li class="nav-item"><button class="nav-link @(activeTab == "rounds" ? "active" : "")"
                                                                                             @onclick="SwitchToRoundsTabAsync">Spielmodus @if (HasMissingRoundConfig()) {<span class="badge text-bg-danger ms-1">@MissingRoundConfigCount() ⚠</span>}</button></li>
                                                                <li class="nav-item"><button class="nav-link @(activeTab == "draw" ? "active" : "")"
                                                                                                 @onclick='() => activeTab = "draw"'>Auslosung</button></li>
                                                                    @if (selectedTournament.Mode == "GroupAndKnockout")
                                                                    {
                                                                        <li class="nav-item"><button class="nav-link @(activeTab == "groups" ? "active" : "")"
                                                                                                         @onclick='() => activeTab = "groups"'>Gruppenphase <span class="badge @PhaseBadgeCss("Group") ms-1">@PhaseBadgeText("Group")</span></button></li>
                                                                        }
                                                                        <li class="nav-item"><button class="nav-link @(activeTab == "knockout" ? "active" : "")"
                                                                                                         @onclick='() => activeTab = "knockout"'>K.O.-Phase <span class="badge @PhaseBadgeCss("Knockout") ms-1">@PhaseBadgeText("Knockout")</span></button></li>
                                                                            <li class="nav-item"><button class="nav-link @(activeTab == "schedule" ? "active" : "")"
                                                                                                         @onclick='() => activeTab = "schedule"'>Spielplan <span
                                                                                class="badge @ScheduleBadgeCss ms-1">@ScheduleBadgeText</span></button></li>
                                                                            </ul>

                                                                            @* ═══════ Tab: Allgemein ═══════ *@
                                                                            @if (activeTab == "general")
                                                                            {
                                                                                @if (selectedTournament.IsLocked)
                                                                                {
                                                                                    <div class="alert alert-info py-2">🔒 Das Turnier ist gesperrt. Entsperren Sie es, um Änderungen
                                                                                        vorzunehmen.</div>
                                                                                }

                                                                                <details class="card mb-3" open>
                                                                                    <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
                                                                                        <span>
                                                                                            Grunddaten
                                                                                            @if (HasGeneralRequiredMissing())
                                                                                            {
                                                                                                <span class="text-danger ms-2" title="Pflichteinstellungen fehlen">⚠</span>
                                                                                            }
                                                                                        </span>
                                                                                        <span class="d-none d-md-inline small text-muted">@GeneralSettingsSummary()</span>
                                                                                    </summary>
                                                                                    <div class="card-body">
                                                                                        @if (CanEditBasicSettings)
                                                                                        {
                                                                                            <div class="mb-3">
                                                                                                <label class="form-label fw-semibold" title="Eindeutiger Turniername für Listen, Suche und Turnierlink.">Turniername</label>
                                                                                                <input class="form-control @(string.IsNullOrWhiteSpace(editName) ? "border-danger" : "")" @bind="editName" @bind:after="AutoSaveSettingAsync" />
                                                                                            </div>
                                                                                            <div class="mb-3">
                                                                                                <label class="form-label fw-semibold" title="Autodarts-Account des Veranstalters; steuert Sichtbarkeit und Berechtigungen.">Veranstalter-Account</label>
                                                                                                <input class="form-control @(string.IsNullOrWhiteSpace(editOrganizer) ? "border-danger" : "")" @bind="editOrganizer" @bind:after="AutoSaveSettingAsync" list="organizerSuggestions" />
                                                                                                <datalist id="organizerSuggestions">
                                                                                                    @if (!string.IsNullOrEmpty(autodartsDisplayName))
                                                                                                    {
                                                                                                        <option value="@autodartsDisplayName" />
                                                                                                    }
                                                                                                    @foreach (var p in participants.Where(p => p.IsAutodartsAccount))
                                                                                                    {
                                                                                                        <option value="@p.AccountName">@p.DisplayName</option>
                                                                                                    }
                                                                                                </datalist>
                                                                                            </div>
                                                                                            <div class="row g-2 mb-3">
                                                                                                <div class="col-md-4">
                                                                                                    <label class="form-label fw-semibold" title="Startdatum des Turniers. Grundlage für aktive/kommende Turniere.">Startdatum</label>
                                                                                                    <input type="date" class="form-control" @bind="editStartDate" @bind:after="AutoSaveSettingAsync" />
                                                                                                </div>
                                                                                                <div class="col-md-4">
                                                                                                    <label class="form-label fw-semibold" title="Enddatum des Turniers; darf nicht vor dem Startdatum liegen.">Enddatum</label>
                                                                                                    <input type="date" class="form-control @((editEndDate < editStartDate) ? "border-danger" : "")" @bind="editEndDate" @bind:after="AutoSaveSettingAsync" />
                                                                                                </div>
                                                                                                <div class="col-md-4">
                                                                                                    <label class="form-label fw-semibold" title="Optional: Uhrzeit für Start und Spielplan-Generierung.">Startzeit</label>
                                                                                                    <input type="time" class="form-control" @bind="editStartTimeInput" @bind:after="AutoSaveSettingAsync" />
                                                                                                </div>
                                                                                            </div>
                                                                                            <div class="mb-3">
                                                                                                <label class="form-label fw-semibold" title="Turniermodus: K.O. oder Gruppe + K.O. beeinflusst Auslosung und Gruppen-Tab.">Modus</label>
                                                                                                <select class="form-select" @bind="editMode" @bind:after="AutoSaveSettingAsync">
                                                                                                    <option value="Knockout">K.O.-Modus</option>
                                                                                                    <option value="GroupAndKnockout">Gruppenphase + K.O.</option>
                                                                                                </select>
                                                                                            </div>
                                                                                            <div class="mb-3">
                                                                                                <label class="form-label fw-semibold" title="Vor-Ort: Board-Zuweisung und lokale Steuerung; Online: ohne Board-Zwang.">Variante</label>
                                                                                                <select class="form-select" @bind="editVariant" @bind:after="AutoSaveSettingAsync">
                                                                                                    <option value="OnSite">Vor-Ort</option>
                                                                                                    <option value="Online">Online</option>
                                                                                                </select>
                                                                                            </div>
                                                                                            <div class="form-check mb-0">
                                                                                                <input class="form-check-input" type="checkbox" id="editThirdPlace" @bind="editThirdPlaceMatch" @bind:after="AutoSaveSettingAsync" />
                                                                                                <label class="form-check-label" for="editThirdPlace" title="Erzeugt nach dem Halbfinale ein zusätzliches Spiel um Platz 3.">Spiel um Platz 3</label>
                                                                                            </div>
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <div class="small text-muted d-flex flex-wrap gap-2">
                                                                                                <span class="badge text-bg-secondary">@ModeDisplay(editMode)</span>
                                                                                                <span class="badge text-bg-secondary">@VariantDisplay(editVariant)</span>
                                                                                                <span class="badge @(editThirdPlaceMatch ? "text-bg-info" : "text-bg-light")">Platz 3: @(editThirdPlaceMatch ? "Ja" : "Nein")</span>
                                                                                                <span class="badge text-bg-light border">Start: @editStartDate.ToString("dd.MM.yyyy")</span>
                                                                                                <span class="badge text-bg-light border">Ende: @editEndDate.ToString("dd.MM.yyyy")</span>
                                                                                            </div>
                                                                                        }
                                                                                    </div>
                                                                                </details>

                                                                                @if (!string.IsNullOrEmpty(selectedTournament.JoinCode))
                                                                                {
                                                                                    <details class="card mb-3">
                                                                                        <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
                                                                                            <span>Turnier-Link</span>
                                                                                            <span class="d-none d-md-inline small text-muted">Code: @selectedTournament.JoinCode</span>
                                                                                        </summary>
                                                                                        <div class="card-body">
                                                                                            <div class="input-group">
                                                                                                <input type="text" class="form-control form-control-sm" readonly value="@TournamentLink" />
                                                                                                @if (CanEditTournamentSettings)
                                                                                                {
                                                                                                    <button class="btn btn-outline-secondary btn-sm" @onclick="CopyTournamentLink" title="Kopiert den direkten Turnierlink in die Zwischenablage.">📋 Kopieren</button>
                                                                                                }
                                                                                            </div>
                                                                                        </div>
                                                                                    </details>
                                                                                }

                                                                                <details class="card mb-3">
                                                                                    <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
                                                                                        <span>Discord Webhook</span>
                                                                                        <span class="d-none d-md-inline small text-muted">@(string.IsNullOrWhiteSpace(editDiscordWebhookUrl) ? "Nicht konfiguriert" : "Konfiguriert")</span>
                                                                                    </summary>
                                                                                    <div class="card-body">
                                                                                        @if (CanEditTournamentSettings)
                                                                                        {
                                                                                            <div class="mb-2">
                                                                                                <label class="form-label small" title="Webhook-URL für automatische Ergebnisposts bei Matchende.">Webhook URL</label>
                                                                                                <div class="input-group">
                                                                                                    <input type="url" class="form-control form-control-sm" @bind="editDiscordWebhookUrl" @bind:after="AutoSaveSettingAsync"
                                                                                                           placeholder="https://discord.com/api/webhooks/..." />
                                                                                                    @if (!string.IsNullOrEmpty(editDiscordWebhookUrl))
                                                                                                    {
                                                                                                        <button class="btn btn-outline-secondary btn-sm" @onclick="TestDiscordWebhookAsync" disabled="@isWorking" title="Sendet eine Testnachricht an den konfigurierten Channel.">🔔 Testen</button>
                                                                                                    }
                                                                                                </div>
                                                                                            </div>
                                                                                            <div class="mb-3">
                                                                                                <label class="form-label small" title="Optionaler Anzeigename für Bot-Nachrichten, z.B. Turnier-Bot.">Anzeigename (optional)</label>
                                                                                                <input type="text" class="form-control form-control-sm" @bind="editDiscordWebhookDisplayText" @bind:after="AutoSaveSettingAsync" placeholder="z.B. Turnier-Bot" />
                                                                                            </div>
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <div class="small text-muted">@(string.IsNullOrWhiteSpace(editDiscordWebhookUrl) ? "Kein Webhook hinterlegt." : "Webhook hinterlegt.")</div>
                                                                                        }

                                                                                        @if (discordTestResult is not null)
                                                                                        {
                                                                                            <div class="alert @(discordTestSuccess ? "alert-success" : "alert-danger") py-1 small">@discordTestResult</div>
                                                                                        }
                                                                                    </div>
                                                                                </details>

                                                                                    @if (editError is not null)
                                                                                    {
                                                                                        <div class="alert alert-danger py-2">@editError</div>
                                                                                    }
                                                                                    @if (editSuccess is not null)
                                                                                    {
                                                                                        <div class="alert alert-success py-2">@editSuccess</div>
                                                                                    }
                                                                                    }

                                                                                    @* ═══════ Tab: Boards & Teilnehmer ═══════ *@
                                                                                    @if (activeTab == "boards-participants")
                                                                                    {
                                                                                        <details class="card mb-3" open>
                                                                                            <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
                                                                                                <span>
                                                                                                    Teamplay & Setzliste
                                                                                                    @if (HasTeamplayRequiredMissing() || HasSeedingRequiredMissing())
                                                                                                    {
                                                                                                        <span class="text-danger ms-2" title="Pflichteinstellungen fehlen">⚠</span>
                                                                                                    }
                                                                                                </span>
                                                                                                <span class="d-none d-md-inline small text-muted">@TeamplaySeedingSummary()</span>
                                                                                            </summary>
                                                                                            <div class="card-body">
                                                                                                @if (CanEditParticipantSettings)
                                                                                                {
                                                                                                    <div class="form-check mb-2">
                                                                                                        <input class="form-check-input" type="checkbox" id="editTeamplay" @bind="editTeamplay" @bind:after="AutoSaveSettingAsync" />
                                                                                                        <label class="form-check-label" for="editTeamplay" title="Aktiviert Teams statt Einzelspielern. Spieler pro Team muss gesetzt werden.">Teamplay aktivieren</label>
                                                                                                    </div>
                                                                                                    <div class="mb-3">
                                                                                                        <label class="form-label small" title="Anzahl Spieler pro Team; bei Teamplay mindestens 2 empfohlen.">Spieler/Team</label>
                                                                                                        <input type="number" class="form-control form-control-sm @(HasTeamplayRequiredMissing() ? "border-danger" : "")" @bind="editPlayersPerTeam" @bind:after="AutoSaveSettingAsync" min="1" disabled="@(!editTeamplay)" />
                                                                                                    </div>

                                                                                                    <div class="form-check mb-2">
                                                                                                        <input class="form-check-input" type="checkbox" id="editSeedingEnabled" @bind="editSeedingEnabled" @bind:after="OnSeedingEnabledChangedAsync" />
                                                                                                        <label class="form-check-label" for="editSeedingEnabled" title="Aktiviert Setzliste für Auslosung und Lostopf-Verfahren.">Setzliste aktivieren</label>
                                                                                                    </div>
                                                                                                    @if (editSeedingEnabled)
                                                                                                    {
                                                                                                        <div class="mb-0">
                                                                                                            <label class="form-label small" title="Anzahl gesetzter Spieler; beeinflusst Bracket- und Gruppenverteilung.">Anzahl gesetzter Spieler</label>
                                                                                                            <input type="number" class="form-control form-control-sm @(HasSeedingRequiredMissing() ? "border-danger" : "")" @bind="editSeedTopCount" @bind:after="OnSeedTopCountChangedAsync" min="0" max="@participants.Count" />
                                                                                                        </div>
                                                                                                    }
                                                                                                }
                                                                                                else
                                                                                                {
                                                                                                    <div class="small text-muted d-flex flex-wrap gap-2">
                                                                                                        <span class="badge @(editTeamplay ? "text-bg-info" : "text-bg-light")">Teamplay: @(editTeamplay ? "Aktiv" : "Aus")</span>
                                                                                                        <span class="badge text-bg-light border">Spieler/Team: @editPlayersPerTeam</span>
                                                                                                        <span class="badge @(editSeedingEnabled ? "text-bg-info" : "text-bg-light")">Setzliste: @(editSeedingEnabled ? "Aktiv" : "Aus")</span>
                                                                                                        @if (editSeedingEnabled)
                                                                                                        {
                                                                                                            <span class="badge text-bg-light border">Gesetzt: @editSeedTopCount</span>
                                                                                                        }
                                                                                                    </div>
                                                                                                }
                                                                                            </div>
                                                                                        </details>

                                                                                        <details class="card mb-3">
                                                                                            <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
                                                                                                <span>
                                                                                                    Registrierung
                                                                                                    @if (HasRegistrationRequiredMissing())
                                                                                                    {
                                                                                                        <span class="text-danger ms-2" title="Pflichteinstellungen fehlen">⚠</span>
                                                                                                    }
                                                                                                </span>
                                                                                                <span class="d-none d-md-inline small text-muted">@RegistrationSummary()</span>
                                                                                            </summary>
                                                                                            <div class="card-body">
                                                                                                @if (CanEditParticipantSettings)
                                                                                                {
                                                                                                    <div class="form-check mb-2">
                                                                                                        <input class="form-check-input" type="checkbox" id="editRegistrationOpen" @bind="editIsRegistrationOpen" @bind:after="AutoSaveSettingAsync" />
                                                                                                        <label class="form-check-label" for="editRegistrationOpen" title="Steuert, ob Teilnehmer sich vor Turnierstart registrieren dürfen.">Registrierung offen</label>
                                                                                                    </div>
                                                                                                    <div class="row g-2 mb-0">
                                                                                                        <div class="col-md-6">
                                                                                                            <label class="form-label small" title="Beginn der Registrierungsphase.">Registrierung Start</label>
                                                                                                            <input type="datetime-local" class="form-control form-control-sm @(HasRegistrationRequiredMissing() && !editRegistrationStart.HasValue ? "border-danger" : "")" @bind="editRegistrationStart" @bind:after="AutoSaveSettingAsync" disabled="@(!editIsRegistrationOpen)" />
                                                                                                        </div>
                                                                                                        <div class="col-md-6">
                                                                                                            <label class="form-label small" title="Ende der Registrierungsphase; muss nach dem Start liegen.">Registrierung Ende</label>
                                                                                                            <input type="datetime-local" class="form-control form-control-sm @(HasRegistrationRequiredMissing() && (!editRegistrationEnd.HasValue || editRegistrationEnd <= editRegistrationStart) ? "border-danger" : "")" @bind="editRegistrationEnd" @bind:after="AutoSaveSettingAsync" disabled="@(!editIsRegistrationOpen)" />
                                                                                                        </div>
                                                                                                    </div>
                                                                                                }
                                                                                                else
                                                                                                {
                                                                                                    <div class="small text-muted d-flex flex-wrap gap-2">
                                                                                                        <span class="badge @(editIsRegistrationOpen ? "text-bg-info" : "text-bg-light")">Registrierung: @(editIsRegistrationOpen ? "Offen" : "Geschlossen")</span>
                                                                                                        @if (editRegistrationStart.HasValue)
                                                                                                        {
                                                                                                            <span class="badge text-bg-light border">Start: @editRegistrationStart.Value.ToString("dd.MM HH:mm")</span>
                                                                                                        }
                                                                                                        @if (editRegistrationEnd.HasValue)
                                                                                                        {
                                                                                                            <span class="badge text-bg-light border">Ende: @editRegistrationEnd.Value.ToString("dd.MM HH:mm")</span>
                                                                                                        }
                                                                                                    </div>
                                                                                                }
                                                                                            </div>
                                                                                        </details>

                                                                                        <h6 class="fw-semibold mb-2">Boards</h6>
                                                                                        @if (boards.Any())
                                                                                        {
                                                                                            <div class="table-responsive mb-4">
                                                                                                <table class="table table-sm table-hover mb-0">
                                                                                                    <thead>
                                                                                                        <tr>
                                                                                                            <th>Board</th>
                                                                                                            <th>Status</th>
                                                                                                            <th>Aktuelles Match</th>
                                                                                                            <th></th>
                                                                                                        </tr>
                                                                                                    </thead>
                                                                                                    <tbody>
                                                                                                        @foreach (var board in boards)
                                                                                                        {
                                                                                                            <tr>
                                                                                                                <td><span role="button" @onclick="() => OpenBoardDetail(board)" class="text-decoration-none fw-semibold" style="cursor:pointer">@board.Name</span></td>
                                                                                                                <td><span class="badge @BoardStatusBadge(board.Status)">@board.Status</span></td>
                                                                                                                <td>
                                                                                                                    @if (!string.IsNullOrEmpty(board.CurrentMatchLabel))
                                                                                                                    {
                                                                                                                        var boardMatch = board.CurrentMatchId.HasValue
                                                                                                                            ? matches.FirstOrDefault(m => m.Id == board.CurrentMatchId.Value)
                                                                                                                            : null;
                                                                                                                        @if (boardMatch is not null)
                                                                                                                        {
                                                                                                                            <span role="button" class="text-primary fw-semibold" style="cursor:pointer;text-decoration:underline dotted"
                                                                                                                                  @onclick="() => OpenMatchDetail(boardMatch)"><span class="autodarts-icon"></span> @board.CurrentMatchLabel</span>
                                                                                                                        }
                                                                                                                        else
                                                                                                                        {
                                                                                                                            <span>@board.CurrentMatchLabel</span>
                                                                                                                        }
                                                                                                                    }
                                                                                                                    else
                                                                                                                    {
                                                                                                                        <span>—</span>
                                                                                                                    }
                                                                                                                </td>
                                                                                                                <td class="d-flex gap-1">
                                                                                                                    <a href="https://play.autodarts.io/boards/@(board.ExternalBoardId)/follow"
                                                                                                                       target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary">📺</a>
                                                                                                                    @if (!selectedTournament.IsLocked)
                                                                                                                    {
                                                                                                                        <button class="btn btn-sm btn-outline-danger"
                                                                                                                                @onclick="() => DeleteBoardAsync(board.Id)" disabled="@isWorking">✕</button>
                                                                                                                    }
                                                                                                                </td>
                                                                                                            </tr>
                                                                                                        }
                                                                                                    </tbody>
                                                                                                </table>
                                                                                            </div>
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <p class="text-muted small mb-4">Keine Boards konfiguriert. Boards können über die <a
                                                                                                href="/boards">Boards-Seite</a> oder die Chrome-Extension hinzugefügt werden.</p>
                                                                                            }

                                                                                            <h6 class="fw-semibold mb-2">Teilnehmer <span class="badge text-bg-secondary">@participants.Count</span>
                                                                                            </h6>
                                                                                            @if (!selectedTournament.IsLocked)
                                                                                            {
                                                                                                <div class="row g-2 align-items-end mb-2">
                                                                                                    <div class="col-md-3 position-relative">
                                                                                                        <label class="form-label small mb-1">Anzeigename</label>
                                                                                                        <input class="form-control" value="@participantName" @oninput="OnParticipantNameInput"
                                                                                                               placeholder="z.B. Max Mustermann" @onkeydown="HandleParticipantKeyAsync"
                                                                                                               @onfocusout="() => { Task.Delay(200).ContinueWith(_ => InvokeAsync(() => { showParticipantSuggestions = false; StateHasChanged(); })); }" />
                                                                                                        @if (showParticipantSuggestions && participantSuggestions.Any())
                                                                                                        {
                                                                                                            <div class="list-group position-absolute w-100 shadow-sm" style="z-index:1050; max-height:200px; overflow-y:auto; top:100%">
                                                                                                                @foreach (var s in participantSuggestions)
                                                                                                                {
                                                                                                                    <button type="button" class="list-group-item list-group-item-action small py-1"
                                                                                                                            @onmousedown="() => SelectParticipantSuggestion(s)" @onmousedown:preventDefault>
                                                                                                                        @s.DisplayName <span class="text-muted">(@s.AccountName)</span>
                                                                                                                        @if (s.IsAutodartsAccount) { <span class="autodarts-icon"></span> }
                                                                                                                    </button>
                                                                                                                }
                                                                                                            </div>
                                                                                                        }
                                                                                                    </div>
                                                                                                    <div class="col-md-2">
                                                                                                        <div class="form-check mb-0">
                                                                                                            <input class="form-check-input" type="checkbox" id="isAuto"
                                                                                                                   checked="@participantIsAutodarts"
                                                                                                                   @onchange="OnAutodartsCheckChanged" />
                                                                                                            <label class="form-check-label small" for="isAuto"><span class="autodarts-icon"></span> Autodarts</label>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                    <div class="col-md-3">
                                                                                                        <label class="form-label small mb-1">Account-Name</label>
                                                                                                        <input class="form-control" @bind="participantAccount" @bind:event="oninput"
                                                                                                               placeholder="@(participantIsAutodarts ? "= Anzeigename" : "Optional")"
                                                                                                               readonly="@participantIsAutodarts"
                                                                                                               @onkeydown="HandleParticipantKeyAsync" />
                                                                                                    </div>
                                                                                                    <div class="col-md-2">
                                                                                                        <div class="form-check mb-0">
                                                                                                            <input class="form-check-input" type="checkbox" id="isMgr" @bind="participantIsManager" />
                                                                                                            <label class="form-check-label small" for="isMgr">Spielleiter</label>
                                                                                                        </div>
                                                                                                    </div>
                                                                                                    <div class="col-md-2">
                                                                                                        <button class="btn btn-outline-primary btn-sm w-100" @onclick="AddParticipantAsync"
                                                                                                                disabled="@isWorking">Hinzufügen</button>
                                                                                                    </div>
                                                                                                </div>
                                                                                            }
                                                                                            @if (participantError is not null)
                                                                                            {
                                                                                                <div class="alert alert-danger py-2 small d-flex justify-content-between align-items-center mb-2">
                                                                                                    <span>@participantError</span>
                                                                                                    <button type="button" class="btn-close btn-sm" @onclick="() => participantError = null"></button>
                                                                                                </div>
                                                                                            }
                                                                                            @if (participants.Any())
                                                                                            {
                                                                                                <ul class="list-group">
                                                                                                    @{ var sortedParticipants = editSeedingEnabled
                                                                                                        ? participants.OrderBy(p => p.Seed > 0 ? p.Seed : int.MaxValue).ThenBy(p => p.DisplayName).ToList()
                                                                                                        : participants; }
                                                                                                    @foreach (var p in sortedParticipants)
                                                                                                    {
                                                                                                        var isSeedTarget = editSeedingEnabled && p.Seed > 0 && p.Seed <= editSeedTopCount;
                                                                                                        <li class="list-group-item d-flex justify-content-between align-items-center @(editSeedingEnabled && CanEditParticipantSettings ? "" : "")"
                                                                                                            draggable="@(editSeedingEnabled && CanEditParticipantSettings ? "true" : "false")"
                                                                                                            @ondragstart="() => draggedSeedIndex = p.Seed"
                                                                                                            @ondragover:preventDefault
                                                                                                            @ondrop="async () => { if (draggedSeedIndex.HasValue && draggedSeedIndex != p.Seed) { var dragP = participants.FirstOrDefault(x => x.Seed == draggedSeedIndex.Value); if (dragP is not null) { await UpdateParticipantSeedAsync(dragP.Id, p.Seed); await UpdateParticipantSeedAsync(p.Id, draggedSeedIndex.Value); } draggedSeedIndex = null; } }">
                                                                                                            <span class="d-flex align-items-center gap-2">
                                                                                                                @if (editSeedingEnabled)
                                                                                                                {
                                                                                                                    @if (isSeedTarget)
                                                                                                                    {
                                                                                                                        <span class="badge text-bg-warning" style="min-width:34px; cursor:grab" title="Setzlistenrang — per Drag & Drop ändern">#@p.Seed</span>
                                                                                                                    }
                                                                                                                    else
                                                                                                                    {
                                                                                                                        <span class="badge text-bg-light text-muted border" style="min-width:34px">@(p.Seed > 0 ? $"#{p.Seed}" : "—")</span>
                                                                                                                    }
                                                                                                                }
                                                                                                                @if (editGroupDrawMode == "SeededPots" && p.SeedPot > 0)
                                                                                                                {
                                                                                                                    <span class="badge @PotBadgeCss(p.SeedPot)" title="Lostopf">Topf @p.SeedPot</span>
                                                                                                                }
                                                                                                                <span role="button" style="cursor:pointer;text-decoration:underline dotted" @onclick="() => OpenPlayerDetail(p.Id)">
                                                                                                                    @p.DisplayName.ToUpperInvariant()
                                                                                                                </span>
                                                                                                                @if (p.IsManager)
                                                                                                                {
                                                                                                                    <span class="badge text-bg-warning ms-1">Spielleiter</span>
                                                                                                                }
                                                                                                                @if (!p.IsAutodartsAccount)
                                                                                                                {
                                                                                                                    <span class="badge text-bg-secondary ms-1">Lokal</span>
                                                                                                                }
                                                                                                                @if (p.GroupNumber.HasValue && p.GroupNumber > 0)
                                                                                                                {
                                                                                                                    <span class="badge text-bg-info ms-1">Gruppe @GroupLabel(p.GroupNumber.Value)</span>
                                                                                                                }
                                                                                                            </span>
                                                                                                            <div class="d-flex align-items-center gap-2">
                                                                                                                <small class="text-muted text-truncate" style="min-width:140px">@p.AccountName</small>
                                                                                                                <span class="text-center" style="width:20px">
                                                                                                                    @if (p.IsAutodartsAccount)
                                                                                                                    {
                                                                                                                        <span class="autodarts-icon" title="Autodarts"></span>
                                                                                                                    }
                                                                                                                </span>
                                                                                                                @if (!selectedTournament.IsLocked)
                                                                                                                {
                                                                                                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEditParticipant(p)"
                                                                                                                            disabled="@isWorking">✏️</button>
                                                                                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveParticipantAsync(p)"
                                                                                                                            disabled="@isWorking">✕</button>
                                                                                                                }
                                                                                                            </div>
                                                                                                        </li>
                                                                                                    }
                                                                                                </ul>
                                                                                            }
                                                                                            else
                                                                                            {
                                                                                                <p class="text-muted small">Noch keine Teilnehmer vorhanden.</p>
                                                                                            }
                                                                                        }

                                                                                        @* ═══════ Tab: Spielmodus ═══════ *@
                                                                                        @if (activeTab == "rounds")
                                                                                        {
                                                                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                                                                <h6 class="fw-semibold mb-0">Spielmodus je Runde</h6>
                                                                                                <button class="btn btn-sm @(editAreGameModesLocked ? "btn-outline-success" : "btn-outline-warning")"
                                                                                                    @onclick="ToggleGameModesLockAsync" disabled="@(isWorking || selectedTournament.IsLocked)">
                                                                                                    @(editAreGameModesLocked ? "🔓 Spielmodi entsperren" : "🔒 Spielmodi sperren")
                                                                                                </button>
                                                                                            </div>
                                                                                            @if (editAreGameModesLocked)
                                                                                            {
                                                                                                <div class="alert alert-info py-2 small">🔒 Spielmodi sind gesperrt. Entsperren Sie die Spielmodi, um Änderungen vorzunehmen.</div>
                                                                                            }
                                                                                            @if (HasMissingRoundConfig())
                                                                                            {
                                                                                                <div class="alert alert-danger py-2 small">⚠ <strong>@MissingRoundConfigCount()</strong> Runde(n) ohne Spielmodus-Konfiguration. Bitte legen Sie für jede Runde den Spielmodus fest.</div>
                                                                                            }
                                                                                            <p class="text-muted small mb-3">Klicken Sie auf eine Runde, um die Einstellungen zu bearbeiten.</p>
                                                                                                <div class="form-check mb-3">
                                                                                                    <input class="form-check-input" type="checkbox" id="showCompletedRounds" @bind="showCompletedRounds" />
                                                                                                    <label class="form-check-label small" for="showCompletedRounds">Abgeschlossene Runden anzeigen</label>
                                                                                                </div>
                                                                                                @if (roundSettings.Any())
                                                                                                {
                                                                                                    @foreach (var rnd in roundSettings.OrderBy(r => r.Phase).ThenBy(r => r.RoundNumber))
                                                                                                    {
                                                                                                        var started = IsRoundStarted(rnd.Phase, rnd.RoundNumber);
                                                                                                        var completed = IsRoundCompleted(rnd.Phase, rnd.RoundNumber);
                                                                                                        @if (!completed || showCompletedRounds)
                                                                                                        {
                                                                                                        <div class="card mb-2 @(completed ? "border-success" : started ? "border-warning" : "")" style="cursor:pointer" @onclick="() => OpenRoundDetail(rnd)">
                                                                                                            <div class="card-body py-2">
                                                                                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                                                                                    <span>
                                                                                                                        <strong class="small">@RoundDisplayLabel(rnd)</strong>
                                                                                                                        @if (completed) { <span class="badge text-bg-success ms-1">✓ Abgeschlossen</span> }
                                                                                                                        else if (started) { <span class="badge text-bg-warning ms-1">▶ Gestartet</span> }
                                                                                                                    </span>
                                                                                                                    <span class="badge text-bg-light">First to @rnd.Legs Legs | @rnd.BaseScore
                                                                                                                        @rnd.OutMode</span>
                                                                                                                    </div>
                                                                                                                    <div class="small text-muted">
                                                                                                                        Matchdauer: @rnd.MatchDurationMinutes min | Pause: @rnd.PauseBetweenMatchesMinutes min |
                                                                                                                        Spielerpause: @rnd.MinPlayerPauseMinutes min | Board: @rnd.BoardAssignment
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            </div>
                                                                                                        }
                                                                                                    }
                                                                                                }
                                                                                                    @if (!selectedTournament.IsLocked && !editAreGameModesLocked)
                                                                                                    {
                                                                                                        <div class="card border-primary mt-3">
                                                                                                            <div class="card-header bg-primary text-white py-2"><strong class="small">Runde hinzufügen /
                                                                                                                bearbeiten</strong></div>
                                                                                                                <div class="card-body">
                                                                                                                    <div class="row g-2 mb-2">
                                                                                                                        <div class="col-md-3">
                                                                                                                            <label class="form-label small">Phase</label>
                                                                                                                            <select class="form-select form-select-sm" @bind="newRoundPhase">
                                                                                                                                <option value="Knockout">Knockout</option>
                                                                                                                                <option value="Group">Gruppe</option>
                                                                                                                            </select>
                                                                                                                        </div>
                                                                                                                        <div class="col-md-2">
                                                                                                                            <label class="form-label small">Rundennr.</label>
                                                                                                                            <input type="number" class="form-control form-control-sm" @bind="newRoundNumber"
                                                                                                                                   min="1" />
                                                                                                                        </div>
                                                                                                                        <div class="col-md-2">
                                                                                                                            <label class="form-label small">Base Score</label>
                                                                                                                            <select class="form-select form-select-sm" @bind="newRoundBaseScore">
                                                                                                                                <option value="121">121</option>
                                                                                                                                <option value="170">170</option>
                                                                                                                                <option value="301">301</option>
                                                                                                                                <option value="501">501</option>
                                                                                                                                <option value="701">701</option>
                                                                                                                                <option value="901">901</option>
                                                                                                                            </select>
                                                                                                                        </div>
                                                                                                                        <div class="col-md-2">
                                                                                                                            <label class="form-label small">Spielmodus</label>
                                                                                                                            <select class="form-select form-select-sm" @bind="newRoundGameMode">
                                                                                                                                <option value="Legs">Legs</option>
                                                                                                                                <option value="Sets">Sets</option>
                                                                                                                            </select>
                                                                                                                        </div>
                                                                                                                        <div class="col-md-2">
                                                                                                                            <label class="form-label small">Legs (First to)</label>
                                                                                                                            @if (newRoundGameMode == "Sets")
                                                                                                                            {
                                                                                                                                <select class="form-select form-select-sm" @bind="newRoundLegs">
                                                                                                                                    <option value="2">2</option>
                                                                                                                                    <option value="3">3</option>
                                                                                                                                </select>
                                                                                                                            }
                                                                                                                            else
                                                                                                                            {
                                                                                                                                <input type="number" class="form-control form-control-sm" @bind="newRoundLegs"
                                                                                                                                       min="1" max="11" />
                                                                                                                            }
                                                                                                                        </div>
                                                                                                                        @if (newRoundGameMode == "Sets")
                                                                                                                        {
                                                                                                                            <div class="col-md-2">
                                                                                                                                <label class="form-label small">Sets (First to)</label>
                                                                                                                                <input type="number" class="form-control form-control-sm" @bind="newRoundSets"
                                                                                                                                       min="2" max="7" />
                                                                                                                            </div>
                                                                                                                        }
                                                                                                                        <div class="col-md-2">
                                                                                                                            <label class="form-label small">In-Modus</label>
                                                                                                                            <select class="form-select form-select-sm" @bind="newRoundInMode">
                                                                                                                                <option value="Straight">Straight In (SI)</option>
                                                                                                                                <option value="Double">Double In (DI)</option>
                                                                                                                                <option value="Master">Master In (MI)</option>
                                                                                                                            </select>
                                                                                                                        </div>
                                                                                                                        <div class="col-md-3">
                                                                                                                            <label class="form-label small">Out-Modus</label>
                                                                                                                            <select class="form-select form-select-sm" @bind="newRoundOutMode">
                                                                                                                                <option value="Straight">Straight Out (SO)</option>
                                                                                                                                <option value="Double">Double Out (DO)</option>
                                                                                                                                <option value="Master">Master Out (MO)</option>
                                                                                                                            </select>
                                                                                                                        </div>
                                                                                                                    </div>
                                                                                                                    <div class="row g-2 mb-2">
                                                                                                                        <div class="col-md-2">
                                                                                                                            <label class="form-label small">Max Runden</label>
                                                                                                                            <select class="form-select form-select-sm" @bind="newRoundMaxRounds">
                                                                                                                                <option value="15">15</option>
                                                                                                                                <option value="20">20</option>
                                                                                                                                <option value="50">50</option>
                                                                                                                                <option value="80">80</option>
                                                                                                                            </select>
                                                                                                                        </div>
                                                                                                                        <div class="col-md-2">
                                                                                                                            <label class="form-label small">Bull Mode</label>
                                                                                                                            <select class="form-select form-select-sm" @bind="newRoundBullMode">
                                                                                                                                <option value="25/50">25/50</option>
                                                                                                                                <option value="50/50">50/50</option>
                                                                                                                            </select>
                                                                                                                        </div>
                                                                                                                        <div class="col-md-2">
                                                                                                                            <label class="form-label small">Bull-off</label>
                                                                                                                            <select class="form-select form-select-sm" @bind="newRoundBullOffMode">
                                                                                                                                <option value="Off">Off</option>
                                                                                                                                <option value="Normal">Normal</option>
                                                                                                                                <option value="Official">Official</option>
                                                                                                                            </select>
                                                                                                                        </div>
                                                                                                                        <div class="col-md-3">
                                                                                                                            <label class="form-label small">Matchdauer (min)</label>
                                                                                                                            <input type="number" class="form-control form-control-sm" @bind="newRoundDuration"
                                                                                                                                   min="0" />
                                                                                                                        </div>
                                                                                                                        <div class="col-md-3">
                                                                                                                            <label class="form-label small">Pause (min)</label>
                                                                                                                            <input type="number" class="form-control form-control-sm" @bind="newRoundPause"
                                                                                                                                   min="0" />
                                                                                                                        </div>
                                                                                                                        <div class="col-md-3">
                                                                                                                            <label class="form-label small">Min. Spielerpause (min)</label>
                                                                                                                            <input type="number" class="form-control form-control-sm" @bind="newRoundPlayerPause"
                                                                                                                                   min="0" />
                                                                                                                        </div>
                                                                                                                        <div class="col-md-3">
                                                                                                                            <label class="form-label small">Boardauswahl</label>
                                                                                                                            <select class="form-select form-select-sm" @bind="newRoundBoardAssignment">
                                                                                                                                <option value="Dynamic">Dynamisch</option>
                                                                                                                                @foreach (var b in boards)
                                                                                                                                {
                                                                                                                                    <option value="Fixed:@b.Id">@b.Name (fix)</option>
                                                                                                                                }
                                                                                                                            </select>
                                                                                                                        </div>
                                                                                                                    </div>
                                                                                                                    <div class="d-flex gap-2 flex-wrap">
                                                                                                                        <button class="btn btn-primary btn-sm" @onclick="SaveRoundAsync" disabled="@isWorking">Runde
                                                                                                                            speichern</button>
                                                                                                                            <button class="btn btn-outline-secondary btn-sm" @onclick="ApplyRoundToAllAsync"
                                                                                                                                    disabled="@isWorking">Für alle Runden festlegen</button>
                                                                                                                            <button class="btn btn-outline-secondary btn-sm" @onclick="ApplyRoundToSubsequentAsync"
                                                                                                                                    disabled="@isWorking">Für alle nachfolgenden Runden festlegen</button>
                                                                                                                        </div>
                                                                                                                        @if (roundError is not null)
                                                                                                                        {
                                                                                                                            <div class="alert alert-danger py-1 mt-2 small">@roundError</div>
                                                                                                                        }
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            }
                                                                                                        }

                                                                                                        @* ═══════ Tab: Auslosung ═══════ *@
                                                                                                        @if (activeTab == "draw")
                                                                                                        {
                                                                                                            @* ─── Group/Draw Settings (moved from Gruppenphase) ─── *@
                                                                                                            @if (ShowGroupSettingsSection())
                                                                                                            {
                                                                                                                <details class="card mb-3" open>
                                                                                                                    <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
                                                                                                                        <span>
                                                                                                                            Gruppenphase-Einstellungen
                                                                                                                            @if (HasGroupSettingsRequiredMissing())
                                                                                                                            {
                                                                                                                                <span class="text-danger ms-2" title="Pflichteinstellungen fehlen">⚠</span>
                                                                                                                            }
                                                                                                                        </span>
                                                                                                                        <span class="d-none d-md-inline small text-muted">@GroupSettingsSummary()</span>
                                                                                                                    </summary>
                                                                                                                    <div class="card-body">
                                                                                                                        @if (CanEditGroupConfig)
                                                                                                                        {
                                                                                                                            <div class="row g-2 mb-3">
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Anzahl Gruppen für die Gruppenphase.">Anzahl Gruppen</label>
                                                                                                                                    <select class="form-select form-select-sm @(editGroupCount < 1 ? "border-danger" : "")" @bind="editGroupCount" @bind:after="AutoSaveSettingAsync">
                                                                                                                                        @for (var i = 1; i <= 16; i++)
                                                                                                                                        {
                                                                                                                                            <option value="@i">@i</option>
                                                                                                                                        }
                                                                                                                                    </select>
                                                                                                                                </div>
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Anzahl qualifizierter Spieler je Gruppe für die K.O.-Phase.">Playoff-Aufsteiger</label>
                                                                                                                                    <input type="number" class="form-control form-control-sm @(editPlayoffAdvancers < 1 ? "border-danger" : "")" @bind="editPlayoffAdvancers" @bind:after="AutoSaveSettingAsync" min="1" />
                                                                                                                                </div>
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Wie oft jeder Teilnehmer gegen denselben Gegner spielt.">Matches/Gegner</label>
                                                                                                                                    <select class="form-select form-select-sm @(editMatchesPerOpponent < 1 ? "border-danger" : "")" @bind="editMatchesPerOpponent" @bind:after="AutoSaveSettingAsync">
                                                                                                                                        @for (var i = 1; i <= 12; i++)
                                                                                                                                        {
                                                                                                                                            <option value="@i">@i Runde@(i > 1 ? "n" : "")</option>
                                                                                                                                        }
                                                                                                                                    </select>
                                                                                                                                </div>
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Anzahl parallel gespielter K.O.-Matches je Runde nach der Gruppenphase.">Knockouts/Runde</label>
                                                                                                                                    <input type="number" class="form-control form-control-sm @(editKnockoutsPerRound < 0 ? "border-danger" : "")" @bind="editKnockoutsPerRound" @bind:after="AutoSaveSettingAsync" min="0" />
                                                                                                                                </div>
                                                                                                                            </div>
                                                                                                                            <div class="row g-2 mb-0">
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Jeder gegen jeden oder alternative Gruppenlogik.">Gruppenmodus</label>
                                                                                                                                    <select class="form-select form-select-sm" @bind="editGroupMode" @bind:after="AutoSaveSettingAsync">
                                                                                                                                        <option value="RoundRobin">Jeder gegen Jeden</option>
                                                                                                                                        <option value="Knockout">Knockout</option>
                                                                                                                                        <option value="GroupTournament">Gruppenturnier</option>
                                                                                                                                    </select>
                                                                                                                                </div>
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Zufällig, manuell oder per Lostopf (SeededPots) auslosen.">Auslosungsmodus</label>
                                                                                                                                    <select class="form-select form-select-sm" @bind="editGroupDrawMode" @bind:after="AutoSaveSettingAsync">
                                                                                                                                        <option value="Manual">Manuell</option>
                                                                                                                                        <option value="Random">Zufällig</option>
                                                                                                                                        @if (editSeedingEnabled)
                                                                                                                                        {
                                                                                                                                            <option value="SeededPots">Lostopf</option>
                                                                                                                                        }
                                                                                                                                    </select>
                                                                                                                                </div>
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Erzeugt Gruppenrunden blockweise oder rundenweise über alle Gruppen.">Planungsvariante</label>
                                                                                                                                    <select class="form-select form-select-sm" @bind="editPlanningVariant" @bind:after="AutoSaveSettingAsync">
                                                                                                                                        <option value="GroupByGroup">Gruppe für Gruppe</option>
                                                                                                                                        <option value="RoundByRound">Runde für Runde</option>
                                                                                                                                    </select>
                                                                                                                                </div>
                                                                                                                                <div class="col-md-3">
                                                                                                                                    <label class="form-label small" title="Reihenfolge der Matches pro Runde innerhalb einer Gruppe.">Reihenfolge</label>
                                                                                                                                    <select class="form-select form-select-sm" @bind="editGroupOrderMode" @bind:after="AutoSaveSettingAsync">
                                                                                                                                        <option value="ReverseEachRound">Folgerunde absteigend</option>
                                                                                                                                        <option value="SameOrder">Immer gleich</option>
                                                                                                                                        <option value="RandomPerRound">Runde zufällig</option>
                                                                                                                                        <option value="AllRandom">Alle zufällig</option>
                                                                                                                                    </select>
                                                                                                                                </div>
                                                                                                                            </div>
                                                                                                                        }
                                                                                                                        else
                                                                                                                        {
                                                                                                                            <div class="small text-muted d-flex flex-wrap gap-2">
                                                                                                                                <span class="badge text-bg-light border">Gruppen: @editGroupCount</span>
                                                                                                                                <span class="badge text-bg-light border">Aufsteiger: @editPlayoffAdvancers</span>
                                                                                                                                <span class="badge text-bg-light border">Matches/Gegner: @editMatchesPerOpponent</span>
                                                                                                                                <span class="badge text-bg-light border">Modus: @editGroupMode</span>
                                                                                                                                <span class="badge text-bg-light border">Auslosung: @editGroupDrawMode</span>
                                                                                                                            </div>
                                                                                                                        }
                                                                                                                    </div>
                                                                                                                </details>

                                                                                                                <details class="card mb-3">
                                                                                                                    <summary class="card-header d-flex justify-content-between align-items-center" style="cursor:pointer">
                                                                                                                        <span>
                                                                                                                            Punktemodus
                                                                                                                            @if (HasScoringRequiredMissing())
                                                                                                                            {
                                                                                                                                <span class="text-danger ms-2" title="Pflichteinstellungen fehlen">⚠</span>
                                                                                                                            }
                                                                                                                        </span>
                                                                                                                        <span class="d-none d-md-inline small text-muted">@ScoringSummary()</span>
                                                                                                                    </summary>
                                                                                                                    <div class="card-body">
                                                                                                                        @if (CanEditScoring)
                                                                                                                        {
                                                                                                                            <div class="row g-2 mb-0">
                                                                                                                                <div class="col-md-6">
                                                                                                                                    <label class="form-label small" title="Punkte je Sieg in der Gruppentabelle.">Punkte für Sieg</label>
                                                                                                                                    <input type="number" class="form-control form-control-sm @(editWinPoints < 1 ? "border-danger" : "")" @bind="editWinPoints" @bind:after="AutoSaveSettingAsync" min="1" />
                                                                                                                                </div>
                                                                                                                                <div class="col-md-6">
                                                                                                                                    <label class="form-label small" title="Gewichtung gewonnener Legs für Ranking/Tiebreak.">Faktor gewonnene Legs</label>
                                                                                                                                    <input type="number" class="form-control form-control-sm @(editLegFactor < 0 ? "border-danger" : "")" @bind="editLegFactor" @bind:after="AutoSaveSettingAsync" min="0" />
                                                                                                                                </div>
                                                                                                                            </div>
                                                                                                                        }
                                                                                                                        else
                                                                                                                        {
                                                                                                                            <div class="small text-muted d-flex flex-wrap gap-2">
                                                                                                                                <span class="badge text-bg-light border">Siegpunkte: @editWinPoints</span>
                                                                                                                                <span class="badge text-bg-light border">Leg-Faktor: @editLegFactor</span>
                                                                                                                            </div>
                                                                                                                        }
                                                                                                                    </div>
                                                                                                                </details>
                                                                                                            }

                                                                                                            @* ─── Draw Area: GroupAndKnockout mode ─── *@
                                                                                                            @if (selectedTournament.Mode == "GroupAndKnockout" && IsCurrentUserManager && !selectedTournament.IsLocked
                                                                                                                 && selectedTournament.Status is "Erstellt" or "Geplant")
                                                                                                            {
                                                                                                                <div class="d-flex flex-wrap gap-2 mb-3">
                                                                                                                    <div class="d-flex align-items-center gap-2 me-2">
                                                                                                                        <label class="small text-muted mb-0">Animation</label>
                                                                                                                        <select class="form-select form-select-sm" style="width: 140px;" @bind="drawAnimationMode" disabled="@(isWorking || isDrawAnimating)">
                                                                                                                            <option value="Off">Aus</option>
                                                                                                                            <option value="Exciting">Spannend</option>
                                                                                                                            <option value="Moderate">Moderat</option>
                                                                                                                        </select>
                                                                                                                    </div>
                                                                                                                    @if (editGroupDrawMode == "SeededPots" && editSeedingEnabled)
                                                                                                                    {
                                                                                                                        <button class="btn btn-outline-primary btn-sm" @onclick="AssignSeedPotsAndDistributeAsync" disabled="@(isWorking || isDrawAnimating)">🎯 Lostöpfe zuteilen</button>
                                                                                                                    }
                                                                                                                    @if (editGroupDrawMode is "Random" or "SeededPots")
                                                                                                                    {
                                                                                                                        <button class="btn btn-primary btn-sm" @onclick="AutoDrawAsync" disabled="@(isWorking || isDrawAnimating)">⚡ Auslosung starten</button>
                                                                                                                    }
                                                                                                                    @if (HasDrawAssignments())
                                                                                                                    {
                                                                                                                        <button class="btn btn-outline-warning btn-sm" @onclick="ResetDrawAsync" disabled="@(isWorking || isDrawAnimating)">↩ Auslosung zurücksetzen</button>
                                                                                                                    }
                                                                                                                </div>
                                                                                                                @if (isDrawAnimating)
                                                                                                                {
                                                                                                                    <div class="alert alert-secondary py-1 small">Auslosung läuft…</div>
                                                                                                                }
                                                                                                                @if (editGroupDrawMode == "SeededPots" && editSeedingEnabled && participants.Any(p => p.SeedPot > 0))
                                                                                                                {
                                                                                                                    <div class="small text-muted mb-2">
                                                                                                                        @foreach (var pot in participants.Where(p => p.SeedPot > 0).GroupBy(p => p.SeedPot).OrderBy(g => g.Key))
                                                                                                                        {
                                                                                                                            <span class="badge @PotBadgeCss(pot.Key) me-1">Topf @pot.Key: @pot.Count()</span>
                                                                                                                        }
                                                                                                                    </div>
                                                                                                                }

                                                                                                                <div class="row g-3">
                                                                                                                    @* ─── Left: Unassigned Participants ─── *@
                                                                                                                    @{ var unassigned = UnassignedParticipants; }
                                                                                                                    @if (unassigned.Any())
                                                                                                                    {
                                                                                                                        <div class="col-md-4">
                                                                                                                            @if (editGroupDrawMode == "SeededPots" && editSeedingEnabled)
                                                                                                                            {
                                                                                                                                var unassignedByPot = unassigned.Where(p => p.SeedPot > 0).GroupBy(p => p.SeedPot).OrderBy(g => g.Key).ToList();
                                                                                                                                <div class="d-flex flex-column gap-2" style="max-height:500px; overflow-y:auto">
                                                                                                                                    @if (unassignedByPot.Any())
                                                                                                                                    {
                                                                                                                                        @foreach (var pot in unassignedByPot)
                                                                                                                                        {
                                                                                                                                            <div class="card border-2 @DrawPotAnimationCss(pot.Key)">
                                                                                                                                                <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                                                                                                                                    <strong class="small">Topf @pot.Key</strong>
                                                                                                                                                    <span class="badge @PotBadgeCss(pot.Key)">@pot.Count()</span>
                                                                                                                                                </div>
                                                                                                                                                <div class="card-body p-2">
                                                                                                                                                    @foreach (var p in pot.OrderBy(p => p.Seed > 0 ? p.Seed : int.MaxValue).ThenBy(p => p.DisplayName))
                                                                                                                                                    {
                                                                                                                                                        <div class="badge bg-dark p-2 me-1 mb-1 user-select-none @DrawParticipantAnimationCss(p.Id)" draggable="true"
                                                                                                                                                             @ondragstart="() => draggedParticipantId = p.Id" style="cursor:grab; font-size:.85em">
                                                                                                                                                            @if (editSeedingEnabled && p.Seed > 0 && p.Seed <= editSeedTopCount)
                                                                                                                                                            {
                                                                                                                                                                <span class="badge text-bg-warning me-1">#@p.Seed</span>
                                                                                                                                                            }
                                                                                                                                                            <span class="badge @PotBadgeCss(p.SeedPot) me-1">Topf @p.SeedPot</span>
                                                                                                                                                            @p.DisplayName.ToUpperInvariant()
                                                                                                                                                        </div>
                                                                                                                                                    }
                                                                                                                                                </div>
                                                                                                                                            </div>
                                                                                                                                        }
                                                                                                                                    }
                                                                                                                                    else
                                                                                                                                    {
                                                                                                                                        <div class="alert alert-info py-2 small mb-0">Keine Lostöpfe vorhanden. Bitte zuerst "Lostöpfe zuteilen" ausführen.</div>
                                                                                                                                    }
                                                                                                                                </div>
                                                                                                                            }
                                                                                                                            else
                                                                                                                            {
                                                                                                                                <div class="card">
                                                                                                                                    <div class="card-header py-2">
                                                                                                                                        <strong class="small">Teilnehmer</strong>
                                                                                                                                        <span class="badge text-bg-secondary ms-1">@unassigned.Count</span>
                                                                                                                                    </div>
                                                                                                                                    <div class="card-body p-2" style="max-height:500px; overflow-y:auto">
                                                                                                                                        @foreach (var p in unassigned.OrderBy(p => p.Seed > 0 ? p.Seed : int.MaxValue).ThenBy(p => p.DisplayName))
                                                                                                                                        {
                                                                                                                                            <div class="badge bg-dark p-2 me-1 mb-1 user-select-none @DrawParticipantAnimationCss(p.Id)" draggable="true"
                                                                                                                                                 @ondragstart="() => draggedParticipantId = p.Id" style="cursor:grab; font-size:.85em">
                                                                                                                                                @if (editSeedingEnabled && p.Seed > 0 && p.Seed <= editSeedTopCount)
                                                                                                                                                {
                                                                                                                                                    <span class="badge text-bg-warning me-1">#@p.Seed</span>
                                                                                                                                                }
                                                                                                                                                @p.DisplayName.ToUpperInvariant()
                                                                                                                                            </div>
                                                                                                                                        }
                                                                                                                                    </div>
                                                                                                                                </div>
                                                                                                                            }
                                                                                                                        </div>
                                                                                                                    }

                                                                                                                    @* ─── Right: Group Containers ─── *@
                                                                                                                    <div class="@(unassigned.Any() ? "col-md-8" : "col-12")">
                                                                                                                        <div class="row g-2">
                                                                                                                            @for (var g = 1; g <= editGroupCount; g++)
                                                                                                                            {
                                                                                                                                var groupNum = g;
                                                                                                                                var groupParts = GroupParticipants(groupNum);
                                                                                                                                var isDropTarget = dropTargetGroupNumber == groupNum;
                                                                                                                                var highlightCss = GroupDropHighlightCss(groupNum);
                                                                                                                                <div class="col-md-6 col-lg-4">
                                                                                                                                      <div class="card @(isDropTarget ? highlightCss : "") @DrawGroupAnimationCss(groupNum)"
                                                                                                                                         @ondragover:preventDefault
                                                                                                                                         @ondragover="() => dropTargetGroupNumber = groupNum"
                                                                                                                                         @ondragleave="() => { if (dropTargetGroupNumber == groupNum) dropTargetGroupNumber = null; }"
                                                                                                                                         @ondrop="() => AssignParticipantToGroupAsync(groupNum)">
                                                                                                                                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                                                                                                                            <strong class="small">Gruppe @GroupLabel(groupNum)</strong>
                                                                                                                                            <span class="badge text-bg-secondary">@groupParts.Count / @IdealGroupSize</span>
                                                                                                                                        </div>
                                                                                                                                        <div class="card-body p-2" style="min-height:60px">
                                                                                                                                            @foreach (var p in groupParts)
                                                                                                                                            {
                                                                                                                                                <div class="badge bg-dark p-2 me-1 mb-1 user-select-none @DrawParticipantAnimationCss(p.Id)" draggable="true"
                                                                                                                                                     @ondragstart="() => draggedParticipantId = p.Id" style="cursor:grab; font-size:.85em">
                                                                                                                                                    @if (editSeedingEnabled && p.Seed > 0 && p.Seed <= editSeedTopCount)
                                                                                                                                                    {
                                                                                                                                                          <span class="badge text-bg-warning me-1">#@p.Seed</span>
                                                                                                                                                    }
                                                                                                                                                        @if (editGroupDrawMode == "SeededPots" && p.SeedPot > 0)
                                                                                                                                                        {
                                                                                                                                                          <span class="badge @PotBadgeCss(p.SeedPot) me-1">Topf @p.SeedPot</span>
                                                                                                                                                        }
                                                                                                                                                    @p.DisplayName.ToUpperInvariant()
                                                                                                                                                    <button class="btn btn-sm p-0 ms-1 text-white-50" style="font-size:.7em; line-height:1"
                                                                                                                                                            @onclick="() => UnassignParticipantFromGroupAsync(p.Id)" @onclick:stopPropagation
                                                                                                                                                            title="Aus Gruppe entfernen">✕</button>
                                                                                                                                                </div>
                                                                                                                                            }
                                                                                                                                            @if (!groupParts.Any())
                                                                                                                                            {
                                                                                                                                                <div class="text-muted small text-center py-2">Teilnehmer hierher ziehen</div>
                                                                                                                                            }
                                                                                                                                        </div>
                                                                                                                                    </div>
                                                                                                                                </div>
                                                                                                                            }
                                                                                                                        </div>
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            }

                                                                                                            @* ─── Draw Area: Knockout mode ─── *@
                                                                                                            @if (selectedTournament.Mode == "Knockout" && IsCurrentUserManager && !selectedTournament.IsLocked
                                                                                                                 && selectedTournament.Status is "Erstellt" or "Geplant")
                                                                                                            {
                                                                                                                <div class="d-flex flex-wrap gap-2 mb-3">
                                                                                                                    <div class="d-flex align-items-center gap-2 me-2">
                                                                                                                        <label class="small text-muted mb-0">Animation</label>
                                                                                                                        <select class="form-select form-select-sm" style="width: 140px;" @bind="drawAnimationMode" disabled="@(isWorking || isDrawAnimating)">
                                                                                                                            <option value="Off">Aus</option>
                                                                                                                            <option value="Exciting">Spannend</option>
                                                                                                                            <option value="Moderate">Moderat</option>
                                                                                                                        </select>
                                                                                                                    </div>
                                                                                                                    @if (editGroupDrawMode is "Random" or "SeededPots")
                                                                                                                    {
                                                                                                                        <button class="btn btn-primary btn-sm" @onclick="AutoDrawAsync" disabled="@(isWorking || isDrawAnimating)">⚡ Auslosung starten</button>
                                                                                                                    }
                                                                                                                    @if (KnockoutAssignedParticipants.Any())
                                                                                                                    {
                                                                                                                        <button class="btn btn-outline-warning btn-sm" @onclick="ResetKnockoutDrawCards" disabled="@(isWorking || isDrawAnimating)">↩ Auslosung zurücksetzen</button>
                                                                                                                    }
                                                                                                                </div>
                                                                                                                @if (isDrawAnimating)
                                                                                                                {
                                                                                                                    <div class="alert alert-secondary py-1 small">Auslosung läuft…</div>
                                                                                                                }

                                                                                                                <div class="row g-3">
                                                                                                                    <div class="col-md-4">
                                                                                                                        <div class="card">
                                                                                                                            <div class="card-header py-2">
                                                                                                                                <strong class="small">Teilnehmer</strong>
                                                                                                                                <span class="badge text-bg-secondary ms-1">@KnockoutUnassignedParticipants.Count</span>
                                                                                                                            </div>
                                                                                                                            <div class="card-body p-2" style="max-height:500px; overflow-y:auto">
                                                                                                                                @foreach (var p in KnockoutUnassignedParticipants)
                                                                                                                                {
                                                                                                                                    <div class="badge bg-dark p-2 me-1 mb-1 user-select-none @DrawParticipantAnimationCss(p.Id)" draggable="true"
                                                                                                                                         @ondragstart="() => StartKnockoutDrag(p.Id)" style="cursor:grab; font-size:.85em">
                                                                                                                                        @if (editSeedingEnabled && p.Seed > 0 && p.Seed <= editSeedTopCount)
                                                                                                                                        {
                                                                                                                                            <span class="badge text-bg-warning me-1">#@p.Seed</span>
                                                                                                                                        }
                                                                                                                                        @p.DisplayName.ToUpperInvariant()
                                                                                                                                    </div>
                                                                                                                                }
                                                                                                                            </div>
                                                                                                                        </div>
                                                                                                                    </div>

                                                                                                                    <div class="col-md-8">
                                                                                                                        <div id="ko-draw-grid" class="position-relative">
                                                                                                                            <div class="row g-2">
                                                                                                                            @foreach (var card in knockoutDrawCards.OrderBy(c => c.MatchNumber))
                                                                                                                            {
                                                                                                                                var home = FindParticipant(card.HomeParticipantId);
                                                                                                                                var away = FindParticipant(card.AwayParticipantId);
                                                                                                                                <div class="col-md-6">
                                                                                                                                    <div class="card">
                                                                                                                                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                                                                                                                            <strong class="small">Match @card.MatchNumber</strong>
                                                                                                                                        </div>
                                                                                                                                        <div class="card-body p-2">
                                                                                                                                            <div id="ko-slot-@card.MatchNumber-home" class="ko-draw-slot mb-2 @DrawKnockoutSlotCss(card.MatchNumber, true)"
                                                                                                                                                 @ondragover:preventDefault
                                                                                                                                                 @ondrop="() => AssignDraggedToKnockoutCard(card.MatchNumber, true)">
                                                                                                                                                @if (home is not null)
                                                                                                                                                {
                                                                                                                                                    <span class="badge bg-dark @DrawParticipantAnimationCss(home.Id)">
                                                                                                                                                        @ParticipantDisplayName(home)
                                                                                                                                                        <button class="btn btn-sm p-0 ms-1 text-white-50" @onclick="() => ClearKnockoutCardSlot(card.MatchNumber, true)" @onclick:stopPropagation>✕</button>
                                                                                                                                                    </span>
                                                                                                                                                }
                                                                                                                                                else
                                                                                                                                                {
                                                                                                                                                    <span class="text-muted small">Spieler 1 hier ablegen</span>
                                                                                                                                                }
                                                                                                                                            </div>

                                                                                                                                            <div id="ko-slot-@card.MatchNumber-away" class="ko-draw-slot @DrawKnockoutSlotCss(card.MatchNumber, false)"
                                                                                                                                                 @ondragover:preventDefault
                                                                                                                                                 @ondrop="() => AssignDraggedToKnockoutCard(card.MatchNumber, false)">
                                                                                                                                                @if (away is not null)
                                                                                                                                                {
                                                                                                                                                    <span class="badge bg-dark @DrawParticipantAnimationCss(away.Id)">
                                                                                                                                                        @ParticipantDisplayName(away)
                                                                                                                                                        <button class="btn btn-sm p-0 ms-1 text-white-50" @onclick="() => ClearKnockoutCardSlot(card.MatchNumber, false)" @onclick:stopPropagation>✕</button>
                                                                                                                                                    </span>
                                                                                                                                                }
                                                                                                                                                else
                                                                                                                                                {
                                                                                                                                                    <span class="text-muted small">Spieler 2 hier ablegen</span>
                                                                                                                                                }
                                                                                                                                            </div>
                                                                                                                                        </div>
                                                                                                                                    </div>
                                                                                                                                </div>
                                                                                                                            }
                                                                                                                            </div>
                                                                                                                            <div class="ko-draw-token @(showKoDrawToken ? "show" : "")" style="@koDrawTokenStyle">🎯</div>
                                                                                                                        </div>
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                            }

                                                                                                            @* ─── Plan Create/Delete Buttons ─── *@
                                                                                                            <div class="mt-3">
                                                                                                                @if (!matches.Any() && participants.Count >= 2 && !selectedTournament.IsLocked && IsCurrentUserManager)
                                                                                                                {
                                                                                                                    @if (selectedTournament.Mode == "GroupAndKnockout")
                                                                                                                    {
                                                                                                                        @if (UnassignedParticipants.Count == 0)
                                                                                                                        {
                                                                                                                            <button class="btn btn-success" @onclick="CreateTournamentPlanAsync" disabled="@isWorking">✓ Turnierplan erstellen</button>
                                                                                                                        }
                                                                                                                        else
                                                                                                                        {
                                                                                                                            <div class="alert alert-info py-2 small">Alle Teilnehmer müssen einer Gruppe zugewiesen sein, bevor der Turnierplan erstellt werden kann. Noch @UnassignedParticipants.Count nicht zugewiesen.</div>
                                                                                                                        }
                                                                                                                    }
                                                                                                                    else
                                                                                                                    {
                                                                                                                        @if (selectedTournament.Mode == "Knockout" && editGroupDrawMode == "Manual")
                                                                                                                        {
                                                                                                                            @if (IsKnockoutDrawComplete)
                                                                                                                            {
                                                                                                                                <button class="btn btn-primary" @onclick="CreateTournamentPlanAsync" disabled="@isWorking">⚡ K.O.-Plan generieren</button>
                                                                                                                            }
                                                                                                                            else
                                                                                                                            {
                                                                                                                                <div class="alert alert-info py-2 small">Bei manueller K.O.-Auslosung müssen alle Teilnehmer einem Match-Slot zugewiesen werden.</div>
                                                                                                                            }
                                                                                                                        }
                                                                                                                        else
                                                                                                                        {
                                                                                                                            <button class="btn btn-primary" @onclick="CreateTournamentPlanAsync" disabled="@isWorking">⚡ K.O.-Plan generieren</button>
                                                                                                                        }
                                                                                                                    }
                                                                                                                }
                                                                                                                else if (matches.Any() && !selectedTournament.IsLocked && IsCurrentUserManager)
                                                                                                                {
                                                                                                                    <div class="d-flex align-items-center gap-3">
                                                                                                                        <button class="btn btn-outline-danger btn-sm" @onclick="DeleteTournamentPlanAsync" disabled="@isWorking">🗑 Turnierplan löschen</button>
                                                                                                                        <button class="btn btn-warning btn-sm" @onclick="RegenerateMatchesAsync" disabled="@isWorking">🔄 Turnierplan neu generieren</button>
                                                                                                                    </div>
                                                                                                                    @if (HasPlayedMatches())
                                                                                                                    {
                                                                                                                        <div class="alert alert-warning py-2 mt-2">⚠ Es wurden bereits Matches gespielt. Beim Neugenerieren werden alle Ergebnisse gelöscht.</div>
                                                                                                                    }
                                                                                                                }

                                                                                                                @* ─── KO Mode: Show round 1 pairings ─── *@
                                                                                                                @if (selectedTournament.Mode == "Knockout" && matches.Any())
                                                                                                                {
                                                                                                                    <h6 class="fw-semibold mt-3">Paarungen (Runde 1)</h6>
                                                                                                                    <ul class="list-group">
                                                                                                                        @foreach (var match in matches.Where(m => m.Round == 1 && m.Phase == "Knockout").OrderBy(m => m.MatchNumber))
                                                                                                                        {
                                                                                                                            var isBye = match.Status == "WalkOver";
                                                                                                                            <li class="list-group-item @(isBye ? "list-group-item-light" : "")" style="cursor:pointer"
                                                                                                                                @onclick="() => OpenMatchDetail(match)">
                                                                                                                                <span class="text-muted small me-1">@MatchLabel(match)</span>
                                                                                                                                @if (match.HomeParticipantId == Guid.Empty)
                                                                                                                                {
                                                                                                                                    <em class="text-muted">Freilos</em>
                                                                                                                                }
                                                                                                                                else
                                                                                                                                {
                                                                                                                                    <strong>@ParticipantName(match.HomeParticipantId)</strong>
                                                                                                                                }
                                                                                                                                <span class="text-muted mx-1">vs</span>
                                                                                                                                @if (match.AwayParticipantId == Guid.Empty)
                                                                                                                                {
                                                                                                                                    <em class="text-muted">Freilos</em>
                                                                                                                                }
                                                                                                                                else
                                                                                                                                {
                                                                                                                                    <strong>@ParticipantName(match.AwayParticipantId)</strong>
                                                                                                                                }
                                                                                                                            </li>
                                                                                                                        }
                                                                                                                    </ul>
                                                                                                                }
                                                                                                                else if (!matches.Any() && participants.Count < 2)
                                                                                                                {
                                                                                                                    <p class="text-muted">Mindestens 2 Teilnehmer erforderlich.</p>
                                                                                                                }
                                                                                                            </div>
                                                                                                        }

                                                                                                        @* ═══════ Tab: Gruppenphase ═══════ *@
                                                                                                        @if (activeTab == "groups")
                                                                                                        {
                                                                                                            var groupMatches = matches.Where(m => m.Phase == "Group").ToList();
                                                                                                                            @if (groupMatches.Any())
                                                                                                                            {
                                                                                                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                                                                                                    <h6 class="fw-semibold mb-0">Gruppenphase</h6>
                                                                                                                                    <button class="btn btn-sm @(showFlashTable ? "btn-warning" : "btn-outline-warning")"
                                                                                                                                        @onclick="() => showFlashTable = !showFlashTable">
                                                                                                                                        ⚡ @(showFlashTable ? "Blitztabelle ausblenden" : "Blitztabelle anzeigen")
                                                                                                                                    </button>
                                                                                                                                </div>
                                                                                                                                var groups = groupMatches.Select(m => m.GroupNumber ?? 0).Distinct().OrderBy(g => g).ToList();
                                                                                                                                @foreach (var groupNum in groups)
                                                                                                                                {
                                                                                                                                    var groupComplete = IsGroupCompleted(groupNum);
                                                                                                                                    <h6 class="fw-semibold mt-3">Gruppe @GroupLabel(groupNum)
                                                                                                                                        @if (groupComplete) { <span class="badge text-bg-success ms-1">✓</span> }
                                                                                                                                    </h6>
                                                                                                                                    @if (groupStandings.Any(s => s.GroupNumber == groupNum))
                                                                                                                                    {
                                                                                                                                        var standingsData = showFlashTable ? GetFlashStandings(groupNum) : groupStandings.Where(x => x.GroupNumber == groupNum).OrderByDescending(x => x.Points).ThenByDescending(x => x.LegDifference).ToList();
                                                                                                                                        @if (showFlashTable)
                                                                                                                                        {
                                                                                                                                            <div class="alert alert-warning py-1 small mb-1">⚡ Blitztabelle — enthält vorläufige Wertungen laufender Matches</div>
                                                                                                                                        }
                                                                                                                                        <GroupTable Standings="@standingsData" QualificationSlots="@selectedTournament.PlayoffAdvancers"
                                                                                                                                                    ShowExtendedStats="true" ShowTiebreaker="true" />
                                                                                                                                    }
                                                                                                                                    @* Collapsed match list — toggle *@
                                                                                                                                    <button class="btn btn-sm btn-outline-secondary mb-2"
                                                                                                                                            @onclick="() => showGroupMatches = !showGroupMatches">
                                                                                                                                        @(showGroupMatches ? "▼ Matches ausblenden" : "▶ Matches anzeigen")
                                                                                                                                    </button>
                                                                                                                                    @if (showGroupMatches)
                                                                                                                                    {
                                                                                                                                        <ul class="list-group mb-2">
                                                                                                                                            @foreach (var match in groupMatches.Where(m => m.GroupNumber == groupNum).OrderBy(m =>
                                                                                                                                                                m.Round).ThenBy(m => m.MatchNumber))
                                                                                                                                            {
                                                                                                                                                <li class="list-group-item" style="cursor:pointer" @onclick="() => OpenMatchDetail(match)">
                                                                                                                                                    <span class="text-muted small me-1">@MatchLabel(match)</span>
                                                                                                                                                    <strong
                                                                                                                                                    class="@(match.WinnerParticipantId == match.HomeParticipantId ? "text-success" : "")">@ParticipantName(match.HomeParticipantId)</strong>
                                                                                                                                                    @if (match.FinishedUtc is not null)
                                                                                                                                                    {
                                                                                                                                                        <span class="text-muted mx-1">@FormatScore(match)</span>
                                                                                                                                                        } else
                                                                                                                                                        {

                                                                                                                                                            <span class="text-muted mx-1">vs</span>
                                                                                                                                                        }
                                                                                                                                                        <strong
                                                                                                                                                        class="@(match.WinnerParticipantId == match.AwayParticipantId ? "text-success" : "")">@ParticipantName(match.AwayParticipantId)</strong>
                                                                                                                                                    </li>
                                                                                                                                                }
                                                                                                                                            </ul>
                                                                                                                                        }
                                                                                                                                    }
                                                                                                                                }
                else
                                                                                                                                {
                                                                                                                                    <p class="text-muted">Keine Gruppenmatches vorhanden. Generieren Sie den Plan im Tab „Auslosung".</p>
                                                                                                                                }
                                                                                                                            }

                                                                                                                            @* ═══════ Tab: K.O.-Phase ═══════ *@
                                                                                                                            @if (activeTab == "knockout")
                                                                                                                            {
                                                                                                                                @if (selectedTournament.Variant == "OnSite" && boards.Any() && matches.Any())
                                                                                                                                {
                                                                                                                                    <div class="p-2 border rounded mb-3 bg-light">
                                                                                                                                        <div class="small fw-semibold text-muted mb-2">Verfügbare Boards — auf Match ziehen zum Zuweisen
                                                                                                                                        </div>
                                                                                                                                        <div class="d-flex flex-wrap gap-2">
                                                                                                                                            @foreach (var board in boards)
                                                                                                                                            {
                                                                                                                                                <div class="badge bg-dark p-2 user-select-none" draggable="true"
                                                                                                                                                     @ondragstart="() => draggedBoardId = board.Id" style="cursor:grab; font-size:.85em">
                                                                                                                                                    📋 @board.Name
                                                                                                                                                    <span class="badge @BoardStatusBadge(board.Status) ms-1"
                                                                                                                                                          style="font-size:.75em">@board.Status</span>
                                                                                                                                                </div>
                                                                                                                                            }
                                                                                                                                        </div>
                                                                                                                                    </div>
                                                                                                                                }

                                                                                                                                var koMatches = matches.Where(m => m.Phase == "Knockout").ToList();
                                                                                                                                var koMaxRound = koMatches.Select(m => m.Round).DefaultIfEmpty(1).Max();
                                                                                                                                @if (koMatches.Any())
                                                                                                                                {
                                                                                                                                    <div class="d-flex gap-2 mb-3">
                                                                                                                                        <button class="btn btn-sm @(koViewMode == "tree" ? "btn-primary" : "btn-outline-primary")" @onclick='() => koViewMode = "tree"'>🌳 Bracket</button>
                                                                                                                                        <button class="btn btn-sm @(koViewMode == "round" ? "btn-primary" : "btn-outline-primary")" @onclick='() => koViewMode = "round"'>📋 Rundenliste</button>
                                                                                                                                    </div>

                                                                                                                                    @if (koViewMode == "tree")
                                                                                                                                    {
                                                                                                                                        <BracketView Matches="@koMatches" ResolvePlayerName="id => ParticipantName(id)" OnMatchClick="OpenMatchDetail" />
                                                                                                                                    }
                                                                                                                                    else
                                                                                                                                    {
                                                                                                                                    var koRounds = koMatches.Select(m => m.Round).Distinct().OrderBy(r => r).ToList();
                                                                                                                                    @foreach (var round in koRounds)
                                                                                                                                    {
                                                                                                                                        <div class="small fw-semibold text-muted mb-1 mt-2">@KoRoundLabel(round, koMaxRound)</div>
                                                                                                                                        <ul class="list-group mb-2">
                                                                                                                                            @foreach (var match in koMatches.Where(m => m.Round == round).OrderBy(m => m.MatchNumber))
                                                                                                                                            {
                                                                                                                                                var assignedBoard = boards.FirstOrDefault(b => b.Id == match.BoardId);
                                                                                                                                                var isTarget = dropTargetMatchId == match.Id;
                                                                                                                                                var isActive = match.WinnerParticipantId is null && match.FinishedUtc is null && match.BoardId is
                                                                                                                                                not null;
                                                                                                                                                var isBye = match.Status == "WalkOver";
                                                                                                                                                <li class="list-group-item @(isTarget ? "border-primary border-2" : "") @(isActive ? "border-start border-success border-3" : "") @(isBye ? "list-group-item-light" : "")"
                                                                                                                                                    style="cursor:pointer; @(isTarget ? "background:rgba(13,110,253,.08)" : "")"
                                                                                                                                                    @ondragover:preventDefault @ondragover="() => dropTargetMatchId = match.Id"
                                                                                                                                                    @ondragleave="() => { if (dropTargetMatchId == match.Id) dropTargetMatchId = null; }"
                                                                                                                                                    @ondrop="() => AssignBoardToMatchAsync(match.Id)" @onclick="() => OpenMatchDetail(match)">
                                                                                                                                                    <div class="d-flex justify-content-between align-items-center">
                                                                                                                                                        <span>
                                                                                                                                                            <span class="text-muted small me-1">@KoMatchLabel(match)</span>
                                                                                                                                                            @if (match.HomeParticipantId == Guid.Empty && match.WinnerParticipantId is null)
                                                                                                                                                            {
                                                                                                                                                                <em class="text-muted">@KoParticipantLabel(match.HomeParticipantId, match, true)</em>
                                                                                                                                                            }
                                                                                                                                                            else
                                                                                                                                                            {

                                                                                                                                                                <strong
                                                                                                                                                                class="@(match.WinnerParticipantId == match.HomeParticipantId ? "text-success" : "")">@ParticipantName(match.HomeParticipantId)</strong>
                                                                                                                                                            }
                                                                                                                                                            @if (match.FinishedUtc is not null)
                                                                                                                                                            {
                                                                                                                                                                <span class="text-muted mx-1">@FormatScore(match)</span>
                                                                                                                                                                } else
                                                                                                                                                                {

                                                                                                                                                                    <span class="text-muted mx-1">vs</span>
                                                                                                                                                                }
                                                                                                                                                                @if (match.AwayParticipantId == Guid.Empty && match.WinnerParticipantId is null)
                                                                                                                                                                {
                                                                                                                                                                    <em class="text-muted">@KoParticipantLabel(match.AwayParticipantId, match, false)</em>
                                                                                                                                                                }
                                                                                                                                                                else
                                                                                                                                                                {

                                                                                                                                                                    <strong
                                                                                                                                                                    class="@(match.WinnerParticipantId == match.AwayParticipantId ? "text-success" : "")">@ParticipantName(match.AwayParticipantId)</strong>
                                                                                                                                                                }
                                                                                                                                                            </span>
                                                                                                                                                            <div class="d-flex align-items-center gap-1">
                                                                                                                                                                @if (assignedBoard is not null)
                                                                                                                                                                {
                                                                                                                                                                    <a href="https://play.autodarts.io/boards/@(assignedBoard.ExternalBoardId)/follow"
                                                                                                                                                                       target="_blank" rel="noopener" class="badge text-bg-success text-decoration-none"
                                                                                                                                                                       @onclick:stopPropagation>📋 @assignedBoard.Name</a>
                                                                                                                                                                }
                                                                                                                                                                else if (selectedTournament.Variant == "OnSite")
                                                                                                                                                                {
                                                                                                                                                                    <span class="badge text-bg-light text-muted border" style="font-size:.75em">Board
                                                                                                                                                                        zuweisen</span>
                                                                                                                                                                    }
                                                                                                                                                                    @if (match.WinnerParticipantId.HasValue)
                                                                                                                                                                    {
                                                                                                                                                                        <span class="badge text-bg-warning">🏆
                                                                                                                                                                            @ParticipantName(match.WinnerParticipantId)</span>
                                                                                                                                                                        }
                                                                                                                                                                        @if (match.PlannedStartUtc is not null)
                                                                                                                                                                        {
                                                                                                                                                                            <span
                                                                                                                                                                                class="badge text-bg-light text-muted border" style="font-size:.75em">⏰
                                                                                                                                                                                @match.PlannedStartUtc.Value.LocalDateTime.ToString("HH:mm")</span>
                                                                                                                                                                            }
                                                                                                                                                                        </div>
                                                                                                                                                                    </div>
                                                                                                                                                                </li>
                                                                                                                                                            }
                                                                                                                                                        </ul>
                                                                                                                                                    }
                                                                                                                                                } @* end else (round list view) *@
                                                                                                                                                }
                else
                                                                                                                                                {
                                                                                                                                                    <p class="text-muted">Noch keine K.O.-Matches vorhanden.</p>
                                                                                                                                                }
                                                                                                                                            }

                                                                                                                                            @* ═══════ Tab: Spielplan (chronologisch) ═══════ *@
                                                                                                                                            @if (activeTab == "schedule")
                                                                                                                                            {
                                                                                                                                                <div class="d-flex justify-content-between align-items-center mb-3">
                                                                                                                                                    <h6 class="fw-semibold mb-0">Spielplan — Chronologische Übersicht</h6>
                                                                                                                                                    @if (matches.Any() && !selectedTournament.IsLocked && IsCurrentUserManager &&
                                                                                                                                                                        !string.IsNullOrEmpty(selectedTournament.StartTime))
                                                                                                                                                    {
                                                                                                                                                        <button class="btn btn-primary btn-sm" @onclick="GenerateScheduleAsync" disabled="@isWorking">⏰
                                                                                                                                                            Spielplan generieren</button>
                                                                                                                                                        }
                                                                                                                                                    </div>

                                                                                                                                                    @* Spielplan Filters *@
                                                                                                                                                    <div class="d-flex flex-wrap gap-3 align-items-center mb-3 small">
                                                                                                                                                        <div class="form-check">
                                                                                                                                                            <input class="form-check-input" type="checkbox" id="schedHideFinished" @bind="scheduleHideFinished" />
                                                                                                                                                            <label class="form-check-label" for="schedHideFinished">Beendete ausblenden</label>
                                                                                                                                                        </div>
                                                                                                                                                        <div class="form-check">
                                                                                                                                                            <input class="form-check-input" type="checkbox" id="schedNoBoard" @bind="scheduleShowNoBoard" />
                                                                                                                                                            <label class="form-check-label" for="schedNoBoard">Nur ohne Board</label>
                                                                                                                                                        </div>
                                                                                                                                                        <select class="form-select form-select-sm" style="width:auto" @bind="scheduleStatusFilter">
                                                                                                                                                            <option value="all">Alle Status</option>
                                                                                                                                                            <option value="running">Laufende Spiele</option>
                                                                                                                                                            <option value="upcoming">Anstehende Spiele</option>
                                                                                                                                                        </select>
                                                                                                                                                    </div>

                                                                                                                                                    @* Board availability / drag source *@
                                                                                                                                                    @if (selectedTournament.Variant == "OnSite" && boards.Any())
                                                                                                                                                    {
                                                                                                                                                        <div class="p-2 border rounded mb-3 bg-light">
                                                                                                                                                            <div class="small fw-semibold text-muted mb-2">Boards — auf Match ziehen zum Zuweisen</div>
                                                                                                                                                            <div class="d-flex flex-wrap gap-2">
                                                                                                                                                                @foreach (var board in boards)
                                                                                                                                                                {
                                                                                                                                                                    var queueCount = BoardQueues.GetValueOrDefault(board.Id)?.Count ?? 0;
                                                                                                                                                                    <div class="badge bg-dark p-2 user-select-none" draggable="true"
                                                                                                                                                                         @ondragstart="() => draggedBoardId = board.Id" style="cursor:grab; font-size:.85em">
                                                                                                                                                                        📋 @board.Name
                                                                                                                                                                        <span class="badge @BoardStatusBadge(board.Status) ms-1"
                                                                                                                                                                              style="font-size:.75em">@board.Status</span>
                                                                                                                                                                        @if (queueCount > 0)
                                                                                                                                                                        {
                                                                                                                                                                            <span class="badge bg-info ms-1">@queueCount</span>
                                                                                                                                                                        }
                                                                                                                                                                    </div>
                                                                                                                                                                }
                                                                                                                                                            </div>
                                                                                                                                                        </div>
                                                                                                                                                    }

                                                                                                                                                    @* Unassigned matches warning *@
                                                                                                                                                    @if (UnassignedUpcoming.Any())
                                                                                                                                                    {
                                                                                                                                                        <div class="alert alert-warning py-2 small mb-3">
                                                                                                                                                            ⚠ <strong>@UnassignedUpcoming.Count</strong> anstehende Matches ohne Board-Zuweisung:
                                                                                                                                                            @foreach (var m in UnassignedUpcoming.Take(10))
                                                                                                                                                            {
                                                                                                                                                                <span class="badge text-bg-warning me-1" style="cursor:pointer"
                                                                                                                                                                     @onclick="() => OpenMatchDetail(m, true)">@MatchLabel(m)</span>
                                                                                                                                                            }
                                                                                                                                                            @if (UnassignedUpcoming.Count > 10)
                                                                                                                                                            {
                                                                                                                                                                <span class="text-muted">… und @(UnassignedUpcoming.Count -
                                                                                                                                                                                            10) weitere</span>
                                                                                                                                                                }
                                                                                                                                                            </div>
                                                                                                                                                        }

                                                                                                                                                        @* Board Queues *@
                                                                                                                                                        @if (boards.Any() && ScheduledMatches.Any(m => m.BoardId.HasValue))
                                                                                                                                                        {
                                                                                                                                                            <h6 class="fw-semibold text-muted small mb-2">Board-Warteschlangen</h6>
                                                                                                                                                            <div class="row g-2 mb-3">
                                                                                                                                                                @foreach (var board in boards)
                                                                                                                                                                {
                                                                                                                                                                    var queue = BoardQueues.GetValueOrDefault(board.Id) ?? [];
                                                                                                                                                                    <div class="col-md-4 col-lg-3">
                                                                                                                                                                        <div class="card h-100">
                                                                                                                                                                            <div class="card-header py-1 d-flex justify-content-between align-items-center">
                                                                                                                                                                                <span class="small fw-semibold">📋 @board.Name</span>
                                                                                                                                                                                <span class="badge @BoardStatusBadge(board.Status)">@board.Status</span>
                                                                                                                                                                            </div>
                                                                                                                                                                            <div class="card-body p-2">
                                                                                                                                                                                @if (queue.Any())
                                                                                                                                                                                {
                                                                                                                                                                                    @foreach (var m in queue.Take(5))
                                                                                                                                                                                    {
                                                                                                                                                                                        <div class="small border-bottom py-1" style="cursor:pointer"
                                                                                                                                                                                            @onclick="() => OpenMatchDetail(m, true)">
                                                                                                                                                                                            <span class="fw-semibold">@MatchLabel(m)</span>
                                                                                                                                                                                            @ParticipantName(m.HomeParticipantId) vs @ParticipantName(m.AwayParticipantId)
                                                                                                                                                                                            @if (m.PlannedStartUtc is not null)
                                                                                                                                                                                            {
                                                                                                                                                                                                <span
                                                                                                                                                                                                class="text-muted ms-1">@m.PlannedStartUtc.Value.LocalDateTime.ToString("HH:mm")</span>
                                                                                                                                                                                            }
                                                                                                                                                                                        </div>
                                                                                                                                                                                    }
                                                                                                                                                                                    @if (queue.Count > 5)
                                                                                                                                                                                    {
                                                                                                                                                                                        <div class="small text-muted">… +@(queue.Count - 5) weitere
                                                                                                                                                                                        </div>
                                                                                                                                                                                    }
                                                                                                                                                                                }
                                                                                                                                                                                else
                                                                                                                                                                                {
                                                                                                                                                                                    <span class="small text-muted">Keine Matches in der Queue</span>
                                                                                                                                                                                }
                                                                                                                                                                            </div>
                                                                                                                                                                        </div>
                                                                                                                                                                    </div>
                                                                                                                                                                }
                                                                                                                                                            </div>
                                                                                                                                                        }

                                                                                                                                                        @* Full chronological match list *@
                                                                                                                                                        @if (ScheduledMatches.Any())
                                                                                                                                                        {
                                                                                                                                                            <div class="table-responsive">
                                                                                                                                                                <table class="table table-sm table-hover">
                                                                                                                                                                    <thead>
                                                                                                                                                                        <tr>
                                                                                                                                                                            <th style="width:6rem">Uhrzeit</th>
                                                                                                                                                                            <th style="width:4rem">Match</th>
                                                                                                                                                                            <th>Heim</th>
                                                                                                                                                                            <th style="width:3rem" class="text-center">Erg.</th>
                                                                                                                                                                            <th>Gast</th>
                                                                                                                                                                            <th>Board</th>
                                                                                                                                                                            <th style="width:3rem"></th>
                                                                                                                                                                        </tr>
                                                                                                                                                                    </thead>
                                                                                                                                                                    <tbody>
                                                                                                                                                                        @foreach (var match in ScheduledMatches)
                                                                                                                                                                        {
                                                                                                                                                                            var assignedBoard = boards.FirstOrDefault(b => b.Id == match.BoardId);
                                                                                                                                                                            var isDone = match.FinishedUtc is not null;
                                                                                                                                                                            var isRunning = match.StartedUtc is not null && match.FinishedUtc is null;
                                                                                                                                                                            var noBoard = !match.BoardId.HasValue && match.FinishedUtc is null;
                                                                                                                                                                            var isTarget = dropTargetMatchId == match.Id;
                                                                                                                                                                            <tr class="@(isDone ? "table-light text-muted" : "") @(isRunning ? "table-info" : "") @(noBoard ? "table-warning" : "") @(isTarget ? "table-primary" : "")"
                                                                                                                                                                                style="cursor:pointer" @ondragover:preventDefault
                                                                                                                                                                                @ondragover="() => dropTargetMatchId = match.Id"
                                                                                                                                                                                @ondragleave="() => { if (dropTargetMatchId == match.Id) dropTargetMatchId = null; }"
                                                                                                                                                                                @ondrop="() => AssignBoardToMatchAsync(match.Id)">
                                                                                                                                                                                <td class="small">
                                                                                                                                                                                    @if (editingMatchTimeId == match.Id)
                                                                                                                                                                                    {
                                                                                                                                                                                        <div class="d-flex gap-1 align-items-center" @onclick:stopPropagation>
                                                                                                                                                                                            <input type="text" class="form-control form-control-sm" style="width:5rem" placeholder="HH:mm" @bind="editMatchTimeValue" />
                                                                                                                                                                                            <button class="btn btn-sm btn-success py-0 px-1" @onclick="() => SaveMatchTimeAsync(match)" disabled="@isWorking">✓</button>
                                                                                                                                                                                            <button class="btn btn-sm btn-secondary py-0 px-1" @onclick="CancelEditMatchTime">✕</button>
                                                                                                                                                                                        </div>
                                                                                                                                                                                    }
                                                                                                                                                                                    else
                                                                                                                                                                                    {
                                                                                                                                                                                        <span @onclick="() => StartEditMatchTime(match)" @onclick:stopPropagation style="cursor:text"
                                                                                                                                                                                            class="@(match.IsStartTimeLocked ? "text-primary fw-semibold" : "")">
                                                                                                                                                                                            @if (match.PlannedStartUtc is not null)
                                                                                                                                                                                            {
                                                                                                                                                                                                @match.PlannedStartUtc.Value.LocalDateTime.ToString("HH:mm")
                                                                                                                                                                                            }
                                                                                                                                                                                            else
                                                                                                                                                                                            {
                                                                                                                                                                                                <span class="text-muted">—</span>
                                                                                                                                                                                            }
                                                                                                                                                                                            @if (match.IsStartTimeLocked) { <span>🔒</span> }
                                                                                                                                                                                        </span>
                                                                                                                                                                                        @if (!isDone)
                                                                                                                                                                                        {
                                                                                                                                                                                            <button class="btn btn-link btn-sm p-0 ms-1 @(match.IsStartTimeLocked ? "text-primary" : "text-muted")"
                                                                                                                                                                                                @onclick="() => ToggleTimeLockAsync(match)" @onclick:stopPropagation
                                                                                                                                                                                                title="@(match.IsStartTimeLocked ? "Startzeit entsperren" : "Startzeit sperren")">
                                                                                                                                                                                                @(match.IsStartTimeLocked ? "🔓" : "🔒")
                                                                                                                                                                                            </button>
                                                                                                                                                                                        }
                                                                                                                                                                                    }
                                                                                                                                                                                </td>
                                                                                                                                                                                <td @onclick="() => OpenMatchDetail(match, true)"><span class="badge text-bg-secondary">@MatchLabel(match)</span></td>
                                                                                                                                                                                <td @onclick="() => OpenMatchDetail(match, true)"
                                                                                                                                                                                    class="@(match.WinnerParticipantId == match.HomeParticipantId ? "fw-bold text-success" : "")">
                                                                                                                                                                                    @ParticipantName(match.HomeParticipantId)</td>
                                                                                                                                                                                    <td @onclick="() => OpenMatchDetail(match, true)" class="text-center small">
                                                                                                                                                                                        @if (isDone)
                                                                                                                                                                                        {
                                                                                                                                                                                            <span>@FormatScore(match)</span>
                                                                                                                                                                                        }
                                                                                                                                                                                        else
                                                                                                                                                                                        {
                                                                                                                                                                                            <span class="text-muted">vs</span>
                                                                                                                                                                                        }
                                                                                                                                                                                    </td>
                                                                                                                                                                                    <td @onclick="() => OpenMatchDetail(match, true)"
                                                                                                                                                                                        class="@(match.WinnerParticipantId == match.AwayParticipantId ? "fw-bold text-success" : "")">
                                                                                                                                                                                        @ParticipantName(match.AwayParticipantId)</td>
                                                                                                                                                                                        <td>
                                                                                                                                                                                            @if (assignedBoard is not null)
                                                                                                                                                                                            {
                                                                                                                                                                                                <span class="badge @(match.IsBoardLocked ? "text-bg-primary" : "text-bg-success")" style="cursor:pointer"
                                                                                                                                                                                                    @onclick="() => OpenBoardDetail(assignedBoard)" @onclick:stopPropagation>
                                                                                                                                                                                                    @assignedBoard.Name @if (match.IsBoardLocked) { <span>🔒</span> }
                                                                                                                                                                                                </span>
                                                                                                                                                                                                @if (!isDone)
                                                                                                                                                                                                {
                                                                                                                                                                                                    <button class="btn btn-link btn-sm p-0 ms-1 @(match.IsBoardLocked ? "text-primary" : "text-muted")"
                                                                                                                                                                                                        @onclick="() => ToggleBoardLockAsync(match)" @onclick:stopPropagation
                                                                                                                                                                                                        title="@(match.IsBoardLocked ? "Board entsperren" : "Board sperren")">
                                                                                                                                                                                                        @(match.IsBoardLocked ? "🔓" : "🔒")
                                                                                                                                                                                                    </button>
                                                                                                                                                                                                }
                                                                                                                                                                                            }
                                                                                                                                                                                            else if (!isDone)
                                                                                                                                                                                            {
                                                                                                                                                                                                <span class="badge text-bg-warning">⚠ kein Board</span>
                                                                                                                                                                                            }
                                                                                                                                                                                        </td>
                                                                                                                                                                                        <td>
                                                                                                                                                                                            @if (match.WinnerParticipantId.HasValue)
                                                                                                                                                                                            {
                                                                                                                                                                                                <span>🏆</span>
                                                                                                                                                                                            }
                                                                                                                                                                                            else if (CanSendUpcomingMatch(match))
                                                                                                                                                                                            {
                                                                                                                                                                                                <button class="btn btn-success btn-sm py-0 px-1" @onclick="() => SendUpcomingMatchAsync(match)" @onclick:stopPropagation
                                                                                                                                                                                                    disabled="@isWorking" title="Match am Board starten">
                                                                                                                                                                                                    ▶
                                                                                                                                                                                                </button>
                                                                                                                                                                                            }
                                                                                                                                                                                        </td>
                                                                                                                                                                                    </tr>
                                                                                                                                                                                }
                                                                                                                                                                            </tbody>
                                                                                                                                                                        </table>
                                                                                                                                                                    </div>
                                                                                                                                                                }
                else
                                                                                                                                                                {
                                                                                                                                                                    <p class="text-muted">Noch kein Spielplan vorhanden. Generieren Sie zuerst den Turnierplan im Tab
                                                                                                                                                                        „Auslosung" und danach den Spielplan.</p>
                                                                                                                                                                    }
                                                                                                                                                                }
                                                                                                                                                            </div>
                                                                                                                                                        </div>
                                                                                                                                                    </div>
                                                                                                                                                }
                                                                                                                                            </div>

@* ─── Board Detail Modal ─── *@
@if (detailBoard is not null)
{
    var currentMatch = CurrentMatchOnBoard(detailBoard.Id);
    var upcomingOnBoard = UpcomingMatchesOnBoard(detailBoard.Id);
    var boardMatchListener = currentMatch is not null ? matchListeners.FirstOrDefault(l => l.MatchId == currentMatch.Id) : null;
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="CloseBoardDetail">
        <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">📋 @detailBoard.Name</h5>
                    <button type="button" class="btn-close" @onclick="CloseBoardDetail"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="badge @BoardStatusBadge(detailBoard.Status)">@detailBoard.Status</span>
                        @if (detailBoard.IsExtensionConnected)
                        {
                            <span class="badge text-bg-success">🔗 Extension verbunden</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">⛓️‍💥 Extension nicht verbunden</span>
                        }
                        <a href="https://play.autodarts.io/boards/@(detailBoard.ExternalBoardId)/follow" target="_blank"
                           rel="noopener" class="btn btn-outline-primary btn-sm"><span class="autodarts-icon"></span> Board verfolgen</a>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => RequestBoardSyncAsync(detailBoard)"
                                disabled="@(isWorking || !detailBoard.IsExtensionConnected)">
                            🔄 Sync
                        </button>
                    </div>
                    @if (boardSyncInfo is not null)
                    {
                        <div class="alert alert-info py-2 small">@boardSyncInfo</div>
                    }
                    @if (boardSyncError is not null)
                    {
                        <div class="alert alert-danger py-2 small">@boardSyncError</div>
                    }
                    @if (IsDevelopmentEnvironment)
                    {
                        <details class="card border-warning-subtle mb-3">
                            <summary class="card-header py-2 d-flex justify-content-between align-items-center" style="cursor:pointer">
                                <span class="small fw-semibold">Dev: Board Sync Debug</span>
                                <span class="small text-muted">@(boardSyncDebug?.Matched is true ? "gematcht" : boardSyncDebug?.ReportedAtUtc is not null ? "reportet" : "eingeklappt")</span>
                            </summary>
                            <div class="card-body py-2">
                                <div class="d-flex justify-content-end mb-2">
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshBoardSyncDebugAsync" disabled="@isBoardSyncDebugLoading">
                                        @(isBoardSyncDebugLoading ? "Lade..." : "Aktualisieren")
                                    </button>
                                </div>
                                @if (boardSyncDebug is null)
                                {
                                    <div class="small text-muted">Noch keine Sync-Daten vorhanden.</div>
                                }
                                else
                                {
                                    <div class="row g-2 small">
                                        <div class="col-md-6"><strong>RequestId:</strong> @boardSyncDebug.RequestId</div>
                                        <div class="col-md-6"><strong>ShouldSync:</strong> @boardSyncDebug.ShouldSync</div>
                                        <div class="col-md-6"><strong>Requested:</strong> @(boardSyncDebug.RequestedAtUtc?.LocalDateTime.ToString("HH:mm:ss") ?? "—")</div>
                                        <div class="col-md-6"><strong>Consumed:</strong> @(boardSyncDebug.ConsumedAtUtc?.LocalDateTime.ToString("HH:mm:ss") ?? "—")</div>
                                        <div class="col-md-6"><strong>Reported:</strong> @(boardSyncDebug.ReportedAtUtc?.LocalDateTime.ToString("HH:mm:ss") ?? "—")</div>
                                        <div class="col-md-6"><strong>Matched:</strong> @boardSyncDebug.Matched</div>
                                        <div class="col-md-6"><strong>MatchedBy:</strong> @(string.IsNullOrWhiteSpace(boardSyncDebug.MatchedBy) ? "—" : boardSyncDebug.MatchedBy)</div>
                                        <div class="col-md-6"><strong>MatchId:</strong> @(boardSyncDebug.MatchId?.ToString() ?? "—")</div>
                                        <div class="col-md-6"><strong>DerivedStatus:</strong> @boardSyncDebug.DerivedStatus</div>
                                        <div class="col-md-6"><strong>ExternalMatchId:</strong> @boardSyncDebug.ExternalMatchId</div>
                                        <div class="col-md-6"><strong>TournamentId:</strong> @(boardSyncDebug.TournamentId?.ToString() ?? "—")</div>
                                        <div class="col-md-6"><strong>Player1:</strong> @(string.IsNullOrWhiteSpace(boardSyncDebug.Player1) ? "—" : boardSyncDebug.Player1)</div>
                                        <div class="col-md-6"><strong>Player2:</strong> @(string.IsNullOrWhiteSpace(boardSyncDebug.Player2) ? "—" : boardSyncDebug.Player2)</div>
                                        <div class="col-12"><strong>SourceUrl:</strong> @(string.IsNullOrWhiteSpace(boardSyncDebug.SourceUrl) ? "—" : boardSyncDebug.SourceUrl)</div>
                                    </div>
                                }
                            </div>
                        </details>
                    }
                    @if (currentMatch is not null)
                    {
                        <h6 class="fw-semibold">▶ Laufendes Match</h6>
                        <div class="card mb-3 border-success">
                            <div class="card-body py-2">
                                <span class="badge text-bg-secondary me-1">@MatchLabel(currentMatch)</span>
                                <strong>@ParticipantName(currentMatch.HomeParticipantId)</strong>
                                <span class="mx-1">@FormatLiveScore(currentMatch)</span>
                                <strong>@ParticipantName(currentMatch.AwayParticipantId)</strong>
                            </div>
                        </div>
                        @if (boardMatchListener is not null && boardMatchListener.IsRunning)
                        {
                            <div class="d-flex flex-column gap-1 mb-3">
                                <div class="d-flex align-items-center gap-2">
                                    @if (boardMatchListener.LastError is not null)
                                    {
                                        <span class="badge text-bg-danger">❌ Listener Fehler</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">🎧 Listener aktiv</span>
                                    }
                                    @if (boardMatchListener.LastUpdateUtc is not null)
                                    {
                                        <span class="small text-muted">Letztes Update: @boardMatchListener.LastUpdateUtc.Value.LocalDateTime.ToString("HH:mm:ss")</span>
                                    }
                                </div>
                                @if (boardMatchListener.LastError is not null)
                                {
                                    <div class="alert alert-danger py-1 px-2 mb-0 small">@boardMatchListener.LastError</div>
                                }
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(currentMatch.ExternalMatchId) && currentMatch.FinishedUtc is null)
                        {
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <span class="badge text-bg-warning">⚠ Kein Listener</span>
                                <button class="btn btn-outline-success btn-sm" @onclick="() => EnsureListenerAsync(currentMatch)" disabled="@isWorking">
                                    🎧 Listener starten
                                </button>
                            </div>
                        }
                    }
                    @if (upcomingOnBoard.Any())
                    {
                        <h6 class="fw-semibold">📋 Warteschlange (@upcomingOnBoard.Count Matches)</h6>
                        <ul class="list-group mb-3">
                            @foreach (var m in upcomingOnBoard)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center" style="cursor:pointer"
                                    @onclick="() => { detailBoard = null; _modalBackStack.Clear(); OpenMatchDetail(m); }">
                                    <span>
                                        <span class="badge text-bg-secondary me-1">@MatchLabel(m)</span>
                                        @ParticipantName(m.HomeParticipantId) vs @ParticipantName(m.AwayParticipantId)
                                    </span>
                                    <span class="small text-muted">
                                        @if (m.PlannedStartUtc is not null)
                                        {
                                            <span>⏰ @m.PlannedStartUtc.Value.LocalDateTime.ToString("HH:mm")</span>
                                        }
                                        @if (m.IsStartTimeLocked) { <span>🔒</span> }
                                    </span>
                                </li>
                            }
                        </ul>
                    }
                    else if (currentMatch is null)
                    {
                        <p class="text-muted">Keine Matches auf diesem Board geplant.</p>
                    }
                    @if (selectedTournament is not null && !selectedTournament.IsLocked)
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="GenerateScheduleAsync" disabled="@isWorking">
                            ⏰ Spielplan neu berechnen
                        </button>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseBoardDetail">Schließen</button>
                </div>
            </div>
        </div>
    </div>
}

@* ─── Round Detail Modal ─── *@
@if (detailRound is not null && selectedTournament is not null)
{
    var roundStarted = IsRoundStarted(detailRound.Phase, detailRound.RoundNumber);
    var roundCompleted = IsRoundCompleted(detailRound.Phase, detailRound.RoundNumber);
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5)" @onclick="CloseRoundDetail">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@RoundDisplayLabel(detailRound)
                        @if (roundCompleted) { <span class="badge text-bg-success ms-2">✓ Abgeschlossen</span> }
                        else if (roundStarted) { <span class="badge text-bg-warning ms-2">▶ Gestartet</span> }
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseRoundDetail"></button>
                </div>
                <div class="modal-body">
                    @if (roundCompleted)
                    {
                        <div class="alert alert-success py-2 small">Diese Runde ist abgeschlossen und kann nicht mehr bearbeitet werden.</div>
                    }
                    else if (roundStarted)
                    {
                        <div class="alert alert-warning py-2 small">⚠ Diese Runde wurde bereits gestartet. Änderungen können laufende Matches beeinflussen.</div>
                    }
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Base Score</label>
                        <select class="form-select form-select-sm" @bind="newRoundBaseScore" disabled="@(roundCompleted || editAreGameModesLocked)">
                            <option value="121">121</option>
                            <option value="170">170</option>
                            <option value="301">301</option>
                            <option value="501">501</option>
                            <option value="701">701</option>
                            <option value="901">901</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Spielmodus</label>
                        <select class="form-select form-select-sm" @bind="newRoundGameMode" disabled="@(roundCompleted || editAreGameModesLocked)">
                            <option value="Legs">Legs</option>
                            <option value="Sets">Sets</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Legs (First to)</label>
                        @if (newRoundGameMode == "Sets")
                        {
                            <select class="form-select form-select-sm" @bind="newRoundLegs" disabled="@(roundCompleted || editAreGameModesLocked)">
                                <option value="2">2</option>
                                <option value="3">3</option>
                            </select>
                        }
                        else
                        {
                            <input type="number" class="form-control form-control-sm" @bind="newRoundLegs" min="1" max="11" disabled="@(roundCompleted || editAreGameModesLocked)" />
                        }
                    </div>
                    @if (newRoundGameMode == "Sets")
                    {
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Sets (First to)</label>
                            <input type="number" class="form-control form-control-sm" @bind="newRoundSets" min="2" max="7" disabled="@(roundCompleted || editAreGameModesLocked)" />
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">In-Modus</label>
                        <select class="form-select form-select-sm" @bind="newRoundInMode" disabled="@(roundCompleted || editAreGameModesLocked)">
                            <option value="Straight">Straight In (SI)</option>
                            <option value="Double">Double In (DI)</option>
                            <option value="Master">Master In (MI)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Out-Modus</label>
                        <select class="form-select form-select-sm" @bind="newRoundOutMode" disabled="@(roundCompleted || editAreGameModesLocked)">
                            <option value="Straight">Straight Out (SO)</option>
                            <option value="Double">Double Out (DO)</option>
                            <option value="Master">Master Out (MO)</option>
                        </select>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label class="form-label small">Max Runden</label>
                            <select class="form-select form-select-sm" @bind="newRoundMaxRounds" disabled="@(roundCompleted || editAreGameModesLocked)">
                                <option value="15">15</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                                <option value="80">80</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Bull Mode</label>
                            <select class="form-select form-select-sm" @bind="newRoundBullMode" disabled="@(roundCompleted || editAreGameModesLocked)">
                                <option value="25/50">25/50</option>
                                <option value="50/50">50/50</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Bull-off</label>
                            <select class="form-select form-select-sm" @bind="newRoundBullOffMode" disabled="@(roundCompleted || editAreGameModesLocked)">
                                <option value="Off">Off</option>
                                <option value="Normal">Normal</option>
                                <option value="Official">Official</option>
                            </select>
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label class="form-label small">Matchdauer (min)</label>
                            <input type="number" class="form-control form-control-sm" @bind="newRoundDuration" min="0" disabled="@(roundCompleted || editAreGameModesLocked)" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Pause (min)</label>
                            <input type="number" class="form-control form-control-sm" @bind="newRoundPause" min="0" disabled="@(roundCompleted || editAreGameModesLocked)" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Min. Spielerpause (min)</label>
                            <input type="number" class="form-control form-control-sm" @bind="newRoundPlayerPause" min="0" disabled="@(roundCompleted || editAreGameModesLocked)" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Boardauswahl</label>
                        <select class="form-select form-select-sm" @bind="newRoundBoardAssignment" disabled="@(roundCompleted || editAreGameModesLocked)">
                            <option value="Dynamic">Dynamisch</option>
                            @foreach (var b in boards)
                            {
                                <option value="Fixed:@b.Id">@b.Name (fix)</option>
                            }
                        </select>
                    </div>
                    @if (roundError is not null)
                    {
                        <div class="alert alert-danger py-1 small">@roundError</div>
                    }
                </div>
                <div class="modal-footer">
                    @if (!roundStarted && !roundCompleted && !editAreGameModesLocked && !selectedTournament.IsLocked)
                    {
                        <button class="btn btn-outline-danger me-auto" @onclick="DeleteRoundAsync" disabled="@isWorking"
                                title="Spielrunde löschen">
                            🗑 Löschen
                        </button>
                    }
                    <button class="btn btn-secondary" @onclick="CloseRoundDetail">Abbrechen</button>
                    @if (!roundCompleted && !editAreGameModesLocked && !selectedTournament.IsLocked)
                    {
                        <button class="btn btn-primary" @onclick="async () => { await SaveRoundAsync(); CloseRoundDetail(); }" disabled="@isWorking">Speichern</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

