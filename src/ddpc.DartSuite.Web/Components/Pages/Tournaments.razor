                                                                                         @onclick='() => activeTab = "boards-participants"'>Boards &amp; Teilnehmer</button></li>
                                                            <li class="nav-item"><button class="nav-link @(activeTab == "rounds" ? "active" : "")"
                                                                                             @onclick="SwitchToRoundsTabAsync">Spielmodus @if (HasMissingRoundConfig()) {<span class="badge text-bg-danger ms-1">@MissingRoundConfigCount() ⚠</span>}</button></li>
                                                                <li class="nav-item"><button class="nav-link @(activeTab == "draw" ? "active" : "")"
                                                                                                 @onclick='() => activeTab = "draw"'>Auslosung</button></li>
                                                                    @if (selectedTournament.Mode == "GroupAndKnockout")
                                                                    {
                                                                        <li class="nav-item"><button class="nav-link @(activeTab == "groups" ? "active" : "")"
                                                                                                         @onclick='() => activeTab = "groups"'>Gruppenphase</button></li>
                                                                        }
                                                                        <li class="nav-item"><button class="nav-link @(activeTab == "knockout" ? "active" : "")"
                                                                                                         @onclick='() => activeTab = "knockout"'>K.O.-Phase</button></li>
                                                                            <li class="nav-item"><button class="nav-link @(activeTab == "schedule" ? "active" : "")"
                                                                                                         @onclick='() => activeTab = "schedule"'>Spielplan <span
                                                                                class="badge text-bg-secondary ms-1">@ScheduledMatches.Count</span></button></li>
                                                                            </ul>

                                                                            @* ═══════ Tab: Allgemein ═══════ *@
                                                                            @if (activeTab == "general")
                                                                            {
                                                                                @if (selectedTournament.IsLocked)
                                                                                {
                                                                                    <div class="alert alert-info py-2">🔒 Das Turnier ist gesperrt. Entsperren Sie es, um Änderungen
                                                                                        vorzunehmen.</div>
                                                                                    }
                                                                                    <div class="mb-3">
                                                                                        <label class="form-label fw-semibold">Turniername</label>
                                                                                        <input class="form-control" @bind="editName" disabled="@selectedTournament.IsLocked" />
                                                                                    </div>
                                                                                    <div class="mb-3">
                                                                                        <label class="form-label fw-semibold">Veranstalter-Account</label>
                                                                                        <input class="form-control" @bind="editOrganizer" list="organizerSuggestions" disabled="@selectedTournament.IsLocked" />
                                                                                        <datalist id="organizerSuggestions">
                                                                                            @if (!string.IsNullOrEmpty(autodartsDisplayName))
                                                                                            {
                                                                                                <option value="@autodartsDisplayName" />
                                                                                            }
                                                                                            @foreach (var p in participants.Where(p => p.IsAutodartsAccount))
                                                                                            {
                                                                                                <option value="@p.AccountName">@p.DisplayName</option>
                                                                                            }
                                                                                        </datalist>
                                                                                    </div>
                                                                                    <div class="row g-2 mb-3">
                                                                                        <div class="col-md-4">
                                                                                            <label class="form-label fw-semibold">Startdatum</label>
                                                                                            <input type="date" class="form-control" @bind="editStartDate"
                                                                                                   disabled="@selectedTournament.IsLocked" />
                                                                                        </div>
                                                                                        <div class="col-md-4">
                                                                                            <label class="form-label fw-semibold">Enddatum</label>
                                                                                            <input type="date" class="form-control" @bind="editEndDate"
                                                                                                   disabled="@selectedTournament.IsLocked" />
                                                                                        </div>
                                                                                        <div class="col-md-4">
                                                                                            <label class="form-label fw-semibold">Startzeit</label>
                                                                                            <input type="time" class="form-control" @bind="editStartTimeInput"
                                                                                                   disabled="@selectedTournament.IsLocked" />
                                                                                        </div>
                                                                                    </div>
                                                                                    <div class="mb-3">
                                                                                        <label class="form-label fw-semibold">Modus</label>
                                                                                        <select class="form-select" @bind="editMode" disabled="@selectedTournament.IsLocked">
                                                                                            <option value="Knockout">K.O.-Modus</option>
                                                                                            <option value="GroupAndKnockout">Gruppenphase + K.O.</option>
                                                                                        </select>
                                                                                    </div>
                                                                                    <div class="mb-3">
                                                                                        <label class="form-label fw-semibold">Variante</label>
                                                                                        <select class="form-select" @bind="editVariant" disabled="@selectedTournament.IsLocked">
                                                                                            <option value="OnSite">Vor-Ort</option>
                                                                                            <option value="Online">Online</option>
                                                                                        </select>
                                                                                    </div>
                                                                                    <div class="form-check mb-2">
                                                                                        <input class="form-check-input" type="checkbox" id="editTeamplay" @bind="editTeamplay"
                                                                                               disabled="@selectedTournament.IsLocked" />
                                                                                        <label class="form-check-label" for="editTeamplay">Teamplay aktivieren</label>
                                                                                    </div>
                                                                                    <div class="form-check mb-3">
                                                                                        <input class="form-check-input" type="checkbox" id="editThirdPlace" @bind="editThirdPlaceMatch"
                                                                                               disabled="@selectedTournament.IsLocked" />
                                                                                        <label class="form-check-label" for="editThirdPlace">Spiel um Platz 3</label>
                                                                                    </div>

                                                                                    @if (editMode == "GroupAndKnockout")
                                                                                    {
