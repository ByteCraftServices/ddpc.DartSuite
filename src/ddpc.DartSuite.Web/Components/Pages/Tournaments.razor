                                                    <span class="badge text-bg-secondary">@ModeDisplay(selectedTournament.Mode)</span>
                                                    <span class="badge text-bg-info">@VariantDisplay(selectedTournament.Variant)</span>
                                                    @if (IsCurrentUserManager)
                                                    {
                                                        <div class="ms-1">
                                                            <SplitButton PrimaryText="@selectedTournament.Status"
                                                                         ButtonStyle="@StatusBadgeCss(selectedTournament.Status).Replace("text-bg-", "")"
                                                                         Size="sm"
                                                                         Disabled="@isWorking"
                                                                         Items="@BuildTournamentStatusItems()" />
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge @StatusBadgeCss(selectedTournament.Status)">@selectedTournament.Status</span>
                                                    }
                                                    @if (IsCurrentUserManager)
                                                    {
                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleLockAsync" title="@(selectedTournament.IsLocked ? "Entsperren" : "Sperren")">
                                                            @(selectedTournament.IsLocked ? "🔒" : "🔓")
                                                        </button>
                                                    }
                                                    <button class="btn btn-sm btn-outline-secondary d-none d-lg-inline-flex align-items-center"
                                                            title="@(tournamentListCollapsed ? "Turnierliste einblenden" : "Turnierliste ausblenden")"
                                                            @onclick="() => tournamentListCollapsed = !tournamentListCollapsed">
                                                        <i class="bi @(tournamentListCollapsed ? "bi-layout-sidebar" : "bi-layout-sidebar-inset")"></i>
                                                    </button>
                                                </div>
                                            </div>
                                            <div class="card-body" id="tournament-tab-content">
                                                @* ─── Tabs ─── *@
                                                <ul class="nav nav-tabs mb-3">
                                                    <li class="nav-item"><button class="nav-link @(activeTab == "general" ? "active" : "")"
                                                                                     @onclick='() => SwitchTabAsync("general")'>Allgemein</button></li>
                                                        <li class="nav-item"><button class="nav-link @(activeTab == "boards-participants" ? "active" : "")"
                                                                                         @onclick='() => SwitchTabAsync("boards-participants")'>Boards &amp; Teilnehmer</button></li>
                                                                <li class="nav-item"><button class="nav-link @(activeTab == "draw" ? "active" : "")"
                                                                                                 @onclick='() => SwitchTabAsync("draw")'>Auslosung</button></li>
                                                                    <li class="nav-item"><button class="nav-link @(activeTab == "rounds" ? "active" : "")"
