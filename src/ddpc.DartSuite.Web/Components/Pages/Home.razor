@page "/"
@using ddpc.DartSuite.Application.Contracts.Boards
@using ddpc.DartSuite.Application.Contracts.Matches
@using ddpc.DartSuite.Application.Contracts.Tournaments
@using ddpc.DartSuite.Web.Services
@inject DartSuiteApiService Api
@inject AppStateService AppState
@inject BoardHubService BoardHubService
@inject IUiHelpService UiHelp
@implements IDisposable

<PageTitle>DartSuite Dashboard</PageTitle>

<h1 class="mb-3">Dashboard <UiHelpIcon HelpKey="page.dashboard" /></h1>

@if (!string.IsNullOrWhiteSpace(apiConnectionError))
{
    <div class="alert alert-danger py-2 mb-3">
        API derzeit nicht erreichbar. Dashboard läuft im eingeschränkten Modus. (@apiConnectionError)
    </div>
}

@if (isRealtimeConnected)
{
    <div class="alert alert-success py-2 mb-3">Echtzeit aktiv: Board- und Match-Updates laufen ueber SignalR.</div>
}
else
{
    <div class="alert alert-warning py-2 mb-3">Echtzeit getrennt: 10s-Fallback-Polling ist aktiv.</div>
}

@* ─── Tournament selector ─── *@
<div class="d-flex align-items-center gap-3 mb-4">
        <select class="form-select w-auto" value="@selectedTournamentId" @onchange="OnTournamentChanged"
            title="@UiHelp.GetTooltip("dashboard.tournament.select")">
        <option value="">-- Turnier auswählen --</option>
        @foreach (var t in filteredTournaments)
        {
            <option value="@t.Id">@t.Name (@t.Status)</option>
        }
    </select>
    <div class="form-check">
         <input type="checkbox" class="form-check-input" id="showFinished" @bind="showFinished"
             title="@UiHelp.GetTooltip("dashboard.toggle.finished")" />
        <label class="form-check-label" for="showFinished">Beendete Turniere anzeigen</label>
    </div>
</div>

@if (selectedTournament is not null)
{
    <div class="mb-3">
        <span class="badge @StatusBadgeClass(selectedTournament.Status) me-2">@selectedTournament.Status</span>
        <strong>@selectedTournament.Name</strong>
        <span class="text-muted ms-2">@selectedTournament.StartDate.ToString("dd.MM.yyyy")</span>
        @if (!string.IsNullOrEmpty(selectedTournament.StartTime))
        {
            <span class="text-muted">@selectedTournament.StartTime Uhr</span>
        }
    </div>

    @if (boards.Count == 0)
    {
        <div class="alert alert-info">Keine Boards konfiguriert. Bitte fügen Sie Boards im <a href="boards">Board-Bereich</a>
            hinzu.</div>
        }
else
        {
            @if (ProblemBoards.Any())
            {
                <div class="alert @(ProblemBoards.Any(b => b.OverallStatus == "Error") ? "alert-danger" : "alert-warning") py-2 mb-3 d-flex flex-wrap align-items-center gap-2">
                    <strong><i class="bi bi-exclamation-triangle-fill me-1"></i>Board-Probleme:</strong>
                    @foreach (var pb in ProblemBoards)
                    {
                        <span class="d-inline-flex align-items-center gap-1 border rounded px-2 py-1 bg-white">
                            <BoardStatusIndicator Board="@pb" ShowLabel="false" />
                            <span>@pb.Name</span>
                            <span class="badge @(pb.OverallStatus == "Error" ? "bg-danger" : "bg-warning text-dark")">@pb.OverallStatus</span>
                        </span>
                    }
                </div>
            }
            <div class="row g-3">
                @foreach (var board in boards)
                {
                    var boardMatches = GetBoardMatches(board.Id);
                    var runningMatch = boardMatches.FirstOrDefault(m => m.Status == "Aktiv");
                    var upcoming = boardMatches.Where(m => m.Status != "Aktiv" && m.Status != "Beendet" && m.Status != "WalkOver")
                    .OrderBy(m => m.PlannedStartUtc).Take(2).ToList();
                    var delay = CalculateBoardDelay(board.Id);

                    <div class="col-md-6 col-lg-4">
                        <div class="card shadow-sm h-100 @BoardCardBorderClass(board.OverallStatus)">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-2">
                                    <BoardStatusIndicator Board="@board" ShowLabel="false" />
                                    <strong>@board.Name</strong>
                                </div>
                                @if (delay.HasValue)
                                {
                                    @if (delay.Value == 0)
                                    {
                                        <span class="badge bg-success">Im Zeitplan</span>
                                    }
                                    else if (delay.Value < 0)
                                    {
                                        <span class="badge bg-info">@Math.Abs(delay.Value) Min. voraus</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@delay.Value Min. Verzögerung</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@board.Status</span>
                                }
                            </div>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush">
                                    @* Running match *@
                                    @if (runningMatch is not null)
                                    {
                                        <li class="list-group-item list-group-item-success">
                                            <div class="d-flex justify-content-between">
                                                <small class="text-uppercase fw-bold text-success">Laufend</small>
                                                <small class="text-muted">@FormatScore(runningMatch)</small>
                                            </div>
                                            <div>@ParticipantName(runningMatch.HomeParticipantId) vs
                                                @ParticipantName(runningMatch.AwayParticipantId)</div>
                                            </li>
                                        }
                    else
                                        {
                                            <li class="list-group-item text-muted fst-italic">Kein laufendes Match</li>
                                        }

                                        @* Next matches *@
                                        @foreach (var match in upcoming)
                                        {
                                            <li class="list-group-item">
                                                <div class="d-flex justify-content-between">
                                                    <small class="text-uppercase text-muted">Nächstes</small>
                                                    @if (match.PlannedStartUtc.HasValue)
                                                    {
                                                        <small
                                                        class="text-muted">@match.PlannedStartUtc.Value.ToLocalTime().ToString("HH:mm")</small>
                                                    }
                                                </div>
                                                <div>@ParticipantName(match.HomeParticipantId) vs @ParticipantName(match.AwayParticipantId)
                                                </div>
                                            </li>
                                        }
                                        @for (var i = upcoming.Count; i < 2; i++)
                                        {
                                            <li class="list-group-item text-muted fst-italic">—</li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
else
        {
            <div class="row g-3 mt-1">
                <div class="col-md-4">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">Boards</h5>
                            <p class="card-text">@boards.Count konfigurierte Boards</p>
                            <a class="btn btn-primary" href="boards">Boards öffnen</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">Turniere</h5>
                            <p class="card-text">@tournaments.Count verfügbare Turniere</p>
                            <a class="btn btn-primary" href="tournaments">Turniere öffnen</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">Autodarts Login</h5>
                            <p class="card-text">Account verbinden und Board-Status überwachen</p>
                            <a class="btn btn-primary" href="login">Login öffnen</a>
                        </div>
                    </div>
                </div>
            </div>
        }

@code {
    private List<TournamentDto> tournaments = new();
    private List<BoardDto> boards = new();
    private List<MatchDto> matchesForTournament = new();
    private List<ParticipantDto> participants = new();
    private List<TournamentRoundDto> rounds = new();
    private bool showFinished;
    private string selectedTournamentId = "";
    private Timer? _autoRefreshTimer;
    private bool isRealtimeConnected;
    private string? apiConnectionError;

    private IReadOnlyList<TournamentDto> filteredTournaments => showFinished
    ? tournaments
    : tournaments.Where(t => t.Status != "Beendet" && t.Status != "Abgebrochen").ToList();

    private TournamentDto? selectedTournament => string.IsNullOrEmpty(selectedTournamentId)
    ? null
    : tournaments.FirstOrDefault(t => t.Id.ToString() == selectedTournamentId);

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += OnAppStateChanged;
        await LoadInitialDashboardStateAsync();

        await ConnectBoardHubAsync();
        UpdateAutoRefreshFallbackState();
    }

    private async Task LoadInitialDashboardStateAsync()
    {
        try
        {
            tournaments = (await Api.GetTournamentsAsync()).ToList();
            boards = [];
            apiConnectionError = null;
        }
        catch (Exception ex)
        {
            apiConnectionError = ex.Message;
            tournaments = [];
            boards = [];
            matchesForTournament = [];
            participants = [];
            rounds = [];
            return;
        }

        // Use AppState selection if available, otherwise auto-select
        if (AppState.SelectedTournament is not null && tournaments.Any(t => t.Id == AppState.SelectedTournament.Id))
        {
            selectedTournamentId = AppState.SelectedTournament.Id.ToString();
        }
        else
        {
            var active = filteredTournaments.FirstOrDefault(t => t.Status == "Gestartet")
                ?? filteredTournaments.FirstOrDefault();
            if (active is not null)
            {
                selectedTournamentId = active.Id.ToString();
                AppState.SetSelectedTournament(active);
            }
        }

        if (selectedTournament is not null)
            await LoadTournamentDataAsync();
    }

    private async Task ConnectBoardHubAsync()
    {
        try
        {
            BoardHubService.OnConnectionChanged += OnBoardHubConnectionChanged;
            BoardHubService.OnBoardAdded += OnBoardChanged;
            BoardHubService.OnBoardStatusChanged += OnBoardChanged;
            BoardHubService.OnBoardConnectionChanged += OnBoardChanged;
            BoardHubService.OnBoardExtensionStatusChanged += OnBoardChanged;
            BoardHubService.OnBoardCurrentMatchChanged += OnBoardChanged;
            BoardHubService.OnBoardManagedModeChanged += OnBoardChanged;
            BoardHubService.OnBoardRemoved += OnBoardRemoved;
            BoardHubService.OnMatchUpdated += OnMatchUpdated;

            await BoardHubService.StartAsync();
        }
        catch
        {
            isRealtimeConnected = false;
        }
    }

    private async Task OnBoardHubConnectionChanged(bool connected)
    {
        isRealtimeConnected = connected;
        UpdateAutoRefreshFallbackState();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnBoardChanged(BoardDto board)
    {
        await InvokeAsync(() =>
        {
            if (selectedTournament is null && board.TournamentId.HasValue)
            {
                boards.RemoveAll(b => b.Id == board.Id);
                StateHasChanged();
                return;
            }

            if (selectedTournament is not null
                && board.TournamentId.HasValue
                && board.TournamentId.Value != selectedTournament.Id)
            {
                boards.RemoveAll(b => b.Id == board.Id);
                StateHasChanged();
                return;
            }

            var index = boards.FindIndex(b => b.Id == board.Id);
            if (index >= 0)
                boards[index] = board;
            else
                boards.Add(board);

            StateHasChanged();
        });
    }

    private async Task OnBoardRemoved(Guid boardId)
    {
        await InvokeAsync(() =>
        {
            boards.RemoveAll(b => b.Id == boardId);
            StateHasChanged();
        });
    }

    private async Task OnMatchUpdated(MatchDto match)
    {
        if (selectedTournament is null || match.TournamentId != selectedTournament.Id)
            return;

        await InvokeAsync(() =>
        {
            var index = matchesForTournament.FindIndex(m => m.Id == match.Id);
            if (index >= 0)
                matchesForTournament[index] = match;
            else
                matchesForTournament.Add(match);

            StateHasChanged();
        });
    }

    private void UpdateAutoRefreshFallbackState()
    {
        if (isRealtimeConnected)
        {
            _autoRefreshTimer?.Change(Timeout.InfiniteTimeSpan, Timeout.InfiniteTimeSpan);
            return;
        }

        _autoRefreshTimer ??= new Timer(OnAutoRefresh, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
        _autoRefreshTimer.Change(TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async void OnAutoRefresh(object? _)
    {
        if (isRealtimeConnected) return;

        try
        {
            if (selectedTournament is not null)
            {
                boards = (await Api.GetBoardsByTournamentAsync(selectedTournament.Id)).ToList();
                matchesForTournament = (await Api.GetMatchesAsync(selectedTournament.Id)).ToList();
            }
            await InvokeAsync(StateHasChanged);
        }
        catch { /* ignore refresh errors */ }
    }

    private async void OnAppStateChanged()
    {
        await InvokeAsync(async () =>
        {
            if (AppState.SelectedTournament is not null)
                selectedTournamentId = AppState.SelectedTournament.Id.ToString();
            else
                selectedTournamentId = "";

            if (selectedTournament is not null)
                await LoadTournamentDataAsync();

            StateHasChanged();
        });
    }

    private async Task OnTournamentChanged(ChangeEventArgs e)
    {
        selectedTournamentId = e.Value?.ToString() ?? "";
        if (selectedTournament is not null)
        {
            AppState.SetSelectedTournament(selectedTournament);
            await LoadTournamentDataAsync();
        }
        else
        {
            AppState.SetSelectedTournament(null);
        }
    }

    private async Task LoadTournamentDataAsync()
    {
        if (selectedTournament is null) return;
        var id = selectedTournament.Id;

        try
        {
            boards = (await Api.GetBoardsByTournamentAsync(id)).ToList();
            matchesForTournament = (await Api.GetMatchesAsync(id)).ToList();
            participants = (await Api.GetParticipantsAsync(id)).ToList();
            rounds = (await Api.GetRoundsAsync(id)).ToList();
            apiConnectionError = null;
        }
        catch (Exception ex)
        {
            apiConnectionError = ex.Message;
            boards = [];
            matchesForTournament = [];
            participants = [];
            rounds = [];
        }
    }

    private List<MatchDto> GetBoardMatches(Guid boardId)
    {
        return matchesForTournament
        .Where(m => m.BoardId == boardId)
        .OrderBy(m => m.PlannedStartUtc)
        .ToList();
    }

    private int? CalculateBoardDelay(Guid boardId)
    {
        var boardMatches = GetBoardMatches(boardId);
        if (boardMatches.Count == 0) return null;

        // Find the next unfinished match on this board
        var nextMatch = boardMatches.FirstOrDefault(m => m.Status == "Aktiv")
        ?? boardMatches.FirstOrDefault(m => m.Status != "Beendet" && m.Status != "WalkOver");
        if (nextMatch?.PlannedStartUtc is null) return null;

        var now = DateTimeOffset.Now;
        var planned = nextMatch.PlannedStartUtc.Value;

        if (nextMatch.Status == "Aktiv")
        {
            // Match is running — check if it started on time
            if (nextMatch.StartedUtc.HasValue)
            {
                var startDelay = (int)(nextMatch.StartedUtc.Value - planned).TotalMinutes;
                return startDelay;
            }
            return 0;
        }

        // Match hasn't started yet — expected vs. now
        // Count how many matches should already be finished at this board
        var finishedCount = boardMatches.Count(m => m.Status is "Beendet" or "WalkOver");
        var expectedFinished = boardMatches.Count(m => m.PlannedStartUtc.HasValue && m.PlannedStartUtc.Value <= now);
        var behindCount = expectedFinished - finishedCount;

        if (behindCount <= 0)
        {
            // Ahead or on time
            var aheadMinutes = (int)(planned - now).TotalMinutes;
            return aheadMinutes > 0 ? -aheadMinutes : 0;
        }

        // Behind — estimate delay from round settings
        var matchRound = rounds.FirstOrDefault(r => r.Phase == nextMatch.Phase && r.RoundNumber == nextMatch.Round);
        var legSecs = matchRound?.LegDurationSeconds > 0 ? matchRound.LegDurationSeconds : 300;
        var avgDuration = (matchRound?.Sets ?? 1) * (matchRound?.Legs ?? 3) * legSecs / 60;
        var pause = matchRound?.PauseBetweenMatchesMinutes ?? 2;
        return behindCount * (avgDuration + pause);
    }

    private string ParticipantName(Guid participantId)
    {
        if (participantId == Guid.Empty) return "Freilos";
        return participants.FirstOrDefault(p => p.Id == participantId)?.DisplayName ?? "TBD";
    }

    private string FormatScore(MatchDto m)
    {
        if (m.HomeSets > 0 || m.AwaySets > 0)
            return $"{m.HomeSets}:{m.AwaySets} ({m.HomeLegs}:{m.AwayLegs})";
        return $"{m.HomeLegs}:{m.AwayLegs}";
    }

    private IEnumerable<BoardDto> ProblemBoards => boards.Where(b => b.OverallStatus is "Warning" or "Error");

    private static string BoardCardBorderClass(string? overallStatus) => overallStatus switch
    {
        "Error" => "border-danger border-2",
        "Warning" => "border-warning border-2",
        _ => ""
    };

    private static string StatusBadgeClass(string status) => status switch
    {
        "Erstellt" => "bg-secondary",
        "Geplant" => "bg-warning text-dark",
        "Gestartet" => "bg-success",
        "Beendet" => "bg-primary",
        "Abgebrochen" => "bg-danger",
        _ => "bg-secondary"
    };

    public void Dispose()
    {
        _autoRefreshTimer?.Dispose();
        AppState.OnChange -= OnAppStateChanged;
        BoardHubService.OnConnectionChanged -= OnBoardHubConnectionChanged;
        BoardHubService.OnBoardAdded -= OnBoardChanged;
        BoardHubService.OnBoardStatusChanged -= OnBoardChanged;
        BoardHubService.OnBoardConnectionChanged -= OnBoardChanged;
        BoardHubService.OnBoardExtensionStatusChanged -= OnBoardChanged;
        BoardHubService.OnBoardCurrentMatchChanged -= OnBoardChanged;
        BoardHubService.OnBoardManagedModeChanged -= OnBoardChanged;
        BoardHubService.OnBoardRemoved -= OnBoardRemoved;
        BoardHubService.OnMatchUpdated -= OnMatchUpdated;
    }
}