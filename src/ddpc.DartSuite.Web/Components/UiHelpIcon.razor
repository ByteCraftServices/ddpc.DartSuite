@inject IUiHelpService UiHelp

<div class="ui-help-details @(IsOpen ? "is-open" : string.Empty) @CssClass">
    <button type="button"
            class="ui-help-summary"
            title="@Tooltip"
            aria-label="@AriaLabel"
            aria-expanded="@IsOpen"
            aria-controls="@_contentId"
            @onclick="Toggle">
        ?
    </button>

    @if (IsOpen)
    {
        <div id="@_contentId" class="ui-help-content" role="note">@Content</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string HelpKey { get; set; } = string.Empty;
    [Parameter] public string? Fallback { get; set; }
    [Parameter] public string CssClass { get; set; } = string.Empty;
    [Parameter] public string AriaLabel { get; set; } = "Kontextbezogene Hilfe";

    private readonly string _contentId = $"ui-help-{Guid.NewGuid():N}";
    private bool IsOpen;

    private string Content => UiHelp.GetContent(HelpKey, Fallback);
    private string Tooltip => UiHelp.GetTooltip(HelpKey, Fallback);

    private void Toggle() => IsOpen = !IsOpen;
}
