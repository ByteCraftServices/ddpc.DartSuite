{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"ddpc.DartSuite.slnx"
			],
			"group": "build",
			"problemMatcher": [
				"$msCompile"
			]
		},
		{
			"label": "test",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"ddpc.DartSuite.slnx"
			],
			"group": "test",
			"problemMatcher": [
				"$msCompile"
			]
		},
		{
			"label": "run-api",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"watch",
				"--project",
				"src/ddpc.DartSuite.Api"
			],
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "run-web",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"watch",
				"--launch-profile",
				"https",
				"--project",
				"src/ddpc.DartSuite.Web"
			],
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "run-web-live-api",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"-c",
				"Release",
				"--environment",
				"Production",
				"--project",
				"src/ddpc.DartSuite.Web"
			],
			"options": {
				"env": {
					"ASPNETCORE_ENVIRONMENT": "Production",
					"DOTNET_ENVIRONMENT": "Production"
				}
			},
			"isBackground": true,
			"problemMatcher": [],
			"dependsOn": [
				"build-web-clean"
			]
		},
		{
			"label": "build-web-clean",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"src/ddpc.DartSuite.Web",
				"--no-incremental"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "web release",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"publish",
				"-c",
				"Release",
				"src/ddpc.DartSuite.Web"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "run-web-published",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"ddpc.DartSuite.Web.dll"
			],
			"options": {
				"cwd": "${workspaceFolder}/src/ddpc.DartSuite.Web/bin/Release/net10.0/publish",
				"env": {
					"ASPNETCORE_ENVIRONMENT": "Production",
					"DOTNET_ENVIRONMENT": "Production"
				}
			},
			"isBackground": true,
			"problemMatcher": [],
			"dependsOn": [
				"web release"
			]
		}
	]
}