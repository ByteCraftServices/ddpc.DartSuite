{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"ddpc.DartSuite.slnx"
			],
			"group": "build",
			"problemMatcher": [
				"$msCompile"
			]
		},
		{
			"label": "test",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"ddpc.DartSuite.slnx"
			],
			"group": "test",
			"problemMatcher": [
				"$msCompile"
			]
		},
		{
			"label": "run-api",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"watch",
				"--project",
				"src/ddpc.DartSuite.Api"
			],
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "run-web",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"watch",
				"--launch-profile",
				"https",
				"--project",
				"src/ddpc.DartSuite.Web"
			],
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "build-web-clean",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"src/ddpc.DartSuite.Web",
				"--no-incremental"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		}
	]
}