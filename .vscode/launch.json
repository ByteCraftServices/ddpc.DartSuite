{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "DartSuite API",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/ddpc.DartSuite.Api/bin/Debug/net10.0/ddpc.DartSuite.Api.dll",
            "cwd": "${workspaceFolder}/src/ddpc.DartSuite.Api",
            "preLaunchTask": "build"
        },
        {
            "name": "DartSuite API (DevOnProdDB)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/ddpc.DartSuite.Api/bin/Debug/net10.0/ddpc.DartSuite.Api.dll",
            "cwd": "${workspaceFolder}/src/ddpc.DartSuite.Api",
            "preLaunchTask": "build",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "DevOnProdDB"
            }
        },
        {
            "name": "DartSuite Web",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/ddpc.DartSuite.Web/bin/Debug/net10.0/ddpc.DartSuite.Web.dll",
            "cwd": "${workspaceFolder}/src/ddpc.DartSuite.Web",
            "preLaunchTask": "build"
        }
    ],
    "compounds": [
        {
            "name": "DartSuite Full Stack",
            "configurations": [
                "DartSuite API",
                "DartSuite Web"
            ]
        }
    ]
}